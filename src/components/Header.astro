---
// src/components/Header.astro
import LoginModal from './authentication/LoginModal.astro';
import RegisterModal from './authentication/RegisterModal.astro';
import AvatarWarga from './AvatarWarga.astro';
import KontakModal from './KontakModal.astro';

// STRUKTUR MENU (Menu Kontak dihapus dari sini)
const navItems = [
  { name: 'Beranda', url: '/' },
  {
    name: 'Profil Desa',
    children: [
      { name: 'Sejarah & Visi Misi', url: '/profil/visi-misi-sejarah' },
      { name: 'Struktur Organisasi', url: '/profil/struktur' },
      { name: 'Demografi Penduduk', url: '/profil/demografi' },
      { name: 'Peta Desa', url: '/profil/peta' },
    ]
  },
  {
    name: 'Layanan',
    children: [
      { name: 'Persuratan Online', url: '/layanan/persuratan' },
      { name: 'Aduan Warga', url: '/layanan/aduan' },
      { name: 'Cek Bansos', url: '/layanan/bansos' },
    ]
  },
  { name: 'Transparansi', url: '/apbdes'},
  { name: 'Berita', url: '/berita' },
  { name: 'UMKM', url: '/umkm' }
];

const pathname = Astro.url.pathname;
const isUMKM = pathname.includes('/umkm');
const bgHeader = isUMKM ? 'bg-orange-600' : 'bg-teal-700';
const bgMobileOverlay = isUMKM ? 'bg-orange-950/95' : 'bg-teal-950/95';
---

<header class={`${bgHeader} text-white shadow-md sticky top-0 z-50 w-full transition-colors duration-500`}>
  <div class="container mx-auto px-4 py-3 flex justify-between items-center relative z-50">
    
    <a href="/" class="flex items-center gap-3 relative z-50 group shrink-0">
      <img src="https://i.ibb.co.com/S7Wv5qST/logo-header.png" alt="Logo Desa Mulyamekar" class="w-10 h-10 object-contain rounded-full shadow-inner border border-white/40 group-hover:scale-105 transition-transform" />
      <div>
        <h1 class="text-lg font-bold leading-tight tracking-wide">Desa Mulyamekar</h1>
        <p class="text-[10px] text-teal-200 uppercase tracking-wider">Kab. Purwakarta</p>
      </div>
    </a>

    <nav class="hidden lg:flex gap-4 xl:gap-6 items-center">
      {navItems.map((item) => (
        item.children ? (
          <div class="relative group">
            <button class="text-sm font-medium hover:text-amber-400 transition-colors flex items-center gap-1 py-4">
              {item.name}
              <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="absolute top-[85%] left-0 bg-white text-teal-950 min-w-[220px] rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-3 group-hover:translate-y-0 border border-gray-100 overflow-hidden z-50">
              <div class="py-2">
                {item.children.map(child => (
                  <a href={child.url} class="block px-5 py-2.5 text-sm font-bold text-gray-600 hover:bg-teal-50 hover:text-teal-700 transition-colors">
                    {child.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.url} class="text-sm font-medium hover:text-amber-400 transition-colors py-4">
            {item.name}
          </a>
        )
      ))}
      
      <button onclick="bukaModalKontak()" class="text-sm font-medium hover:text-amber-400 transition-colors py-4 cursor-pointer focus:outline-none">
        Kontak
      </button>
      
      <button id="btnNavLogin" onclick="bukaLoginModal()" class="hidden text-sm font-bold border-2 border-white hover:bg-white hover:text-teal-700 px-5 py-1.5 rounded-full transition-colors shadow-sm ml-2">
        Masuk / Daftar
      </button>

      <div id="navProfile" class="hidden items-center gap-4 border-l border-teal-600 pl-5 ml-2">
        <a href="#" id="linkDashboard" class="flex items-center gap-2 group cursor-pointer">
          <AvatarWarga id="headerAvatarDesktop" className="w-8 h-8 group-hover:ring-2 group-hover:ring-amber-400 transition-all" />
          <div class="flex flex-col">
            <span id="userName" class="text-sm font-bold leading-tight group-hover:text-amber-400 transition-colors max-w-[100px] truncate">Memuat...</span>
            <span id="userRole" class="text-[10px] text-teal-200 uppercase tracking-wider">Role</span>
          </div>
        </a>
        <button id="btnNavLogout" class="text-xs bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded-lg font-bold transition-colors shadow-sm">Keluar</button>
      </div>
    </nav>

    <button id="mobile-menu-btn" class="lg:hidden relative p-2 text-white hover:text-amber-400 focus:outline-none w-10 h-10 z-50 shrink-0">
      <div class="absolute inset-0 flex flex-col items-center justify-center gap-1.5 transform transition-all duration-300 origin-center">
        <span id="line-1" class="w-6 h-0.5 bg-current transform transition-all duration-300 origin-center"></span>
        <span id="line-2" class="w-6 h-0.5 bg-current transform transition-all duration-300 origin-center"></span>
        <span id="line-3" class="w-6 h-0.5 bg-current transform transition-all duration-300 origin-center"></span>
      </div>
    </button>
  </div>

  <div id="mobile-menu-overlay" class={`fixed inset-0 ${bgMobileOverlay} backdrop-blur-md z-40 transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] lg:hidden flex flex-col pt-24 pb-8 overflow-y-auto`}>
    <nav id="mobile-nav-links" class="flex flex-col w-full px-6 opacity-0 transform translate-y-8 transition-all duration-500 delay-200">
      
      <div class="flex flex-col gap-2 mb-6">
        {navItems.map((item) => (
          item.children ? (
            <details class="w-full group [&_summary::-webkit-details-marker]:hidden">
              <summary class="text-lg font-bold text-white hover:text-amber-400 transition-colors tracking-wide py-3 border-b border-teal-800/50 cursor-pointer list-none flex justify-between items-center">
                {item.name}
                <svg class="w-5 h-5 transition-transform group-open:rotate-180 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </summary>
              <div class="flex flex-col gap-1 py-3 px-4 bg-teal-900/50 rounded-b-xl mb-1">
                {item.children.map(child => (
                  <a href={child.url} class="text-sm font-medium text-teal-200 hover:text-amber-400 transition-colors py-2 block border-l-2 border-teal-600 pl-3">
                    {child.name}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a href={item.url} class="text-lg font-bold text-white hover:text-amber-400 transition-colors tracking-wide py-3 border-b border-teal-800/50 block w-full">
              {item.name}
            </a>
          )
        ))}

        <button onclick="bukaModalKontak(); document.getElementById('mobile-menu-btn').click();" class="text-lg font-bold text-white hover:text-amber-400 transition-colors tracking-wide py-3 border-b border-teal-800/50 block w-full cursor-pointer text-left focus:outline-none">
          Kontak
        </button>

      </div>

      <div class="flex flex-col items-center gap-4 mt-auto pt-6">
        <button id="btnMobileLogin" onclick="bukaLoginModal(); document.getElementById('mobile-menu-btn').click();" class="hidden w-full max-w-xs text-center border-2 border-white hover:bg-white text-white hover:text-teal-950 py-3 rounded-full text-lg font-bold transition-colors">
          Masuk / Daftar
        </button>

        <div id="mobileProfile" class="hidden flex-col items-center w-full max-w-xs gap-3">
          <a href="#" id="mobileLinkDashboard" class="flex items-center gap-3 bg-teal-800 p-4 rounded-2xl w-full">
            <AvatarWarga id="headerAvatarMobile" className="w-10 h-10 border-2 border-white/50" />
            <div class="flex flex-col text-left">
              <span id="mobileUserName" class="text-white font-bold text-lg leading-tight">Memuat...</span>
              <span id="mobileUserRole" class="text-teal-300 text-xs uppercase font-bold tracking-wider">Role</span>
            </div>
          </a>
          <button id="btnMobileLogout" class="w-full bg-red-500 hover:bg-red-600 text-white py-3 rounded-xl font-bold transition-colors shadow-md">Keluar Akun</button>
        </div>
      </div>
    </nav>
  </div> <LoginModal />
  <RegisterModal />
  <KontakModal /> </header>

<script>
  import { supabase } from '../lib/supabase.js';

  const btn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-menu-overlay');
  const navLinks = document.getElementById('mobile-nav-links');
  const [line1, line2, line3] = ['line-1', 'line-2', 'line-3'].map(id => document.getElementById(id));
  let isOpen = false;

  if (btn && overlay && navLinks) {
    btn.addEventListener('click', () => {
      isOpen = !isOpen;
      if (isOpen) {
        document.body.style.overflow = 'hidden';
        line1.classList.add('translate-y-2', 'rotate-45');
        line2.classList.add('opacity-0', 'translate-x-3');
        line3.classList.add('-translate-y-2', '-rotate-45');
        overlay.classList.remove('translate-x-full');
        overlay.classList.add('translate-x-0');
        setTimeout(() => {
          navLinks.classList.remove('opacity-0', 'translate-y-8');
          navLinks.classList.add('opacity-100', 'translate-y-0');
        }, 100);
      } else {
        document.body.style.overflow = '';
        line1.classList.remove('translate-y-2', 'rotate-45');
        line2.classList.remove('opacity-0', 'translate-x-3');
        line3.classList.remove('-translate-y-2', '-rotate-45');
        navLinks.classList.remove('opacity-100', 'translate-y-0');
        navLinks.classList.add('opacity-0', 'translate-y-8');
        overlay.classList.remove('translate-x-0');
        overlay.classList.add('translate-x-full');
      }
    });
  }

  async function checkHeaderAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    const btnNavLogin = document.getElementById('btnNavLogin');
    const navProfile = document.getElementById('navProfile');
    const btnMobileLogin = document.getElementById('btnMobileLogin');
    const mobileProfile = document.getElementById('mobileProfile');

    if (session) {
      const { data: profil } = await supabase.from('profil_user').select('nama_lengkap, role, avatar_url, jenis_kelamin').eq('id', session.user.id).single();
      if (profil) {
        let targetUrl = '/pengguna';
        let namaRole = 'Warga Desa';
        if (profil.role === 'admin') { targetUrl = '/admin'; namaRole = 'Admin Desa'; } 
        else if (profil.role === 'rt') { namaRole = 'Ketua RT'; }
        else if (profil.role === 'rw') { namaRole = 'Ketua RW'; }

        const namaPendek = profil.nama_lengkap ? profil.nama_lengkap.split(' ')[0] : 'User';
        let finalAvatar = profil.avatar_url;

        if (profil.role === 'admin') { finalAvatar = 'https://i.ibb.co.com/S7Wv5qST/logo-header.png'; } 
        else if (!finalAvatar) {
            const gender = profil.jenis_kelamin === 'Perempuan' ? 'Perempuan' : 'Laki-laki'; 
            finalAvatar = gender === 'Perempuan' 
                ? `https://api.dicebear.com/7.x/avataaars/svg?seed=${profil.nama_lengkap}&backgroundColor=ffdfbf&clothing=blazerAndShirt&hair=longButNotTooLong`
                : `https://api.dicebear.com/7.x/avataaars/svg?seed=${profil.nama_lengkap}&backgroundColor=b6e3f4&clothing=blazerAndSweater&hair=shortHairShortFlat`;
        }

        if(document.getElementById('headerAvatarDesktop')) document.getElementById('headerAvatarDesktop').src = finalAvatar;
        if(document.getElementById('headerAvatarMobile')) document.getElementById('headerAvatarMobile').src = finalAvatar;

        if(btnNavLogin) btnNavLogin.classList.add('hidden');
        if(navProfile) {
            navProfile.classList.remove('hidden');
            navProfile.classList.add('flex');
            document.getElementById('userName').innerText = namaPendek;
            document.getElementById('userRole').innerText = namaRole;
            document.getElementById('linkDashboard').href = targetUrl;
        }

        if(btnMobileLogin) btnMobileLogin.classList.add('hidden');
        if(mobileProfile) {
            mobileProfile.classList.remove('hidden');
            mobileProfile.classList.add('flex');
            document.getElementById('mobileUserName').innerText = namaPendek;
            document.getElementById('mobileUserRole').innerText = namaRole;
            document.getElementById('mobileLinkDashboard').href = targetUrl;
        }
      }
    } else {
      if(btnNavLogin) btnNavLogin.classList.remove('hidden');
      if(navProfile) { navProfile.classList.add('hidden'); navProfile.classList.remove('flex'); }
      if(btnMobileLogin) btnMobileLogin.classList.remove('hidden');
      if(mobileProfile) { mobileProfile.classList.add('hidden'); mobileProfile.classList.remove('flex'); }
    }
  }

  async function handleLogout() {
    await supabase.auth.signOut();
    window.location.href = '/'; 
  }

  document.getElementById('btnNavLogout')?.addEventListener('click', handleLogout);
  document.getElementById('btnMobileLogout')?.addEventListener('click', handleLogout);
  document.addEventListener('DOMContentLoaded', checkHeaderAuth);
</script>