---
// src/components/LoginModal.astro
---

<div id="loginModal" class="fixed inset-0 z-[100] bg-slate-900/80 hidden flex items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300 ease-out">
    <div id="loginModalBox" class="bg-white rounded-3xl w-full max-w-md shadow-2xl transform scale-95 transition-transform duration-300 ease-out overflow-hidden flex flex-col h-max max-h-[90vh]">
        
        <div class="bg-gradient-to-r from-teal-600 to-teal-800 p-6 text-white flex justify-between items-center relative overflow-hidden shrink-0">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
            <div class="relative z-10">
                <h3 class="text-2xl font-black tracking-tight" id="loginTitle">Masuk Akun</h3>
                <p class="text-teal-100 text-sm mt-1" id="loginDesc">Layanan Digital Desa Mulyamekar</p>
            </div>
            <button type="button" onclick="tutupLoginModal()" class="relative z-10 text-teal-100 hover:text-white bg-white/10 hover:bg-white/20 p-2 rounded-full transition-colors">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="p-6 md:p-8 overflow-y-auto">
            <form id="loginForm" class="space-y-4 animate-fadeIn" novalidate>
                
                <div id="fieldResetNik" class="hidden animate-contentIn">
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">NIK KTP (16 Digit)</label>
                    <div class="relative">
                        <i class="bi bi-credit-card-2-front absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="text" id="loginNik" maxlength="16" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none transition-all text-sm font-bold font-mono tracking-widest text-slate-900 placeholder-slate-400" placeholder="16 Digit Angka">
                    </div>
                </div>

                <div id="fieldResetTglLahir" class="hidden animate-contentIn">
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Tanggal Lahir (Sesuai KTP)</label>
                    <div class="relative">
                        <i class="bi bi-calendar-date absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="date" id="loginTglLahir" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400">
                    </div>
                </div>

                <div id="fieldLoginContact" class="bg-slate-50 p-3 rounded-2xl border border-slate-100 animate-fadeIn">
                    <div class="flex bg-slate-200/50 p-1 rounded-xl mb-3 relative z-0">
                        <button type="button" id="btnLoginModePhone" onclick="setLoginContactMode('phone')" class="flex-1 py-2 text-xs font-bold rounded-lg bg-white shadow-sm text-teal-600 transition-all duration-300 relative z-10">Nomor HP</button>
                        <button type="button" id="btnLoginModeEmail" onclick="setLoginContactMode('email')" class="flex-1 py-2 text-xs font-bold rounded-lg text-slate-500 hover:text-slate-700 transition-all duration-300 relative z-10">Email</button>
                    </div>

                    <div id="wrapperLoginPhone" class="animate-contentIn">
                        <div class="flex shadow-sm rounded-xl overflow-hidden border border-slate-200 focus-within:ring-2 focus-within:ring-teal-500 focus-within:border-teal-500 transition-all bg-white">
                            <span class="inline-flex items-center px-4 bg-slate-100 text-slate-500 font-bold text-sm border-r border-slate-200">+62</span>
                            <input type="tel" id="loginPhone" oninput="this.value = this.value.replace(/[^0-9]/g, '').replace(/^0+/, '')" class="w-full px-4 py-3 outline-none text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="81234567890">
                        </div>
                    </div>

                    <div id="wrapperLoginEmail" class="hidden animate-contentIn">
                        <div class="relative bg-white shadow-sm rounded-xl border border-slate-200 focus-within:ring-2 focus-within:ring-teal-500">
                            <i class="bi bi-envelope absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                            <input type="email" id="loginEmail" class="w-full pl-12 pr-4 py-3 bg-transparent outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="email@anda.com">
                        </div>
                    </div>
                </div>
                
                <div class="pt-2">
                    <div class="flex justify-between items-center mb-1.5">
                        <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider" id="labelLoginPassword">Kata Sandi</label>
                        <button type="button" onclick="setModeLogin('reset')" id="btnLupaSandi" class="text-xs font-bold text-teal-600 hover:text-teal-800 transition-colors">Lupa Sandi?</button>
                    </div>
                    <div class="relative">
                        <i class="bi bi-shield-lock absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="password" id="loginPassword" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Minimal 6 karakter">
                    </div>
                </div>

                <button type="submit" id="btnLoginSubmit" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-black py-3.5 mt-2 rounded-xl shadow-md shadow-teal-600/20 transition-all active:scale-95 flex justify-center items-center gap-2">
                    Masuk Sekarang <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <div class="mt-5 text-center border-t border-slate-100 pt-5">
                <p class="text-sm text-slate-500 font-medium" id="loginToggleText">
                    Belum punya akun warga?
                    <button type="button" onclick="tutupLoginModal(); setTimeout(() => bukaRegisterModal(), 300);" class="text-teal-600 font-bold hover:text-teal-800 hover:underline">Daftar di sini</button>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Definisi animasi custom jika belum ada di global CSS */
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    @keyframes contentIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
        animation: fadeIn 0.4s ease-out forwards;
    }
    .animate-contentIn {
        animation: contentIn 0.3s ease-out forwards;
    }
</style>

<script>
    import { supabase } from '../../lib/supabase.js';

    let isResetMode = false;
    let loginContactMode = 'phone'; // Default mode

    window.bukaLoginModal = () => {
        const m = document.getElementById('loginModal');
        const b = document.getElementById('loginModalBox');
        setModeLogin('login');
        setLoginContactMode('phone'); 
        m.classList.remove('hidden');
        setTimeout(() => { 
            m.classList.remove('opacity-0'); 
            b.classList.remove('scale-95'); 
            b.classList.add('scale-100'); 
        }, 10);
    };

    window.tutupLoginModal = () => {
        const m = document.getElementById('loginModal');
        const b = document.getElementById('loginModalBox');
        m.classList.add('opacity-0'); 
        b.classList.remove('scale-100'); 
        b.classList.add('scale-95');
        setTimeout(() => { 
            m.classList.add('hidden'); 
            document.getElementById('loginForm').reset(); 
        }, 300);
    };

    window.setLoginContactMode = (mode) => {
        if(loginContactMode === mode && !document.getElementById('loginModal').classList.contains('hidden')) return;
        loginContactMode = mode;
        const btnPhone = document.getElementById('btnLoginModePhone');
        const btnEmail = document.getElementById('btnLoginModeEmail');
        const wrapPhone = document.getElementById('wrapperLoginPhone');
        const wrapEmail = document.getElementById('wrapperLoginEmail');

        if (mode === 'phone') {
            btnPhone.className = "flex-1 py-2 text-xs font-bold rounded-lg bg-white shadow-sm text-teal-600 transition-all duration-300 relative z-10";
            btnEmail.className = "flex-1 py-2 text-xs font-bold rounded-lg text-slate-500 hover:text-slate-700 transition-all duration-300 relative z-10";
            wrapPhone.classList.remove('hidden');
            wrapEmail.classList.add('hidden');
        } else {
            btnEmail.className = "flex-1 py-2 text-xs font-bold rounded-lg bg-white shadow-sm text-teal-600 transition-all duration-300 relative z-10";
            btnPhone.className = "flex-1 py-2 text-xs font-bold rounded-lg text-slate-500 hover:text-slate-700 transition-all duration-300 relative z-10";
            wrapEmail.classList.remove('hidden');
            wrapPhone.classList.add('hidden');
        }
    };

    window.setModeLogin = (mode) => {
        isResetMode = (mode === 'reset');
        document.getElementById('loginTitle').innerText = isResetMode ? "Reset Kata Sandi" : "Masuk Akun";
        document.getElementById('loginDesc').innerText = isResetMode ? "Validasi Identitas KTP Anda" : "Layanan Digital Desa Mulyamekar";
        document.getElementById('btnLoginSubmit').innerHTML = isResetMode ? "Reset Sandi <i class='bi bi-shield-lock'></i>" : "Masuk <i class='bi bi-arrow-right'></i>";
        
        document.getElementById('loginToggleText').innerHTML = isResetMode 
            ? `Ingat kata sandi? <button type="button" onclick="setModeLogin('login')" class="text-teal-600 font-bold hover:text-teal-800 hover:underline">Kembali Masuk</button>`
            : `Belum punya akun? <button type="button" onclick="tutupLoginModal(); setTimeout(() => bukaRegisterModal(), 300);" class="text-teal-600 font-bold hover:text-teal-800 hover:underline">Daftar di sini</button>`;

        const fResetNik = document.getElementById('fieldResetNik');
        const fResetTgl = document.getElementById('fieldResetTglLahir');
        const fContact = document.getElementById('fieldLoginContact');

        if(isResetMode) {
            fResetNik.classList.remove('hidden');
            fResetTgl.classList.remove('hidden');
            fContact.classList.add('hidden');
        } else {
            fResetNik.classList.add('hidden');
            fResetTgl.classList.add('hidden');
            fContact.classList.remove('hidden');
        }
        
        document.getElementById('btnLupaSandi').classList.toggle('hidden', isResetMode);
        document.getElementById('labelLoginPassword').innerText = isResetMode ? "Kata Sandi Baru" : "Kata Sandi";
    };

    // --- Logic Submit Pintar ---
    document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const rawPhone = document.getElementById('loginPhone').value.trim();
        const email = document.getElementById('loginEmail').value.trim();
        const password = document.getElementById('loginPassword').value;
        const nik = document.getElementById('loginNik').value.trim();
        const tglLahir = document.getElementById('loginTglLahir').value;
        const btn = document.getElementById('btnLoginSubmit');

        btn.disabled = true;
        btn.innerHTML = "Memproses... <i class='bi bi-hourglass-split animate-spin'></i>";

        try {
            if (!isResetMode) {
                // LOGIKA LOGIN BIASA
                if(!password) throw new Error('Kata Sandi wajib diisi!');
                if (loginContactMode === 'phone' && !rawPhone) throw new Error("Silakan isi Nomor HP!");
                if (loginContactMode === 'email' && !email) throw new Error("Silakan isi Alamat Email!");
                
                let loginPayload = { password: password };
                if (loginContactMode === 'phone') loginPayload.phone = `+62${rawPhone}`;
                else loginPayload.email = email;

                const { data, error } = await supabase.auth.signInWithPassword(loginPayload);
                
                if (error) {
                    let errMsg = error.message;
                    if (errMsg.includes('Invalid login')) errMsg = "Nomor HP/Email atau Kata Sandi salah!";
                    throw new Error(errMsg);
                }

                // Arahkan otomatis ke dashboard sesuai Role
                const { data: profil } = await supabase.from('profil_user').select('role').eq('id', data.user.id).single();
                window.location.href = (profil && profil.role === 'admin') ? '/admin' : '/pengguna';

            } else {
                // LOGIKA RESET SANDI
                if (!nik || !tglLahir || !password) throw new Error("Data NIK, Tanggal Lahir, dan Kata Sandi Baru wajib diisi!");
                if (nik.length !== 16) throw new Error("NIK harus 16 digit!");
                if (password.length < 6) throw new Error("Kata sandi baru minimal 6 karakter!");
                
                const { data: hasilReset, error: invokeErr } = await supabase.functions.invoke('reset-sandi', {
                    body: { nik: nik, tanggalLahir: tglLahir, passwordBaru: password }
                });

                if (invokeErr) throw new Error("Sistem sedang sibuk, coba lagi nanti.");
                if (hasilReset && hasilReset.status !== 'sukses') throw new Error(hasilReset.pesan);
                
                if (typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Sandi Diperbarui', 'Kata sandi berhasil direset! Silakan masuk.');
                else alert('Kata sandi berhasil direset! Silakan masuk.');
                
                document.getElementById('loginForm').reset();
                setModeLogin('login');
            }
        } catch (error) {
            console.error("❌ [ERROR LOGIN]:", error);
            if (typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', error.message);
            else alert(error.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = isResetMode ? "Reset Sandi <i class='bi bi-shield-lock'></i>" : "Masuk <i class='bi bi-arrow-right'></i>";
        }
    });
</script>