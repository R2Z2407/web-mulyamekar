---
---

<div id="modalProfil" class="fixed inset-0 z-[100] bg-slate-900/80 hidden items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <div id="modalProfilBox" class="bg-white rounded-3xl w-full max-w-lg shadow-2xl transform scale-95 transition-transform duration-300 flex flex-col relative max-h-[95vh]">
        
        <button onclick="tutupModalProfil()" class="absolute top-4 right-4 z-[60] text-white bg-black/20 hover:bg-black/40 p-2 rounded-full transition-colors flex items-center justify-center shadow-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="overflow-y-auto hide-scrollbar rounded-3xl">
            <div class="h-28 bg-gradient-to-r from-teal-500 to-teal-700 relative shrink-0">
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
            </div>

            <div class="px-6 md:px-8 pb-8 relative">
                <div class="flex justify-center -mt-14 mb-6 relative z-10">
                    <div class="relative group cursor-pointer" onclick="document.getElementById('uploadFotoProfil').click()">
                        <img id="imgModalProfil" src="" alt="Foto Profil" class="w-28 h-28 rounded-full object-cover border-4 border-white shadow-lg bg-white transition-transform duration-300 group-hover:scale-105">
                        <div class="absolute inset-0 bg-slate-900/50 rounded-full opacity-0 group-hover:opacity-100 flex items-center justify-center transition-all duration-300">
                            <i class="bi bi-camera-fill text-white text-3xl"></i>
                        </div>
                        <div id="loadingUpload" class="absolute inset-0 bg-white/80 rounded-full hidden items-center justify-center backdrop-blur-sm">
                            <i class="bi bi-arrow-repeat animate-spin text-teal-600 text-3xl"></i>
                        </div>
                    </div>
                    <input type="file" id="uploadFotoProfil" accept="image/jpeg, image/png, image/webp" class="hidden">
                </div>

                <form id="formEditProfil" class="space-y-4">
                    <div class="p-3 bg-teal-50/50 border border-teal-100 rounded-xl">
                        <label class="block text-[10px] font-black text-teal-800 uppercase tracking-wider mb-2">Kontak Warga (Bisa Diedit)</label>
                        <div class="space-y-3">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Email Aktif</label>
                                <input type="email" id="inputEditEmail" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-teal-500 outline-none text-sm font-medium text-slate-900" placeholder="email@anda.com">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1">Nomor HP / WA</label>
                                <input type="text" id="inputEditPhone" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-teal-500 outline-none font-mono text-sm font-medium text-slate-900" placeholder="08...">
                            </div>
                        </div>
                    </div>

                    <div class="p-4 bg-slate-50 border border-slate-200 rounded-xl space-y-3 mt-2">
                        <div class="flex items-center gap-2 mb-1">
                            <i class="bi bi-lock-fill text-slate-400"></i>
                            <label class="block text-[10px] font-black text-slate-500 uppercase tracking-wider">Data Kependudukan (Permanen)</label>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Nama Sesuai KTP</label>
                            <input type="text" id="inputEditNama" disabled class="w-full px-4 py-2 bg-slate-200/50 border border-slate-200 rounded-lg text-sm font-bold text-slate-400 cursor-not-allowed">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">NIK KTP</label>
                            <input type="text" id="inputEditNik" disabled class="w-full px-4 py-2 bg-slate-200/50 border border-slate-200 rounded-lg text-sm font-bold font-mono text-slate-400 cursor-not-allowed">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Jenis Kelamin</label>
                            <input type="text" id="inputEditGender" disabled class="w-full px-4 py-2 bg-slate-200/50 border border-slate-200 rounded-lg text-sm font-bold text-slate-400 cursor-not-allowed">
                            <p class="text-[9px] text-teal-600 font-medium mt-1"><i class="bi bi-check-circle-fill"></i> Terdeteksi otomatis dari NIK</p>
                        </div>
                    </div>

                    <div class="pt-4 border-t border-slate-100 flex justify-end gap-3 mt-4">
                        <button type="button" onclick="tutupModalProfil()" class="px-5 py-2.5 rounded-xl font-bold text-slate-500 hover:bg-slate-100 transition-colors">Batal</button>
                        <button type="submit" id="btnSimpanProfil" class="bg-teal-600 hover:bg-teal-700 text-white font-bold py-2.5 px-6 rounded-xl shadow-md transition-all active:scale-95">Simpan Perubahan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
<script>
    import { supabase, SECRET_KEY } from '../../lib/supabase.js';
    const IMGBB_KEY = import.meta.env.PUBLIC_IMGBB_API_KEY;

    window.bukaModalProfil = () => { document.body.classList.add('overflow-hidden'); const m = document.getElementById('modalProfil'), b = document.getElementById('modalProfilBox'); m.classList.remove('hidden'); m.classList.add('flex'); setTimeout(() => { m.classList.remove('opacity-0'); b.classList.remove('scale-95'); b.classList.add('scale-100'); }, 10); };
    window.tutupModalProfil = () => { document.body.classList.remove('overflow-hidden'); const m = document.getElementById('modalProfil'), b = document.getElementById('modalProfilBox'); m.classList.add('opacity-0'); b.classList.remove('scale-100'); b.classList.add('scale-95'); setTimeout(() => { m.classList.add('hidden'); m.classList.remove('flex'); }, 300); };

    // --- UPLOAD FOTO KE IMGBB ---
    document.getElementById('uploadFotoProfil')?.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        if (file.size > 10 * 1024 * 1024) { alert('Maksimal ukuran foto asli 10 MB!'); e.target.value = ''; return; }

        document.getElementById('loadingUpload')?.classList.replace('hidden', 'flex');

        try {
            const img = new Image(); img.src = URL.createObjectURL(file);
            await new Promise((resolve, reject) => { img.onload = resolve; img.onerror = reject; });

            const MAX_SIZE = 500; let width = img.width, height = img.height;
            if (width > height) { if (width > MAX_SIZE) { height *= MAX_SIZE / width; width = MAX_SIZE; } } 
            else { if (height > MAX_SIZE) { width *= MAX_SIZE / height; height = MAX_SIZE; } }

            const canvas = document.createElement('canvas');
            canvas.width = width; canvas.height = height;
            const ctx = canvas.getContext('2d'); ctx.drawImage(img, 0, 0, width, height);
            const blobBaru = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.8));
            URL.revokeObjectURL(img.src); 

            const formData = new FormData(); formData.append('image', blobBaru, 'profil.jpg');
            const res = await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_KEY}`, { method: 'POST', body: formData });
            const responseData = await res.json();
            
            if (responseData.success) {
                const imageUrl = responseData.data.url;
                await supabase.from('profil_user').update({ avatar_url: imageUrl }).eq('id', window.currentUser.id);
                document.querySelectorAll('.foto-profil-global').forEach(img => img.src = imageUrl);
                if(document.getElementById('imgModalProfil')) document.getElementById('imgModalProfil').src = imageUrl;
                alert('Foto profil diperbarui!');
            } else throw new Error("Gagal mengunggah gambar ke ImgBB.");
        } catch (error) {
            alert('Gagal: ' + error.message);
        } finally {
            document.getElementById('loadingUpload')?.classList.replace('flex', 'hidden');
            e.target.value = '';
        }
    });

    // --- SUBMIT PENGATURAN PROFIL ---
    document.getElementById('formEditProfil')?.addEventListener('submit', async (e) => {
        e.preventDefault(); 
        const btn = document.getElementById('btnSimpanProfil'); 
        btn.disabled = true; btn.innerHTML = "Menyimpan...";

        const emailBaru = document.getElementById('inputEditEmail').value.trim();
        const phoneBaru = document.getElementById('inputEditPhone').value.trim();

        try {
            const namaLama = window.profilWarga.nama_lengkap ? window.profilWarga.nama_lengkap.trim() : null; 
            if (namaLama) {
                const { data: dpt, error: errCari } = await supabase.from('data_penduduk').select('id').ilike('nama_lengkap', namaLama).maybeSingle();
                if (errCari) throw new Error("Error nyari data di Buku Induk: " + errCari.message);
                if (dpt) {
                    const hpEncrypted = CryptoJS.AES.encrypt(phoneBaru, SECRET_KEY).toString();
                    const { error: errDukcapil } = await supabase.from('data_penduduk').update({ no_telp: hpEncrypted }).eq('id', dpt.id);
                    if (errDukcapil) throw new Error("Akses Ditolak Buku Induk (RLS): " + errDukcapil.message);
                } else {
                    throw new Error(`Nama '${namaLama}' tidak ditemukan di Buku Induk. Hubungi RT!`);
                }
            }

            const { error: errProfil } = await supabase.from('profil_user').update({ email: emailBaru, phone: phoneBaru }).eq('id', window.currentUser.id);
            if (errProfil) throw errProfil; 
            
            window.profilWarga.email = emailBaru; window.profilWarga.phone = phoneBaru;
            alert('Profil dan Kontak berhasil diperbarui!');
            tutupModalProfil();
        } catch (error) {
            alert('Gagal: ' + error.message);
        } finally {
            btn.disabled = false; btn.innerText = "Simpan Perubahan";
        }
    });
</script>