---
// src/components/RegisterModal.astro
---

<div id="registerModal" class="fixed inset-0 z-[100] bg-slate-900/80 hidden flex items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <div id="registerModalBox" class="bg-white rounded-3xl w-full max-w-md shadow-2xl transform scale-95 transition-transform duration-300 overflow-hidden flex flex-col">
        
        <div class="bg-gradient-to-r from-emerald-600 to-teal-800 p-6 text-white flex justify-between items-center relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
            <div class="relative z-10">
                <h3 class="text-2xl font-black tracking-tight">Daftar Akun Baru</h3>
                <p class="text-emerald-100 text-sm mt-1">Validasi NIK Dukcapil Mulyamekar</p>
            </div>
            <button type="button" onclick="tutupRegisterModal()" class="relative z-10 text-emerald-100 hover:text-white bg-white/10 hover:bg-white/20 p-2 rounded-full transition-colors">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="p-6 md:p-8">
            <form id="registerForm" class="space-y-5" novalidate>
                
                <div>
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">NIK KTP (16 Digit)</label>
                    <div class="relative">
                        <i class="bi bi-credit-card-2-front absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="text" id="regNik" maxlength="16" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all text-sm font-bold font-mono tracking-widest text-slate-900 placeholder-slate-400" placeholder="16 Digit Angka">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Nama Sesuai KTP</label>
                    <div class="relative">
                        <i class="bi bi-person absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="text" id="regNama" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Nama Lengkap Anda">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Alamat Email</label>
                    <div class="relative">
                        <i class="bi bi-envelope absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="email" id="regEmail" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="email@anda.com">
                    </div>
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Buat Kata Sandi</label>
                    <div class="relative">
                        <i class="bi bi-shield-lock absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="password" id="regPassword" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Minimal 6 karakter">
                    </div>
                </div>

                <button type="submit" id="btnRegSubmit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-black py-3.5 rounded-xl shadow-md shadow-emerald-600/20 transition-all active:scale-95 flex justify-center items-center gap-2">
                    Validasi & Daftar <i class="bi bi-check2-circle text-lg"></i>
                </button>
            </form>

            <div class="mt-6 text-center border-t border-slate-100 pt-6">
                <p class="text-sm text-slate-500 font-medium">
                    Sudah punya akun? <button type="button" onclick="tutupRegisterModal(); setTimeout(() => bukaLoginModal(), 300);" class="text-emerald-600 font-bold hover:text-emerald-800 hover:underline">Masuk di sini</button>
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    import { supabase } from '../lib/supabase.js';

    window.bukaRegisterModal = () => {
        const m = document.getElementById('registerModal');
        const b = document.getElementById('registerModalBox');
        m.classList.remove('hidden');
        setTimeout(() => { m.classList.remove('opacity-0'); b.classList.remove('scale-95'); b.classList.add('scale-100'); }, 10);
    };

    window.tutupRegisterModal = () => {
        const m = document.getElementById('registerModal');
        const b = document.getElementById('registerModalBox');
        m.classList.add('opacity-0'); b.classList.remove('scale-100'); b.classList.add('scale-95');
        setTimeout(() => { m.classList.add('hidden'); document.getElementById('registerForm').reset(); }, 300);
    };

    document.getElementById('registerForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const nik = document.getElementById('regNik').value.trim();
        const nama = document.getElementById('regNama').value.trim();
        const email = document.getElementById('regEmail').value.trim();
        const password = document.getElementById('regPassword').value;
        const btn = document.getElementById('btnRegSubmit');

        btn.disabled = true;
        btn.innerHTML = "Mengecek Dukcapil... <i class='bi bi-hourglass-split animate-spin'></i>";

        try {
            if (nik.length !== 16) throw new Error("NIK harus 16 digit!");
            if (!email || !password || !nama) throw new Error("Semua data wajib diisi!");

            // 1. Tembak Edge Function Dukcapil
            const { data: hasil, error: invokeError } = await supabase.functions.invoke('cek-nik', {
                body: { nik: nik, nama: nama }
            });

            if (invokeError) throw new Error("Sistem verifikasi sedang sibuk. Coba beberapa saat lagi.");
            if (hasil && hasil.status !== 'sukses') throw new Error(hasil.pesan || "Verifikasi gagal!");

            btn.innerHTML = "Membuat Akun... <i class='bi bi-hourglass-split animate-spin'></i>";

            // 2. SignUp Auth Supabase (Trigger Database akan otomatis handle profil_user)
            const { data: authData, error: signError } = await supabase.auth.signUp({ 
                email, password, options: { 
                    data: { 
                        nama_lengkap: nama, 
                        nik: nik,
                        wilayah_rt: hasil.wilayah_rt || ''
                    } 
                } 
            });
            
            if (signError) throw signError;

            showCustomAlert('success', 'Pendaftaran Berhasil', 'Identitas valid. Mengalihkan ke Dashboard...');
            setTimeout(() => { window.location.href = '/warga'; }, 1500);

        } catch (error) {
            console.error("❌ ERROR DAFTAR:", error);
            let msg = error.message;
            if(msg.includes('already registered')) msg = "Email ini sudah terdaftar!";
            showCustomAlert('error', 'Gagal', msg);
            
            btn.disabled = false;
            btn.innerHTML = "Validasi & Daftar <i class='bi bi-check2-circle text-lg'></i>";
        }
    });
</script>