---
// src/components/umkm/UmkmModalZoom.astro
---
<div id="modalZoomFoto" class="fixed inset-0 z-[100] bg-black/95 hidden flex flex-col items-center justify-center opacity-0 transition-opacity duration-300">
    <button onclick="tutupZoom()" class="absolute top-4 right-4 md:top-6 md:right-6 z-50 bg-white/10 hover:bg-rose-500 text-white w-12 h-12 rounded-full flex items-center justify-center transition-colors backdrop-blur-sm border border-white/20 shadow-lg">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    
    <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 z-50 bg-black/50 text-white/80 text-xs px-4 py-2 rounded-full backdrop-blur-md pointer-events-none">
        <span class="hidden md:inline">Gunakan Scroll Mouse untuk Zoom</span>
        <span class="inline md:hidden">Cubit Layar (Pinch) untuk Zoom</span>
    </div>

    <div class="w-full h-full flex items-center justify-center overflow-hidden relative">
        <img id="gambarZoom" src="" class="max-w-full max-h-full object-contain transition-transform duration-100 ease-out cursor-grab active:cursor-grabbing" style="transform: scale(1); touch-action: none;">
    </div>
</div>

<script>
    let currentScale = 1;

    window.bukaZoomFoto = (url) => {
        const m = document.getElementById('modalZoomFoto');
        const img = document.getElementById('gambarZoom');
        
        img.src = url;
        currentScale = 1;
        img.style.transform = `scale(1)`;
        document.body.classList.add('overflow-hidden');
        m.classList.remove('hidden');
        setTimeout(() => m.classList.remove('opacity-0'), 10);
    };

    window.tutupZoom = () => {
        const m = document.getElementById('modalZoomFoto');
        m.classList.add('opacity-0');
        setTimeout(() => {
            m.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }, 300);
    };

    document.addEventListener('DOMContentLoaded', () => {
        const imgZoom = document.getElementById('gambarZoom');

        // 1. ZOOM DESKTOP
        imgZoom.addEventListener('wheel', (e) => {
            e.preventDefault();
            currentScale += e.deltaY * -0.002;
            currentScale = Math.min(Math.max(1, currentScale), 4); 
            imgZoom.style.transform = `scale(${currentScale})`;
        });

        // 2. ZOOM MOBILE
        let startDistance = 0;
        imgZoom.addEventListener('touchstart', (e) => {
            if (e.touches.length === 2) {
                startDistance = Math.hypot(
                    e.touches[0].pageX - e.touches[1].pageX,
                    e.touches[0].pageY - e.touches[1].pageY
                );
            }
        });

        imgZoom.addEventListener('touchmove', (e) => {
            if (e.touches.length === 2) {
                e.preventDefault(); 
                const currentDistance = Math.hypot(
                    e.touches[0].pageX - e.touches[1].pageX,
                    e.touches[0].pageY - e.touches[1].pageY
                );
                const distanceRatio = currentDistance / startDistance;
                let newScale = currentScale * distanceRatio;
                newScale = Math.min(Math.max(1, newScale), 4);
                imgZoom.style.transform = `scale(${newScale})`;
                
                startDistance = currentDistance;
                currentScale = newScale;
            }
        });
    });
</script>