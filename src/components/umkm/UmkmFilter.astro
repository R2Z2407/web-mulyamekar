---
// src/components/umkm/UmkmFilter.astro
---
<div class="max-w-4xl mx-auto mb-10 flex flex-col sm:flex-row gap-4 sm:gap-5">
    <div class="relative flex-grow">
        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <input type="text" id="inputPencarian" onkeyup="cariProduk()" class="w-full pl-14 pr-5 py-4 bg-white border border-gray-200 rounded-2xl shadow-sm outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-all font-medium text-gray-700 text-sm md:text-base placeholder-gray-400" placeholder="Cari seblak, kerajinan, atau nama toko...">
    </div>

    <div class="relative w-full sm:w-72 shrink-0">
        <select id="selectUrutan" onchange="ubahUrutan()" class="w-full px-5 py-4 bg-white border border-gray-200 rounded-2xl shadow-sm outline-none focus:ring-2 focus:ring-orange-500 transition-all font-bold text-gray-700 text-sm cursor-pointer appearance-none">
            <option value="Terbaru">✨ Paling Baru</option>
            <option value="HargaTermurah">💸 Harga: Termurah</option>
            <option value="HargaTermahal">💎 Harga: Termahal</option>
            <option value="Terlaris">🔥 Paling Laris</option>
        </select>
        <div class="absolute inset-y-0 right-0 pr-5 flex items-center pointer-events-none">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
    </div>
</div>

<div class="mb-12">
    <div class="flex overflow-x-auto hide-scrollbar gap-4 md:gap-6 md:justify-center snap-x snap-mandatory pb-6 pt-2" id="kategoriContainer">
        
        <button onclick="filterKategori('Semua', this)" class="btn-kategori active group shrink-0 snap-center w-[90px] md:w-28 flex flex-col items-center justify-start p-3 rounded-2xl bg-white border-2 border-gray-100 hover:border-orange-300 hover:shadow-md transition-all active:scale-95">
            <div class="pointer-events-none w-14 h-14 bg-gray-50 group-[.active]:bg-orange-100 rounded-full flex items-center justify-center text-3xl mb-3 transition-colors shadow-inner">🏪</div>
            <span class="pointer-events-none text-[11px] md:text-xs font-black uppercase tracking-wider text-gray-500 group-[.active]:text-orange-600 text-center leading-tight">Semua</span>
        </button>

        <button onclick="filterKategori('Makanan', this)" class="btn-kategori group shrink-0 snap-center w-[90px] md:w-28 flex flex-col items-center justify-start p-3 rounded-2xl bg-white border-2 border-gray-100 hover:border-orange-300 hover:shadow-md transition-all active:scale-95">
            <div class="pointer-events-none w-14 h-14 bg-gray-50 group-[.active]:bg-orange-100 rounded-full flex items-center justify-center text-3xl mb-3 transition-colors shadow-inner">🍔</div>
            <span class="pointer-events-none text-[11px] md:text-xs font-black uppercase tracking-wider text-gray-500 group-[.active]:text-orange-600 text-center leading-tight">Makanan</span>
        </button>

        <button onclick="filterKategori('Minuman', this)" class="btn-kategori group shrink-0 snap-center w-[90px] md:w-28 flex flex-col items-center justify-start p-3 rounded-2xl bg-white border-2 border-gray-100 hover:border-orange-300 hover:shadow-md transition-all active:scale-95">
            <div class="pointer-events-none w-14 h-14 bg-gray-50 group-[.active]:bg-orange-100 rounded-full flex items-center justify-center text-3xl mb-3 transition-colors shadow-inner">🧋</div>
            <span class="pointer-events-none text-[11px] md:text-xs font-black uppercase tracking-wider text-gray-500 group-[.active]:text-orange-600 text-center leading-tight">Minuman</span>
        </button>

        <button onclick="filterKategori('Kerajinan', this)" class="btn-kategori group shrink-0 snap-center w-[90px] md:w-28 flex flex-col items-center justify-start p-3 rounded-2xl bg-white border-2 border-gray-100 hover:border-orange-300 hover:shadow-md transition-all active:scale-95">
            <div class="pointer-events-none w-14 h-14 bg-gray-50 group-[.active]:bg-orange-100 rounded-full flex items-center justify-center text-3xl mb-3 transition-colors shadow-inner">🏺</div>
            <span class="pointer-events-none text-[11px] md:text-xs font-black uppercase tracking-wider text-gray-500 group-[.active]:text-orange-600 text-center leading-tight">Kerajinan</span>
        </button>

        <button onclick="filterKategori('Pertanian', this)" class="btn-kategori group shrink-0 snap-center w-[90px] md:w-28 flex flex-col items-center justify-start p-3 rounded-2xl bg-white border-2 border-gray-100 hover:border-orange-300 hover:shadow-md transition-all active:scale-95">
            <div class="pointer-events-none w-14 h-14 bg-gray-50 group-[.active]:bg-orange-100 rounded-full flex items-center justify-center text-3xl mb-3 transition-colors shadow-inner">🌾</div>
            <span class="pointer-events-none text-[11px] md:text-xs font-black uppercase tracking-wider text-gray-500 group-[.active]:text-orange-600 text-center leading-tight">Pertanian</span>
        </button>

        <button onclick="filterKategori('Jasa', this)" class="btn-kategori group shrink-0 snap-center w-[90px] md:w-28 flex flex-col items-center justify-start p-3 rounded-2xl bg-white border-2 border-gray-100 hover:border-orange-300 hover:shadow-md transition-all active:scale-95">
            <div class="pointer-events-none w-14 h-14 bg-gray-50 group-[.active]:bg-orange-100 rounded-full flex items-center justify-center text-3xl mb-3 transition-colors shadow-inner">🛠️</div>
            <span class="pointer-events-none text-[11px] md:text-xs font-black uppercase tracking-wider text-gray-500 group-[.active]:text-orange-600 text-center leading-tight">Jasa</span>
        </button>

    </div>
</div>

<style>
    .btn-kategori.active {
        border-color: #f97316; /* orange-500 */
        box-shadow: 0 4px 6px -1px rgba(249, 115, 22, 0.1), 0 2px 4px -1px rgba(249, 115, 22, 0.06);
    }
</style>