---
// src/components/umkm/toko/SellerHeader.astro
---
<div class="bg-gradient-to-r from-orange-600 to-amber-500 rounded-3xl p-8 text-white shadow-xl mb-8 flex flex-col md:flex-row justify-between items-center gap-6 relative overflow-hidden border border-orange-400/50">
    <div class="absolute -right-20 -top-20 w-64 h-64 bg-orange-400 rounded-full opacity-30 blur-3xl"></div>
    
    <div class="flex items-center gap-6 relative z-10 w-full md:w-auto">
        <div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center backdrop-blur-md border-2 border-white/30 shadow-inner overflow-hidden">
            <span class="text-4xl">🏪</span>
        </div>
        <div>
            <h1 class="text-2xl md:text-3xl font-black tracking-tight" id="namaTokoHeadline">Memuat Toko...</h1>
            <div class="flex flex-wrap gap-2 mt-2">
                <span class="bg-orange-900/40 px-3 py-1 rounded-full text-xs font-bold border border-orange-400/50 shadow-sm" id="namaPemilikToko">...</span>
                <span class="bg-green-900/40 px-3 py-1 rounded-full text-xs font-bold border border-green-400/50 shadow-sm" id="statusTokoBadge">Status: Aktif</span>
            </div>
        </div>
    </div>

    <div class="relative z-10 flex gap-3">
        <a href="/umkm" class="bg-white/20 hover:bg-white/30 text-white border border-white/50 px-5 py-3 rounded-2xl font-bold transition-all shadow-sm text-sm flex items-center gap-2">
            <i class="bi bi-eye-fill"></i> Lihat Etalase Desa
        </a>
    </div>
</div>