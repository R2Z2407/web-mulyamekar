---
// src/components/umkm/toko/ModalAddProduct.astro
---
<div id="modalProduk" class="fixed inset-0 z-[100] bg-slate-900/80 hidden items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <div id="modalProdukBox" class="bg-white rounded-3xl w-full max-w-xl shadow-2xl transform scale-95 transition-transform duration-300 flex flex-col relative max-h-[95vh] overflow-hidden">
        
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-orange-50/50">
            <h3 class="text-xl font-black text-orange-900" id="modalTitle">Tambah Produk Baru</h3>
            <button onclick="tutupModalProduk()" class="text-orange-400 hover:text-red-500 bg-white p-2 rounded-full shadow-sm transition-colors">
                <i class="bi bi-x-lg font-black"></i>
            </button>
        </div>

        <div class="p-6 overflow-y-auto hide-scrollbar">
            <form id="formProduk" class="space-y-5">
                <input type="hidden" id="prod_id">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="col-span-full">
                        <label class="block text-xs font-bold text-gray-500 mb-1.5 uppercase">Nama Produk *</label>
                        <input type="text" id="prod_nama" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition-all font-bold text-gray-800" placeholder="Misal: Seblak Instan Pedas">
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-gray-500 mb-1.5 uppercase">Kategori *</label>
                        <select id="prod_kategori" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition-all font-bold text-gray-700">
                            <option value="Makanan">Makanan</option>
                            <option value="Minuman">Minuman</option>
                            <option value="Kerajinan">Kerajinan</option>
                            <option value="Pertanian">Pertanian</option>
                            <option value="Jasa">Jasa</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-gray-500 mb-1.5 uppercase">Harga (Rp) *</label>
                        <input type="number" id="prod_harga" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition-all font-mono font-bold" placeholder="0">
                    </div>

                    <div class="col-span-full">
                        <label class="block text-xs font-bold text-gray-500 mb-1.5 uppercase">Deskripsi Produk *</label>
                        <textarea id="prod_deskripsi" required rows="4" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition-all font-medium text-gray-700" placeholder="Ceritakan detail produkmu..."></textarea>
                    </div>

                    <div class="col-span-full">
                        <label class="block text-xs font-bold text-gray-500 mb-1.5 uppercase">Foto Produk</label>
                        <div class="flex items-center gap-4 w-full">
                            <div id="wadahPreview" class="hidden w-24 h-24 shrink-0 rounded-2xl border-2 border-gray-100 overflow-hidden bg-gray-50 shadow-inner">
                                <img id="preview_foto" src="" alt="Preview" class="w-full h-full object-cover">
                            </div>
                            
                            <label for="prod_foto" class="flex flex-col items-center justify-center w-full h-24 border-2 border-gray-200 border-dashed rounded-2xl cursor-pointer bg-gray-50 hover:bg-orange-50 hover:border-orange-300 transition-all group">
                                <div class="flex flex-col items-center justify-center pt-2 pb-2 px-2">
                                    <i class="bi bi-cloud-arrow-up-fill text-2xl text-gray-300 group-hover:text-orange-400 transition-colors"></i>
                                    <p class="text-[10px] text-gray-500 mt-1 font-bold uppercase" id="labelFotoProduk">Klik untuk Upload Gambar</p>
                                </div>
                                <input id="prod_foto" type="file" accept="image/*" class="hidden" />
                            </label>
                        </div>
                    </div>
                </div>

                <div class="pt-4 border-t border-gray-50 flex flex-col gap-3">
                    <button type="submit" id="btnSimpanProduk" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-black py-4 rounded-2xl shadow-lg transition-all active:scale-95">Simpan Produk</button>
                </div>
            </form>
        </div>
    </div>
</div>