---
// src/components/Footer.astro
import CustomAlert from './CustomAlert.astro'; // <--- TAMBAHKAN INI
const currentYear = new Date().getFullYear();
---

<footer class="bg-teal-950 text-teal-100 pt-16 pb-8 border-t-4 border-amber-500">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-amber-500 rounded-full flex items-center justify-center text-teal-950 font-extrabold text-xl shadow-sm">
            M
          </div>
          <div>
            <h2 class="text-xl font-bold text-white leading-tight tracking-wide">Desa Mulyamekar</h2>
            <p class="text-xs text-teal-400">Kab. Purwakarta</p>
          </div>
        </a>
        <p class="text-teal-300 text-sm leading-relaxed">
          Website portal resmi Pemerintahan Desa Mulyamekar sebagai sarana transparansi, informasi publik, dan pelayanan administrasi warga berbasis digital.
        </p>
      </div>

      <div>
        <h3 class="text-white font-bold text-lg mb-6 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-amber-500"></span> Tautan Cepat
        </h3>
        <ul class="space-y-3 text-sm text-teal-300">
          <li><a href="/profil" class="hover:text-amber-400 hover:translate-x-1 inline-block transition-transform">Profil Desa</a></li>
          <li><a href="/pemerintahan" class="hover:text-amber-400 hover:translate-x-1 inline-block transition-transform">Pemerintahan</a></li>
          <li><a href="/transparansi" class="hover:text-amber-400 hover:translate-x-1 inline-block transition-transform">Transparansi Dana (APBDes)</a></li>
          <li><a href="/informasi" class="hover:text-amber-400 hover:translate-x-1 inline-block transition-transform">Berita & Artikel</a></li>
          <li><a href="/layanan" class="hover:text-amber-400 hover:translate-x-1 inline-block transition-transform">Layanan Surat Online</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-bold text-lg mb-6 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-amber-500"></span> Hubungi Kami
        </h3>
        <ul class="space-y-4 text-sm text-teal-300">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="leading-relaxed">Jl. Raya Mulyamekar No. 123, Kec. Babakancikao, Kab. Purwakarta, Jawa Barat 41151</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href="mailto:pemdes@mulyamekar.desa.id" class="hover:text-amber-400 transition-colors">pemdes@mulyamekar.desa.id</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <span>(0264) 1234567</span>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-bold text-lg mb-6 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-amber-500"></span> Jam Layanan
        </h3>
        <ul class="space-y-2 text-sm text-teal-300">
          <li class="flex justify-between border-b border-teal-800 pb-2">
            <span>Senin - Kamis</span>
            <span class="text-white font-semibold">08:00 - 15:00</span>
          </li>
          <li class="flex justify-between border-b border-teal-800 pb-2">
            <span>Jumat</span>
            <span class="text-white font-semibold">08:00 - 14:00</span>
          </li>
          <li class="flex justify-between text-amber-400 font-semibold pt-1">
            <span>Sabtu & Minggu</span>
            <span>Tutup (Libur)</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-teal-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-teal-500">
      <p>&copy; {currentYear} Pemerintah Desa Mulyamekar. Hak Cipta Dilindungi.</p>
      <p>Dikembangkan dengan <span class="text-rose-500">&hearts;</span> oleh Rijal</p>
    </div>

  </div>
</footer>
<CustomAlert />
<script is:inline>
    // 1. Blokir Klik Kanan & Shortcut (Kode sebelumnya)
    document.addEventListener('contextmenu', event => event.preventDefault());
    document.onkeydown = function(e) {
        if(e.keyCode == 123) return false; // F12
        if(e.ctrlKey && e.shiftKey && e.keyCode == 'I'.charCodeAt(0)) return false; // Ctrl+Shift+I
        if(e.ctrlKey && e.shiftKey && e.keyCode == 'J'.charCodeAt(0)) return false; // Ctrl+Shift+J
        if(e.ctrlKey && e.keyCode == 'U'.charCodeAt(0)) return false; // Ctrl+U
    };

    // 2. TEKNIK BARU: DEBUGGER LOOP (Jebakan Freeze)
    // Pakai try-catch dan konstruktor rahasia biar kodenya agak susah dilacak sama hacker amatir
    (function jebakanDebugger() {
        try {
            (function() { return false; })['constructor']('debugger')['call']();
        } catch (err) {}
        setTimeout(jebakanDebugger, 100); // Akan terus menerus menyerang setiap 0.1 detik
    })();
</script>