---
// src/components/AuthModal.astro
---

<div id="authModal" class="fixed inset-0 z-[100] bg-slate-900/80 hidden flex items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    
    <div id="authModalBox" class="bg-white rounded-3xl w-full max-w-md shadow-2xl transform scale-95 transition-transform duration-300 overflow-hidden flex flex-col">
        
        <div class="bg-gradient-to-r from-teal-600 to-teal-800 p-6 text-white flex justify-between items-center relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
            <div class="relative z-10">
                <h3 class="text-2xl font-black tracking-tight" id="authTitle">Masuk Akun</h3>
                <p class="text-teal-100 text-sm mt-1" id="authDesc">Layanan Digital Desa Mulyamekar</p>
            </div>
            <button onclick="tutupAuthModal()" class="relative z-10 text-teal-100 hover:text-white bg-white/10 hover:bg-white/20 p-2 rounded-full transition-colors">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="p-6 md:p-8">
            <form id="authForm" class="space-y-5" novalidate>
                
                <div id="wadahInputUtama" class="space-y-5 block">
                    <div id="fieldNik" class="hidden animate-fadeIn">
                        <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">NIK KTP (16 Digit)</label>
                        <div class="relative">
                            <i class="bi bi-credit-card-2-front absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                            <input type="text" id="authNik" maxlength="16" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:bg-white outline-none transition-all text-sm font-bold font-mono tracking-widest text-slate-900 placeholder-slate-400" placeholder="16 Digit Angka">
                        </div>
                    </div>

                    <div id="fieldNama" class="hidden animate-fadeIn">
                        <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Nama Sesuai KTP</label>
                        <div class="relative">
                            <i class="bi bi-person absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                            <input type="text" id="authNama" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:bg-white outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Nama Lengkap Anda">
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Alamat Email</label>
                        <div class="relative">
                            <i class="bi bi-envelope absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                            <input type="email" id="authEmail" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:bg-white outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="email@anda.com">
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Kata Sandi</label>
                        <div class="relative">
                            <i class="bi bi-shield-lock absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                            <input type="password" id="authPassword" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:bg-white outline-none transition-all text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Minimal 6 karakter">
                        </div>
                    </div>
                </div>

                <div id="wadahOTP" class="hidden space-y-4 text-center">
                    <div class="w-16 h-16 bg-teal-50 text-teal-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-2 border border-teal-100">
                        <i class="bi bi-envelope-check"></i>
                    </div>
                    <label class="block text-sm font-bold text-slate-600 uppercase tracking-tight">Verifikasi Kode OTP</label>
                    <p class="text-xs text-slate-500 font-medium">Kode rahasia 6-digit telah dikirim ke email Anda. Cek folder Inbox/Spam.</p>
                    
                    <div class="relative mt-2">
                        <input type="text" id="authOTP" maxlength="6" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full text-center tracking-[0.5em] font-mono text-2xl py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:bg-white outline-none transition-all font-black text-slate-900 placeholder-slate-300" placeholder="------">
                    </div>

                    <div class="pt-2 text-xs font-medium text-slate-500">
                        Belum menerima kode? <br>
                        <div class="mt-1 flex items-center justify-center gap-2">
                            <button type="button" id="btnResendOTP" onclick="kirimUlangOTP()" class="text-teal-600 font-bold hover:text-teal-800 disabled:text-slate-400 disabled:cursor-not-allowed transition-colors" disabled>
                                Kirim Ulang (Sisa: 2)
                            </button>
                            <span id="resendTimerText" class="text-slate-400 font-mono bg-slate-100 px-2 py-0.5 rounded-md hidden">60s</span>
                        </div>
                    </div>
                </div>

                <button type="submit" id="btnSubmitAuth" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-black py-3.5 rounded-xl shadow-md shadow-teal-600/20 transition-all active:scale-95 flex justify-center items-center gap-2">
                    Masuk Sekarang <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <div class="mt-6 text-center border-t border-slate-100 pt-6" id="authToggleContainer">
                <p class="text-sm text-slate-500 font-medium" id="authToggleText">
                    Belum punya akun warga? 
                    <button type="button" onclick="setAuthMode('register')" class="text-teal-600 font-bold hover:text-teal-800 hover:underline">Daftar di sini</button>
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    import { supabase } from '../lib/supabase.js';

    let currentMode = 'login'; 
    let tempNama = ''; 
    let tempNik = '';
    let sisaResend = 2; // Total 3x (1x Signup awal + 2x Resend)
    let waktuTunggu = 0;
    let intervalTimer = null;

    window.bukaAuthModal = () => {
        const m = document.getElementById('authModal');
        const b = document.getElementById('authModalBox');
        setAuthMode('login');
        m.classList.remove('hidden');
        setTimeout(() => { m.classList.remove('opacity-0'); b.classList.remove('scale-95'); b.classList.add('scale-100'); }, 10);
    };

    window.tutupAuthModal = () => {
        const m = document.getElementById('authModal');
        const b = document.getElementById('authModalBox');
        m.classList.add('opacity-0');
        b.classList.remove('scale-100');
        b.classList.add('scale-95');
        clearInterval(intervalTimer);
        setTimeout(() => { m.classList.add('hidden'); document.getElementById('authForm').reset(); }, 300);
    };

    window.setAuthMode = (mode) => {
        currentMode = mode;
        const title = document.getElementById('authTitle');
        const desc = document.getElementById('authDesc');
        const btn = document.getElementById('btnSubmitAuth');
        const toggleText = document.getElementById('authToggleText');
        const toggleContainer = document.getElementById('authToggleContainer');
        const wadahUtama = document.getElementById('wadahInputUtama');
        const wadahOTP = document.getElementById('wadahOTP');
        const fieldNama = document.getElementById('fieldNama');
        const fieldNik = document.getElementById('fieldNik');
        const inputOTP = document.getElementById('authOTP');

        if (mode === 'login') {
            title.innerText = "Masuk Akun";
            desc.innerText = "Layanan Digital Desa Mulyamekar";
            btn.innerHTML = "Masuk Sekarang <i class='bi bi-arrow-right'></i>";
            toggleContainer.classList.remove('hidden');
            toggleText.innerHTML = `Belum punya akun warga? <button type="button" onclick="setAuthMode('register')" class="text-teal-600 font-bold hover:text-teal-800 hover:underline">Daftar di sini</button>`;
            wadahUtama.classList.remove('hidden');
            wadahOTP.classList.add('hidden');
            fieldNama.classList.add('hidden');
            fieldNik.classList.add('hidden');
        } 
        else if (mode === 'register') {
            title.innerText = "Daftar Akun Baru";
            desc.innerText = "Validasi NIK Dukcapil Mulyamekar";
            btn.innerHTML = "Validasi & Daftar <i class='bi bi-arrow-right'></i>";
            toggleContainer.classList.remove('hidden');
            toggleText.innerHTML = `Sudah punya akun? <button type="button" onclick="setAuthMode('login')" class="text-teal-600 font-bold hover:text-teal-800 hover:underline">Masuk di sini</button>`;
            wadahUtama.classList.remove('hidden');
            wadahOTP.classList.add('hidden');
            fieldNama.classList.remove('hidden');
            fieldNik.classList.remove('hidden');
        }
        else if (mode === 'otp') {
            title.innerText = "Verifikasi Email";
            desc.innerText = "Masukkan kode rahasia dari email Anda";
            btn.innerHTML = "Verifikasi & Masuk <i class='bi bi-check-circle-fill'></i>";
            toggleContainer.classList.add('hidden'); 
            wadahUtama.classList.add('hidden');
            wadahOTP.classList.remove('hidden');
            inputOTP.value = ''; 
        }
    };

    window.mulaiTimerResend = () => {
        waktuTunggu = 60;
        const btn = document.getElementById('btnResendOTP');
        const txt = document.getElementById('resendTimerText');
        btn.disabled = true;
        txt.classList.remove('hidden');
        clearInterval(intervalTimer);
        intervalTimer = setInterval(() => {
            waktuTunggu--;
            txt.innerText = `${waktuTunggu}s`;
            if (waktuTunggu <= 0) {
                clearInterval(intervalTimer);
                txt.classList.add('hidden');
                if (sisaResend > 0) {
                    btn.disabled = false;
                    btn.innerText = `Kirim Ulang (Sisa: ${sisaResend})`;
                } else {
                    btn.innerText = 'Batas Habis (1 Jam)';
                    btn.classList.replace('text-teal-600', 'text-red-500');
                }
            }
        }, 1000);
    };

    window.kirimUlangOTP = async () => {
        if (sisaResend <= 0) return;
        const email = document.getElementById('authEmail').value.trim();
        const btn = document.getElementById('btnResendOTP');
        btn.disabled = true;
        btn.innerText = "Mengirim...";
        console.log("👉 [CCTV] Mencoba kirim ulang OTP ke:", email);

        try {
            const { error } = await supabase.auth.resend({ type: 'signup', email: email });
            if (error) throw error;
            sisaResend--;
            
            // 🔥 Pakai Custom Alert
            showCustomAlert('success', 'Terkirim', 'Kode OTP baru telah dikirim!');
            
            console.log("👉 [CCTV] Kirim ulang sukses! Sisa resend:", sisaResend);
            mulaiTimerResend();
        } catch (error) {
            console.error("❌ [ERROR Resend OTP]:", error);
            let msg = error.message;
            if(msg.includes('rate limit')) msg = "Batas pengiriman email per jam tercapai. Coba lagi nanti.";
            
            // 🔥 Pakai Custom Alert
            showCustomAlert('error', 'Gagal Mengirim', msg);
            
            btn.disabled = false;
            btn.innerText = `Kirim Ulang (Sisa: ${sisaResend})`;
        }
    };

    document.getElementById('authForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('authEmail').value.trim();
        const password = document.getElementById('authPassword').value;
        const nama = document.getElementById('authNama').value.trim();
        const nik = document.getElementById('authNik').value.trim();
        const otp = document.getElementById('authOTP').value.trim();
        const btn = document.getElementById('btnSubmitAuth');

        console.log("👉 [CCTV 1] Tombol Ditekan! Mode saat ini:", currentMode);

        if(currentMode !== 'otp' && (!email || !password)) {
            // 🔥 Pakai Custom Alert
            showCustomAlert('warning', 'Peringatan', 'Email dan Password wajib diisi!');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = "Memproses... <i class='bi bi-hourglass-split animate-spin'></i>";

        try {
            if (currentMode === 'login') {
                console.log("👉 [CCTV 2] Memproses Login...");
                const { data, error } = await supabase.auth.signInWithPassword({ email, password });
                if (error) {
                    if(error.message.includes('Email not confirmed')) throw new Error('Email belum diverifikasi. Cek inbox/spam.');
                    throw error;
                }
                const { data: profil } = await supabase.from('profil_user').select('role').eq('id', data.user.id).single();
                console.log("👉 [CCTV 3] Login sukses, mengalihkan halaman...");
                window.location.href = (profil && profil.role === 'admin') ? '/admin' : '/warga';
            } 
            else if (currentMode === 'register') {
                console.log("👉 [CCTV 2] Memproses Pendaftaran NIK:", nik);
                if (nik.length !== 16) throw new Error("NIK harus 16 digit!");

                const resp = await fetch('/api/cek-nik', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nik })
                });

                const hasil = await resp.json();
                if (hasil.status !== 'sukses') throw new Error("NIK tidak terdaftar di Desa Mulyamekar!");

                console.log("👉 [CCTV 3] NIK Valid! Mendaftarkan ke Supabase...");
                tempNama = nama; tempNik = nik;
                const { error: signError } = await supabase.auth.signUp({ 
                    email, password, options: { data: { nama_lengkap: tempNama } } 
                });
                
                if (signError) throw signError;
                
                console.log("👉 [CCTV 4] Signup Sukses! Pindah ke mode OTP.");
                setAuthMode('otp');
                sisaResend = 2; // Sisa 2x kirim ulang (Total 3 email)
                mulaiTimerResend();
                
                // 🔥 Pakai Custom Alert
                showCustomAlert('success', 'Berhasil', 'NIK Valid! Kode OTP telah dikirim ke email Anda.');
                
                btn.disabled = false;
            }
            else if (currentMode === 'otp') {
                console.log("👉 [CCTV 2] Memulai Verifikasi OTP untuk email:", email);
                if (otp.length < 6) throw new Error("Masukkan 6 digit kode OTP!");
                
                console.log("👉 [CCTV 3] Mengirim token ke Supabase...");
                const { data, error } = await supabase.auth.verifyOtp({ email, token: otp, type: 'signup' });
                if (error) throw error;

                console.log("👉 [CCTV 4] OTP Cocok! Menyimpan profil ke database...");
                if (data.user) {
                    const { error: errProfil } = await supabase.from('profil_user').insert([{ 
                        id: data.user.id, nama_lengkap: tempNama, nik: tempNik, role: 'warga' 
                    }]);
                    if (errProfil) console.error("❌ [Peringatan] Gagal simpan profil:", errProfil);
                }
                
                console.log("👉 [CCTV 5] Berhasil! Mengalihkan ke /warga");
                window.location.href = '/warga';
            }
        } catch (error) {
            console.error("❌ [TERTANGKAP ERROR]:", error);
            let msg = error.message;
            if(msg.includes('rate limit')) msg = "Terlalu banyak permintaan. Tunggu sebentar.";
            if(msg.includes('already registered')) msg = "Email ini sudah digunakan!";
            if(msg.includes('Token has expired or is invalid')) msg = "Kode OTP salah atau sudah hangus!";
            
            // 🔥 Pakai Custom Alert
            showCustomAlert('error', 'Gagal', msg);
            
            btn.disabled = false;
            btn.innerHTML = currentMode === 'login' ? "Masuk Sekarang <i class='bi bi-arrow-right'></i>" : (currentMode === 'register' ? "Validasi & Daftar <i class='bi bi-arrow-right'></i>" : "Verifikasi & Masuk <i class='bi bi-check-circle-fill'></i>");
        }
    });
</script>