    // --- UPLOAD FOTO KE IMGBB (DENGAN AUTO RESIZE) ---
    document.getElementById('uploadFotoProfil')?.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        if (file.size > 10 * 1024 * 1024) {
            if(typeof showCustomAlert !== 'undefined') showCustomAlert('warning', 'Terlalu Besar', 'Maksimal ukuran foto asli 10 MB!');
            else alert('Maksimal ukuran foto asli 10 MB!');
            e.target.value = ''; 
            return;
        }

        document.getElementById('loadingUpload')?.classList.replace('hidden', 'flex');

        try {
            const img = new Image();
            img.src = URL.createObjectURL(file);
            await new Promise((resolve, reject) => { img.onload = resolve; img.onerror = reject; });

            const MAX_SIZE = 500;
            let width = img.width; let height = img.height;

            if (width > height) {
                if (width > MAX_SIZE) { height *= MAX_SIZE / width; width = MAX_SIZE; }
            } else {
                if (height > MAX_SIZE) { width *= MAX_SIZE / height; height = MAX_SIZE; }
            }

            const canvas = document.createElement('canvas');
            canvas.width = width; canvas.height = height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, width, height);

            const blobBaru = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.8));
            URL.revokeObjectURL(img.src); 

            const formData = new FormData();
            formData.append('image', blobBaru, 'profil.jpg');

            const res = await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_KEY}`, { method: 'POST', body: formData });
            const responseData = await res.json();

            if (responseData.success) {
                const imageUrl = responseData.data.url;
                const { error } = await supabase.from('profil_user').update({ avatar_url: imageUrl }).eq('id', currentUser.id);
                if (error) throw error;

                const semuaAvatar = document.querySelectorAll('.foto-profil-global');
                semuaAvatar.forEach(img => img.src = imageUrl);
                if(document.getElementById('imgModalProfil')) document.getElementById('imgModalProfil').src = imageUrl;
                
                if(typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Berhasil', 'Foto profil diperbarui!');
                else alert('Foto profil diperbarui!');
            } else {
                throw new Error("Gagal mengunggah gambar ke ImgBB.");
            }
        } catch (error) {
            console.error(error);
            if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', error.message);
            else alert('Gagal: ' + error.message);
        } finally {
            document.getElementById('loadingUpload')?.classList.replace('flex', 'hidden');
            e.target.value = ''; 
        }
    });

    // --- SUBMIT PENGATURAN PROFIL (Fix Kolom Phone) ---
    document.getElementById('formEditProfil')?.addEventListener('submit', async (e) => {
        e.preventDefault(); 
        const btn = document.getElementById('btnSimpanProfil'); 
        btn.disabled = true; 
        btn.innerHTML = "<i class='bi bi-hourglass-split animate-spin'></i> Menyimpan...";

        // Kita cuma ambil Email dan Phone
        const emailBaru = document.getElementById('inputEditEmail').value.trim();
        const phoneBaru = document.getElementById('inputEditPhone').value.trim();

        try {
            // 🔥 1. SINKRONISASI KE BUKU INDUK DULU (data_penduduk) 🔥
            // Tambahkan .trim() biar kalau ada spasi nyasar dari database langsung bersih
            const namaLama = profilWarga.nama_lengkap ? profilWarga.nama_lengkap.trim() : null; 
            
            if (namaLama) {
                // Cari ID warganya di Buku Induk (ilike = abaikan huruf besar/kecil)
                const { data: dpt, error: errCari } = await supabase.from('data_penduduk')
                    .select('id')
                    .ilike('nama_lengkap', namaLama)
                    .maybeSingle();

                if (errCari) throw new Error("Error nyari data di Buku Induk: " + errCari.message);

                if (dpt) {
                    // Enkripsi nomor barunya!
                    const hpEncrypted = CryptoJS.AES.encrypt(phoneBaru, SECRET_KEY).toString();
                    
                    // Tembak ke kolom `no_telp` di data_penduduk
                    const { error: errDukcapil } = await supabase.from('data_penduduk')
                        .update({ no_telp: hpEncrypted }) 
                        .eq('id', dpt.id);
                    
                    if (errDukcapil) throw new Error("Akses Ditolak Buku Induk (RLS): " + errDukcapil.message);
                } else {
                    throw new Error(`Nama '${namaLama}' tidak ditemukan di Buku Induk. Pastikan nama profil Anda sama PERSIS dengan yang didata oleh RT!`);
                }
            }

            // 🔥 2. BARU UPDATE DATA AKUN APLIKASI (profil_user) 🔥
            const { error: errProfil } = await supabase.from('profil_user').update({ 
                email: emailBaru,
                phone: phoneBaru 
            }).eq('id', currentUser.id);
            
            if (errProfil) throw errProfil; 
            
            // 🔥 3. SELESAI 🔥
            profilWarga.email = emailBaru;
            profilWarga.phone = phoneBaru;
            
            if(typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Berhasil', 'Profil & Kontak Anda berhasil diperbarui dan disinkronkan!');
            else alert('Profil dan Kontak berhasil diperbarui!');
            
            tutupModalProfil();
        } catch (error) {
            // SEKARANG ERRORNYA BAKAL JELAS MUNCUL DI LAYAR
            if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal Sinkronisasi', error.message);
            else alert('Gagal: ' + error.message);
        } finally {
            btn.disabled = false;
            btn.innerText = "Simpan Perubahan";
        }
    });

