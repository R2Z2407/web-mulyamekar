        } catch (error) {
            console.error("Gagal kirim laporan:", error);
            if (typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', error.message);
            else alert('Gagal: ' + error.message);
        } finally {
            // Kembalikan tombol ke keadaan semula
            btn.disabled = false;
            btn.innerHTML = "<i class='bi bi-send-fill'></i> Kirim Laporan ke Admin Desa";
        }
    });
    // === LOGIKA TAB SURAT & ADUAN ===
    window.pindahTabWarga = (tab) => {
        const tabSurat = document.getElementById('tab_surat');
        const tabAduan = document.getElementById('tab_aduan');
        const kontenSurat = document.getElementById('konten_surat');
        const kontenAduan = document.getElementById('konten_aduan');

        // Reset semua tampilan tombol ke warna abu-abu (tidak aktif)
        const classNonAktif = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-transparent text-gray-500 hover:bg-gray-100 hover:text-gray-700";
        tabSurat.className = classNonAktif;
        tabAduan.className = classNonAktif;

        // Sembunyikan semua konten
        kontenSurat.classList.add('hidden');
        kontenAduan.classList.add('hidden');

        // Tampilkan yang dipilih saja
        if (tab === 'surat') {
            tabSurat.className = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-teal-600 text-teal-800 bg-teal-100/50";
            kontenSurat.classList.remove('hidden');
            kontenSurat.classList.add('block');
        } else if (tab === 'aduan') {
            tabAduan.className = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-rose-500 text-rose-800 bg-rose-100/50";
            kontenAduan.classList.remove('hidden');
            kontenAduan.classList.add('block');
        }
    };
    initDashboard();
</script>