    window.updateStatusRT = async (id, statusBaru) => {
        let payload = { status_rt: statusBaru };

        // 🔥 LOGIKA PINTAR: OTOMATISASI PENOLAKAN 🔥
        if (statusBaru === 'Ditolak RT') {
            payload.status = 'Ditolak'; // Otomatis ubah status Desa jadi Ditolak
            payload.alasan_penolakan = 'Pengajuan dibatalkan/ditolak oleh Ketua RT setempat.';
        } 
        // Jaga-jaga kalau RT klik "Batal Tolak/Batal ACC", kita balikin lagi status Desanya
        else if (statusBaru === 'Menunggu ACC RT') {
            payload.status = 'Menunggu';
            payload.alasan_penolakan = null;
        }

        // Eksekusi ke database
        const { error } = await supabase.from('pengajuan_surat').update(payload).eq('id', id);
        
        if (!error) {
            loadSuratRT();
        } else {
            console.error("Gagal update status RT:", error);
