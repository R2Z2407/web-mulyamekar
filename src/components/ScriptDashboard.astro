---
// src/components/ScriptDashboard.astro
// Komponen ini khusus menampung semua logika Javascript dan CSS halaman Dashboard Warga/RT
---

<style>
    .animate-fadeIn { animation: fadeIn 0.3s ease-in-out forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
    import { supabase, SECRET_KEY } from '../lib/supabase.js';
    
    // 🔥 KUNCI IMGBB DARI .ENV 🔥
    const IMGBB_KEY = import.meta.env.PUBLIC_IMGBB_API_KEY;

    let currentUser = null;
    let profilWarga = null;

    const itemsPerPage = 5;
    let rawRiwayatWarga = [];  let filteredRiwayatWarga = [];
    let rawRiwayatAduan = [];  let filteredRiwayatAduan = [];
    let rawSuratRT = [];       let filteredSuratRT = [];
    let rawAduanRT = [];       let filteredAduanRT = [];
    
    // 🔥 VARIABEL BARU UNTUK TABEL DAFTAR WARGA RT 🔥
    let rawDaftarWargaRT = []; let filteredDaftarWargaRT = [];

    function steril(teks) {
        if (!teks) return '';
        return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
    }

    // ================= FUNGSI BIKIN TAB PAGINATION =================
    function createTabPaginationUI(tipe, pageSekarang, totalData) {
        const totalPages = Math.ceil(totalData / itemsPerPage) || 1;
        if (totalPages <= 1) return ''; 

        let html = '<div class="flex justify-center gap-2 mt-6 mb-2 flex-wrap">';
        for (let i = 1; i <= totalPages; i++) {
            if (i === pageSekarang) {
                html += `<button class="w-10 h-10 rounded-xl bg-teal-600 text-white font-black shadow-md transform scale-110 transition-transform">${i}</button>`;
            } else {
                html += `<button onclick="gantiHalaman('${tipe}', ${i})" class="w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 hover:border-teal-400 hover:text-teal-600 font-bold shadow-sm transition-colors">${i}</button>`;
            }
        }
        html += '</div>';
        return html;
    }

    window.gantiHalaman = (tipe, page) => {
        if (tipe === 'Warga') renderRiwayatWarga(page);
        if (tipe === 'AduanWarga') renderRiwayatAduan(page);
        if (tipe === 'SuratRT') renderSuratRT(page);
        if (tipe === 'AduanRT') renderAduanRT(page);
        // 🔥 TAMBAHAN PAGINASI WARGA RT 🔥
        if (tipe === 'DaftarWargaRT') renderDaftarWargaRT(page);
    };

    // ================= KONTROL MODAL FOTO =================
    window.lihatFoto = (url) => {
        const modalF = document.getElementById('modalFoto');
        const imgP = document.getElementById('imgPreview');
        imgP.src = url;
        modalF.classList.remove('hidden');
        setTimeout(() => { modalF.classList.remove('opacity-0'); imgP.classList.remove('scale-95'); imgP.classList.add('scale-100'); }, 10);
    };
    
    window.tutupFoto = () => {
        const modalF = document.getElementById('modalFoto');
        const imgP = document.getElementById('imgPreview');
        modalF.classList.add('opacity-0'); imgP.classList.remove('scale-100'); imgP.classList.add('scale-95');
        setTimeout(() => { modalF.classList.add('hidden'); imgP.src=''; }, 300);
    };

    // ================= INIT =================
    async function initDashboard() {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) { window.location.href = '/'; return; }
        currentUser = session.user;

        const { data: profil, error } = await supabase.from('profil_user').select('*').eq('id', currentUser.id).single();
        if (error || !profil) { window.location.href = '/'; return; }
        if (profil.role === 'admin') { window.location.href = '/admin'; return; }

        // 🔥 1. CEK STEMPEL SAAT HALAMAN DIBUKA 🔥
        const localToken = localStorage.getItem('mulyamekar_session');
        if (profil.active_token && profil.active_token !== localToken) {
            // Token beda! Berarti akun ini udah dipakai login di perangkat lain.
            await supabase.auth.signOut();
            localStorage.removeItem('mulyamekar_session');
            if(typeof showCustomAlert !== 'undefined') {
                await showCustomAlert('warning', 'Sesi Berakhir', 'Akun Anda sedang digunakan di perangkat lain!');
            } else {
                alert('Sesi Berakhir: Akun sedang digunakan di perangkat lain.');
            }
            window.location.href = '/';
            return; // Hentikan proses render dashboard
        }

        // 🔥 2. SATPAM REALTIME (TENDANG OTOMATIS) 🔥
        supabase.channel('patroli-sesi')
            .on(
            'postgres_changes',
            { event: 'UPDATE', schema: 'public', table: 'profil_user', filter: `id=eq.${currentUser.id}` },
            async (payload) => {
                const newToken = payload.new.active_token;
                // Kalau ada update token di database dan beda sama yang di HP ini -> TENDANG!
                if (newToken && newToken !== localStorage.getItem('mulyamekar_session')) {
                    await supabase.auth.signOut();
                    localStorage.removeItem('mulyamekar_session');
                    alert('Sesi Berakhir! Seseorang baru saja login menggunakan akun Anda di perangkat lain.');
                    window.location.href = '/';
                }
            }
            )
            .subscribe();

        // Lanjut proses render dashboard jika aman...
        profilWarga = profil;

        // 🔥 REVISI: LOGIKA HACKER NIK (MUTLAK DARI NIK) 🔥
        let finalGender = profil.jenis_kelamin || 'Laki-laki'; 
        
        // Paksa SELALU baca dari NIK (jika ada), abaikan data di database
        if (profil.nik && profil.nik.length >= 8) {
            const kodeTglLahir = parseInt(profil.nik.substring(6, 8)); 
            finalGender = (kodeTglLahir > 40) ? 'Perempuan' : 'Laki-laki';
            profilWarga.jenis_kelamin = finalGender;
        }

        // Tentukan avatar berdasarkan hasil bedah NIK
        let avatarDefault = finalGender === 'Perempuan' 
            ? `https://api.dicebear.com/7.x/avataaars/svg?seed=${profil.nama_lengkap}&backgroundColor=ffdfbf&clothing=blazerAndShirt&hair=longButNotTooLong`
            : `https://api.dicebear.com/7.x/avataaars/svg?seed=${profil.nama_lengkap}&backgroundColor=b6e3f4&clothing=blazerAndSweater&hair=shortHairShortFlat`;
            
        let avatarFix = profil.avatar_url || avatarDefault;

        const safeName = steril(profil.nama_lengkap) || profil.nama || 'Warga';
        
        const semuaAvatar = document.querySelectorAll('.foto-profil-global');
        semuaAvatar.forEach(img => img.src = avatarFix);
        if(document.getElementById('imgModalProfil')) document.getElementById('imgModalProfil').src = avatarFix;

        if(document.getElementById('namaWarga')) document.getElementById('namaWarga').innerText = safeName;
        if(document.getElementById('nikWarga')) document.getElementById('nikWarga').innerText = steril(profil.nik) || 'NIK Kosong';
        if(document.getElementById('wilayahWarga')) document.getElementById('wilayahWarga').innerText = steril(profil.wilayah_rt) || 'RT/RW Kosong';
        
        const genderLabel = document.getElementById('genderWarga');
        if (genderLabel && finalGender) {
            genderLabel.innerText = finalGender;
            genderLabel.classList.remove('hidden');
        }

        if(document.getElementById('inputEditNama')) document.getElementById('inputEditNama').value = safeName;
        if(document.getElementById('inputEditNik')) document.getElementById('inputEditNik').value = steril(profil.nik);
        if(document.getElementById('inputEditGender')) document.getElementById('inputEditGender').value = finalGender || 'Belum diketahui';

        if(document.getElementById('inputNama')) document.getElementById('inputNama').value = safeName;
        if(document.getElementById('inputNik')) document.getElementById('inputNik').value = steril(profil.nik);
        if(document.getElementById('inputRT') && profil.wilayah_rt) document.getElementById('inputRT').value = steril(profil.wilayah_rt);

        // Kalo dia Pak RT, aktifkan tab RT
        if (profil.role === 'rt_rw') {
            document.getElementById('kontrolModeRT').classList.remove('hidden');
            document.getElementById('namaRT').innerText = safeName || 'Ketua RT';
            document.getElementById('wilayahRTLabel').innerText = steril(profil.wilayah_rt) || 'Belum Diatur';
            
            if(profil.wilayah_rt) {
                const inputHidden = document.getElementById('rt_wilayah_rt');
                if(inputHidden) inputHidden.value = profil.wilayah_rt;
                
                // MENGISI KOTAK TAMPILAN RT & RW (Readonly)
                if (profil.wilayah_rt.includes('/')) {
                    const parts = profil.wilayah_rt.split('/');
                    const elRT = document.getElementById('tampil_rt');
                    const elRW = document.getElementById('tampil_rw');
                    if(elRT) elRT.value = parts[0].trim();
                    if(elRW) elRW.value = parts[1].trim();
                }
            }

            loadSuratRT();
            loadAduanRT();
            loadDaftarWargaRT(); // 🔥 SEDOT DAFTAR WARGA 🔥
            switchTabRT('surat'); 
        }

        loadRiwayatSurat();
        loadRiwayatAduan();
        cekStatusToko();
    }

    // 🔥 LOGIKA TAB BARU UNTUK DAFTAR WARGA 🔥
    window.switchTabRT = (tabName) => {
        // 1. Sembunyikan semua konten tab
        ['surat', 'aduan', 'daftarwarga', 'laporan'].forEach(id => {
            const el = document.getElementById(`tab-${id}`);
            if(el) { el.classList.add('hidden'); el.classList.remove('block'); }
        });

        // 2. Ambil semua tombol tab
        const btnSurat = document.getElementById('btnTab-surat');
        const btnAduan = document.getElementById('btnTab-aduan');
        const btnDaftar = document.getElementById('btnTab-daftarwarga');
        const btnLaporan = document.getElementById('btnTab-laporan');

        // 3. Reset warna semua tombol ke abu-abu (Gaya Warga)
        const classNonAktif = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-transparent text-gray-500 hover:bg-gray-100 hover:text-gray-700 whitespace-nowrap flex items-center gap-2";
        [btnSurat, btnAduan, btnDaftar, btnLaporan].forEach(btn => {
            if(btn) btn.className = classNonAktif;
        });

        // 4. Tampilkan konten yang dipilih
        const targetTab = document.getElementById(`tab-${tabName}`);
        if(targetTab) {
            targetTab.classList.remove('hidden'); targetTab.classList.add('block');
        }

        // 5. Beri garis bawah & warna khas untuk tab yang sedang aktif
        if(tabName === 'surat' && btnSurat) 
            btnSurat.className = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-amber-500 text-amber-800 bg-amber-100/50 whitespace-nowrap flex items-center gap-2";
        else if(tabName === 'aduan' && btnAduan) 
            btnAduan.className = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-rose-500 text-rose-800 bg-rose-100/50 whitespace-nowrap flex items-center gap-2";
        else if(tabName === 'daftarwarga' && btnDaftar) 
            btnDaftar.className = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-emerald-500 text-emerald-800 bg-emerald-100/50 whitespace-nowrap flex items-center gap-2";
        else if(tabName === 'laporan' && btnLaporan) 
            btnLaporan.className = "px-6 py-3 font-bold text-sm rounded-t-xl transition-all border-b-4 border-purple-500 text-purple-800 bg-purple-100/50 whitespace-nowrap flex items-center gap-2";
    };

    window.gantiMode = (isModeRT) => {
        if (isModeRT) {
            document.getElementById('tampilanWarga').classList.add('hidden');
            document.getElementById('tampilanRT').classList.remove('hidden');
        } else {
            document.getElementById('tampilanRT').classList.add('hidden');
            document.getElementById('tampilanWarga').classList.remove('hidden');
        }
    };

    window.bukaModalProfil = () => { document.body.classList.add('overflow-hidden'); const m = document.getElementById('modalProfil'); const b = document.getElementById('modalProfilBox'); m.classList.remove('hidden'); m.classList.add('flex'); setTimeout(() => { m.classList.remove('opacity-0'); b.classList.remove('scale-95'); b.classList.add('scale-100'); }, 10); };
    window.tutupModalProfil = () => { document.body.classList.remove('overflow-hidden'); const m = document.getElementById('modalProfil'); const b = document.getElementById('modalProfilBox'); m.classList.add('opacity-0'); b.classList.remove('scale-100'); b.classList.add('scale-95'); setTimeout(() => { m.classList.add('hidden'); m.classList.remove('flex'); }, 300); };
    window.bukaModalToko = () => { document.body.classList.add('overflow-hidden'); const m = document.getElementById('modalDaftarToko'); const b = document.getElementById('modalDaftarTokoBox'); m.classList.remove('hidden'); setTimeout(() => { m.classList.remove('opacity-0'); b.classList.remove('scale-95'); b.classList.add('scale-100'); }, 10); };
    window.tutupModalToko = () => { document.body.classList.remove('overflow-hidden'); const m = document.getElementById('modalDaftarToko'); const b = document.getElementById('modalDaftarTokoBox'); m.classList.add('opacity-0'); b.classList.remove('scale-100'); b.classList.add('scale-95'); setTimeout(() => { m.classList.add('hidden'); }, 300); };

    async function cekStatusToko() {
        if (!currentUser) return;
        const aksi = document.getElementById('aksiUmkm');
        const { data, error } = await supabase.from('umkm_toko').select('*').eq('user_id', currentUser.id).maybeSingle();
        if (error || !data) {
            document.getElementById('teksUmkmDesc').innerText = "Daftarkan usaha Anda gratis.";
            aksi.innerHTML = `<button onclick="bukaModalToko()" class="w-full bg-white text-orange-600 font-extrabold py-2.5 rounded-xl shadow-sm hover:scale-105 transition-transform text-sm">Daftar Buka Toko</button>`;
        } else if (data.status === 'Disetujui') {
            document.getElementById('teksUmkmDesc').innerText = `Toko ${data.nama_toko} aktif.`;
            aksi.innerHTML = `<a href="/toko" class="block text-center w-full bg-emerald-500 text-white font-extrabold py-2.5 rounded-xl shadow-sm hover:bg-emerald-600 transition-colors text-sm">Masuk Toko Saya →</a>`;
        } else {
            document.getElementById('teksUmkmDesc').innerText = `Status: ${data.status}`;
            aksi.innerHTML = `<div class="bg-white/20 text-white font-bold py-2.5 px-4 rounded-xl text-center text-sm border border-white/30">Diproses Admin</div>`;
        }
    }

    async function loadRiwayatSurat() {
        const container = document.getElementById('riwayatContainer');
        const { data, error } = await supabase.from('pengajuan_surat').select('*').eq('user_id', currentUser.id).order('created_at', { ascending: false });
        if (error) { container.innerHTML = `<div class="text-center py-8 text-rose-500 font-bold">Gagal memuat data surat.</div>`; return; }
        rawRiwayatWarga = data || []; filteredRiwayatWarga = rawRiwayatWarga; renderRiwayatWarga(1);
    }

    function renderRiwayatWarga(page) {
        const container = document.getElementById('riwayatContainer');
        const paginasiContainer = document.getElementById('paginationWarga');
        if (filteredRiwayatWarga.length === 0) {
            container.innerHTML = `<div class="text-center py-12 bg-gray-50 rounded-2xl border border-dashed border-gray-200"><p class="text-gray-500 font-bold">Tidak ada riwayat pengajuan surat.</p></div>`;
            paginasiContainer.innerHTML = ''; return;
        }
        const start = (page - 1) * itemsPerPage; const dataTampil = filteredRiwayatWarga.slice(start, start + itemsPerPage);
        let html = '';
        dataTampil.forEach(s => {
            const tgl = new Date(s.created_at).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' });
            const statusRtText = s.status_rt || ''; 
            let bDesa = s.status === 'Menunggu' ? 'bg-amber-50 text-amber-600 border-amber-200' : (s.status === 'Diproses' ? 'bg-blue-50 text-blue-600 border-blue-200' : (s.status === 'Ditolak' ? 'bg-rose-50 text-rose-600 border-rose-200' : 'bg-emerald-50 text-emerald-600 border-emerald-200'));
            let bRT = statusRtText === 'Menunggu ACC RT' ? 'bg-amber-50 text-amber-600 border-amber-200' : (statusRtText.includes('Disetujui') ? 'bg-emerald-50 text-emerald-600 border-emerald-200' : (statusRtText.includes('Ditolak') ? 'bg-rose-50 text-rose-600 border-rose-200' : 'bg-gray-100 text-gray-500 border-gray-200'));
            let catatanHTML = '';
            if (s.status === 'Selesai' && s.file_hasil) catatanHTML = `<a href="${s.file_hasil}" target="_blank" class="mt-3 inline-block bg-emerald-500 text-white px-4 py-2 rounded-xl text-[11px] font-bold shadow-md hover:bg-emerald-600 transition-all hover:-translate-y-0.5">📥 Download Surat (PDF)</a>`;
            else if (s.status === 'Ditolak' && s.alasan_penolakan) catatanHTML = `<div class="mt-3 bg-rose-50 p-3 rounded-xl border border-rose-100"><p class="text-[10px] font-black text-rose-800 uppercase">Alasan Penolakan:</p><p class="text-xs text-rose-600 font-medium mt-1">${steril(s.alasan_penolakan)}</p></div>`;
            else if (statusRtText === 'Ditolak RT') catatanHTML = `<div class="mt-3 bg-rose-50 p-3 rounded-xl border border-rose-100"><p class="text-xs text-rose-600 font-medium">Ditolak oleh RT. Silakan hubungi Pak RT.</p></div>`;
            html += `<div class="p-5 border border-gray-100 rounded-3xl hover:border-teal-200 bg-white flex flex-col md:flex-row justify-between gap-4 shadow-sm transition-all hover:shadow-md"><div class="flex-grow"><h3 class="font-black text-teal-950 text-base">${steril(s.jenis_surat)}</h3><p class="text-[11px] text-gray-500 font-medium mt-1">Tgl Pengajuan: ${tgl}</p>${catatanHTML}</div><div class="flex flex-col gap-2 shrink-0 items-start md:items-end"><span class="px-3 py-1.5 rounded-lg text-[10px] font-bold border ${bRT} whitespace-nowrap">RT: ${statusRtText || 'Menunggu'}</span><span class="px-3 py-1.5 rounded-lg text-[10px] font-bold border ${bDesa} whitespace-nowrap">Desa: ${s.status}</span></div></div>`;
        });
        container.innerHTML = html; paginasiContainer.innerHTML = createTabPaginationUI('Warga', page, filteredRiwayatWarga.length);
    }

    document.getElementById('searchRiwayat')?.addEventListener('input', (e) => {
        const keyword = e.target.value.toLowerCase();
        filteredRiwayatWarga = rawRiwayatWarga.filter(s => s.jenis_surat.toLowerCase().includes(keyword) || s.status.toLowerCase().includes(keyword) || (s.status_rt || '').toLowerCase().includes(keyword));
        renderRiwayatWarga(1);
    });

    async function loadRiwayatAduan() {
        const container = document.getElementById('riwayatAduanContainer');
        const { data, error } = await supabase.from('aduan_warga').select('*').eq('user_id', currentUser.id).order('created_at', { ascending: false });
        if (error) { container.innerHTML = `<div class="text-center py-8 text-rose-500 font-bold">Gagal memuat data aduan.</div>`; return; }
        rawRiwayatAduan = data || []; filteredRiwayatAduan = rawRiwayatAduan; renderRiwayatAduan(1);
    }

    function renderRiwayatAduan(page) {
        const container = document.getElementById('riwayatAduanContainer');
        const paginasiContainer = document.getElementById('paginationAduanWarga');
        if (filteredRiwayatAduan.length === 0) {
            container.innerHTML = `<div class="text-center py-12 bg-gray-50 rounded-2xl border border-dashed border-gray-200"><p class="text-gray-500 font-bold">Belum ada riwayat aduan yang diajukan.</p></div>`;
            paginasiContainer.innerHTML = ''; return;
        }
        const start = (page - 1) * itemsPerPage;
        const dataTampil = filteredRiwayatAduan.slice(start, start + itemsPerPage);
        let html = '';
        dataTampil.forEach(a => {
            const tgl = new Date(a.created_at).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
            let bStatus = a.status === 'Menunggu' ? 'bg-amber-50 text-amber-600 border-amber-200' : (a.status === 'Diproses' ? 'bg-blue-50 text-blue-600 border-blue-200' : 'bg-emerald-50 text-emerald-600 border-emerald-200');
            let fotoHTML = a.foto_url ? `<button type="button" onclick="lihatFoto('${a.foto_url}')" class="mt-2 inline-flex items-center gap-1 bg-white text-gray-700 border border-gray-200 px-3 py-1.5 rounded-lg text-[10px] font-bold shadow-sm hover:border-teal-400 hover:text-teal-600 transition-all">📸 Lihat Foto Bukti</button>` : '';
            let deskripsiHTML = steril(a.deskripsi).replace(/\(Maps:\s*(-?\d+\.\d+),\s*(-?\d+\.\d+)\)/g, '<a href="https://www.google.com/maps?q=$1,$2" target="_blank" class="text-blue-600 font-bold underline bg-blue-50 px-2 py-0.5 rounded-lg hover:bg-blue-100 transition-colors inline-flex items-center gap-1 mt-1">🗺️ Buka di Google Maps</a>');
            html += `<div class="p-5 border border-gray-100 rounded-3xl hover:border-rose-200 bg-white flex flex-col md:flex-row justify-between gap-4 shadow-sm transition-all hover:shadow-md"><div class="flex-grow"><span class="text-[9px] font-bold text-rose-600 uppercase bg-rose-50 px-2 py-0.5 rounded border border-rose-100 mb-1.5 inline-block">${steril(a.kategori)}</span><h3 class="font-bold text-gray-800 text-sm">${steril(a.judul)}</h3><p class="text-[11px] text-gray-500 font-medium mt-1 mb-2">Dikirim pada: ${tgl}</p><p class="text-xs text-gray-600 whitespace-pre-wrap leading-relaxed">${deskripsiHTML}</p>${fotoHTML}</div><div class="flex flex-col gap-2 shrink-0 items-start md:items-end"><span class="px-3 py-1.5 rounded-lg text-[10px] font-bold border ${bStatus} whitespace-nowrap">Status: ${a.status}</span></div></div>`;
        });
        container.innerHTML = html; paginasiContainer.innerHTML = createTabPaginationUI('AduanWarga', page, filteredRiwayatAduan.length);
    }

    document.getElementById('searchRiwayatAduan')?.addEventListener('input', (e) => {
        const keyword = e.target.value.toLowerCase();
        filteredRiwayatAduan = rawRiwayatAduan.filter(a => (a.kategori || '').toLowerCase().includes(keyword) || (a.judul || '').toLowerCase().includes(keyword) || (a.status || '').toLowerCase().includes(keyword));
        renderRiwayatAduan(1);
    });

    async function loadSuratRT() {
        if (!profilWarga.wilayah_rt) return;
        const { data, error } = await supabase.from('pengajuan_surat').select('*').eq('wilayah_rt', profilWarga.wilayah_rt).order('created_at', { ascending: false });
        if (error) return;
        rawSuratRT = data || []; filteredSuratRT = rawSuratRT; renderSuratRT(1);
    }

    function renderSuratRT(page) {
        const tbody = document.getElementById('tableSuratRT');
        const paginasiContainer = document.getElementById('paginationSuratRT');
        if (filteredSuratRT.length === 0) { tbody.innerHTML = `<tr><td colspan="5" class="p-8 text-center text-gray-500">Tidak ada pengajuan surat.</td></tr>`; paginasiContainer.innerHTML = ''; return; }
        const start = (page - 1) * itemsPerPage; const dataTampil = filteredSuratRT.slice(start, start + itemsPerPage);
        let html = ''; const sekarang = new Date();
        dataTampil.forEach(s => {
            const tglDibuat = new Date(s.created_at); const tgl = tglDibuat.toLocaleDateString('id-ID', { day:'numeric', month:'short' });
            const isExpired = ((sekarang - tglDibuat) / (1000 * 60 * 60)) > 24; const statusRtText = s.status_rt || '';
            let bRT = statusRtText === 'Menunggu ACC RT' ? 'bg-amber-100 text-amber-700' : (statusRtText.includes('Disetujui') ? 'bg-emerald-100 text-emerald-700' : (statusRtText === 'Ditolak RT' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700'));
            let berkasHTML = '';
