            html += `<tr class="hover:bg-amber-50/30 border-b border-gray-50"><td class="p-4 text-gray-500 text-xs">${tgl}</td><td class="p-4"><p class="font-bold text-gray-900">${steril(s.nama_lengkap)}</p><p class="text-[10px] text-gray-500 font-mono mt-1 bg-gray-100 inline-block px-1.5 py-0.5 rounded">${steril(s.nik)}</p>${berkasHTML}</td><td class="p-4 text-gray-600 text-sm"><p class="font-bold text-gray-800 text-xs">${steril(s.jenis_surat)}</p><p class="text-[11px] text-gray-500 mt-1 line-clamp-2">${steril(s.keperluan)}</p></td><td class="p-4 text-center"><span class="px-2 py-1 rounded-md text-[9px] font-bold uppercase ${bRT}">${statusRtText}</span></td><td class="p-4 text-center align-middle">${tombolAksi}</td></tr>`;
