---
// src/components/StatistikDesa.astro
import { supabase } from '../lib/supabase.js';

// 1. Tarik data statistik mentah dari database
const { data: statistikMentah, error } = await supabase
  .from('statistik_desa')
  .select('*')
  .order('urutan', { ascending: true });

if (error) {
  console.error("Gagal menarik data Statistik:", error);
}

// 2. 🔥 BATASI DATA: Hanya tampilkan label kependudukan 🔥
const labelDemografi = [
  'Total Penduduk', 
  'Kepala Keluarga (KK)', 
  'Warga Laki-laki', 
  'Warga Perempuan', 
  'Kelahiran / Bayi', 
  'Warga Bekerja', 
  'Tidak/Belum Bekerja', 
  'Pelajar & Mahasiswa', 
  'Pensiunan'
];

// Saring datanya agar yang wilayah/infrastruktur terbuang dari slider ini
const statistik = statistikMentah ? statistikMentah.filter(item => labelDemografi.includes(item.label)) : [];

// Fungsi pembantu format ribuan
const formatRibuan = (angka) => {
  return new Intl.NumberFormat('id-ID').format(angka);
};

const getIconClass = (label) => {
  if (!label) return 'bi-pin-fill';
  const l = label.toLowerCase();
  
  if (l === 'total penduduk') return 'bi-people-fill';
  if (l === 'kepala keluarga (kk)') return 'bi-house-heart-fill';
  if (l === 'warga laki-laki') return 'bi-gender-male';
  if (l === 'warga perempuan') return 'bi-gender-female';
  
  // 🔥 INI DIA PERBAIKANNYA, JAL! PAKAI ICON ADD PERSON BIAR LEBIH PRO 🔥
  if (l === 'kelahiran / bayi') return 'bi-person-plus-fill'; 
  
  if (l === 'warga bekerja') return 'bi-briefcase-fill';
  if (l === 'tidak/belum bekerja') return 'bi-cup-hot';
  if (l === 'pelajar & mahasiswa') return 'bi-book-fill';
  if (l === 'pensiunan') return 'bi-person-badge';

  return 'bi-bar-chart-fill';
};
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section id="statistik" class="py-16 md:py-24 bg-teal-950 text-white relative overflow-hidden">
  
  <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/connected.png')]"></div>

  <div class="container mx-auto px-0 md:px-4 max-w-6xl relative z-10">
    
    <div class="text-center max-w-2xl mx-auto mb-8 md:mb-12 px-4" data-aos="fade-up">
      <h2 class="text-xs md:text-sm font-black uppercase tracking-widest text-amber-400 mb-2">Informasi Penduduk</h2>
      <h3 class="text-3xl md:text-4xl lg:text-5xl font-black leading-tight tracking-tight">Mulyamekar Dalam Angka</h3>
      
      <div class="mt-4 inline-flex items-center gap-2 bg-teal-900/80 px-4 py-2 rounded-full border border-teal-700/50 backdrop-blur-sm">
        <i class="bi bi-arrow-left-circle-fill text-amber-400 animate-pulse"></i>
        <p class="text-xs font-bold text-teal-200">Geser ke samping untuk melihat data</p>
        <i class="bi bi-arrow-right-circle-fill text-amber-400 animate-pulse"></i>
      </div>
    </div>

    {error || !statistik || statistik.length === 0 ? (
      <div class="text-center py-10 mx-4 bg-teal-900 rounded-xl text-teal-300 font-bold border border-teal-800">Data statistik belum tersedia.</div>
    ) : (
      <>
        <div class="flex overflow-x-auto gap-4 md:gap-6 pb-10 pt-4 px-6 md:px-2 custom-scrollbar snap-x snap-mandatory">
          {statistik.map((item, index) => (
            
            <div 
              class="flex-none w-[80vw] sm:w-[280px] snap-center bg-teal-900 border border-teal-800 p-6 md:p-8 rounded-3xl flex flex-col items-center text-center shadow-lg transition-all duration-300 hover:border-amber-400 hover:shadow-amber-900/50 hover:-translate-y-2 group"
              data-aos="fade-up"
              data-aos-delay={index * 50} 
            >
              <div class="w-16 h-16 rounded-full bg-teal-800 text-amber-400 flex items-center justify-center mb-5 border-[3px] border-teal-700 transition-colors group-hover:bg-amber-100 group-hover:border-amber-200 group-hover:text-amber-700 shadow-inner">
                <i class={`bi ${getIconClass(item.label)} text-3xl`}></i>
              </div>
              
              <span class="text-xs font-bold text-teal-300 uppercase tracking-wide mb-1 leading-snug group-hover:text-amber-300 transition-colors">
                {item.label}
              </span>
              
              <div class="mt-auto pt-3 w-full border-t border-teal-800/50">
                <h4 class="text-4xl md:text-5xl font-black text-white mt-2 group-hover:scale-110 transition-transform origin-bottom">
                  {formatRibuan(item.nilai)}
                </h4>
                <span class="text-[10px] md:text-xs text-teal-400 font-bold block mt-1">
                  {item.satuan}
                </span>
              </div>
            </div>

          ))}
        </div>

        <div class="mt-4 text-center px-4" data-aos="zoom-in">
            <a href="/profil/demografi" class="inline-flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3 bg-amber-500 hover:bg-amber-600 text-teal-950 font-black px-6 sm:px-8 py-4 rounded-2xl sm:rounded-full transition-all hover:scale-105 shadow-xl shadow-amber-500/20 text-sm sm:text-base tracking-wide w-full sm:w-auto active:scale-95">
                <i class="bi bi-bar-chart-line-fill text-xl sm:text-lg"></i>
                <span>Buka Portal Data & Infografis</span>
            </a>
        </div>
      </>
    )}

  </div>
</section>

<style>
  .custom-scrollbar {
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
  
  .custom-scrollbar::-webkit-scrollbar { 
    height: 10px; 
  }
  
  .custom-scrollbar::-webkit-scrollbar-track { 
    background: rgba(13, 148, 136, 0.3);
    border-radius: 10px; 
    margin: 0 20px; 
  }
  
  .custom-scrollbar::-webkit-scrollbar-thumb { 
    background: rgba(251, 191, 36, 1);
    border-radius: 10px; 
  }
</style>