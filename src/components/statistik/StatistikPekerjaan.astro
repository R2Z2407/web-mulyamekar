---
// src/components/statistik/StatistikPekerjaan.astro
const { stats } = Astro.props;
---

<div class="bg-white rounded-[2.5rem] p-6 md:p-8 shadow-sm border border-slate-200 hover:shadow-lg transition-shadow mb-8" data-aos="fade-up" data-aos-delay="400">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-8 gap-4">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-8 h-1 bg-teal-500 rounded-full"></span>
                <h3 id="titleDistribusi" class="text-xl font-black text-slate-800 uppercase tracking-wide">Distribusi Pekerjaan</h3>
            </div>
            <p id="subtitleDistribusi" class="text-sm text-slate-500 font-medium">Klik pada diagram untuk melihat rincian profesi dan pendidikan warga.</p>
        </div>
        
        <div class="flex flex-wrap gap-2 shrink-0">
            <button onclick="kembaliKeChartUtama()" id="btnBackChart" class="hidden px-4 py-2 rounded-xl text-xs font-bold bg-rose-50 text-rose-600 hover:bg-rose-100 border border-rose-200 transition-all flex items-center gap-2"><i class="bi bi-arrow-left"></i> Kembali</button>
            <div class="flex bg-slate-100 p-1 rounded-xl shadow-inner shrink-0">
                <button onclick="ubahTipeChartPekerjaan('bar')" id="btnBar" class="px-4 py-2 rounded-lg text-xs font-bold bg-white text-teal-600 shadow-sm transition-all flex items-center gap-2"><i class="bi bi-bar-chart-fill"></i> Batang</button>
                <button onclick="ubahTipeChartPekerjaan('pie')" id="btnPie" class="px-4 py-2 rounded-lg text-xs font-bold text-slate-500 hover:text-teal-600 transition-all flex items-center gap-2"><i class="bi bi-pie-chart-fill"></i> Donat</button>
            </div>
        </div>
    </div>
    
    <div id="chartPekerjaan" class="relative w-full h-[250px] md:h-[300px]"></div>
</div>

<script is:inline define:vars={{ statsData: stats }}>
    window.dbStats = statsData || [];
</script>

<script>
    import { supabase } from '../../lib/supabase.js';

    const formatRp = (angka) => new Intl.NumberFormat('id-ID').format(angka);
    const getVal = (lbl) => {
        const item = window.dbStats.find(s => s.label.toLowerCase() === lbl.toLowerCase());
        return item ? parseInt(item.nilai) || 0 : 0;
    };

    let chartPekerjaanTipe = 'bar'; 
    let chartViewLevel = 'main';    
    let detailDataD3 = [];          

    function renderPekerjaanChart() {
        const tt = d3.select("#d3Tooltip");
        const container = d3.select("#chartPekerjaan");
        container.selectAll("*").remove();

        let dataToRender = [];
        let isMainView = chartViewLevel === 'main';

        const chartTitle = document.getElementById('titleDistribusi');
        const chartSubtitle = document.getElementById('subtitleDistribusi');
        const btnBack = document.getElementById('btnBackChart');

        if (isMainView) {
            dataToRender = [
                { label: 'Bekerja', value: getVal('warga bekerja'), color: '#0d9488' },
                { label: 'Tdk Bekerja', value: getVal('tidak/belum bekerja'), color: '#f43f5e' },
                { label: 'Pelajar', value: getVal('pelajar & mahasiswa'), color: '#f59e0b' },
                { label: 'Pensiunan', value: getVal('pensiunan'), color: '#94a3b8' }
            ];
            chartTitle.innerText = "Distribusi Pekerjaan";
            chartSubtitle.innerText = "Klik pada diagram untuk melihat rincian profesi dan pendidikan warga.";
            btnBack.classList.add('hidden');
        } else {
            dataToRender = detailDataD3.slice(0, 6); 
            chartTitle.innerText = chartViewLevel === 'bekerja' ? "Rincian Profesi Penduduk" : "Tingkat Pendidikan Pelajar";
            chartSubtitle.innerText = "Menampilkan kelompok teratas berdasarkan data Dukcapil.";
            btnBack.classList.remove('hidden');
        }

        const width = container.node().clientWidth || 600;
        const height = container.node().clientHeight || 300;
        const svg = container.append("svg").attr("viewBox", `0 0 ${width} ${height}`).style("max-width", "100%").style("height", "auto");

        if (chartPekerjaanTipe === 'bar') {
            const margin = { top: 20, right: 20, bottom: 40, left: 40 };
            const w = width - margin.left - margin.right;
            const h = height - margin.top - margin.bottom;

            const x = d3.scaleBand().range([0, w]).domain(dataToRender.map(d => d.label)).padding(0.4);
            const y = d3.scaleLinear().range([h, 0]).domain([0, d3.max(dataToRender, d => d.value) * 1.2]); 

            const g = svg.append("g").attr("transform", `translate(${margin.left},${margin.top})`);

            g.append("g").attr("class", "grid").call(d3.axisLeft(y).tickSize(-w).tickFormat("").ticks(5)).selectAll("line").attr("stroke", "#f1f5f9").attr("stroke-dasharray", "4 4");
            g.select(".domain").remove(); 

            g.append("g").attr("transform", `translate(0,${h})`).call(d3.axisBottom(x).tickSize(0)).select(".domain").attr("stroke", "#e2e8f0");
            g.selectAll(".tick text").attr("fill", "#64748b").attr("font-weight", "bold").attr("font-family", "Inter").attr("dy", "10px").text(d => d.length > 12 ? d.substring(0, 10) + '...' : d); 

            const bars = g.selectAll(".bar").data(dataToRender).enter().append("rect")
                .attr("class", "bar").attr("x", d => x(d.label)).attr("width", x.bandwidth()).attr("y", h).attr("height", 0)
                .attr("fill", d => d.color).attr("rx", 6).style("cursor", d => (isMainView && (d.label === 'Bekerja' || d.label === 'Pelajar')) ? 'pointer' : 'default'); 

            bars.on("mouseover", function(event, d) {
                d3.select(this).attr("fill", d3.rgb(d.color).brighter(0.5));
                const clickHint = (isMainView && (d.label === 'Bekerja' || d.label === 'Pelajar')) ? '<br><span class="text-[10px] font-normal text-amber-200 mt-1 inline-block">(Klik untuk Detail)</span>' : '';
                tt.style("display", "block").html(`${d.label}<br><span class="text-2xl">${formatRp(d.value)}</span> Jiwa${clickHint}`);
            }).on("mousemove", function(event) { tt.style("left", (event.pageX) + "px").style("top", (event.pageY - 10) + "px"); })
            .on("mouseout", function(event, d) { d3.select(this).attr("fill", d.color); tt.style("display", "none"); })
            .on("click", function(event, d) { if (isMainView && (d.label === 'Bekerja' || d.label === 'Pelajar')) drillDownChart(d.label); });

            bars.transition().duration(1000).ease(d3.easeCubicOut).attr("y", d => y(d.value)).attr("height", d => h - y(d.value));
        } else {
            const radius = Math.min(width, height) / 2.2;
            const g = svg.append("g").attr("transform", `translate(${width / 2},${height / 2})`);
            const pie = d3.pie().value(d => d.value).sort(null);
            const arc = d3.arc().innerRadius(radius * 0.4).outerRadius(radius);
            const arcHover = d3.arc().innerRadius(radius * 0.4).outerRadius(radius * 1.05);

            const slices = g.selectAll("path").data(pie(dataToRender)).enter().append("path")
                .attr("fill", d => d.data.color).attr("stroke", "white").attr("stroke-width", "2px").style("cursor", d => (isMainView && (d.data.label === 'Bekerja' || d.data.label === 'Pelajar')) ? 'pointer' : 'default');

            slices.on("mouseover", function(event, d) {
                d3.select(this).transition().duration(200).attr("d", arcHover);
                const clickHint = (isMainView && (d.data.label === 'Bekerja' || d.data.label === 'Pelajar')) ? '<br><span class="text-[10px] font-normal text-amber-200 mt-1 inline-block">(Klik untuk Detail)</span>' : '';
                tt.style("display", "block").html(`${d.data.label}<br><span class="text-2xl">${formatRp(d.data.value)}</span> Jiwa${clickHint}`);
            }).on("mousemove", function(event) { tt.style("left", (event.pageX) + "px").style("top", (event.pageY - 10) + "px"); })
            .on("mouseout", function(event, d) { d3.select(this).transition().duration(200).attr("d", arc); tt.style("display", "none"); })
            .on("click", function(event, d) { if (isMainView && (d.data.label === 'Bekerja' || d.data.label === 'Pelajar')) drillDownChart(d.data.label); });

            slices.transition().duration(1000).attrTween("d", function(d) { const i = d3.interpolate({startAngle: 0, endAngle: 0}, d); return function(t) { return arc(i(t)); }});
        }
    }

    async function drillDownChart(kategori) {
        d3.select("#d3Tooltip").style("display", "none"); 
        const container = d3.select("#chartPekerjaan");
        container.selectAll("*").remove();
        container.append("div").attr("class", "absolute inset-0 flex items-center justify-center").html('<i class="bi bi-arrow-repeat animate-spin text-4xl text-teal-400"></i>');

        try {
            const { data, error } = await supabase.from('data_penduduk').select('pekerjaan, pendidikan');
            if(error) throw error;

            let kelompok = {};
            data.forEach(d => {
                if (kategori === 'Bekerja' && d.pekerjaan && d.pekerjaan !== 'Belum/Tidak Bekerja' && d.pekerjaan !== 'Pelajar/Mahasiswa') {
                    kelompok[d.pekerjaan] = (kelompok[d.pekerjaan] || 0) + 1;
                } else if (kategori === 'Pelajar' && d.pekerjaan === 'Pelajar/Mahasiswa' && d.pendidikan) {
                    kelompok[d.pendidikan] = (kelompok[d.pendidikan] || 0) + 1;
                }
            });

            let arraySort = Object.keys(kelompok).map((key, index) => {
                return { label: key, value: kelompok[key], color: kategori === 'Bekerja' ? '#0ea5e9' : '#f59e0b' };
            });
            arraySort.sort((a, b) => b.value - a.value);

            detailDataD3 = arraySort;
            chartViewLevel = kategori.toLowerCase(); 
            renderPekerjaanChart();
        } catch(e) {
            chartViewLevel = 'main'; 
            renderPekerjaanChart();
        }
    }

    window.kembaliKeChartUtama = () => { chartViewLevel = 'main'; renderPekerjaanChart(); };
    window.ubahTipeChartPekerjaan = (tipe) => {
        chartPekerjaanTipe = tipe;
        const bBar = document.getElementById('btnBar'); const bPie = document.getElementById('btnPie');
        if (tipe === 'bar') {
            bBar.className = "px-4 py-2 rounded-lg text-xs font-bold bg-white text-teal-600 shadow-sm transition-all flex items-center gap-2";
            bPie.className = "px-4 py-2 rounded-lg text-xs font-bold text-slate-500 hover:text-teal-600 transition-all flex items-center gap-2";
        } else {
            bPie.className = "px-4 py-2 rounded-lg text-xs font-bold bg-white text-teal-600 shadow-sm transition-all flex items-center gap-2";
            bBar.className = "px-4 py-2 rounded-lg text-xs font-bold text-slate-500 hover:text-teal-600 transition-all flex items-center gap-2";
        }
        renderPekerjaanChart();
    };

    document.addEventListener('DOMContentLoaded', () => {
        setTimeout(renderPekerjaanChart, 100);
        window.addEventListener('resize', renderPekerjaanChart);
    });
</script>