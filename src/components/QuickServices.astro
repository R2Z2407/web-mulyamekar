---
// src/components/QuickServices.astro
const services = [
  {
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    title: 'Persuratan Online',
    description: 'Ajukan surat pengantar RT/RW, kelahiran, kematian, dll dari rumah.',
    url: '/layanan/persuratan'
  },
  {
    icon: 'M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z',
    title: 'Aduan Warga',
    description: 'Laporkan masalah infrastruktur atau keluhan layanan secara anonim.',
    url: '/layanan/aduan'
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Cek Bansos',
    description: 'Cek daftar penerima bantuan sosial (BLT, PKH) tahun ini.',
    url: '/layanan/bansos'
  },
  {
    icon: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
    title: 'Berita & Kegiatan',
    description: 'Informasi terbaru tentang kegiatan desa dan pengumuman penting.',
    url: '/berita'
  }
];
---

<section id="layanan" class="min-h-screen flex flex-col justify-center py-16 lg:py-20 bg-gray-50">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-16">
      <h2 class="text-xs font-bold uppercase tracking-widest text-amber-600 mb-2">Akses Cepat</h2>
      <p class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-teal-900 leading-tight">Pelayanan Desa Di Ujung Jari</p>
      <div class="w-16 md:w-24 h-1 md:h-1.5 bg-amber-400 mx-auto mt-4 lg:mt-6 rounded-full"></div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 lg:gap-8">
      {services.map((service, index) => (
        <a href={service.url} 
           data-aos="fade-up" 
           data-aos-delay={index * 100} 
           class="group bg-white p-5 sm:p-6 lg:p-8 rounded-3xl shadow-sm border border-gray-100/50 flex flex-col items-center text-center transition-all duration-300 hover:shadow-2xl hover:border-teal-100 hover:-translate-y-2 active:scale-95">
          
          <div class="w-14 h-14 sm:w-16 sm:h-16 lg:w-20 lg:h-20 rounded-full bg-teal-50 text-teal-600 flex items-center justify-center mb-4 sm:mb-5 lg:mb-8 border-[3px] lg:border-4 border-teal-100 transition-all duration-300 group-hover:bg-amber-100 group-hover:border-amber-200 group-hover:text-amber-700">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 lg:w-10 lg:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon}></path>
            </svg>
          </div>
          
          <h3 class="text-sm sm:text-base lg:text-xl font-extrabold text-gray-900 mb-1 lg:mb-3 group-hover:text-teal-800 transition-colors leading-snug">
            {service.title}
          </h3>
          
          <p class="hidden md:block text-gray-500 text-xs lg:text-sm leading-relaxed flex-grow">
            {service.description}
          </p>
          
        </a>
      ))}
    </div>

  </div>
</section>