---
---
<div id="tab-laporan" class="p-6 md:p-8 hidden animate-fadeIn">
    <div class="mb-6 border-b border-gray-50 pb-4">
        <h2 class="text-xl font-bold text-gray-900">Laporan & Pengajuan Khusus RT</h2>
        <p class="text-sm text-gray-500 mt-1">Ajukan laporan warga meninggal, pindah domisili, perubahan data, atau kewenangan RT lainnya.</p>
    </div>
    
    <form id="formLaporanRT" class="space-y-6 max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-700 mb-1">Kategori Laporan *</label>
                    <select id="laporan_kategori" required class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 text-sm font-bold outline-none cursor-pointer transition-all">
                        <option value="" disabled selected>-- Pilih Kategori --</option>
                        <option value="Warga Meninggal">🪦 Lapor Warga Meninggal</option>
                        <option value="Pindah Keluar">🚚 Lapor Warga Pindah Keluar Mulyamekar</option>
                        <option value="Perubahan Status Ekonomi">💰 Pengajuan Ubah Status (Mampu/Tidak Mampu)</option>
                        <option value="Perubahan Pendidikan/Pekerjaan">🎓 Pengajuan Ubah Pendidikan / Pekerjaan</option>
                        <option value="Lainnya">📝 Lainnya (Jelaskan di keterangan)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-700 mb-1">Nama Warga Terkait (Opsional)</label>
                    <input type="text" id="laporan_nama_warga" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 text-sm outline-none transition-all" placeholder="Nama warga yang dimaksud...">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-700 mb-1">NIK Warga Terkait (Opsional)</label>
                    <input type="text" id="laporan_nik_warga" maxlength="16" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 font-mono text-sm outline-none transition-all" placeholder="16 Digit NIK">
                </div>
            </div>
            <div class="space-y-4">
                <div class="h-full flex flex-col">
                    <label class="block text-xs font-bold text-gray-700 mb-1">Detail Keterangan & Pengajuan *</label>
                    <textarea id="laporan_keterangan" required rows="6" class="w-full h-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 text-sm outline-none transition-all resize-none" placeholder="Tuliskan keterangan lengkap di sini..."></textarea>
                </div>
            </div>
        </div>
        <div class="pt-6 border-t border-gray-100 flex justify-end">
            <button type="submit" id="btnSubmitLaporanRT" class="px-8 py-3.5 bg-purple-600 hover:bg-purple-700 text-white font-black rounded-xl text-sm transition-all shadow-md shadow-purple-600/20 flex items-center justify-center gap-2 w-full sm:w-auto active:scale-95">
                <i class="bi bi-send-fill"></i> Kirim Laporan ke Admin Desa
            </button>
        </div>
    </form>
</div>
<script>
    import { supabase } from '../../lib/supabase.js';

    document.getElementById('formLaporanRT')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btnSubmitLaporanRT');
        const kategori = document.getElementById('laporan_kategori').value;
        const namaTarget = document.getElementById('laporan_nama_warga').value;
        const nikTarget = document.getElementById('laporan_nik_warga').value;
        const keterangan = document.getElementById('laporan_keterangan').value;

        if (!kategori) {
            if (typeof showCustomAlert !== 'undefined') showCustomAlert('warning', 'Pilih Kategori!', 'Kategori laporan harus diisi.');
            return;
        }

        btn.disabled = true; btn.innerHTML = "<i class='bi bi-hourglass-split animate-spin'></i> Mengirim...";

        try {
            const labelJabatan = window.profilWarga.role === 'rw' ? 'RW' : 'RT';
            const jenisSuratKhusus = `LAPORAN ${labelJabatan}: ${kategori}`;
            const detailKeperluan = `Target Warga: ${namaTarget || 'Tidak spesifik'} (NIK: ${nikTarget || '-'}) \nKeterangan ${labelJabatan}:\n${keterangan}`.trim();

            const { error } = await supabase.from('pengajuan_surat').insert({
                user_id: window.currentUser.id, 
                nama_lengkap: window.profilWarga.nama_lengkap || `Ketua ${labelJabatan}`, 
                nik: window.profilWarga.nik || '-',                          
                wilayah_rt: window.profilWarga.wilayah_rt || 'Belum Diset',
                rt: window.profilWarga.rt, rw: window.profilWarga.rw, 
                jenis_surat: jenisSuratKhusus, keperluan: detailKeperluan, status: 'Menunggu',
                status_rt: window.profilWarga.role === 'rt' ? 'Menunggu ACC RW' : 'Menunggu ACC RT', 
                alamat: '-'
            });

            if (error) throw error;
            if (typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Laporan Terkirim!', 'Laporan diteruskan ke Admin Desa.');
            document.getElementById('formLaporanRT').reset();
            if (typeof window.loadSuratRT === 'function') window.loadSuratRT();

        } catch (error) {
            if (typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', error.message);
        } finally {
            btn.disabled = false; btn.innerHTML = "<i class='bi bi-send-fill'></i> Kirim Laporan ke Admin Desa";
        }
    });
</script>