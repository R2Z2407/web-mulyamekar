---
---
<div id="tab-surat" class="p-6 md:p-8 block animate-fadeIn">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6 border-b border-gray-50 pb-4">
        <div>
            <h2 class="text-xl font-bold text-gray-900">Verifikasi Surat Warga</h2>
            <p class="text-sm text-gray-500 mt-1">Daftar permohonan surat di wilayah Anda.</p>
        </div>
        <div class="relative w-full sm:w-64">
            <input type="text" id="searchSuratRT" placeholder="Cari pemohon / surat..." class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-amber-500 outline-none transition-all">
            <svg class="w-4 h-4 text-gray-400 absolute left-4 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-50 border-b border-gray-100 text-gray-600">
                <tr>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider">Tanggal</th>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider">Pemohon & Berkas</th>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider">Keperluan Surat</th>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider text-center">Status</th>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider text-center">Aksi Verifikasi</th>
                </tr>
            </thead>
            <tbody id="tableSuratRT" class="divide-y divide-gray-100 text-sm">
                <tr><td colspan="5" class="p-8 text-center text-gray-400 animate-pulse font-bold">Memuat data...</td></tr>
            </tbody>
        </table>
    </div>
    <div id="paginationSuratRT" class="mt-4 pt-4 border-t border-gray-50"></div>
</div>
<script>
    import { supabase } from '../../lib/supabase.js';

    let rawSuratRT = [];
    let filteredSuratRT = [];
    const itemsPerPage = 5;

    window.loadSuratRT = async () => {
        const tbody = document.getElementById('tableSuratRT');
        if (!window.profilWarga?.rw) return;
        try {
            let query = supabase.from('pengajuan_surat').select('*');
            if (window.profilWarga.role === 'rw') query = query.eq('rw', window.profilWarga.rw);
            else query = query.eq('rw', window.profilWarga.rw).eq('rt', window.profilWarga.rt);

            const { data, error } = await query.order('created_at', { ascending: false });
            if (error) throw error;
            rawSuratRT = data || []; filteredSuratRT = rawSuratRT; 
            window.renderSuratRT(1);
        } catch (err) {
            if(tbody) tbody.innerHTML = `<tr><td colspan="5" class="p-8 text-center text-rose-500 font-bold bg-rose-50 rounded-xl">Error: ${err.message}</td></tr>`;
        }
    };

    window.renderSuratRT = (page) => {
        const tbody = document.getElementById('tableSuratRT');
        const paginasiContainer = document.getElementById('paginationSuratRT');
        if (filteredSuratRT.length === 0) { 
            tbody.innerHTML = `<tr><td colspan="5" class="p-8 text-center text-gray-500">Tidak ada pengajuan surat.</td></tr>`;
            if(paginasiContainer) paginasiContainer.innerHTML = ''; return; 
        }
        
        const start = (page - 1) * itemsPerPage;
        const dataTampil = filteredSuratRT.slice(start, start + itemsPerPage);
        let html = ''; const sekarang = new Date();

        // LOGIKA RENDER (Sama persis seperti di ScriptDashboard sebelumnya)
        dataTampil.forEach(s => {
            const tglDibuat = new Date(s.created_at); const tgl = tglDibuat.toLocaleDateString('id-ID', { day:'numeric', month:'short' });
            const isExpired = ((sekarang - tglDibuat) / (1000 * 60 * 60)) > 24; const statusRtText = s.status_rt || '';
            let bRT = statusRtText === 'Menunggu ACC RT' ? 'bg-amber-100 text-amber-700' : (statusRtText.includes('Disetujui') ? 'bg-emerald-100 text-emerald-700' : (statusRtText === 'Ditolak RT' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700'));
            
            let berkasHTML = '';
            if (isExpired && s.status === 'Menunggu') { berkasHTML = `<span class="inline-block mt-2 bg-rose-50 border border-rose-200 text-rose-600 font-bold px-2 py-1 rounded text-[10px]">⚠️ Berkas Hangus (>24 Jam)</span>`; }
            else if (s.file_persyaratan) { try { const files = JSON.parse(s.file_persyaratan); berkasHTML = `<div class="mt-2 space-y-1">`; for (const [nama, url] of Object.entries(files)) { berkasHTML += `<a href="${url}" target="_blank" class="block text-[10px] text-blue-600 hover:underline">📄 Cek ${nama}</a>`; } berkasHTML += `</div>`; } catch(e) { berkasHTML = `<a href="${s.file_persyaratan}" target="_blank" class="text-[10px] text-blue-600 underline">Lihat Berkas</a>`; } }
            
            let tombolAksi = '';
            if (s.status !== 'Menunggu') { tombolAksi = `<span class="text-[9px] text-gray-500 font-bold uppercase bg-gray-100 px-2 py-1.5 rounded border border-gray-200 shadow-inner block"><span class="text-xs">🔒</span> Terkunci Desa</span>`; } 
            else {
                if (window.profilWarga.role === 'rw') {
                    if (statusRtText === 'Menunggu ACC RW') tombolAksi = `<div class="flex flex-col gap-1.5"><button onclick="updateStatusRT('${s.id}', 'Disetujui RW')" class="bg-blue-600 text-white font-bold py-1.5 px-2 rounded-lg text-[10px] shadow-sm hover:bg-blue-700">ACC RW</button><button onclick="updateStatusRT('${s.id}', 'Ditolak RW')" class="bg-rose-500 text-white font-bold py-1.5 px-2 rounded-lg text-[10px] shadow-sm hover:bg-rose-600">Tolak</button></div>`;
                    else if (statusRtText === 'Menunggu ACC RT') tombolAksi = `<span class="text-[9px] text-amber-600 font-bold bg-amber-50 px-2 py-1 rounded border border-amber-100 block text-center">Menunggu RT</span>`;
                    else if (statusRtText === 'Disetujui RW' || statusRtText === 'Bypass RT' || statusRtText === 'Laporan RT') tombolAksi = `<button onclick="updateStatusRT('${s.id}', 'Menunggu ACC RW')" class="text-[10px] text-gray-500 underline hover:text-gray-800 font-bold">Batal ACC</button>`;
                    else tombolAksi = '-';
                } else {
                    if (statusRtText === 'Menunggu ACC RT') tombolAksi = `<div class="flex flex-col gap-1.5"><button onclick="updateStatusRT('${s.id}', 'Menunggu ACC RW')" class="bg-emerald-500 text-white font-bold py-1.5 px-2 rounded-lg text-[10px] shadow-sm hover:bg-emerald-600">ACC RT</button><button onclick="updateStatusRT('${s.id}', 'Ditolak RT')" class="bg-rose-500 text-white font-bold py-1.5 px-2 rounded-lg text-[10px] shadow-sm hover:bg-rose-600">Tolak</button></div>`;
                    else if (statusRtText === 'Menunggu ACC RW') tombolAksi = `<button onclick="updateStatusRT('${s.id}', 'Menunggu ACC RT')" class="text-[10px] text-gray-500 underline hover:text-gray-800 font-bold">Batal ACC</button>`;
                    else if (statusRtText === 'Disetujui RW' || statusRtText === 'Bypass RT' || statusRtText === 'Laporan RT') tombolAksi = `<span class="text-[9px] text-emerald-600 font-bold bg-emerald-50 px-2 py-1 rounded border border-emerald-100 block text-center">Sudah di RW</span>`;
                    else tombolAksi = '-';
                }
            }
            html += `<tr class="hover:bg-amber-50/30 border-b border-gray-50"><td class="p-4 text-gray-500 text-xs">${tgl}</td><td class="p-4"><p class="font-bold text-gray-900">${window.steril(s.nama_lengkap)}</p><div class="flex flex-wrap gap-1 mt-1"><p class="text-[10px] text-gray-500 font-mono bg-gray-100 px-1.5 py-0.5 rounded">${window.steril(s.nik)}</p><p class="text-[10px] text-amber-700 font-bold bg-amber-50 border border-amber-100 px-1.5 py-0.5 rounded">${window.steril(s.wilayah_rt)}</p></div>${berkasHTML}</td><td class="p-4 text-gray-600 text-sm"><p class="font-bold text-gray-800 text-xs">${window.steril(s.jenis_surat)}</p><p class="text-[11px] text-gray-500 mt-1 line-clamp-2">${window.steril(s.keperluan)}</p></td><td class="p-4 text-center"><span class="px-2 py-1 rounded-md text-[9px] font-bold uppercase ${bRT}">${statusRtText}</span></td><td class="p-4 text-center align-middle">${tombolAksi}</td></tr>`;
        });
        
        tbody.innerHTML = html; 
        if(typeof window.createTabPaginationUI === 'function') paginasiContainer.innerHTML = window.createTabPaginationUI('SuratRT', page, filteredSuratRT.length);
    };

    window.updateStatusRT = async (id, statusBaru) => {
        const suratInfo = rawSuratRT.find(s => s.id === id);
        if (statusBaru === 'Menunggu ACC RW' && suratInfo?.jenis_surat?.includes('LAPORAN RW')) statusBaru = 'Disetujui RW';

        const payload = { status_rt: statusBaru };
        if (statusBaru.includes('Ditolak')) {
            payload.status = 'Ditolak'; payload.alasan_penolakan = 'Pengajuan ditolak oleh Pengurus Wilayah.';
        } else if (statusBaru === 'Disetujui RW') {
            payload.status = 'Menunggu'; payload.alasan_penolakan = null;
        }

        const { error } = await supabase.from('pengajuan_surat').update(payload).eq('id', id);
        if (!error) { window.loadSuratRT(); if(typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Berhasil', `Status diperbarui!`); } 
        else alert("Gagal: " + error.message);
    };

    document.getElementById('searchSuratRT')?.addEventListener('input', (e) => {
        const keyword = e.target.value.toLowerCase();
        filteredSuratRT = rawSuratRT.filter(s => s.nama_lengkap.toLowerCase().includes(keyword) || s.jenis_surat.toLowerCase().includes(keyword));
        window.renderSuratRT(1);
    });
</script>