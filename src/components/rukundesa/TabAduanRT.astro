---
---
<div id="tab-aduan" class="p-6 md:p-8 hidden animate-fadeIn">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6 border-b border-gray-50 pb-4">
        <div>
            <h2 class="text-xl font-bold text-gray-900">Pantauan Aduan Warga</h2>
            <p class="text-sm text-gray-500 mt-1">Laporan masalah di wilayah Anda (Hanya pantauan).</p>
        </div>
        <div class="relative w-full sm:w-64">
            <input type="text" id="searchAduanRT" placeholder="Cari pelapor / masalah..." class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-rose-500 outline-none transition-all">
            <svg class="w-4 h-4 text-gray-400 absolute left-4 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-50 border-b border-gray-100 text-gray-600">
                <tr>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider">Pelapor</th>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider">Kategori & Laporan</th>
                    <th class="p-4 font-bold text-xs uppercase tracking-wider text-center">Status Desa</th>
                </tr>
            </thead>
            <tbody id="tableAduanRT" class="divide-y divide-gray-100 text-sm">
                <tr><td colspan="3" class="p-8 text-center text-gray-400 animate-pulse font-bold">Memuat data aduan...</td></tr>
            </tbody>
        </table>
    </div>
    <div id="paginationAduanRT" class="mt-4 pt-4 border-t border-gray-50"></div>
</div>
<script>
    import { supabase } from '../../lib/supabase.js';

    let rawAduanRT = [];
    let filteredAduanRT = [];
    const itemsPerPage = 5;

    window.loadAduanRT = async () => {
        const tbody = document.getElementById('tableAduanRT');
        if (!window.profilWarga?.rw) return;
        try {
            let query = supabase.from('aduan_warga').select('*');
            if (window.profilWarga.role === 'rw') {
                query = query.or(`rw.eq.${window.profilWarga.rw},wilayah_rt.ilike.%RW ${window.profilWarga.rw}%`);
            } else {
                const stringWilayah = `RT ${window.profilWarga.rt} / RW ${window.profilWarga.rw}`;
                query = query.or(`and(rt.eq.${window.profilWarga.rt},rw.eq.${window.profilWarga.rw}),wilayah_rt.ilike.%${stringWilayah}%`);
            }

            const { data, error } = await query.order('created_at', { ascending: false });
            if (error) throw error;
            rawAduanRT = data || []; filteredAduanRT = rawAduanRT; window.renderAduanRT(1);
        } catch (err) {
            if(tbody) tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-rose-500 font-bold bg-rose-50 rounded-xl">Error: ${err.message}</td></tr>`;
        }
    };

    window.renderAduanRT = (page) => {
        const tbody = document.getElementById('tableAduanRT');
        const paginasiContainer = document.getElementById('paginationAduanRT');
        if (!tbody || !paginasiContainer) return;

        if (filteredAduanRT.length === 0) {
            tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-gray-400">Tidak ada aduan warga di wilayah ini.</td></tr>`;
            paginasiContainer.innerHTML = ''; return;
        }

        const start = (page - 1) * itemsPerPage;
        const dataTampil = filteredAduanRT.slice(start, start + itemsPerPage);
        let html = '';

        dataTampil.forEach(a => {
            const tgl = new Date(a.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });
            let bStatus = a.status === 'Selesai' ? 'bg-emerald-100 text-emerald-700 border-emerald-200' : (a.status === 'Diproses' ? 'bg-blue-100 text-blue-700 border-blue-200' : (a.status === 'Ditolak' ? 'bg-rose-100 text-rose-700 border-rose-200' : 'bg-gray-100 text-gray-600 border-gray-200'));
            const labelWilayah = a.rt ? `RT ${a.rt} / RW ${a.rw}` : (a.wilayah_rt || 'Wilayah Pusaka');

            html += `<tr class="hover:bg-rose-50/30 border-b border-gray-50 transition-colors"><td class="p-4 align-top"><p class="font-bold text-gray-900">${window.steril(a.nama_pelapor)}</p><span class="text-[10px] text-emerald-700 font-bold bg-emerald-50 border border-emerald-100 px-1.5 py-0.5 rounded mt-1 inline-block">${labelWilayah}</span><p class="text-[9px] text-gray-400 mt-1">${tgl}</p></td><td class="p-4 align-top"><span class="text-[9px] font-bold text-rose-600 uppercase bg-rose-50 px-2 py-0.5 rounded border border-rose-100 block w-max mb-1">${window.steril(a.kategori)}</span><p class="text-sm font-bold text-gray-800">${window.steril(a.judul)}</p><p class="text-xs text-gray-600 mt-1 line-clamp-2">${window.steril(a.deskripsi)}</p></td><td class="p-4 text-center align-top"><span class="px-2 py-1 rounded-full text-[9px] font-bold uppercase ${bStatus} border shadow-sm">${a.status}</span></td></tr>`;
        });

        tbody.innerHTML = html;
        if(typeof window.createTabPaginationUI === 'function') paginasiContainer.innerHTML = window.createTabPaginationUI('AduanRT', page, filteredAduanRT.length);
    };

    document.getElementById('searchAduanRT')?.addEventListener('input', (e) => {
        const keyword = e.target.value.toLowerCase();
        filteredAduanRT = rawAduanRT.filter(a => a.nama_pelapor?.toLowerCase().includes(keyword) || a.judul?.toLowerCase().includes(keyword) || a.kategori?.toLowerCase().includes(keyword));
        window.renderAduanRT(1);
    });
</script>