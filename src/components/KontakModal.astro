---
// src/components/KontakModal.astro
---

<div id="modalKontak" class="fixed inset-0 z-[9999] bg-slate-900/60 hidden items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300" onclick="tutupModalKontak(event)">
    
    <div id="modalKontakBox" class="bg-white rounded-3xl w-full max-w-lg shadow-2xl transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh] overflow-hidden border border-emerald-500/20" onclick="event.stopPropagation()">
        
        <div class="px-6 py-4 border-b border-emerald-100 flex justify-between items-center bg-emerald-600 text-white shrink-0">
            <h2 class="text-lg font-black tracking-wide flex items-center gap-2">
                <i class="bi bi-headset text-xl"></i> Hubungi Kami
            </h2>
            <button onclick="tutupModalKontak()" class="bg-white/20 hover:bg-white/40 p-1.5 rounded-full transition-colors focus:outline-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div class="p-6 overflow-y-auto custom-scrollbar flex flex-col gap-6">
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                <a href="https://wa.me/6281234567890" target="_blank" class="flex items-start gap-3 p-3 rounded-2xl bg-emerald-50 hover:bg-emerald-100 transition-colors border border-emerald-100 group">
                    <div class="w-8 h-8 rounded-full bg-emerald-200 text-emerald-700 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform"><i class="bi bi-whatsapp"></i></div>
                    <div>
                        <p class="font-bold text-slate-800">WhatsApp</p>
                        <p class="text-xs text-emerald-600 font-medium">+62 812-3456-7890</p>
                    </div>
                </a>
                <a href="mailto:pemdes@mulyamekar.desa.id" class="flex items-start gap-3 p-3 rounded-2xl bg-slate-50 hover:bg-slate-100 transition-colors border border-slate-200 group">
                    <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-700 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform"><i class="bi bi-envelope-at-fill"></i></div>
                    <div>
                        <p class="font-bold text-slate-800">Email Resmi</p>
                        <p class="text-xs text-slate-500 font-medium">pemdes@mulyamekar.desa.id</p>
                    </div>
                </a>
                <div class="flex items-start gap-3 p-3 rounded-2xl bg-slate-50 border border-slate-200 sm:col-span-2">
                    <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-700 flex items-center justify-center shrink-0"><i class="bi bi-geo-alt-fill"></i></div>
                    <div>
                        <p class="font-bold text-slate-800">Alamat Kantor Desa</p>
                        <p class="text-xs text-slate-500 font-medium leading-relaxed">Jl. Raya Mulyamekar No. 123, Kec. Babakancikao, Purwakarta 41151</p>
                    </div>
                </div>
                <div class="flex items-start gap-3 p-3 rounded-2xl bg-slate-50 border border-slate-200 sm:col-span-2">
                    <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-700 flex items-center justify-center shrink-0"><i class="bi bi-clock-fill"></i></div>
                    <div class="w-full">
                        <p class="font-bold text-slate-800 mb-1">Jam Operasional</p>
                        <div class="text-xs text-slate-500 font-medium flex justify-between border-b border-slate-200 pb-1 mb-1"><span>Senin - Kamis</span> <span>08:00 - 15:00</span></div>
                        <div class="text-xs text-slate-500 font-medium flex justify-between border-b border-slate-200 pb-1 mb-1"><span>Jumat</span> <span>08:00 - 14:00</span></div>
                        <div class="text-xs text-rose-500 font-bold flex justify-between"><span>Sabtu & Minggu</span> <span>Tutup</span></div>
                    </div>
                </div>
            </div>

            <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-inner h-32 relative group">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d18856.684577026543!2d107.4445346240424!3d-6.505272065780127!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e690dc736e9218b%3A0xde1b5c1acf477787!2sMulyamekar%2C%20Kec.%20Babakancikao%2C%20Kabupaten%20Purwakarta%2C%20Jawa%20Barat!5e0!3m2!1sid!2sid!4v1773041713147!5m2!1sid!2sid" width="100%" height="100%" style="border: 0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" class="absolute inset-0 z-0"></iframe>
                <a href="https://maps.google.com" target="_blank" class="absolute inset-0 z-10 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center backdrop-blur-sm">
                    <span class="bg-white text-emerald-700 px-4 py-2 rounded-full font-bold text-xs shadow-lg flex items-center gap-2"><i class="bi bi-arrows-fullscreen"></i> Buka Layar Penuh</span>
                </a>
            </div>

            <form class="space-y-4 mt-2" onsubmit="event.preventDefault(); alert('Pesan sedang dikirim...'); tutupModalKontak();">
                <p class="font-bold text-slate-800 text-sm border-b border-slate-100 pb-2">Kirim Pesan Langsung</p>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label for="namaPengirim" class="text-xs font-bold text-slate-600">Nama Lengkap <span class="text-rose-500">*</span></label>
                        <input type="text" id="namaPengirim" placeholder="Contoh: Budi Santoso" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all placeholder:text-slate-400">
                    </div>
                    
                    <div class="flex flex-col gap-1.5">
                        <label for="kontakPengirim" class="text-xs font-bold text-slate-600">No. WhatsApp <span class="text-rose-500">*</span></label>
                        <input type="tel" id="kontakPengirim" placeholder="Contoh: 08123456789" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all placeholder:text-slate-400">
                    </div>
                </div>

                <div class="flex flex-col gap-1.5">
                    <label for="isiPesan" class="text-xs font-bold text-slate-600">Isi Pesan / Keperluan <span class="text-rose-500">*</span></label>
                    <textarea id="isiPesan" placeholder="Tuliskan keluhan, pertanyaan, atau keperluan Anda di sini secara detail..." rows="3" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all resize-none placeholder:text-slate-400"></textarea>
                </div>

                <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl transition-all shadow-md active:scale-95 flex justify-center items-center gap-2 mt-2">
                    <i class="bi bi-send-fill"></i> Kirim Pesan Sekarang
                </button>
            </form>

            <div class="flex justify-center gap-4 pt-2 border-t border-slate-100">
                <a href="#" class="w-10 h-10 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center hover:bg-pink-100 hover:text-pink-600 transition-colors text-lg"><i class="bi bi-instagram"></i></a>
                <a href="#" class="w-10 h-10 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center hover:bg-blue-100 hover:text-blue-600 transition-colors text-lg"><i class="bi bi-facebook"></i></a>
                <a href="#" class="w-10 h-10 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center hover:bg-red-100 hover:text-red-600 transition-colors text-lg"><i class="bi bi-youtube"></i></a>
                <a href="#" class="w-10 h-10 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center hover:bg-slate-800 hover:text-white transition-colors text-lg"><i class="bi bi-tiktok"></i></a>
            </div>

        </div>

        <div class="px-6 py-3 border-t border-emerald-100 bg-emerald-50 text-center shrink-0">
            <p class="text-[11px] md:text-xs text-emerald-800 font-bold tracking-wide">Terima kasih telah menghubungi Desa Mulyamekar</p>
        </div>

    </div>
</div>

<script is:inline>
    // 1. FUNGSI DITEMPEL LANGSUNG KE WINDOW (Tanpa DOMContentLoaded)
    window.bukaModalKontak = function() {
        const modal = document.getElementById('modalKontak');
        const box = document.getElementById('modalKontakBox');
        
        if (modal && box) {
            document.body.classList.add('overflow-hidden');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            setTimeout(() => { 
                modal.classList.remove('opacity-0'); 
                box.classList.remove('scale-95'); 
                box.classList.add('scale-100'); 
            }, 10);
        } else {
            console.error("GAGAL: Elemen HTML modalKontak tidak ditemukan di halaman ini!");
        }
    };

    // 2. FUNGSI TUTUP MODAL
    window.tutupModalKontak = function(event) {
        // Cek target klik agar tidak menutup jika isi form yang diklik
        if (event && event.target.id !== 'modalKontak' && !event.target.closest('button')) return; 

        const modal = document.getElementById('modalKontak');
        const box = document.getElementById('modalKontakBox');
        
        if (modal && box) {
            document.body.classList.remove('overflow-hidden');
            modal.classList.add('opacity-0'); 
            box.classList.remove('scale-100'); 
            box.classList.add('scale-95');
            
            setTimeout(() => { 
                modal.classList.add('hidden'); 
                modal.classList.remove('flex'); 
            }, 300);
        }
    };
</script>