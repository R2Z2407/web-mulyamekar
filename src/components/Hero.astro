---
// src/components/Hero.astro
---
<section id="home" class="min-h-screen flex items-center justify-center pt-24 pb-12 bg-white overflow-hidden relative">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

  <div class="container mx-auto px-4 max-w-7xl relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center max-md:landscape:gap-6">
      
      <div class="space-y-6 max-md:landscape:space-y-3" data-aos="fade-up" data-aos-delay="100">
        <h1 class="text-4xl md:text-6xl max-md:landscape:text-3xl font-extrabold text-teal-950 leading-tight">
          Selamat Datang di Portal <span class="text-amber-500">Desa Mulyamekar</span>
        </h1>
        <p class="text-lg md:text-xl max-md:landscape:text-base text-gray-600 leading-relaxed max-w-2xl">
          Pusat informasi dan layanan digital resmi Pemerintah Desa Mulyamekar. Mewujudkan tata kelola desa yang transparan, akuntabel, dan inovatif.
        </p>
        <div class="flex flex-wrap gap-4 pt-4 max-md:landscape:pt-2">
          <a href="/layanan" class="bg-teal-700 hover:bg-teal-800 text-white font-bold py-3.5 px-8 max-md:landscape:py-2.5 max-md:landscape:px-6 rounded-full transition-all text-base max-md:landscape:text-sm shadow-md hover:shadow-lg">
            Ajukan Surat Online
          </a>
          <a href="/informasi" class="bg-white hover:bg-teal-50 text-teal-700 font-bold py-3.5 px-8 max-md:landscape:py-2.5 max-md:landscape:px-6 rounded-full transition-all text-base max-md:landscape:text-sm border border-teal-200 shadow-sm">
            Kabar Desa
          </a>
        </div>
      </div>

      <div class="relative w-full max-w-lg mx-auto" data-aos="fade-left" data-aos-delay="300">
        <div class="absolute -inset-4 bg-teal-100/50 rounded-3xl blur-3xl opacity-70"></div>
        
        <div class="swiper hero-swiper rounded-3xl shadow-2xl relative z-10 border-8 border-white overflow-hidden aspect-video bg-gray-100">
          <div class="swiper-wrapper" id="heroSliderWadah">
            
            <div class="swiper-slide flex items-center justify-center bg-gray-100 animate-pulse">
                <p class="text-teal-600 font-bold text-sm">🔄 Memuat gambar...</p>
            </div>

          </div>
          <div class="swiper-pagination"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  import { supabase } from '../lib/supabase.js';

  document.addEventListener('DOMContentLoaded', async () => {
    const wadahSlider = document.getElementById('heroSliderWadah');
    
    try {
        // 1. Tarik data dari Supabase
        const { data, error } = await supabase
            .from('hero_slider')
            .select('*')
            .order('created_at', { ascending: false });

        if (error) throw error;

        let html = '';
        
        // 2. Jika database masih kosong, tampilkan gambar default 1 biji
        if (!data || data.length === 0) {
            html = `
            <div class="swiper-slide">
              <img src="https://images.unsplash.com/photo-1596401349880-997f37f3743c?q=80&w=1200&h=675&auto=format&fit=crop" alt="Balai Desa Mulyamekar Default" class="w-full h-full object-cover" />
            </div>`;
        } else {
            // 3. Looping data gambar dari database
            data.forEach(item => {
                html += `
                <div class="swiper-slide relative group">
                  <img src="${item.image_url}" alt="${item.alt_text || 'Gambar Beranda'}" class="w-full h-full object-cover" />
                  
                  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-teal-950/90 to-transparent p-5 pt-12 translate-y-2 group-hover:translate-y-0 transition-transform">
                     <p class="text-white font-bold text-sm md:text-base line-clamp-1 drop-shadow-md">${item.alt_text || ''}</p>
                  </div>
                </div>`;
            });
        }

        // 4. Suntik HTML ke dalam Slider
        wadahSlider.innerHTML = html;

    } catch (err) {
        console.error("Gagal memuat slider beranda:", err);
        wadahSlider.innerHTML = `
            <div class="swiper-slide flex items-center justify-center bg-gray-100">
               <p class="text-rose-500 font-bold text-xs">Gagal memuat gambar dari server.</p>
            </div>`;
    }

    // 5. 🔥 INISIALISASI SWIPER WAJIB SETELAH GAMBAR DISUNTIKKAN 🔥
    // Biar Swiper bisa ngitung jumlah gambar dan bikin titik-titik (pagination) dengan benar
    new Swiper('.hero-swiper', {
      loop: true,
      grabCursor: true,
      effect: 'slide', 
      autoplay: {
        delay: 5000, 
        disableOnInteraction: false, 
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
        dynamicBullets: true,
      },
    });

  });
</script>

<style is:global>
  /* Kustomisasi warna titik pagination biar senada sama tema web lu */
  .swiper-pagination-bullet {
    background-color: #e2e8f0; /* Warna abu redup */
    opacity: 0.8;
  }
  .swiper-pagination-bullet-active {
    background-color: #0d9488; /* Warna teal-600 */
    width: 24px;
    border-radius: 10px;
    transition: all 0.3s ease;
  }
</style>