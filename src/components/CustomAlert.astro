---
// src/components/CustomAlert.astro
---
<div id="customAlertOverlay" class="fixed inset-0 z-[9999] bg-gray-900/60 hidden flex items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <div id="customAlertBox" class="bg-white rounded-3xl p-6 md:p-8 w-full max-w-sm shadow-2xl transform scale-95 transition-transform duration-300 text-center flex flex-col items-center">
        
        <div id="alertIconContainer" class="w-20 h-20 rounded-full flex items-center justify-center mb-5 shadow-inner">
            <svg id="alertIcon" class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"></svg>
        </div>

        <h3 id="alertTitle" class="text-2xl font-extrabold text-gray-900 mb-2">Judul</h3>
        <p id="alertMessage" class="text-gray-500 text-sm mb-8 leading-relaxed">Pesan pesan pesan.</p>

        <div class="flex gap-3 w-full">
            <button id="alertBtnCancel" class="hidden flex-1 font-bold py-3.5 px-6 rounded-xl transition-all active:scale-95 bg-gray-100 text-gray-700 hover:bg-gray-200">
                Batal
            </button>
            <button id="alertBtn" class="flex-1 font-bold py-3.5 px-6 rounded-xl transition-all active:scale-95 text-white shadow-md focus:outline-none focus:ring-4">
                Tutup
            </button>
        </div>

    </div>
</div>

<script is:inline>
    // 1. FUNGSI ALERT BIASA (Success, Error, Warning, Info)
    window.showCustomAlert = (type, title, message) => {
        return new Promise((resolve) => {
            const overlay = document.getElementById('customAlertOverlay');
            const box = document.getElementById('customAlertBox');
            const iconContainer = document.getElementById('alertIconContainer');
            const icon = document.getElementById('alertIcon');
            let btn = document.getElementById('alertBtn');
            const btnCancel = document.getElementById('alertBtnCancel');

            // Clone tombol untuk mematikan event listener dari alert sebelumnya
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
            btn = newBtn;

            // Reset tombol cancel agar tidak muncul di alert biasa
            btnCancel.classList.add('hidden');
            btn.classList.remove('flex-1');
            btn.classList.add('w-full');

            // Isi Konten
            document.getElementById('alertTitle').innerText = title;
            document.getElementById('alertMessage').innerHTML = message;

            // Atur Tema Berdasarkan Tipe
            iconContainer.className = 'w-20 h-20 rounded-full flex items-center justify-center mb-5 shadow-inner';
            btn.className = 'w-full font-bold py-3.5 px-6 rounded-xl transition-all active:scale-95 text-white shadow-md focus:outline-none focus:ring-4';

            if (type === 'success') {
                iconContainer.classList.add('bg-emerald-100', 'text-emerald-500');
                btn.classList.add('bg-emerald-500', 'hover:bg-emerald-600', 'focus:ring-emerald-200');
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>';
                btn.innerText = 'Oke, Lanjutkan';
            } else if (type === 'error') {
                iconContainer.classList.add('bg-rose-100', 'text-rose-500');
                btn.classList.add('bg-rose-500', 'hover:bg-rose-600', 'focus:ring-rose-200');
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path>';
                btn.innerText = 'Tutup';
            } else if (type === 'warning') {
                iconContainer.classList.add('bg-amber-100', 'text-amber-500');
                btn.classList.add('bg-amber-500', 'hover:bg-amber-600', 'focus:ring-amber-200');
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>';
                btn.innerText = 'Mengerti';
            } else { // info
                iconContainer.classList.add('bg-blue-100', 'text-blue-500');
                btn.classList.add('bg-blue-500', 'hover:bg-blue-600', 'focus:ring-blue-200');
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>';
                btn.innerText = 'Baiklah';
            }

            // Tampilkan Animasi
            overlay.classList.remove('hidden');
            setTimeout(() => {
                overlay.classList.remove('opacity-0');
                box.classList.remove('scale-95');
                box.classList.add('scale-100');
            }, 10);

            // Aksi saat diklik
            btn.addEventListener('click', () => {
                overlay.classList.add('opacity-0');
                box.classList.remove('scale-100');
                box.classList.add('scale-95');
                setTimeout(() => {
                    overlay.classList.add('hidden');
                    resolve(true); // Lanjutkan kode berikutnya!
                }, 300);
            });
        });
    };

    // 2. FUNGSI KONFIRMASI (Pengganti confirm('Yakin?'))
    window.showConfirmAlert = (title, message) => {
        return new Promise((resolve) => {
            const overlay = document.getElementById('customAlertOverlay');
            const box = document.getElementById('customAlertBox');
            const iconContainer = document.getElementById('alertIconContainer');
            const icon = document.getElementById('alertIcon');
            let btn = document.getElementById('alertBtn');
            let btnCancel = document.getElementById('alertBtnCancel');

            // Clone ulang tombol
            const newBtn = btn.cloneNode(true); btn.parentNode.replaceChild(newBtn, btn); btn = newBtn;
            const newBtnCancel = btnCancel.cloneNode(true); btnCancel.parentNode.replaceChild(newBtnCancel, btnCancel); btnCancel = newBtnCancel;

            // Tema Warning
            iconContainer.className = 'w-20 h-20 rounded-full flex items-center justify-center mb-5 shadow-inner bg-amber-100 text-amber-500';
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>';
            
            document.getElementById('alertTitle').innerText = title;
            document.getElementById('alertMessage').innerHTML = message;

            // Tombol Kanan (Hapus/Aksi Merah)
            btn.className = 'flex-1 font-bold py-3.5 px-6 rounded-xl transition-all active:scale-95 text-white shadow-md bg-rose-500 hover:bg-rose-600 focus:ring-4 focus:ring-rose-200';
            btn.innerText = 'Ya, Lanjutkan';
            
            // Tombol Kiri (Batal)
            btnCancel.className = 'flex-1 font-bold py-3.5 px-6 rounded-xl transition-all active:scale-95 bg-gray-100 text-gray-700 hover:bg-gray-200';
            btnCancel.classList.remove('hidden');

            // Tampilkan
            overlay.classList.remove('hidden');
            setTimeout(() => { overlay.classList.remove('opacity-0'); box.classList.remove('scale-95'); box.classList.add('scale-100'); }, 10);

            const tutupModal = (hasil) => {
                overlay.classList.add('opacity-0');
                box.classList.remove('scale-100'); box.classList.add('scale-95');
                setTimeout(() => {
                    overlay.classList.add('hidden');
                    btnCancel.classList.add('hidden');
                    resolve(hasil); // Mengembalikan nilai true / false
                }, 300);
            };

            btn.addEventListener('click', () => tutupModal(true));
            btnCancel.addEventListener('click', () => tutupModal(false));
        });
    };
</script>