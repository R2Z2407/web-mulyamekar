---
// src/layouts/BaseLayout.astro
import '../global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CustomAlert from '../components/CustomAlert.astro';
import KontakModal from '../components/KontakModal.astro';

// Menangkap properti title dari halaman yang memanggil layout ini
const { title = "Desa Mulyamekar Smart Village" } = Astro.props;
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    </head>
<body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen">
    
    <Header />
    
    <slot />
    
    <Footer />
    <CustomAlert/>
    <KontakModal />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>  
    <div id="layarLoadingUtama" class="fixed inset-0 z-[9999] bg-[#196d63] flex flex-col items-center justify-center transition-opacity duration-500 ease-in-out">
        <img 
            id="gambarLoadingUtama" 
            src="/animasi-galeri/ezgif-frame-010.jpg" 
            alt="Loading..." 
            class="w-40 h-40 object-contain drop-shadow-2xl" 
        />
        <p class="text-teal-400 font-bold mt-6 animate-pulse tracking-widest text-sm">MEMUAT HALAMAN...</p>
    </div>

    <script>
        (function() {
            const loader = document.getElementById('layarLoadingUtama');
            const imgElement = document.getElementById('gambarLoadingUtama');
            
            if (!loader || !imgElement) return;

            const folderGambar = '/animasi-galeri'; // Pastikan nama folder bener!
            const namaFileAwal = 'ezgif-frame-';
            const ekstensi = '.jpg'; // Perhatikan huruf kecil/besarnya (.png atau .PNG)

            const frameMulai = 10;
            const totalFrames = 184;
            const intervalTime = 1000 / 21; // 21 FPS

            let currentFrame = frameMulai;

            // 1. Nyalakan mesin pemutar gambar
            const loaderInterval = setInterval(() => {
                currentFrame++;
                if (currentFrame > totalFrames) currentFrame = frameMulai;
                
                const frameFormat = String(currentFrame).padStart(3, '0');
                imgElement.src = `${folderGambar}/${namaFileAwal}${frameFormat}${ekstensi}`;
            }, intervalTime);

            // 2. Fungsi saklar untuk mematikan loading
            function tutupLoader() {
                if(loader.style.display === 'none') return; // Cegah double trigger
                
                loader.classList.add('opacity-0');
                setTimeout(() => {
                    loader.style.display = 'none';
                    clearInterval(loaderInterval);
                }, 500);
            }

            // 3. Deteksi "Selesai" Multi-Lapis (Dijamin Hilang!)
            
            // Lapis A: Jika halaman memang sudah selesai dari tadi
            if (document.readyState === 'complete') {
                setTimeout(tutupLoader, 500); 
            } else {
                // Lapis B: Menunggu halaman selesai normal
                window.addEventListener('load', tutupLoader);
            }

            // Lapis C: Khusus jika lu pakai Astro ViewTransitions
            document.addEventListener('astro:page-load', tutupLoader);

            // Lapis D: JARING PENGAMAN! Apapun yang terjadi, paksa hilang setelah 4 detik.
            setTimeout(tutupLoader, 4000);

        })();
    </script>
</body>
</html>