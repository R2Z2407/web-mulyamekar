---
// src/pages/toko/index.astro
import BaseLayout from '../../layout/BaseLayout.astro';
import SellerHeader from '../../components/umkm/toko/SellerHeader.astro';
import SellerStats from '../../components/umkm/toko/SellerStats.astro';
import SellerProductList from '../../components/umkm/toko/SellerProductList.astro';
import ModalAddProduct from '../../components/umkm/toko/ModalAddProduct.astro';
---

<BaseLayout title="Seller Center - Toko UMKM Mulyamekar">
    <main class="flex-grow pt-24 pb-20 bg-gray-50">
        <div class="container mx-auto px-4 max-w-6xl">
            
            <SellerHeader />
            <SellerStats />
            <SellerProductList />

        </div>
    </main>

    <ModalAddProduct />

    <script>
        import { supabase } from '../../lib/supabase.js';
        const IMGBB_KEY = import.meta.env.PUBLIC_IMGBB_API_KEY;

        let tokoSaya = null;
        let isEditMode = false;
        let currentProducts = []; // Simpan data produk lokal untuk referensi cepat

        // --- 1. INISIALISASI DATA ---
        async function initSellerCenter() {
            const { data: { user } } = await supabase.auth.getUser();
            if (!user) { window.location.href = '/'; return; }

            // Ambil data toko milik user ini
            const { data: toko, error } = await supabase.from('umkm_toko').select('*').eq('user_id', user.id).single();
            if (error || !toko) { window.location.href = '/warga'; return; }

            tokoSaya = toko;
            document.getElementById('namaTokoHeadline').innerText = toko.nama_toko;
            document.getElementById('namaPemilikToko').innerText = `👤 ${toko.nama_pemilik}`;
            
            loadProduk();
        }

        // --- 2. LOAD PRODUK (Versi Gabungan Stats + Edit) ---
        async function loadProduk() {
            const tbody = document.getElementById('tableProdukSeller');
            const { data: produk, error } = await supabase.from('umkm_produk').select('*').eq('toko_id', tokoSaya.id).order('created_at', { ascending: false });

            if (error) { tbody.innerHTML = '<tr><td colspan="4" class="p-8 text-center text-red-500 font-bold">Gagal memuat data.</td></tr>'; return; }

            document.getElementById('statTotalProduk').innerText = produk.length;
            const totalKlik = produk.reduce((acc, p) => acc + (p.klik_wa || 0), 0);
            document.getElementById('statKlikWA').innerText = totalKlik;

            currentProducts = produk;

            if (produk.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="p-12 text-center text-gray-400 font-bold">Belum ada produk.</td></tr>';
                return;
            }

            let html = '';
            produk.forEach(p => {
                html += `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 flex items-center gap-3">
                        <img src="${p.foto_url}" class="w-10 h-10 rounded-lg object-cover shadow-sm">
                        <p class="font-bold text-gray-800 text-sm">${p.nama_produk}</p>
                    </td>
                    <td class="p-4 font-mono font-bold text-orange-600">Rp ${p.harga.toLocaleString('id-ID')}</td>
                    <td class="p-4 text-center">
                        <span class="px-2 py-1 rounded-md text-[9px] font-black border uppercase ${p.is_active ? 'bg-green-50 text-green-600 border-green-100' : 'bg-red-50 text-red-600 border-red-100'}">
                            ${p.is_active ? 'Tayang' : 'Draft'}
                        </span>
                    </td>
                    <td class="p-4">
                        <div class="flex items-center justify-center gap-2">
                            <button onclick="toggleStatusProduk('${p.id}', ${p.is_active})" class="p-2 rounded-xl bg-gray-100 text-gray-500 hover:bg-orange-100 hover:text-orange-600 transition-all">
                                <i class="bi ${p.is_active ? 'bi-eye-slash-fill' : 'bi-eye-fill'}"></i>
                            </button>
                            <button onclick="persiapanEditProduk('${p.id}')" class="p-2 rounded-xl bg-gray-100 text-gray-500 hover:bg-blue-100 hover:text-blue-600 transition-all">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button onclick="hapusProduk('${p.id}')" class="p-2 rounded-xl bg-gray-100 text-gray-500 hover:bg-red-100 hover:text-red-600 transition-all">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </div>
                    </td>
                </tr>`;
            });
            tbody.innerHTML = html;
        }

        // --- 3. LOGIKA MODAL & PERSIAPAN ---
        window.bukaModalProduk = () => { const m = document.getElementById('modalProduk'); m.classList.replace('hidden', 'flex'); setTimeout(() => { m.classList.remove('opacity-0'); document.getElementById('modalProdukBox').classList.replace('scale-95', 'scale-100'); }, 10); };
        window.tutupModalProduk = () => { const m = document.getElementById('modalProduk'); m.classList.add('opacity-0'); document.getElementById('modalProdukBox').classList.replace('scale-100', 'scale-95'); setTimeout(() => m.classList.replace('flex', 'hidden'), 300); };

        window.persiapanTambahProduk = () => {
            isEditMode = false;
            document.getElementById('modalTitle').innerText = "Tambah Produk Baru";
            document.getElementById('formProduk').reset();
            document.getElementById('prod_id').value = "";
            
            // 🔥 OTOMATIS ISI LOKASI DARI DATABASE TOKO 🔥
            // Kita ambil dari variabel 'tokoSaya' yang sudah diisi saat init
            if (tokoSaya) {
                const inputLokasi = document.getElementById('prod_lokasi');
                if (inputLokasi) {
                    // Gunakan alamat_usaha atau alamat sesuai nama kolom di tabel umkm_toko kamu
                    inputLokasi.value = tokoSaya.alamat_usaha || tokoSaya.alamat || "";
                }
            }

            document.getElementById('wadahPreview').classList.add('hidden');
            document.getElementById('preview_foto').src = "";
            document.getElementById('labelFotoProduk').innerText = "Klik untuk Upload Gambar";
            
            bukaModalProduk();
        };

        window.persiapanEditProduk = (id) => {
            isEditMode = true;
            const p = currentProducts.find(item => item.id === id);
            if (!p) return;

            document.getElementById('modalTitle').innerText = "Edit Produk";
            document.getElementById('prod_id').value = p.id;
            document.getElementById('prod_nama').value = p.nama_produk;
            document.getElementById('prod_kategori').value = p.kategori;
            document.getElementById('prod_harga').value = p.harga;
            document.getElementById('prod_deskripsi').value = p.deskripsi || "";
            
            // 🔥 JIKA DATA LOKASI PRODUK KOSONG, KITA AMBIL DARI DATABASE TOKO 🔥
            const inputLokasi = document.getElementById('prod_lokasi');
            if (inputLokasi) {
                inputLokasi.value = p.lokasi || tokoSaya.alamat_usaha || tokoSaya.alamat || "";
            }
            
            document.getElementById('wadahPreview').classList.remove('hidden');
            document.getElementById('preview_foto').src = p.foto_url;
            document.getElementById('labelFotoProduk').innerText = "Ganti Foto? Klik di sini";
            
            bukaModalProduk();
        };

        // --- 4. SUBMIT FORM PRODUK (INSERT / UPDATE) ---
        document.getElementById('formProduk')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnSimpanProduk');
            const fileInput = document.getElementById('prod_foto');
            const file = fileInput.files[0];
            const id = document.getElementById('prod_id').value;

            btn.disabled = true;
            btn.innerText = "Memproses...";

            try {
                let fotoUrl = null;
                if (file) {
                    const formData = new FormData();
                    formData.append('image', file);
                    const resImg = await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_KEY}`, { method: 'POST', body: formData });
                    const dataImg = await resImg.json();
                    fotoUrl = dataImg.data.url;
                }

                // 🔥 PAYLOAD OTOMATIS: Nama Penjual & No WA diambil dari 'tokoSaya' 🔥
                const payload = {
                    nama_produk: document.getElementById('prod_nama').value,
                    kategori: document.getElementById('prod_kategori').value,
                    harga: parseInt(document.getElementById('prod_harga').value),
                    deskripsi: document.getElementById('prod_deskripsi').value,
                    nama_penjual: tokoSaya.nama_pemilik, // Ambil dari data profil toko             // Ambil dari data profil toko
                    is_active: true
                };

                if (fotoUrl) payload.foto_url = fotoUrl;

                if (isEditMode) {
                    const { error } = await supabase.from('umkm_produk').update(payload).eq('id', id);
                    if (error) throw error;
                } else {
                    payload.toko_id = tokoSaya.id;
                    payload.user_id = tokoSaya.user_id;
                    const { error } = await supabase.from('umkm_produk').insert([payload]);
                    if (error) throw error;
                }

                tutupModalProduk();
                loadProduk();
                alert('Berhasil disimpan!');
            } catch (err) {
                alert('Gagal: ' + err.message);
            } finally {
                btn.disabled = false;
                btn.innerText = "Simpan Produk";
            }
        });

        // --- 5. FUNGSI HAPUS PRODUK ---
        window.hapusProduk = async (id) => {
            // Konfirmasi sebelum menghapus agar tidak kepencet tidak sengaja
            if (!confirm('Apakah kamu yakin ingin menghapus produk ini? Tindakan ini tidak dapat dibatalkan.')) return;
            
            try {
                const { error } = await supabase.from('umkm_produk').delete().eq('id', id);
                if (error) throw error;
                
                alert('Produk berhasil dihapus!');
                loadProduk(); // Muat ulang tabel setelah dihapus
            } catch (err) {
                alert('Gagal menghapus produk: ' + err.message);
                console.error(err);
            }
        };

        // --- 6. FUNGSI TOGGLE TAYANG / DRAFT ---
        window.toggleStatusProduk = async (id, currentStatus) => {
            try {
                // Balikkan statusnya (kalau true jadi false, kalau false jadi true)
                const newStatus = !currentStatus; 
                
                const { error } = await supabase.from('umkm_produk').update({ is_active: newStatus }).eq('id', id);
                if (error) throw error;
                
                loadProduk(); // Muat ulang tabel untuk melihat perubahan badge warna
            } catch (err) {
                alert('Gagal mengubah status: ' + err.message);
                console.error(err);
            }
        };

        // Tampilkan nama file saat dipilih
        // --- FUNGSI BARU: Tampilkan Preview Saat Foto Dipilih Lokal ---
        document.getElementById('prod_foto')?.addEventListener('change', (e) => {
            const file = e.target.files[0];
            const label = document.getElementById('labelFotoProduk');
            const wadahPreview = document.getElementById('wadahPreview');
            const imgPreview = document.getElementById('preview_foto');

            if (file) {
                // Tampilkan nama file pendek
                label.innerText = file.name.length > 15 ? file.name.substring(0, 15) + '...' : file.name;
                
                // Bikin URL lokal (sementara) biar foto langsung muncul tanpa harus upload dulu
                const tempUrl = URL.createObjectURL(file);
                wadahPreview.classList.remove('hidden');
                imgPreview.src = tempUrl;
            } else {
                // Kalau user batal milih (cancel)
                label.innerText = isEditMode ? "Ganti Foto? Klik di sini" : "Klik untuk Upload Gambar";
                if (!isEditMode) {
                    wadahPreview.classList.add('hidden');
                    imgPreview.src = "";
                }
            }
        });

        document.addEventListener('DOMContentLoaded', initSellerCenter);
    </script>
</BaseLayout>