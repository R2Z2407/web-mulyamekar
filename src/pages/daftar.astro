---
// src/pages/daftar.astro
import '../global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Daftar Akun Warga - Desa Mulyamekar</title>
</head>
<body class="bg-gray-100 font-sans text-gray-800 flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow flex items-center justify-center py-20 px-4">
        <div class="bg-white p-8 rounded-3xl shadow-xl border border-gray-100 w-full max-w-md" data-aos="zoom-in">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-extrabold text-teal-950">Daftar Akun</h1>
                <p class="text-gray-500 mt-2 text-sm">Akses layanan surat dan pantau progresnya langsung dari rumah.</p>
            </div>

            <form id="registerForm" class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">NIK (16 Digit) *</label>
                    <input type="text" id="nik" required minlength="16" maxlength="16" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 focus:border-teal-500 outline-none transition-all" placeholder="Contoh: 3214012345678901" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Nama Lengkap *</label>
                    <input type="text" id="nama" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 focus:border-teal-500 outline-none transition-all" placeholder="Sesuai KTP" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Wilayah RT/RW Anda *</label>
                    <select id="wilayah" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 focus:border-teal-500 outline-none transition-all">
                        <option value="" disabled selected>-- Pilih RT/RW Sesuai KTP --</option>
                        <option value="RT 01 / RW 01">RT 01 / RW 01</option>
                        <option value="RT 02 / RW 01">RT 02 / RW 01</option>
                        <option value="RT 01 / RW 02">RT 01 / RW 02</option>
                        <option value="RT 02 / RW 02">RT 02 / RW 02</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Email *</label>
                    <input type="email" id="email" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 focus:border-teal-500 outline-none transition-all" placeholder="email.anda@gmail.com" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Password *</label>
                    <input type="password" id="password" required minlength="6" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 focus:border-teal-500 outline-none transition-all" placeholder="Minimal 6 karakter" />
                </div>
                
                <button type="submit" id="btnRegister" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-4 rounded-xl shadow-lg transition-all active:scale-95 flex justify-center items-center gap-2">
                    Buat Akun Warga
                </button>
            </form>

            <div id="messageBox" class="hidden mt-4 p-3 rounded-lg text-center font-medium text-sm"></div>

            <div class="mt-6 text-center text-sm text-gray-500">
                Sudah punya akun? 
                <a href="/login" class="text-amber-600 font-bold hover:underline">Masuk di sini</a>
            </div>
        </div>
    </main>

    <Footer />

    <script>
        import { supabase } from '../lib/supabase.js';

        const registerForm = document.getElementById('registerForm');
        const messageBox = document.getElementById('messageBox');
        const btnRegister = document.getElementById('btnRegister');

        registerForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // UI Loading state
            btnRegister.disabled = true;
            btnRegister.innerText = "Memproses...";
            messageBox.classList.add('hidden');

            const nik = document.getElementById('nik').value;
            const nama = document.getElementById('nama').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            try {
                // Di dalam blok try { ... }
                const wilayah = document.getElementById('wilayah').value; // Ambil nilai RT

                const { data: authData, error: authError } = await supabase.auth.signUp({
                    email: email,
                    password: password,
                });

                if (authError) throw authError;

                if (authData.user) {
                    const { error: updateError } = await supabase
                        .from('profil_user')
                        .update({ 
                            nik: nik, 
                            nama_lengkap: nama,
                            wilayah_rt: wilayah // SAKTI: Simpan RT ke profil warga!
                        })
                        .eq('id', authData.user.id);

                    if (updateError) throw updateError;
                }

                // Sukses
                messageBox.classList.remove('hidden', 'bg-red-50', 'text-red-600');
                messageBox.classList.add('bg-emerald-50', 'text-emerald-600');
                messageBox.innerText = "Pendaftaran berhasil! Mengalihkan ke halaman login...";
                
                setTimeout(() => {
                    window.location.href = '/login';
                }, 2000);

            } catch (error) {
                // Gagal
                messageBox.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-600');
                messageBox.classList.add('bg-red-50', 'text-red-600');
                messageBox.innerText = "Gagal mendaftar: " + error.message;
            } finally {
                btnRegister.disabled = false;
                btnRegister.innerText = "Buat Akun Warga";
            }
        });
    </script>
</body>
</html>