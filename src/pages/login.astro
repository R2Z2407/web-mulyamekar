---
// src/pages/login.astro
import '../global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - Mulyamekar Smart Village</title>
</head>
<body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow flex items-center justify-center py-20 px-4">
        <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl border border-gray-100 w-full max-w-md relative overflow-hidden" data-aos="zoom-in">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-teal-50 rounded-full opacity-50 blur-2xl"></div>

            <div class="text-center mb-8 relative z-10">
                <div class="w-16 h-16 bg-teal-600 text-white rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 shadow-lg">
                    🔒
                </div>
                <h1 class="text-3xl font-extrabold text-teal-950">Selamat Datang</h1>
                <p class="text-gray-500 mt-2 text-sm">Masuk untuk mengakses layanan E-Government dan E-Commerce desa.</p>
            </div>

            <form id="loginForm" class="space-y-5 relative z-10">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Email Terdaftar</label>
                    <input type="email" id="email" required class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all font-medium" placeholder="nama@email.com" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Kata Sandi</label>
                    <input type="password" id="password" required class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all font-medium" placeholder="••••••••" />
                </div>

                <div id="errorMessage" class="hidden mt-4 p-3 bg-red-50 border border-red-100 text-red-600 text-sm rounded-xl text-center font-bold"></div>

                <button type="submit" id="btnLogin" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-black py-4 rounded-xl shadow-lg transition-all active:scale-95 mt-4">
                    Masuk Sekarang
                </button>
            </form>

            <div class="mt-8 text-center text-sm text-gray-500 border-t border-gray-100 pt-6 relative z-10">
                Belum terdaftar sebagai warga digital? <br/>
                <a href="/daftar" class="inline-block mt-2 text-teal-600 font-extrabold hover:text-teal-700 hover:underline transition-colors">Buat Akun Baru</a>
            </div>
        </div>
    </main>

    <Footer />

    <script>
        import { supabase } from '../lib/supabase.js';

        const loginForm = document.getElementById('loginForm');
        const errorMessage = document.getElementById('errorMessage');
        const btnLogin = document.getElementById('btnLogin');

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            btnLogin.disabled = true;
            btnLogin.innerText = "Memeriksa Kredensial...";
            errorMessage.classList.add('hidden');

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            // 1. Proses Autentikasi dengan Supabase
            const { data, error } = await supabase.auth.signInWithPassword({
                email: email,
                password: password,
            });

            if (error) {
                errorMessage.classList.remove('hidden');
                errorMessage.innerText = "Gagal Masuk: Email atau Kata Sandi salah.";
                btnLogin.disabled = false;
                btnLogin.innerText = "Masuk Sekarang";
                return;
            }

            // 2. Jika sukses login, cek Role di database profil
            if (data.user) {
                const userId = data.user.id;
                
                const { data: profil, error: profilError } = await supabase
                    .from('profil_user')
                    .select('role')
                    .eq('id', userId)
                    .single();

                if (profilError || !profil) {
                    errorMessage.classList.remove('hidden');
                    errorMessage.innerText = "Gagal memuat data profil. Silakan hubungi Admin.";
                    btnLogin.disabled = false;
                    btnLogin.innerText = "Masuk Sekarang";
                    return;
                }

                btnLogin.innerText = "Mengalihkan...";

                // 3. Smart Routing Berdasarkan Role
                if (profil.role === 'admin') {
                    window.location.href = '/admin';
                } else if (profil.role === 'rt') {
                    window.location.href = '/pengguna'; // <-- Kembalikan ke /rt
                } else if (profil.role === 'rw') {
                    window.location.href = '/pengguna'; // <-- Kembalikan ke /rt
                } else {
                    window.location.href = '/pengguna'; 
                }
            }
        });
    </script>
</body>
</html>