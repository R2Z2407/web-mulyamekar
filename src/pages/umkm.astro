---
// src/pages/umkm.astro
import '../global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pasar Desa Mulyamekar - E-Commerce UMKM</title>
</head>
<body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow pt-24 pb-20">
        <section class="bg-gradient-to-br from-orange-500 to-amber-500 text-white py-12 mb-8 shadow-inner relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/food.png')]"></div>
            <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="md:w-1/2 text-center md:text-left">
                    <span class="inline-block px-4 py-1 bg-white text-orange-600 font-extrabold rounded-full text-[10px] uppercase tracking-widest mb-4 shadow-sm">100% Produk Lokal Asli</span>
                    <h1 class="text-4xl md:text-6xl font-black mb-4 leading-tight">Pasar Desa <br/> <span class="text-yellow-200">Mulyamekar</span></h1>
                    <p class="text-orange-50 text-lg mb-6">Dukung UMKM lokal. Beli produk dari tetangga, putar ekonomi desa!</p>
                    
                    <a href="/warga?bukaToko=true" class="inline-block bg-white text-orange-600 font-extrabold py-3 px-8 rounded-full shadow-xl hover:scale-105 transition-transform">
                        🛒 Buka Toko / Jualan Di Sini
                    </a>
                </div>
                <div class="md:w-1/2 flex justify-center">
                    <div class="w-64 h-64 bg-white/20 rounded-full flex items-center justify-center backdrop-blur-sm border-8 border-white/30 shadow-2xl"><span class="text-8xl">🛍️</span></div>
                </div>
            </div>
        </section>

        <div class="container mx-auto px-4 max-w-6xl">
            <div class="flex flex-wrap justify-center gap-3 mb-10" id="kategoriContainer">
                <button onclick="filterKategori('Semua')" class="btn-kategori active px-6 py-2 rounded-full font-bold text-sm bg-orange-500 text-white shadow-md transition-all">Semua</button>
                <button onclick="filterKategori('Makanan')" class="btn-kategori px-6 py-2 rounded-full font-bold text-sm bg-white text-gray-600 border border-gray-200 hover:border-orange-500 hover:text-orange-500 transition-all">🍔 Makanan</button>
                <button onclick="filterKategori('Kerajinan')" class="btn-kategori px-6 py-2 rounded-full font-bold text-sm bg-white text-gray-600 border border-gray-200 hover:border-orange-500 hover:text-orange-500 transition-all">🏺 Kerajinan</button>
                <button onclick="filterKategori('Pertanian')" class="btn-kategori px-6 py-2 rounded-full font-bold text-sm bg-white text-gray-600 border border-gray-200 hover:border-orange-500 hover:text-orange-500 transition-all">🌾 Pertanian</button>
                <button onclick="filterKategori('Jasa')" class="btn-kategori px-6 py-2 rounded-full font-bold text-sm bg-white text-gray-600 border border-gray-200 hover:border-orange-500 hover:text-orange-500 transition-all">🛠️ Jasa</button>
            </div>
            
            <div id="gridProduk" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                </div>
        </div>
    </main>

    <div id="modalZoomFoto" class="fixed inset-0 z-[100] bg-black/95 hidden flex flex-col items-center justify-center opacity-0 transition-opacity duration-300">
        <button onclick="tutupZoom()" class="absolute top-4 right-4 md:top-6 md:right-6 z-50 bg-white/10 hover:bg-rose-500 text-white w-12 h-12 rounded-full flex items-center justify-center transition-colors backdrop-blur-sm border border-white/20 shadow-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 z-50 bg-black/50 text-white/80 text-xs px-4 py-2 rounded-full backdrop-blur-md pointer-events-none">
            <span class="hidden md:inline">Gunakan Scroll Mouse untuk Zoom</span>
            <span class="inline md:hidden">Cubit Layar (Pinch) untuk Zoom</span>
        </div>

        <div class="w-full h-full flex items-center justify-center overflow-hidden relative">
            <img id="gambarZoom" src="" class="max-w-full max-h-full object-contain transition-transform duration-100 ease-out cursor-grab active:cursor-grabbing" style="transform: scale(1); touch-action: none;">
        </div>
    </div>

    <Footer />

    <script>
        import { supabase } from '../lib/supabase.js';

        let dataProdukMentah = [];

        const formatRupiah = (angka) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(angka);
        
        const buatLinkWA = (noWa, namaProduk) => {
            if (!noWa) return '#';
            let no = String(noWa).replace(/\D/g, ''); 
            if(no.startsWith('0')) no = '62' + no.substring(1);
            return `https://wa.me/${no}?text=${encodeURIComponent(`Halo! Saya lihat produk *${namaProduk}* di Pasar Desa Mulyamekar. Apakah masih tersedia?`)}`;
        };

        async function loadProduk() {
            const grid = document.getElementById('gridProduk');
            grid.innerHTML = '<div class="col-span-full text-center py-10 text-gray-400 font-bold animate-pulse">Menarik data dari database...</div>';
            
            const { data, error } = await supabase
                .from('umkm_produk')
                .select('*, umkm_toko ( nama_toko, nama_pemilik, no_wa )')
                .eq('is_active', true)
                .order('created_at', { ascending: false });

            if (!error) {
                dataProdukMentah = data;
                renderProduk('Semua');
            } else {
                console.error(error);
                grid.innerHTML = `<div class="col-span-full text-center text-red-500 font-bold">Gagal memuat katalog: ${error.message}</div>`;
            }
        }

        window.filterKategori = (kategori) => {
            document.querySelectorAll('.btn-kategori').forEach(btn => btn.className = "btn-kategori px-6 py-2 rounded-full font-bold text-sm bg-white text-gray-600 border border-gray-200 hover:border-orange-500 hover:text-orange-500 transition-all");
            event.target.className = "btn-kategori active px-6 py-2 rounded-full font-bold text-sm bg-orange-500 text-white shadow-md transition-all";
            renderProduk(kategori);
        };

        function renderProduk(kategori) {
            const grid = document.getElementById('gridProduk');
            let produkTampil = kategori === 'Semua' ? dataProdukMentah : dataProdukMentah.filter(p => p.kategori === kategori);

            if (produkTampil.length === 0) {
                grid.innerHTML = `<div class="col-span-full bg-orange-50 p-10 rounded-3xl text-center border border-orange-100 mt-4"><span class="text-5xl mb-3 block">🏪</span><h3 class="text-xl font-bold text-orange-900">Belum Ada Produk</h3></div>`;
                return;
            }

            let html = '';
            produkTampil.forEach(p => {
                const noWaAman = p.umkm_toko ? p.umkm_toko.no_wa : '';
                const namaTokoAman = p.umkm_toko ? p.umkm_toko.nama_toko : 'Toko Tidak Dikenal';

                // Tambahkan aksi onclick="bukaZoomFoto" dan ubah kursor jadi pointer di gambar
                html += `
                <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl border border-gray-100 overflow-hidden transition-all group flex flex-col h-full">
                    <div class="relative w-full h-48 bg-gray-100 overflow-hidden shrink-0 cursor-zoom-in" onclick="bukaZoomFoto('${p.foto_url}')">
                        <img src="${p.foto_url}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        <div class="absolute top-2 right-2 bg-white/90 backdrop-blur text-orange-600 text-[10px] font-bold px-2 py-1 rounded-md shadow-sm">${p.kategori}</div>
                        <div class="absolute inset-0 bg-black/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="bg-white/80 p-2 rounded-full backdrop-blur-sm shadow-lg text-lg">🔍</span>
                        </div>
                    </div>
                    <div class="p-4 flex flex-col flex-grow">
                        <h3 class="font-extrabold text-gray-800 line-clamp-2 mb-1 group-hover:text-orange-600 transition-colors">${p.nama_produk}</h3>
                        <p class="text-[10px] font-bold text-gray-500 mb-2 truncate">🏪 ${namaTokoAman}</p>
                        <div class="mt-auto pt-3 border-t border-gray-50 flex items-center justify-between">
                            <span class="font-black text-orange-600 text-lg">${formatRupiah(p.harga)}</span>
                            <a href="${buatLinkWA(noWaAman, p.nama_produk)}" target="_blank" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-3 py-2 rounded-xl transition-colors shadow-sm text-sm">Beli</a>
                        </div>
                    </div>
                </div>`;
            });
            grid.innerHTML = html;
        }

        // ================= LOGIKA ZOOM FOTO =================
        let currentScale = 1;
        
        window.bukaZoomFoto = (url) => {
            const m = document.getElementById('modalZoomFoto');
            const img = document.getElementById('gambarZoom');
            
            img.src = url;
            currentScale = 1; // Reset zoom tiap buka foto baru
            img.style.transform = `scale(1)`;
            
            document.body.classList.add('overflow-hidden'); // Kunci scroll layar belakang
            m.classList.remove('hidden');
            setTimeout(() => m.classList.remove('opacity-0'), 10);
        };

        window.tutupZoom = () => {
            const m = document.getElementById('modalZoomFoto');
            m.classList.add('opacity-0');
            setTimeout(() => {
                m.classList.add('hidden');
                document.body.classList.remove('overflow-hidden'); // Buka kunci layar belakang
            }, 300);
        };

        document.addEventListener('DOMContentLoaded', () => {
            loadProduk();

            // Pasang Event Listener untuk Zoom
            const imgZoom = document.getElementById('gambarZoom');

            // 1. ZOOM DESKTOP (SCROLL MOUSE)
            imgZoom.addEventListener('wheel', (e) => {
                e.preventDefault();
                // Hitung arah scroll (ke atas/bawah)
                currentScale += e.deltaY * -0.002;
                // Batasi zoom minimal ukuran asli (1x) dan maksimal 4x
                currentScale = Math.min(Math.max(1, currentScale), 4); 
                imgZoom.style.transform = `scale(${currentScale})`;
            });

            // 2. ZOOM MOBILE (PINCH / CUBIT)
            let startDistance = 0;

            imgZoom.addEventListener('touchstart', (e) => {
                if (e.touches.length === 2) {
                    // Hitung jarak awal antara dua jari saat nyentuh layar
                    startDistance = Math.hypot(
                        e.touches[0].pageX - e.touches[1].pageX,
                        e.touches[0].pageY - e.touches[1].pageY
                    );
                }
            });

            imgZoom.addEventListener('touchmove', (e) => {
                if (e.touches.length === 2) {
                    e.preventDefault(); // Cegah browser ikutan ke-zoom
                    
                    // Hitung jarak baru antara dua jari yang lagi geser
                    const currentDistance = Math.hypot(
                        e.touches[0].pageX - e.touches[1].pageX,
                        e.touches[0].pageY - e.touches[1].pageY
                    );
                    
                    // Hitung rasio pelebaran jari
                    const distanceRatio = currentDistance / startDistance;
                    let newScale = currentScale * distanceRatio;
                    
                    // Batasi batas maksimal dan minimal zoom
                    newScale = Math.min(Math.max(1, newScale), 4);
                    imgZoom.style.transform = `scale(${newScale})`;
                    
                    // Update titik awal untuk pergerakan selanjutnya biar mulus
                    startDistance = currentDistance;
                    currentScale = newScale;
                }
            });
        });
    </script>
</body>
</html>