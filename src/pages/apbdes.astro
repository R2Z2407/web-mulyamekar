---
// src/pages/transparansi.astro
import BaseLayout from '../layout/BaseLayout.astro';
---

<BaseLayout title="Transparansi APBDes - Portal Resmi Desa Mulyamekar">
    <main class="flex-grow pb-24">
        
        <section class="bg-teal-950 text-white pt-16 pb-24 relative overflow-hidden rounded-b-[3rem] shadow-sm mb-12">
            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
            <div class="absolute -left-20 -top-20 w-96 h-96 bg-teal-800 rounded-full blur-3xl opacity-40"></div>
            <div class="absolute right-0 bottom-0 w-64 h-64 bg-amber-500/20 rounded-full blur-3xl"></div>
            
            <div class="container mx-auto px-4 max-w-6xl relative z-10 text-center">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-teal-900/80 border border-teal-700 rounded-full text-xs font-bold tracking-widest uppercase mb-6 text-amber-400 backdrop-blur-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Keterbukaan Informasi Publik
                </div>
                <h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">Transparansi APBDes</h1>
                <p class="text-teal-200 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
                    Laporan Realisasi Anggaran Pendapatan dan Belanja Desa (APBDes) Mulyamekar Tahun Anggaran <span id="labelTahun" class="font-black text-amber-400 border-b-2 border-amber-400">...</span>
                </p>
            </div>
        </section>

        <div class="container mx-auto px-4 max-w-6xl -mt-20 relative z-20">
            
            <div class="grid md:grid-cols-3 gap-6 mb-16" id="ringkasanContainer">
                <div class="bg-white h-40 rounded-3xl shadow-lg animate-pulse border border-gray-100"></div>
                <div class="bg-white h-40 rounded-3xl shadow-lg animate-pulse border border-gray-100"></div>
                <div class="bg-white h-40 rounded-3xl shadow-lg animate-pulse border border-gray-100"></div>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-8 border-b border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4 bg-gray-50/50">
                    <div>
                        <h2 class="text-2xl font-extrabold text-teal-950">Rincian Alokasi Dana</h2>
                        <p class="text-sm text-gray-500 mt-1">Klik pada setiap item kegiatan untuk melihat rincian pengeluaran.</p>
                    </div>
                </div>
                
                <div class="p-6 md:p-8" id="rincianContainer">
                    <div class="text-center py-16 text-gray-400 flex flex-col items-center">
                        <svg class="w-12 h-12 mb-4 animate-spin text-teal-200" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        <span class="font-medium">Menarik data dari server...</span>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script>
        import { supabase } from '../lib/supabase.js';

        const formatRp = (angka) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(angka);
        
        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
        }

        // FUNGSI BUKA TUTUP AKORDION
        window.toggleRincian = (id) => {
            const el = document.getElementById(id);
            const icon = document.getElementById('icon-' + id);
            if (el.classList.contains('hidden')) {
                el.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                el.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        };

        async function loadAPBDes() {
            try {
                const { data, error } = await supabase.from('apbdes').select('*').order('tahun', { ascending: false });
                if (error) throw error;

                if (!data || data.length === 0) {
                    document.getElementById('labelTahun').innerText = new Date().getFullYear();
                    document.getElementById('ringkasanContainer').innerHTML = `<div class="col-span-3 text-center py-10 bg-white shadow-sm rounded-3xl text-gray-500 border border-gray-100">Data belum dipublikasikan.</div>`;
                    document.getElementById('rincianContainer').innerHTML = `<div class="text-center py-10 text-gray-500">Belum ada rincian data.</div>`;
                    return;
                }

                const tahunTerbaru = data[0].tahun;
                document.getElementById('labelTahun').innerText = tahunTerbaru;
                const dataTahunIni = data.filter(d => d.tahun === tahunTerbaru);
                
                let rekap = {
                    Pendapatan: { anggaran: 0, realisasi: 0, warna: 'emerald' },
                    Belanja: { anggaran: 0, realisasi: 0, warna: 'amber' },
                    Pembiayaan: { anggaran: 0, realisasi: 0, warna: 'blue' }
                };
                
                let htmlRincian = '<div class="grid lg:grid-cols-2 gap-6">';
                const kategoriUnik = ['Pendapatan', 'Belanja', 'Pembiayaan'];

                kategoriUnik.forEach(kat => {
                    const itemKategori = dataTahunIni.filter(d => d.kategori === kat);
                    
                    if(itemKategori.length > 0) {
                        const warnaTema = rekap[kat].warna;
                        htmlRincian += `
                            <div class="bg-gray-50/50 p-6 rounded-3xl border border-gray-100 shadow-sm">
                                <div class="flex items-center gap-3 mb-6 border-b border-gray-200 pb-4">
                                    <div class="w-10 h-10 rounded-xl bg-${warnaTema}-100 text-${warnaTema}-600 flex items-center justify-center font-bold shadow-sm">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    </div>
                                    <h3 class="text-xl font-extrabold text-gray-800">${kat}</h3>
                                </div>
                                <div class="space-y-4">
                        `;
                        
                        itemKategori.forEach((item, index) => {
                            rekap[kat].anggaran += item.anggaran;
                            rekap[kat].realisasi += item.realisasi;

                            const persentase = item.anggaran > 0 ? Math.round((item.realisasi / item.anggaran) * 100) : 0;
                            const persenAman = persentase > 100 ? 100 : persentase;

                            // 🌟 LOGIKA INDIKATOR STATUS 🌟
                            let statusText, statusColor, statusIcon;
                            if (kat === 'Pendapatan') {
                                if (persentase >= 100) { statusText = 'Target Terlampaui'; statusColor = 'emerald'; statusIcon = '🌟'; }
                                else if (persentase >= 75) { statusText = 'Hampir Memenuhi Target'; statusColor = 'blue'; statusIcon = '🔵'; }
                                else if (persentase > 0) { statusText = 'Masih Jauh dari Target'; statusColor = 'amber'; statusIcon = '🟡'; }
                                else { statusText = 'Belum Ada Pemasukan'; statusColor = 'gray'; statusIcon = '⏳'; }
                            } else { // Belanja & Pembiayaan
                                if (persentase > 100) { statusText = 'Anggaran Membengkak'; statusColor = 'rose'; statusIcon = '⚠️'; }
                                else if (persentase === 100) { statusText = 'Tepat Sasaran'; statusColor = 'emerald'; statusIcon = '✅'; }
                                else if (persentase >= 50) { statusText = 'Penyerapan Sedang'; statusColor = 'blue'; statusIcon = '🔵'; }
                                else if (persentase > 0) { statusText = 'Kurang Terserap'; statusColor = 'amber'; statusIcon = '🟡'; }
                                else { statusText = 'Belum Ada Realisasi'; statusColor = 'gray'; statusIcon = '⏳'; }
                            }

                            // 🌟 LOGIKA PARSER JSON & JUDUL 🌟
                            // Jika uraian berisi JSON, kita cari kolom lain buat dijadikan judul.
                            let judulUraian = steril(item.uraian);
                            let htmlListRincian = '';

                            try {
                                let dataRincian = null;
                                if (item.uraian && typeof item.uraian === 'string' && item.uraian.trim().startsWith('[')) {
                                    dataRincian = JSON.parse(item.uraian);
                                    // Fallback Title (Kalau uraian kepakai JSON, cari nama_kegiatan/judul di db)
                                    judulUraian = steril(item.nama_kegiatan || item.nama_program || item.judul || item.bidang || 'Detail Kegiatan / Program');
                                } else if (item.rincian && typeof item.rincian === 'string' && item.rincian.trim().startsWith('[')) {
                                    dataRincian = JSON.parse(item.rincian);
                                }

                                if (Array.isArray(dataRincian) && dataRincian.length > 0) {
                                    htmlListRincian = '<div class="mt-4 space-y-2 bg-slate-50 p-4 rounded-xl border border-slate-100 shadow-inner">';
                                    dataRincian.forEach(detail => {
                                        const namaDetail = detail.nama || detail.uraian || 'Item Kegiatan';
                                        const hargaDetail = detail.harga || detail.anggaran || 0;
                                        htmlListRincian += `
                                            <div class="flex justify-between items-center gap-3 border-b border-slate-200/60 pb-2 last:border-0 last:pb-0">
                                                <div class="flex items-start gap-2 text-[11px] text-slate-600 font-bold leading-tight">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-${warnaTema}-400 mt-1 shrink-0"></span>
                                                    <span>${steril(namaDetail)}</span>
                                                </div>
                                                <span class="text-[10px] font-bold text-slate-800 bg-white px-2 py-1 rounded shadow-sm border border-slate-200 shrink-0">
                                                    ${formatRp(hargaDetail)}
                                                </span>
                                            </div>
                                        `;
                                    });
                                    htmlListRincian += '</div>';
                                }
                            } catch(e) {
                                console.warn("Bukan JSON:", e);
                            }

                            // ID UNIK UNTUK AKORDION
                            const accordionId = `rincian-${index}-${kat}`;

                            htmlRincian += `
                                <div class="group flex flex-col justify-between bg-white p-4 md:p-5 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-teal-200 transition-all">
                                    
                                    <div class="cursor-pointer flex justify-between items-start gap-4" onclick="toggleRincian('${accordionId}')">
                                        <div class="flex-grow">
                                            <h4 class="font-extrabold text-gray-800 text-sm group-hover:text-${warnaTema}-600 transition-colors leading-snug">${judulUraian}</h4>
                                            
                                            <div class="inline-flex items-center gap-1.5 mt-2 text-[9px] md:text-[10px] font-bold text-${statusColor}-700 bg-${statusColor}-50 px-2 py-1 rounded-md border border-${statusColor}-100">
                                                <span>${statusIcon}</span> ${statusText}
                                            </div>
                                        </div>
                                        
                                        <div class="flex flex-col items-end shrink-0 gap-2">
                                            <span class="text-[11px] font-black text-${warnaTema}-600 bg-${warnaTema}-50 px-2.5 py-1 rounded-lg border border-${warnaTema}-100">
                                                ${persenAman}%
                                            </span>
                                            <svg id="icon-${accordionId}" class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                        </div>
                                    </div>

                                    <div id="${accordionId}" class="hidden mt-4 pt-4 border-t border-gray-50 transition-all">
                                        ${htmlListRincian}

                                        <div class="mt-4 flex justify-between text-[11px] mb-2 font-mono bg-gray-50/50 p-3 rounded-xl border border-gray-100">
                                            <span class="text-gray-500 flex flex-col">
                                                <span class="text-[9px] uppercase tracking-wider mb-0.5 font-bold">Anggaran</span>
                                                <span class="font-bold text-gray-800">${formatRp(item.anggaran)}</span>
                                            </span>
                                            <span class="text-gray-500 flex flex-col text-right">
                                                <span class="text-[9px] uppercase tracking-wider mb-0.5 font-bold">Realisasi</span>
                                                <span class="font-bold text-${warnaTema}-700">${formatRp(item.realisasi)}</span>
                                            </span>
                                        </div>
                                        
                                        <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden shadow-inner">
                                            <div class="bg-${warnaTema}-500 h-2.5 rounded-full transition-all duration-1000" style="width: ${persenAman}%"></div>
                                        </div>
                                    </div>
                                </div>
                            `;
                        });

                        htmlRincian += `</div></div>`;
                    }
                });
                
                htmlRincian += '</div>';
                document.getElementById('rincianContainer').innerHTML = htmlRincian;

                // 6. Cetak Ringkasan Atas
                let htmlRingkasan = '';
                Object.keys(rekap).forEach(kat => {
                    const dataRekap = rekap[kat];
                    const persenTotal = dataRekap.anggaran > 0 ? Math.round((dataRekap.realisasi / dataRekap.anggaran) * 100) : 0;
                    
                    let bgClass = ''; let iconClass = '';
                    if(kat === 'Pendapatan') { bgClass = 'from-emerald-500 to-teal-600'; iconClass = 'text-emerald-100'; }
                    if(kat === 'Belanja') { bgClass = 'from-amber-400 to-orange-500'; iconClass = 'text-amber-100'; }
                    if(kat === 'Pembiayaan') { bgClass = 'from-blue-500 to-indigo-600'; iconClass = 'text-blue-100'; }

                    htmlRingkasan += `
                        <div class="bg-gradient-to-br ${bgClass} p-6 md:p-8 rounded-3xl shadow-lg text-white relative overflow-hidden transform hover:-translate-y-1 transition-transform">
                            <div class="absolute right-0 top-0 w-32 h-32 bg-white opacity-10 rounded-bl-full"></div>
                            <div class="flex justify-between items-start mb-4 relative z-10">
                                <p class="${iconClass} font-bold uppercase tracking-widest text-[10px] md:text-xs">${kat}</p>
                            </div>
                            <h3 class="text-2xl md:text-3xl font-extrabold mb-6 relative z-10">${formatRp(dataRekap.anggaran)}</h3>
                            
                            <div class="bg-black/15 p-4 rounded-2xl backdrop-blur-sm relative z-10 shadow-inner">
                                <div class="flex justify-between text-xs mb-2 font-medium">
                                    <span class="text-white/80">Realisasi</span>
                                    <span class="font-bold">${formatRp(dataRekap.realisasi)}</span>
                                </div>
                                <div class="w-full bg-black/20 rounded-full h-1.5 mb-2 shadow-inner">
                                    <div class="bg-white h-1.5 rounded-full" style="width: ${persenTotal > 100 ? 100 : persenTotal}%"></div>
                                </div>
                                <div class="text-right text-[10px] font-bold text-white/90">${persenTotal}% Tercapai</div>
                            </div>
                        </div>
                    `;
                });

                document.getElementById('ringkasanContainer').innerHTML = htmlRingkasan;

            } catch (error) {
                document.getElementById('ringkasanContainer').innerHTML = `<div class="col-span-3 text-center text-red-500 font-bold bg-white p-6 rounded-2xl shadow-sm">Gagal memuat data: ${error.message}</div>`;
            }
        }

        loadAPBDes();
    </script>
</BaseLayout>