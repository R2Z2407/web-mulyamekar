// 2. BONGKAR DATA DUKCAPIL BUAT COCOKIN TANGGAL LAHIR
const { data: dbPenduduk, error } = await supabaseAdmin.from("data_penduduk").select("nik, tanggal_lahir");
if (error) throw error;
let isWargaSah = false;
for (const p of dbPenduduk) {
  try {
    // Decrypt NIK
    const bytesNik = CryptoJS.AES.decrypt(p.nik, SECRET_KEY);
    const decNik = bytesNik.toString(CryptoJS.enc.Utf8);
    if (decNik === nik) {
      // 🔥 REVISI: DECRYPT TANGGAL LAHIR DULU SEBELUM DICOCOKIN 🔥
      const bytesTgl = CryptoJS.AES.decrypt(p.tanggal_lahir, SECRET_KEY);
      const decTglLahir = bytesTgl.toString(CryptoJS.enc.Utf8); // Cocokkan Tanggal Lahir yang sudah sama-sama plain-text
      if (decTglLahir === tanggalLahir) {
        isWargaSah = true;
      }
      break; // Stop looping karena NIK udah ketemu
    }
  } catch (err) {
    continue; // Lanjut ke data berikutnya kalau gagal decrypt data ini
  }
}
