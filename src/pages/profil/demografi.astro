---
// src/pages/demografi.astro
import BaseLayout from '../../layout/BaseLayout.astro';
import { supabase } from '../../lib/supabase.js';

// 1. Tarik Data Statistik dari Database
const { data: stats, error } = await supabase.from('statistik_desa').select('*').order('urutan', { ascending: true });

const getVal = (label) => {
    if(!stats) return 0;
    const item = stats.find(s => s.label.toLowerCase() === label.toLowerCase());
    return item ? parseInt(item.nilai) || 0 : 0;
};

// 🔥 VARIABEL DATA (SAMA SEPERTI SEBELUMNYA) 🔥
const totalPenduduk = getVal('Total Penduduk') || 4872; 
const totalKK = getVal('Kepala Keluarga (KK)') || 1428;
const totalLaki = getVal('Warga Laki-laki') || 2451;
const totalPerempuan = getVal('Warga Perempuan') || 2421;
const persenLaki = totalPenduduk ? ((totalLaki / totalPenduduk) * 100).toFixed(1) : 50.3;
const persenPerempuan = totalPenduduk ? ((totalPerempuan / totalPenduduk) * 100).toFixed(1) : 49.7;

const pendTidakSekolah = getVal('Tidak/Belum Sekolah') || 450;
const pendSD = getVal('Tamat SD/Sederajat') || 1200;
const pendSMP = getVal('SLTP/Sederajat') || 1150;
const pendSMA = getVal('SLTA/Sederajat') || 1500;
const pendDiploma = getVal('Diploma I/II/III') || 200;
const pendS1 = getVal('Strata I') || 350;
const pendS2S3 = getVal('Strata II/III') || 22;

const kerjaBelum = getVal('Belum/Tidak Bekerja') || 850;
const kerjaPelajar = getVal('Pelajar/Mahasiswa') || 1100;
const kerjaIRT = getVal('Mengurus Rumah Tangga') || 950;
const kerjaPetani = getVal('Petani/Pekebun') || 320;
const kerjaPedagang = getVal('Pedagang') || 410;
const kerjaSwasta = getVal('Karyawan Swasta') || 820;
const kerjaPNS = getVal('PNS/TNI/POLRI') || 122;
const kerjaWirausaha = getVal('Wiraswasta') || 300;

const agamaIslam = getVal('Islam') || 4800;
const agamaKristen = getVal('Kristen') || 50;
const agamaKatolik = getVal('Katolik') || 15;
const agamaHindu = getVal('Hindu') || 5;
const agamaBuddha = getVal('Buddha') || 2;

const kawinBelum = getVal('Belum Kawin') || 2100;
const kawinSudah = getVal('Kawin') || 2450;
const kawinCeraiH = getVal('Cerai Hidup') || 120;
const kawinCeraiM = getVal('Cerai Mati') || 202;

const u0_4L = getVal('Usia 0-4 Laki') || 150; const u0_4P = getVal('Usia 0-4 Pr') || 140;
const u5_14L = getVal('Usia 5-14 Laki') || 300; const u5_14P = getVal('Usia 5-14 Pr') || 290;
const u15_24L = getVal('Usia 15-24 Laki') || 400; const u15_24P = getVal('Usia 15-24 Pr') || 390;
const u25_34L = getVal('Usia 25-34 Laki') || 450; const u25_34P = getVal('Usia 25-34 Pr') || 460;
const u35_44L = getVal('Usia 35-44 Laki') || 420; const u35_44P = getVal('Usia 35-44 Pr') || 430;
const u45_54L = getVal('Usia 45-54 Laki') || 350; const u45_54P = getVal('Usia 45-54 Pr') || 360;
const u55_64L = getVal('Usia 55-64 Laki') || 250; const u55_64P = getVal('Usia 55-64 Pr') || 220;
const u65plusL = getVal('Usia 65+ Laki') || 131; const u65plusP = getVal('Usia 65+ Pr') || 131;

const daftarBulan = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
const tahunSekarang = new Date().getFullYear();
const daftarTahun = [tahunSekarang, tahunSekarang - 1, tahunSekarang - 2];
---

<BaseLayout title="Demografi - Desa Mulyamekar">
    <script is:inline src="https://d3js.org/d3.v7.min.js"></script>

    <main class="bg-[#F8FAFC] min-h-screen pb-20 font-sans text-slate-800">
        
        <div class="bg-teal-950 pt-24 pb-28 px-4 text-center rounded-b-[40px] shadow-lg relative overflow-hidden">
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#0d9488_1px,transparent_1px),linear-gradient(to_bottom,#0d9488_1px,transparent_1px)] bg-[size:32px_32px] opacity-20"></div>
            <div class="relative z-10 flex flex-col items-center">
                <p class="text-xs md:text-sm text-orange-400 uppercase tracking-[0.3em] font-bold mb-2">Statistik Kependudukan</p>
                <h1 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight uppercase">Demografi <span class="text-orange-400">Mulyamekar</span></h1>
                <p class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white mb-8 tracking-tighter drop-shadow-lg">
                    {totalPenduduk.toLocaleString('id-ID')} <span class="text-xl md:text-2xl font-medium text-orange-300 tracking-normal -ml-1 md:-ml-2">Jiwa</span>
                </p>
            </div>
        </div>

        <div class="container mx-auto px-4 max-w-5xl">
            
            <div class="grid grid-cols-3 gap-2 md:gap-4 -mt-10 relative z-10 mb-8">
                <div class="bg-white p-4 md:p-6 rounded-3xl shadow-lg border border-slate-100 text-center flex flex-col justify-center">
                    <p class="text-xs md:text-sm font-bold text-slate-500 mb-1">Total KK</p>
                    <p class="text-xl md:text-3xl font-black text-slate-800">{totalKK.toLocaleString('id-ID')}</p>
                </div>
                <div class="bg-white p-4 md:p-6 rounded-3xl shadow-lg border border-slate-100 text-center flex flex-col justify-center">
                    <p class="text-xs md:text-sm font-bold text-slate-500 mb-1">Laki-laki</p>
                    <p class="text-xl md:text-3xl font-black text-slate-800">{totalLaki.toLocaleString('id-ID')}</p>
                </div>
                <div class="bg-white p-4 md:p-6 rounded-3xl shadow-lg border border-slate-100 text-center flex flex-col justify-center">
                    <p class="text-xs md:text-sm font-bold text-slate-500 mb-1">Perempuan</p>
                    <p class="text-xl md:text-3xl font-black text-slate-800">{totalPerempuan.toLocaleString('id-ID')}</p>
                </div>
            </div>

            <div class="flex overflow-x-auto hide-scrollbar gap-2 p-1.5 bg-slate-200/50 rounded-2xl md:justify-center mb-6">
                <button onclick="filterChart('semua')" id="btn-filter-semua" class="tab-filter active whitespace-nowrap px-5 py-2.5 rounded-xl text-sm font-bold bg-white text-teal-700 shadow-sm transition-all">Semua Data</button>
                <button onclick="filterChart('penduduk')" id="btn-filter-penduduk" class="tab-filter whitespace-nowrap px-5 py-2.5 rounded-xl text-sm font-bold text-slate-500 hover:text-slate-800 transition-all">Kependudukan</button>
                <button onclick="filterChart('sosial')" id="btn-filter-sosial" class="tab-filter whitespace-nowrap px-5 py-2.5 rounded-xl text-sm font-bold text-slate-500 hover:text-slate-800 transition-all">Sosial & Agama</button>
                <button onclick="filterChart('ekonomi')" id="btn-filter-ekonomi" class="tab-filter whitespace-nowrap px-5 py-2.5 rounded-xl text-sm font-bold text-slate-500 hover:text-slate-800 transition-all">Pendidikan & Ekonomi</button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6" id="chartContainer">
                
                <div class="chart-card penduduk col-span-1 bg-white p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
                    <h3 class="text-base md:text-lg font-extrabold text-slate-800 mb-4 text-center">Komposisi Gender</h3>
                    <div id="d3-gender" class="w-full flex justify-center"></div>
                </div>

                <div class="chart-card sosial col-span-1 bg-white p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
                    <h3 class="text-base md:text-lg font-extrabold text-slate-800 mb-4 text-center">Agama</h3>
                    <div id="d3-agama" class="w-full flex justify-center"></div>
                </div>

                <div class="chart-card sosial col-span-1 bg-white p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
                    <h3 class="text-base md:text-lg font-extrabold text-slate-800 mb-4 text-center">Status Perkawinan</h3>
                    <div id="d3-perkawinan" class="w-full flex justify-center"></div>
                </div>

                <div class="chart-card penduduk col-span-1 md:col-span-2 lg:col-span-3 bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
                    <h3 class="text-base md:text-lg font-extrabold text-slate-800 mb-6 text-center">Kelompok Usia Warga</h3>
                    <div id="d3-usia" class="w-full"></div>
                </div>

                <div class="chart-card ekonomi col-span-1 md:col-span-2 lg:col-span-3 bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
                    <h3 class="text-base md:text-lg font-extrabold text-slate-800 mb-6 text-center">Tingkat Pendidikan</h3>
                    <div id="d3-pendidikan" class="w-full"></div>
                </div>

                <div class="chart-card ekonomi col-span-1 md:col-span-2 lg:col-span-3 bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
                    <h3 class="text-base md:text-lg font-extrabold text-slate-800 mb-6 text-center">Mata Pencaharian</h3>
                    <div id="d3-pekerjaan" class="w-full"></div>
                </div>

            </div>

        </div>
    </main>

    <script define:vars={{
        totalLaki, totalPerempuan,
        pendTidakSekolah, pendSD, pendSMP, pendSMA, pendDiploma, pendS1, pendS2S3,
        kerjaBelum, kerjaPelajar, kerjaIRT, kerjaPetani, kerjaPedagang, kerjaSwasta, kerjaPNS, kerjaWirausaha,
        agamaIslam, agamaKristen, agamaKatolik, agamaHindu, agamaBuddha,
        kawinBelum, kawinSudah, kawinCeraiH, kawinCeraiM,
        u0_4L, u5_14L, u15_24L, u25_34L, u35_44L, u45_54L, u55_64L, u65plusL,
        u0_4P, u5_14P, u15_24P, u25_34P, u35_44P, u45_54P, u55_64P, u65plusP
    }}>
        document.addEventListener('DOMContentLoaded', () => {

            // --- DATA PERSIAPAN ---
            const dataGender = [
                { label: "Laki-laki", value: totalLaki, color: "#3b82f6" },
                { label: "Perempuan", value: totalPerempuan, color: "#ec4899" }
            ];

            const dataAgama = [
                { label: "Islam", value: agamaIslam, color: "#10b981" },
                { label: "Kristen", value: agamaKristen, color: "#3b82f6" },
                { label: "Katolik", value: agamaKatolik, color: "#f43f5e" },
                { label: "Hindu", value: agamaHindu, color: "#f59e0b" },
                { label: "Buddha", value: agamaBuddha, color: "#8b5cf6" }
            ];

            const dataPerkawinan = [
                { label: "Belum Kawin", value: kawinBelum, color: "#94a3b8" },
                { label: "Kawin", value: kawinSudah, color: "#0ea5e9" },
                { label: "Cerai Hidup", value: kawinCeraiH, color: "#f59e0b" },
                { label: "Cerai Mati", value: kawinCeraiM, color: "#64748b" }
            ];

            const dataPendidikan = [
                { label: "Tdk Sekolah", value: pendTidakSekolah, color: "#0d9488" },
                { label: "SD", value: pendSD, color: "#0f766e" },
                { label: "SMP", value: pendSMP, color: "#115e59" },
                { label: "SMA", value: pendSMA, color: "#134e4a" },
                { label: "Diploma", value: pendDiploma, color: "#14b8a6" },
                { label: "S1", value: pendS1, color: "#2dd4bf" },
                { label: "S2/S3", value: pendS2S3, color: "#5eead4" }
            ];

            const dataPekerjaan = [
                { label: "Tdk Kerja", value: kerjaBelum, color: "#d97706" },
                { label: "Pelajar", value: kerjaPelajar, color: "#f59e0b" },
                { label: "IRT", value: kerjaIRT, color: "#fbbf24" },
                { label: "Petani", value: kerjaPetani, color: "#fcd34d" },
                { label: "Pedagang", value: kerjaPedagang, color: "#fde68a" },
                { label: "Swasta", value: kerjaSwasta, color: "#b45309" },
                { label: "PNS/Polri", value: kerjaPNS, color: "#78350f" },
                { label: "Wiraswasta", value: kerjaWirausaha, color: "#92400e" }
            ];

            const dataUsia = [
                { label: "0-4", Laki: u0_4L, Pr: u0_4P },
                { label: "5-14", Laki: u5_14L, Pr: u5_14P },
                { label: "15-24", Laki: u15_24L, Pr: u15_24P },
                { label: "25-34", Laki: u25_34L, Pr: u25_34P },
                { label: "35-44", Laki: u35_44L, Pr: u35_44P },
                { label: "45-54", Laki: u45_54L, Pr: u45_54P },
                { label: "55-64", Laki: u55_64L, Pr: u55_64P },
                { label: "65+", Laki: u65plusL, Pr: u65plusP }
            ];

            // --- FUNGSI DRAW D3 DONUT CHART (Dengan Animasi Mekar & Keterangan HTML) ---
            function drawDonut(selector, data) {
                const width = 300, height = 300; // Dibikin lebih kompak biar fit di tengah
                const radius = Math.min(width, height) / 2;
                
                const svg = d3.select(selector).append("svg")
                    .attr("viewBox", `0 0 ${width} ${height}`)
                    .style("width", "100%")
                    .style("height", "auto")
                    .style("max-width", "300px") 
                    .append("g")
                    .attr("transform", `translate(${width/2},${height/2})`);

                const pie = d3.pie().value(d => d.value).sort(null);
                const data_ready = pie(data);

                const arc = d3.arc().innerRadius(radius * 0.55).outerRadius(radius);

                // 1. Render Potongan Kue & Tooltip (Hover)
                const paths = svg.selectAll('path')
                    .data(data_ready)
                    .join('path')
                    .attr('fill', d => d.data.color)
                    .attr("stroke", "white")
                    .style("stroke-width", "4px")
                    .on("mouseover", function() { d3.select(this).style("opacity", 0.8) })
                    .on("mouseout", function() { d3.select(this).style("opacity", 1) });

                paths.append("title").text(d => `${d.data.label}: ${d.data.value} Jiwa`);

                // 🔥 ANIMASI BERPUTAR & MEKAR 🔥
                paths.transition()
                    .duration(1200)
                    .attrTween('d', function(d) {
                        const i = d3.interpolate({startAngle: 0, endAngle: 0}, d);
                        return function(t) { return arc(i(t)); };
                    });

                // 2. Render Keterangan (Legend) di bawah diagram menggunakan HTML Tailwind
                const legendContainer = d3.select(selector)
                    .append("div")
                    .attr("class", "flex flex-wrap justify-center items-center gap-x-5 gap-y-3 mt-6");

                const legendItems = legendContainer.selectAll("div")
                    .data(data)
                    .join("div")
                    .attr("class", "flex items-center gap-2");

                legendItems.append("span")
                    .attr("class", "w-3 h-3 rounded-full shadow-sm")
                    .style("background-color", d => d.color);

                legendItems.append("span")
                    .attr("class", "text-sm md:text-base font-bold text-slate-700")
                    .text(d => `${d.label} (${d.value.toLocaleString('id-ID')})`);
            }

            // --- FUNGSI DRAW D3 HORIZONTAL BAR (Dengan Animasi Meluncur) ---
            function drawHBar(selector, data) {
                const margin = {top: 20, right: 80, bottom: 20, left: 140}; 
                const width = 800 - margin.left - margin.right;
                const height = (data.length * 50); 
                
                const svg = d3.select(selector).append("svg")
                    .attr("viewBox", `0 0 ${width + margin.left + margin.right} ${height + margin.top + margin.bottom}`)
                    .style("width", "100%")
                    .style("height", "auto")
                    .append("g")
                    .attr("transform", `translate(${margin.left},${margin.top})`);

                const y = d3.scaleBand().range([0, height]).domain(data.map(d => d.label)).padding(.3);
                const x = d3.scaleLinear().domain([0, d3.max(data, d => d.value)]).range([0, width]);

                // Sumbu Y (Teks Kategori)
                svg.append("g")
                    .call(d3.axisLeft(y).tickSize(0))
                    .select(".domain").remove(); 
                
                svg.selectAll(".tick text")
                    .style("font-size", "18px") 
                    .style("font-weight", "bold")
                    .style("fill", "#475569");

                // Batang Data
                svg.selectAll("myRect")
                    .data(data)
                    .join("rect")
                    .attr("x", x(0) )
                    .attr("y", d => y(d.label) )
                    .attr("height", y.bandwidth() )
                    .attr("fill", d => d.color)
                    .attr("rx", 6)
                    .attr("width", 0) // 🔥 Set awal width 0 untuk Animasi 🔥
                    .transition()
                    .duration(1200)
                    .ease(d3.easeCubicOut) // Efek ngerem perlahan di ujung
                    .attr("width", d => x(d.value) );

                // Teks Angka di sebelah batang
                svg.selectAll("myText")
                    .data(data)
                    .join("text")
                    .attr("y", d => y(d.label) + y.bandwidth()/2 + 6) 
                    .text(d => d.value.toLocaleString('id-ID'))
                    .style("font-size", "18px") 
                    .style("font-weight", "900")
                    .style("fill", "#0f766e")
                    .attr("x", x(0)) // 🔥 Set awal x 0 untuk Animasi 🔥
                    .transition()
                    .duration(1200)
                    .ease(d3.easeCubicOut)
                    .attr("x", d => x(d.value) + 10);
            }

            // --- FUNGSI KUSUS DRAW D3 GROUPED BAR (Usia Laki & Perempuan) ---
            function drawGroupedHBar(selector, data) {
                const margin = {top: 40, right: 80, bottom: 20, left: 100};
                const width = 800 - margin.left - margin.right;
                const height = (data.length * 70); 
                
                const svg = d3.select(selector).append("svg")
                    .attr("viewBox", `0 0 ${width + margin.left + margin.right} ${height + margin.top + margin.bottom}`)
                    .style("width", "100%")
                    .style("height", "auto")
                    .append("g")
                    .attr("transform", `translate(${margin.left},${margin.top})`);

                const subgroups = ['Laki', 'Pr'];
                const groups = data.map(d => d.label);

                const y = d3.scaleBand().domain(groups).range([0, height]).padding([0.2]);
                const ySubgroup = d3.scaleBand().domain(subgroups).range([0, y.bandwidth()]).padding([0.05]);
                const maxVal = d3.max(data, d => Math.max(d.Laki, d.Pr));
                const x = d3.scaleLinear().domain([0, maxVal]).range([0, width]);
                const color = d3.scaleOrdinal().domain(subgroups).range(['#3b82f6','#ec4899']);

                // Sumbu Y
                svg.append("g").call(d3.axisLeft(y).tickSize(0)).select(".domain").remove();
                svg.selectAll(".tick text").style("font-size", "18px").style("font-weight", "bold").style("fill", "#475569");

                // Render Batang
                const group = svg.selectAll("myGroup")
                    .data(data).join("g")
                    .attr("transform", d => `translate(0,${y(d.label)})`);

                group.selectAll("rect")
                    .data(d => subgroups.map(key => ({key: key, value: d[key]})))
                    .join("rect")
                    .attr("x", x(0))
                    .attr("y", d => ySubgroup(d.key))
                    .attr("height", ySubgroup.bandwidth())
                    .attr("fill", d => color(d.key))
                    .attr("rx", 4)
                    .attr("width", 0) // 🔥 Animasi 🔥
                    .transition()
                    .duration(1200)
                    .ease(d3.easeCubicOut)
                    .attr("width", d => x(d.value));

                // Teks Angka
                group.selectAll("text")
                    .data(d => subgroups.map(key => ({key: key, value: d[key]})))
                    .join("text")
                    .attr("y", d => ySubgroup(d.key) + ySubgroup.bandwidth()/2 + 6)
                    .text(d => d.value.toLocaleString('id-ID'))
                    .style("font-size", "14px").style("font-weight", "bold").style("fill", d => color(d.key))
                    .attr("x", x(0)) // 🔥 Animasi 🔥
                    .transition()
                    .duration(1200)
                    .ease(d3.easeCubicOut)
                    .attr("x", d => x(d.value) + 8);

                // Legend Laki & Pr
                const legend = svg.append("g").attr("transform", `translate(0, -30)`);
                legend.append("rect").attr("x", 0).attr("y", 0).attr("width", 15).attr("height", 15).style("fill", "#3b82f6").attr("rx", 3);
                legend.append("text").attr("x", 25).attr("y", 13).text("Laki-laki").style("font-size", "16px").style("font-weight", "bold").style("fill", "#3b82f6");
                legend.append("rect").attr("x", 120).attr("y", 0).attr("width", 15).attr("height", 15).style("fill", "#ec4899").attr("rx", 3);
                legend.append("text").attr("x", 145).attr("y", 13).text("Perempuan").style("font-size", "16px").style("font-weight", "bold").style("fill", "#ec4899");
            }

            // --- EKSEKUSI RENDER ---
            // Kita kasih setTimeout supaya pas halaman kelar render, animasinya bener-bener kelihatan jalannya
            setTimeout(() => {
                drawDonut("#d3-gender", dataGender);
                drawDonut("#d3-agama", dataAgama);
                drawDonut("#d3-perkawinan", dataPerkawinan);
                drawGroupedHBar("#d3-usia", dataUsia);
                drawHBar("#d3-pendidikan", dataPendidikan);
                drawHBar("#d3-pekerjaan", dataPekerjaan);
            }, 100);
        });

        // --- FUNGSI FILTER TAB (TETAP ADA) ---
        window.filterChart = function(kategori) {
            document.querySelectorAll('.tab-filter').forEach(btn => {
                btn.classList.remove('bg-white', 'text-teal-700', 'shadow-sm', 'active');
                btn.classList.add('text-slate-500');
            });
            const btnAktif = document.getElementById('btn-filter-' + kategori);
            btnAktif.classList.remove('text-slate-500');
            btnAktif.classList.add('bg-white', 'text-teal-700', 'shadow-sm', 'active');

            document.querySelectorAll('.chart-card').forEach(card => {
                if (kategori === 'semua' || card.classList.contains(kategori)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        };
    </script>
</BaseLayout>