---
// src/pages/statistik.astro
import BaseLayout from '../../layout/BaseLayout.astro';
import { supabase } from '../../lib/supabase.js';

// 1. Tarik Data Statistik dari Database
const { data: stats, error } = await supabase.from('statistik_desa').select('*').order('urutan', { ascending: true });

// 2. Helper & Metrik Utama
const getVal = (label) => {
    if(!stats) return 0;
    const item = stats.find(s => s.label.toLowerCase() === label.toLowerCase());
    return item ? parseInt(item.nilai) || 0 : 0;
};

// 🔥 INI DIA DATANYA UDAH DIAMBIL DARI DB 🔥
const totalPenduduk = getVal('Total Penduduk') || 4872; 
const totalKK = getVal('Kepala Keluarga (KK)') || 1428;
const totalLaki = getVal('Warga Laki-laki') || 2451;
const totalPerempuan = getVal('Warga Perempuan') || 2421;

// Kalkulasi Persentase Gender
const persenLaki = totalPenduduk ? ((totalLaki / totalPenduduk) * 100).toFixed(1) : 50.3;
const persenPerempuan = totalPenduduk ? ((totalPerempuan / totalPenduduk) * 100).toFixed(1) : 49.7;

// Data untuk Filter
const daftarBulan = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
const tahunSekarang = new Date().getFullYear();
const daftarTahun = [tahunSekarang, tahunSekarang - 1, tahunSekarang - 2];
---

<BaseLayout title="Demografi - Desa Mulyamekar">
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <main class="bg-[#F8FAFC] min-h-screen pb-20 font-sans text-slate-800">
        
        <div class="bg-teal-950 pt-24 pb-28 px-4 text-center rounded-b-[40px] shadow-lg relative overflow-hidden">
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#0d9488_1px,transparent_1px),linear-gradient(to_bottom,#0d9488_1px,transparent_1px)] bg-[size:32px_32px] opacity-20"></div>
            <svg class="absolute bottom-0 left-0 w-full h-32 text-teal-800 opacity-60" preserveAspectRatio="none" viewBox="0 0 1440 320">
                <path fill="currentColor" d="M0,256L48,229.3C96,203,192,149,288,154.7C384,160,480,224,576,218.7C672,213,768,139,864,128C960,117,1056,171,1152,197.3C1248,224,1344,224,1392,224L1440,224L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
            </svg>

            <div class="relative z-10 flex flex-col items-center">
                <p class="text-[10px] md:text-xs text-orange-400 uppercase tracking-[0.3em] font-bold mb-2">Statistik Kependudukan</p>
                <h1 class="text-2xl md:text-4xl font-black text-white mb-4 tracking-tight uppercase">
                    Demografi <span class="text-orange-400">Mulyamekar</span>
                </h1>
                <p class="text-5xl md:text-6xl font-extrabold text-white mb-8 tracking-tighter drop-shadow-lg">
                    {totalPenduduk.toLocaleString('id-ID')} <span class="text-2xl font-medium text-orange-300 tracking-normal -ml-2">Jiwa</span>
                </p>

                <div class="flex flex-col sm:flex-row items-center gap-3 bg-teal-900/50 p-2 rounded-2xl border border-teal-500/30 backdrop-blur-md shadow-xl">
                    <div class="flex items-center px-3 gap-2">
                        <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                        <span class="text-[10px] font-black text-orange-400 uppercase tracking-widest">Filter Data:</span>
                    </div>
                    <div class="flex gap-2">
                        <select id="filterBulan" class="bg-teal-800 text-white text-xs font-bold py-2 px-4 rounded-xl border border-teal-600 focus:ring-2 focus:ring-orange-400 outline-none cursor-pointer appearance-none shadow-inner">
                            {daftarBulan.map((bulan) => (
                                <option value={bulan}>{bulan}</option>
                            ))}
                        </select>
                        <select id="filterTahun" class="bg-teal-800 text-white text-xs font-bold py-2 px-4 rounded-xl border border-teal-600 focus:ring-2 focus:ring-orange-400 outline-none cursor-pointer appearance-none shadow-inner">
                            {daftarTahun.map((tahun) => (
                                <option value={tahun}>{tahun}</option>
                            ))}
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="container mx-auto px-4 max-w-4xl">
            
            <div class="grid grid-cols-3 gap-2 md:gap-4 -mt-10 relative z-10">
                <div class="bg-white p-3 md:p-5 rounded-2xl shadow-lg border border-slate-100 text-center flex flex-col justify-center transform transition-transform hover:-translate-y-1">
                    <p class="text-[10px] md:text-xs font-bold text-slate-500 mb-1">Total KK</p>
                    <p class="text-lg md:text-2xl font-black text-slate-800">{totalKK.toLocaleString('id-ID')}</p>
                </div>
                <div class="bg-white p-3 md:p-5 rounded-2xl shadow-lg border border-slate-100 text-center flex flex-col justify-center transform transition-transform hover:-translate-y-1">
                    <p class="text-[10px] md:text-xs font-bold text-slate-500 mb-1">Laki-laki</p>
                    <p class="text-lg md:text-2xl font-black text-slate-800">{totalLaki.toLocaleString('id-ID')}</p>
                    <p class="text-[9px] md:text-xs text-orange-500 font-bold mt-0.5">({persenLaki}%)</p>
                </div>
                <div class="bg-white p-3 md:p-5 rounded-2xl shadow-lg border border-slate-100 text-center flex flex-col justify-center transform transition-transform hover:-translate-y-1">
                    <p class="text-[10px] md:text-xs font-bold text-slate-500 mb-1">Perempuan</p>
                    <p class="text-lg md:text-2xl font-black text-slate-800">{totalPerempuan.toLocaleString('id-ID')}</p>
                    <p class="text-[9px] md:text-xs text-orange-500 font-bold mt-0.5">({persenPerempuan}%)</p>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 md:gap-5 mt-6">
                
                <div class="bg-white p-4 md:p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
                    <h3 class="text-[11px] md:text-sm font-bold text-slate-800 mb-4 text-center">Komposisi Gender</h3>
                    
                    <div class="relative w-full aspect-square max-h-40 md:max-h-56 mx-auto flex items-center justify-center">
                        <canvas id="chartGender" data-laki={totalLaki} data-perempuan={totalPerempuan}></canvas>
                        
                        <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none mt-2">
                            <span class="text-[9px] md:text-[10px] font-black text-slate-400 uppercase tracking-widest">Total</span>
                            <span class="text-sm md:text-xl font-black text-slate-800 leading-none">{(totalLaki + totalPerempuan).toLocaleString('id-ID')}</span>
                        </div>
                    </div>

                    <div class="flex justify-center gap-4 mt-auto pt-5">
                        <div class="flex flex-col items-center text-center">
                            <div class="flex items-center gap-1.5 mb-1">
                                <span class="w-2.5 h-2.5 rounded-full bg-blue-500 shadow-sm"></span>
                                <span class="text-[10px] md:text-xs font-bold text-slate-600">Laki-laki</span>
                            </div>
                            <span class="text-[9px] md:text-[10px] font-black text-blue-600 bg-blue-50 px-2 py-0.5 rounded-lg">{persenLaki}%</span>
                        </div>
                        <div class="flex flex-col items-center text-center">
                            <div class="flex items-center gap-1.5 mb-1">
                                <span class="w-2.5 h-2.5 rounded-full bg-pink-500 shadow-sm"></span>
                                <span class="text-[10px] md:text-xs font-bold text-slate-600">Perempuan</span>
                            </div>
                            <span class="text-[9px] md:text-[10px] font-black text-pink-600 bg-pink-50 px-2 py-0.5 rounded-lg">{persenPerempuan}%</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-4 md:p-5 rounded-3xl shadow-sm border border-slate-100">
                    <h3 class="text-[11px] md:text-sm font-bold text-slate-800 mb-3 text-center">Piramida Usia</h3>
                    <div class="aspect-square bg-slate-50 rounded-xl flex items-center justify-center border border-slate-100 border-dashed">
                        <span class="text-[10px] text-slate-400 font-medium">Chart Piramida</span>
                    </div>
                </div>

                <div class="bg-white p-4 md:p-5 rounded-3xl shadow-sm border border-slate-100">
                    <h3 class="text-[11px] md:text-sm font-bold text-slate-800 mb-3">Tingkat Pendidikan</h3>
                    <div class="aspect-[4/3] md:aspect-video bg-slate-50 rounded-xl flex items-center justify-center border border-slate-100 border-dashed">
                        <span class="text-[10px] text-slate-400 font-medium">Chart Bar</span>
                    </div>
                </div>

                <div class="bg-white p-4 md:p-5 rounded-3xl shadow-sm border border-slate-100">
                    <h3 class="text-[11px] md:text-sm font-bold text-slate-800 mb-3">Mata Pencaharian</h3>
                    <div class="aspect-[4/3] md:aspect-video bg-slate-50 rounded-xl flex items-center justify-center border border-slate-100 border-dashed">
                        <span class="text-[10px] text-slate-400 font-medium">Horizontal Bar</span>
                    </div>
                </div>

                <div class="bg-white p-4 md:p-5 rounded-3xl shadow-sm border border-slate-100">
                    <h3 class="text-[11px] md:text-sm font-bold text-slate-800 mb-3">Agama</h3>
                    <div class="aspect-square bg-slate-50 rounded-xl flex items-center justify-center border border-slate-100 border-dashed">
                        <span class="text-[10px] text-slate-400 font-medium text-orange-500 font-bold">Chart Pie 1</span>
                    </div>
                </div>

                <div class="bg-white p-4 md:p-5 rounded-3xl shadow-sm border border-slate-100">
                    <h3 class="text-[11px] md:text-sm font-bold text-slate-800 mb-3">Status Perkawinan</h3>
                    <div class="aspect-square bg-slate-50 rounded-xl flex items-center justify-center border border-slate-100 border-dashed">
                        <span class="text-[10px] text-slate-400 font-medium text-orange-500 font-bold">Chart Pie 2</span>
                    </div>
                </div>

            </div>

            <div class="grid grid-cols-2 gap-3 mt-8 mb-8">
                <button class="bg-white text-teal-700 border-2 border-teal-600 hover:bg-teal-50 font-bold py-3.5 rounded-2xl shadow-sm transition-all active:scale-95 text-xs md:text-sm tracking-wide">
                    Download PDF
                </button>
                <button class="bg-[#0f766e] hover:bg-teal-800 text-white font-bold py-3.5 rounded-2xl shadow-md transition-all active:scale-95 text-xs md:text-sm tracking-wide">
                    Cetak Data
                </button>
            </div>

        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // === 1. LOGIKA FILTER REAL-TIME ===
            const date = new Date();
            const bulanNames = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
            const currentBulan = bulanNames[date.getMonth()];
            const currentTahun = date.getFullYear().toString();

            const selectBulan = document.getElementById('filterBulan');
            const selectTahun = document.getElementById('filterTahun');

            if (selectBulan) selectBulan.value = currentBulan;
            if (selectTahun) selectTahun.value = currentTahun;

            const triggerDataRefresh = () => {
                console.log(`Mencari data untuk: ${selectBulan.value} ${selectTahun.value}`);
                // Panggil fungsi API Edge Function kamu disini nantinya
            };

            if(selectBulan) selectBulan.addEventListener('change', triggerDataRefresh);
            if(selectTahun) selectTahun.addEventListener('change', triggerDataRefresh);


            // === 2. RENDER CHART GENDER ===
            const ctxGender = document.getElementById('chartGender');
            if (ctxGender) {
                // Ambil data yang udah disuntik dari Astro ke atribut 'data-*'
                const valLaki = parseInt(ctxGender.getAttribute('data-laki')) || 0;
                const valPerempuan = parseInt(ctxGender.getAttribute('data-perempuan')) || 0;

                new Chart(ctxGender, {
                    type: 'doughnut',
                    data: {
                        labels: ['Laki-laki', 'Perempuan'],
                        datasets: [{
                            data: [valLaki, valPerempuan],
                            backgroundColor: ['#3b82f6', '#ec4899'], // Biru & Pink persis gambar lu
                            borderWidth: 0,
                            hoverOffset: 6 // Efek membesar saat disentuh
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '75%', // Bikin lubang tengah membesar buat teks Total
                        plugins: {
                            legend: { display: false }, // Legend default dimatikan, kita pakai HTML khusus di bawah chart
                            tooltip: {
                                padding: 10,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function(context) {
                                        let label = context.label || '';
                                        if (label) { label += ': '; }
                                        label += context.parsed.toLocaleString('id-ID') + ' Jiwa';
                                        return label;
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
</BaseLayout>