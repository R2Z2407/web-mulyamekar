---
// src/pages/admin/pemerintahan.astro
import BaseLayout from '../../layout/BaseLayout.astro';
import ModalAparaturDashboard from '../../components/ModalAparaturDashboard.astro';
---

<BaseLayout title="Kelola Aparatur Desa - Admin Mulyamekar">
    <main class="flex-grow pt-24 pb-20">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="mb-8 flex flex-col md:flex-row justify-between items-end gap-4">
                <div>
                    <a href="/admin" class="text-teal-600 font-bold text-sm hover:text-amber-600 transition-colors">
                        &larr; Kembali ke Dashboard
                    </a>
                    <h1 class="text-3xl font-extrabold text-teal-950 mt-2">Kelola Aparatur Desa</h1>
                    <p class="text-sm text-gray-500">Sesuaikan peran (Role) SOTK agar struktur OrgChart di halaman depan rapi.</p>
                </div>
                <button onclick="bukaModalAparatur()" class="bg-teal-600 text-white font-bold py-2.5 px-6 rounded-xl shadow-lg hover:bg-teal-700 transition-all active:scale-95">
                    + Aparatur Baru
                </button>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-teal-50 text-teal-900 border-b border-teal-100">
                            <tr>
                                <th class="p-4 font-bold text-sm w-20 text-center">No Urut</th>
                                <th class="p-4 font-bold text-sm w-24">Foto</th>
                                <th class="p-4 font-bold text-sm">Nama & Jabatan</th>
                                <th class="p-4 font-bold text-sm text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="tableAparatur" class="divide-y divide-gray-100 text-sm">
                            <tr><td colspan="4" class="p-8 text-center text-gray-400 italic animate-pulse">Memuat data aparatur...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <ModalAparaturDashboard />

    <script>
        import { supabase } from '../../lib/supabase.js';
        let dataGlobal = [];

        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
        }

        async function initPage() {
            const { data: { session } } = await supabase.auth.getSession();
            if (!session) { window.location.href = '/login'; return; }

            const { data: profil } = await supabase.from('profil_user').select('role').eq('id', session.user.id).single();
            if (!profil || profil.role !== 'admin') {
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Akses Ditolak', 'Khusus Admin Desa.');
                window.location.href = '/'; return;
            }

            loadAparatur();
        }

        async function loadAparatur() {
            const { data, error } = await supabase.from('aparatur').select('*').order('urutan', { ascending: true });
            const tbody = document.getElementById('tableAparatur');
            
            if (error) {
                tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-red-500">Gagal memuat: ${error.message}</td></tr>`;
                return;
            }
            dataGlobal = data;

            let html = '';
            data.forEach(item => {
                const fotoAman = steril(item.foto_url) || `https://ui-avatars.com/api/?name=${item.nama}&background=0D8B93&color=fff`;
                html += `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 font-black text-teal-600 text-center text-lg">#${item.urutan}</td>
                    <td class="p-4">
                        <div class="w-12 h-12 rounded-full overflow-hidden border border-gray-200 bg-gray-100 shadow-sm">
                            <img src="${fotoAman}" class="w-full h-full object-cover">
                        </div>
                    </td>
                    <td class="p-4">
                        <p class="font-bold text-teal-950">${steril(item.nama)}</p>
                        <p class="text-[10px] font-bold text-emerald-600 bg-emerald-50 border border-emerald-100 px-2 py-0.5 rounded uppercase tracking-wider inline-block mt-1">${steril(item.jabatan)}</p>
                    </td>
                    <td class="p-4">
                        <div class="flex justify-center gap-2">
                            <button onclick="editAparaturLokal('${item.id}')" class="text-amber-600 font-bold text-[10px] bg-amber-50 px-3 py-1.5 rounded-lg border border-amber-200 hover:bg-amber-100 transition-all">EDIT</button>
                            <button onclick="hapusAparaturLokal('${item.id}')" class="text-red-600 font-bold text-[10px] bg-red-50 px-3 py-1.5 rounded-lg border border-red-200 hover:bg-red-100 transition-all">HAPUS</button>
                        </div>
                    </td>
                </tr>`;
            });
            tbody.innerHTML = html || '<tr><td colspan="4" class="p-8 text-center text-gray-400 italic">Belum ada data aparatur desa.</td></tr>';
        }

        // FUNGSI JEMBATAN KE MODAL
        window.editAparaturLokal = (id) => {
            const item = dataGlobal.find(d => d.id === id);
            if (item && typeof window.bukaModalEditAparatur === 'function') {
                window.bukaModalEditAparatur(item);
            }
        };

        window.hapusAparaturLokal = async (id) => {
            const yakin = typeof showConfirmAlert !== 'undefined' 
                ? await showConfirmAlert('Peringatan Hapus', 'Yakin menghapus aparatur ini secara permanen?')
                : confirm('Hapus data ini?');

            if (yakin) {
                const { error } = await supabase.from('aparatur').delete().eq('id', id);
                if (!error) {
                    if(typeof showCustomAlert !== 'undefined') await showCustomAlert('success', 'Terhapus', 'Data aparatur dihapus.');
                    loadAparatur();
                } else {
                    if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Gagal', error.message);
                }
            }
        };

        // DENGARKAN SINYAL DARI MODAL UNTUK REFRESH TABEL
        window.addEventListener('refreshDataAparatur', () => {
            loadAparatur();
        });

        initPage();
    </script>
</BaseLayout>