---
// src/pages/admin/pemerintahan.astro
import '../../global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Kelola Aparatur Desa - Admin Mulyamekar</title>
</head>
<body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow pt-24 pb-20">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="mb-8 flex flex-col md:flex-row justify-between items-end gap-4">
                <div>
                    <a href="/admin" class="text-teal-600 font-bold text-sm hover:text-amber-600 transition-colors">
                        &larr; Kembali ke Dashboard
                    </a>
                    <h1 class="text-3xl font-extrabold text-teal-950 mt-2">Kelola Aparatur Desa</h1>
                    <p class="text-sm text-gray-500">Gunakan urutan 1 khusus untuk Kepala Desa agar muncul di posisi utama.</p>
                </div>
                <button id="btnTambah" class="bg-teal-600 text-white font-bold py-2.5 px-6 rounded-xl shadow-lg hover:bg-teal-700 transition-all active:scale-95">
                    + Aparatur Baru
                </button>
            </div>

            <div id="formContainer" class="hidden bg-white p-8 rounded-3xl shadow-sm border border-gray-100 mb-8 transition-all">
                <h2 id="formTitle" class="text-xl font-bold text-teal-900 mb-6">Tambah Aparatur</h2>
                <form id="formAparatur" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="hidden" id="editId">
                    <input type="hidden" id="foto_url_lama"> <div>
                        <label class="block text-xs font-bold text-gray-700 mb-1">Nama Lengkap *</label>
                        <input type="text" id="nama" required class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none" placeholder="Contoh: Nama Lengkap, Gelar">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 mb-1">Jabatan *</label>
                        <input type="text" id="jabatan" required class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none" placeholder="Contoh: Sekretaris Desa">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 mb-1">Urutan Tampil *</label>
                        <input type="number" id="urutan" required min="1" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none" placeholder="1 = Kades, 2 = Sekdes, dst">
                    </div>

                    <div class="bg-blue-50 border border-blue-100 p-4 rounded-xl md:col-span-2 mt-2">
                        <label class="block text-sm font-bold text-blue-900 mb-2">Upload Foto Profil Baru (Opsional saat edit)</label>
                        <input type="file" id="input_file_foto" accept="image/*" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-blue-600 file:text-white hover:file:bg-blue-700 transition-all cursor-pointer">
                        <p id="statusUpload" class="text-xs font-bold text-amber-600 mt-2 hidden"></p>
                    </div>

                    <div class="md:col-span-2 flex justify-end gap-3 mt-4 border-t pt-6">
                        <button type="button" id="btnBatal" class="px-6 py-2 bg-gray-100 text-gray-700 font-bold rounded-xl hover:bg-gray-200 transition-colors">Batal</button>
                        <button type="submit" id="btnSimpan" class="px-6 py-2 bg-teal-600 text-white font-bold rounded-xl shadow-md hover:bg-teal-700 transition-colors">Simpan Data</button>
                    </div>
                </form>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-teal-50 text-teal-900 border-b border-teal-100">
                            <tr>
                                <th class="p-4 font-bold text-sm w-20 text-center">Urutan</th>
                                <th class="p-4 font-bold text-sm w-24">Foto</th>
                                <th class="p-4 font-bold text-sm">Nama & Jabatan</th>
                                <th class="p-4 font-bold text-sm text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="tableAparatur" class="divide-y divide-gray-100 text-sm">
                            <tr><td colspan="4" class="p-8 text-center text-gray-400 italic animate-pulse">Memuat data aparatur...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
    <Footer />

    <script>
        import { supabase } from '../../lib/supabase.js';

        // PANGGIL API KEY DARI FILE .env (Format Vercel/Astro)
        const IMGBB_API_KEY = import.meta.env.PUBLIC_IMGBB_API_KEY;
        
        let dataGlobal = [];

        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
        }

        async function initPage() {
            const { data: { session } } = await supabase.auth.getSession();
            if (!session) { window.location.href = '/login'; return; }

            const { data: profil } = await supabase.from('profil_user').select('role').eq('id', session.user.id).single();
            if (!profil || profil.role !== 'admin') {
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Akses Ditolak', 'Khusus Admin Desa.');
                window.location.href = '/'; return;
            }

            loadAparatur();
        }

        async function loadAparatur() {
            const { data, error } = await supabase.from('aparatur').select('*').order('urutan', { ascending: true });
            const tbody = document.getElementById('tableAparatur');
            
            if (error) {
                tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-red-500">Gagal memuat: ${error.message}</td></tr>`;
                return;
            }
            dataGlobal = data;

            let html = '';
            data.forEach(item => {
                // Placeholder kalau foto masih kosong
                const fotoAman = steril(item.foto_url) || `https://ui-avatars.com/api/?name=${item.nama}&background=0D8B93&color=fff`;
                html += `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 font-bold text-teal-600 text-center">#${item.urutan}</td>
                    <td class="p-4">
                        <div class="w-12 h-12 rounded-full overflow-hidden border border-gray-200 bg-gray-100 shadow-sm">
                            <img src="${fotoAman}" class="w-full h-full object-cover">
                        </div>
                    </td>
                    <td class="p-4">
                        <p class="font-bold text-teal-950">${steril(item.nama)}</p>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">${steril(item.jabatan)}</p>
                    </td>
                    <td class="p-4">
                        <div class="flex justify-center gap-2">
                            <button onclick="editData('${item.id}')" class="text-amber-600 font-bold text-[10px] bg-amber-50 px-3 py-1.5 rounded-lg border border-amber-200 hover:bg-amber-100 transition-all">EDIT</button>
                            <button onclick="hapusData('${item.id}')" class="text-red-600 font-bold text-[10px] bg-red-50 px-3 py-1.5 rounded-lg border border-red-200 hover:bg-red-100 transition-all">HAPUS</button>
                        </div>
                    </td>
                </tr>`;
            });
            tbody.innerHTML = html || '<tr><td colspan="4" class="p-8 text-center text-gray-400 italic">Belum ada data aparatur desa.</td></tr>';
        }

        // FUNGSI UPLOAD GAMBAR KE IMGBB
        async function uploadKeImgBB(file) {
            const formData = new FormData();
            formData.append('image', file);
            
            const response = await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_API_KEY}`, {
                method: 'POST',
                body: formData
            });
            
            const data = await response.json();
            if (data.success) {
                return data.data.url; 
            } else {
                throw new Error("Gagal mengupload foto ke server ImgBB.");
            }
        }

        const formContainer = document.getElementById('formContainer');
        const formAparatur = document.getElementById('formAparatur');

        document.getElementById('btnTambah').addEventListener('click', () => {
            resetForm();
            formContainer.classList.remove('hidden');
        });

        document.getElementById('btnBatal').addEventListener('click', resetForm);

        function resetForm() {
            formAparatur.reset();
            document.getElementById('editId').value = '';
            document.getElementById('foto_url_lama').value = '';
            document.getElementById('formTitle').innerText = 'Tambah Aparatur';
            document.getElementById('btnSimpan').innerText = 'Simpan Data';
            document.getElementById('statusUpload').classList.add('hidden');
            formContainer.classList.add('hidden');
        }

        formAparatur.addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = document.getElementById('editId').value;
            const btn = document.getElementById('btnSimpan');
            const fileInput = document.getElementById('input_file_foto');
            const statusUp = document.getElementById('statusUpload');
            
            btn.disabled = true; 
            
            // Default pakai URL lama jika ada
            let finalImageUrl = document.getElementById('foto_url_lama').value; 

            try {
                // 1. CEK APAKAH ADA GAMBAR BARU YANG DI-UPLOAD
                if (fileInput.files.length > 0) {
                    btn.innerText = "Mengupload Foto...";
                    statusUp.innerText = "⏳ Sedang mengupload ke server gambar...";
                    statusUp.classList.remove('hidden');
                    
                    finalImageUrl = await uploadKeImgBB(fileInput.files[0]);
                    
                    statusUp.innerText = "✅ Foto berhasil diupload!";
                    statusUp.classList.replace('text-amber-600', 'text-emerald-600');
                }

                // 2. SIMPAN DATA KE SUPABASE
                btn.innerText = "Menyimpan Data...";

                const payload = {
                    nama: document.getElementById('nama').value,
                    jabatan: document.getElementById('jabatan').value,
                    foto_url: finalImageUrl, // Link dari ImgBB masuk kesini
                    urutan: parseInt(document.getElementById('urutan').value)
                };

                let error;
                if (id) {
                    const res = await supabase.from('aparatur').update(payload).eq('id', id);
                    error = res.error;
                } else {
                    const res = await supabase.from('aparatur').insert([payload]);
                    error = res.error;
                }

                btn.disabled = false; btn.innerText = id ? 'Update Data' : 'Simpan Data';

                if (error) throw error;

                if(typeof showCustomAlert !== 'undefined') {
                    await showCustomAlert('success', 'Berhasil', id ? 'Data aparatur diperbarui!' : 'Data aparatur ditambahkan!');
                } else {
                    alert('Berhasil!');
                }
                
                resetForm();
                loadAparatur();

            } catch (err) {
                btn.disabled = false; btn.innerText = id ? 'Update Data' : 'Simpan Data';
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Gagal', err.message);
                else alert('Error: ' + err.message);
            }
        });

        window.editData = (id) => {
            const item = dataGlobal.find(d => d.id === id);
            if (item) {
                document.getElementById('editId').value = item.id;
                document.getElementById('nama').value = item.nama;
                document.getElementById('jabatan').value = item.jabatan;
                document.getElementById('urutan').value = item.urutan;
                
                // Simpan URL lama ke input hidden
                document.getElementById('foto_url_lama').value = item.foto_url || '';
                
                document.getElementById('formTitle').innerText = 'Edit Aparatur';
                document.getElementById('btnSimpan').innerText = 'Update Data';
                document.getElementById('statusUpload').classList.add('hidden');
                
                formContainer.classList.remove('hidden');
                formContainer.scrollIntoView({ behavior: 'smooth' });
            }
        };

        window.hapusData = async (id) => {
            const yakin = typeof showConfirmAlert !== 'undefined' 
                ? await showConfirmAlert('Peringatan Hapus', 'Yakin ingin menghapus aparatur ini secara permanen?')
                : confirm('Hapus data ini?');

            if (yakin) {
                const { error } = await supabase.from('aparatur').delete().eq('id', id);
                if (!error) {
                    if(typeof showCustomAlert !== 'undefined') await showCustomAlert('success', 'Terhapus', 'Data aparatur dihapus.');
                    loadAparatur();
                } else {
                    if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Gagal', error.message);
                }
            }
        };

        initPage();
    </script>
</body>
</html>