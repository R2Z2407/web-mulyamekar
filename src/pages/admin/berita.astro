---
// src/pages/admin/berita.astro
import AdminLayout from '../../layout/AdminLayout.astro';

const kategoriBerita = ["Pemerintahan", "Kegiatan Warga", "Pemberdayaan", "Pengumuman"];
---

<AdminLayout 
    title="Kelola Berita - Admin Mulyamekar"
    pageTitle="Kelola Berita"
>
    <button slot="action" id="btnTambah" class="bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all active:scale-95">
        + Tulis Berita Baru
    </button>

            <div id="formContainer" class="hidden bg-white p-8 rounded-3xl shadow-sm border border-gray-100 mb-8">
                <h2 id="formTitle" class="text-xl font-bold text-teal-900 mb-6">Form Berita Baru</h2>
                <form id="formBerita" class="space-y-4">
                    <input type="hidden" id="editId">
                    <input type="hidden" id="gambar_url_lama"> <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">Judul Berita *</label>
                            <input type="text" id="judul" required class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500" />
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">Kategori *</label>
                            <select id="kategori" required class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl">
                                {kategoriBerita.map(k => <option value={k}>{k}</option>)}
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Ringkasan (Maks 150 huruf) *</label>
                        <textarea id="ringkasan" required rows="2" maxlength="150" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl"></textarea>
                    </div>
                    
                    <div class="bg-blue-50 border border-blue-100 p-4 rounded-xl">
                        <label class="block text-sm font-bold text-blue-900 mb-2">Upload Gambar Thumbnail (Opsional saat edit)</label>
                        <input type="file" id="input_file_gambar" accept="image/*" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-blue-600 file:text-white hover:file:bg-blue-700 transition-all cursor-pointer">
                        <p id="statusUpload" class="text-xs font-bold text-amber-600 mt-2 hidden"></p>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Isi Berita Lengkap</label>
                        <textarea id="konten" rows="5" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl"></textarea>
                    </div>
                    <div class="flex justify-end gap-3 mt-4">
                        <button type="button" id="btnBatal" class="px-6 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-xl transition-colors">Batal</button>
                        <button type="submit" id="btnSimpan" class="px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl transition-colors shadow-sm">Simpan & Terbitkan</button>
                    </div>
                </form>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-teal-50 text-teal-900 border-b border-teal-100">
                            <tr>
                                <th class="p-4 font-bold text-sm">Tanggal</th>
                                <th class="p-4 font-bold text-sm">Judul Berita</th>
                                <th class="p-4 font-bold text-sm">Kategori</th>
                                <th class="p-4 font-bold text-sm text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="tableBerita" class="divide-y divide-gray-100 text-sm">
                            <tr><td colspan="4" class="p-8 text-center text-gray-400">Memuat data...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </AdminLayout>
    <script>
        import { supabase } from '../../lib/supabase.js';

        // MASUKAN API KEY IMGBB LU DI SINI:
        const IMGBB_API_KEY = import.meta.env.PUBLIC_IMGBB_API_KEY; 

        let beritaGlobal = [];

        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
        }

        async function initPage() {
            try {
                const { data: { session } } = await supabase.auth.getSession();
                if (!session) { window.location.href = '/login'; return; }
                const { data: profil } = await supabase.from('profil_user').select('role').eq('id', session.user.id).single();
                if (!profil || profil.role !== 'admin') {
                    if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Ditolak', 'Akses Admin.');
                    window.location.href = '/'; return;
                }
                loadBerita();
            } catch (error) { console.error("Crash:", error); }
        }

        async function loadBerita() {
            const { data, error } = await supabase.from('berita').select('*').order('created_at', { ascending: false });
            const tbody = document.getElementById('tableBerita');
            if (error) return;
            beritaGlobal = data;
            
            let html = '';
            data.forEach(row => {
                const tgl = new Date(row.created_at).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' });
                html += `
                    <tr class="hover:bg-gray-50">
                        <td class="p-4 text-gray-500">${tgl}</td>
                        <td class="p-4 font-bold text-teal-900">
                            <div class="flex items-center gap-3">
                                <img src="${row.gambar_url || 'https://via.placeholder.com/150'}" class="w-10 h-10 rounded-lg object-cover border border-gray-200">
                                <span>${steril(row.judul)}</span>
                            </div>
                        </td>
                        <td class="p-4"><span class="bg-amber-100 text-amber-700 px-2 py-1 rounded text-xs font-bold">${steril(row.kategori)}</span></td>
                        <td class="p-4 text-center">
                            <div class="flex justify-center gap-2">
                                <button onclick="editBerita('${row.id}')" class="text-amber-600 font-bold text-xs bg-amber-50 px-3 py-1 rounded border border-amber-200">Edit</button>
                                <button onclick="hapusBerita('${row.id}')" class="text-red-500 font-bold text-xs bg-red-50 px-3 py-1 rounded border border-red-200">Hapus</button>
                            </div>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html || `<tr><td colspan="4" class="p-8 text-center text-gray-500">Belum ada berita.</td></tr>`;
        }

        // FUNGSI UPLOAD KE IMGBB
        async function uploadKeImgBB(file) {
            const formData = new FormData();
            formData.append('image', file);
            
            const response = await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_API_KEY}`, {
                method: 'POST',
                body: formData
            });
            
            const data = await response.json();
            if (data.success) {
                return data.data.url; // Mengembalikan link gambar
            } else {
                throw new Error("Gagal mengupload gambar ke ImgBB");
            }
        }

        const formContainer = document.getElementById('formContainer');

        function resetForm() {
            document.getElementById('formBerita').reset();
            document.getElementById('editId').value = '';
            document.getElementById('gambar_url_lama').value = '';
            document.getElementById('formTitle').innerText = 'Form Berita Baru';
            document.getElementById('btnSimpan').innerText = 'Simpan & Terbitkan';
            document.getElementById('statusUpload').classList.add('hidden');
            formContainer.classList.add('hidden');
        }

        document.getElementById('btnTambah').addEventListener('click', () => { resetForm(); formContainer.classList.remove('hidden'); });
        document.getElementById('btnBatal').addEventListener('click', resetForm);

        window.editBerita = (id) => {
            const berita = beritaGlobal.find(b => b.id === id);
            if (berita) {
                document.getElementById('editId').value = berita.id;
                document.getElementById('judul').value = berita.judul;
                document.getElementById('kategori').value = berita.kategori;
                document.getElementById('ringkasan').value = berita.ringkasan;
                document.getElementById('konten').value = berita.konten;
                document.getElementById('gambar_url_lama').value = berita.gambar_url; // Simpan URL lama

                document.getElementById('formTitle').innerText = 'Edit Berita';
                document.getElementById('btnSimpan').innerText = 'Update Berita';
                formContainer.classList.remove('hidden');
                formContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        };

        window.hapusBerita = async (id) => {
            const yakin = typeof showConfirmAlert !== 'undefined' 
                ? await showConfirmAlert('Peringatan', 'Yakin hapus berita ini?')
                : confirm('Yakin hapus?');
            
            if(yakin) {
                await supabase.from('berita').delete().eq('id', id);
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('success', 'Terhapus', 'Berita dihapus.');
                loadBerita();
            }
        };

        document.getElementById('formBerita').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnSimpan');
            const fileInput = document.getElementById('input_file_gambar');
            const statusUp = document.getElementById('statusUpload');
            
            const id = document.getElementById('editId').value;
            const judul = document.getElementById('judul').value;
            const slug = judul.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, ''); 
            
            btn.disabled = true; 
            let finalImageUrl = document.getElementById('gambar_url_lama').value; // Default pakai URL lama jika ada

            try {
                // PROSES UPLOAD GAMBAR DULU (JIKA ADA FILE YANG DIPILIH)
                if (fileInput.files.length > 0) {
                    btn.innerText = "Mengupload Gambar...";
                    statusUp.innerText = "⏳ Sedang mengupload ke server gambar...";
                    statusUp.classList.remove('hidden');
                    
                    finalImageUrl = await uploadKeImgBB(fileInput.files[0]);
                    
                    statusUp.innerText = "✅ Gambar berhasil diupload!";
                    statusUp.classList.replace('text-amber-600', 'text-emerald-600');
                } else if (!id) {
                    // Jika buat berita baru tapi gak milih gambar
                    throw new Error("Mohon pilih gambar thumbnail untuk berita baru!");
                }

                btn.innerText = "Menyimpan Berita...";

                const payload = {
                    judul: judul,
                    kategori: document.getElementById('kategori').value,
                    ringkasan: document.getElementById('ringkasan').value,
                    gambar_url: finalImageUrl, // Simpan LINK dari ImgBB ke Supabase!
                    konten: document.getElementById('konten').value,
                    is_published: true
                };

                let error;
                if (id) {
                    const res = await supabase.from('berita').update(payload).eq('id', id);
                    error = res.error;
                } else {
                    payload.slug = slug + '-' + Date.now();
                    const res = await supabase.from('berita').insert([payload]);
                    error = res.error;
                }

                btn.disabled = false; btn.innerText = id ? "Update Berita" : "Simpan & Terbitkan";

                if (error) throw error;

                if(typeof showCustomAlert !== 'undefined') {
                    await showCustomAlert('success', 'Berhasil!', id ? 'Berita diperbarui!' : 'Berita diterbitkan!');
                } else {
                    alert('Sukses!');
                }
                resetForm();
                loadBerita();

            } catch (err) {
                btn.disabled = false; btn.innerText = id ? "Update Berita" : "Simpan & Terbitkan";
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Gagal', err.message);
                else alert('Error: ' + err.message);
            }
        });

        initPage();
    </script>
</body>
</html>