---
// src/pages/admin/layanan.astro
import '../../global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Kelola Layanan Surat - Admin Mulyamekar</title>
</head>
<body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow pt-10 pb-20">
        <div class="container mx-auto px-4 max-w-7xl">
            <div class="mb-8">
                <a href="/admin" class="text-teal-600 font-bold text-sm hover:text-amber-600 transition-colors">&larr; Kembali ke Dashboard</a>
                <h1 class="text-3xl font-extrabold text-teal-950 mt-2">Layanan Administrasi Surat</h1>
                <p class="text-sm text-gray-500">Kelola permohonan pengajuan surat, tinjau berkas, dan berikan tindak lanjut kepada warga.</p>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                
                <div class="p-6 border-b border-gray-100 bg-gray-50 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div>
                        <h2 class="text-xl font-bold text-gray-900">Daftar Pengajuan Masuk</h2>
                        <button type="button" onclick="downloadSemuaArsip()" id="btnDownloadArsip" class="mt-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-xl shadow-md transition-all active:scale-95 text-xs flex items-center gap-2">
                            📦 Download Arsip Hari Ini (ZIP)
                        </button>
                    </div>
                    <div class="relative w-full sm:w-72">
                        <input type="text" id="searchSurat" placeholder="Cari pemohon / jenis surat..." class="w-full pl-10 pr-4 py-2 bg-white border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-teal-500 outline-none transition-all shadow-sm">
                        <svg class="w-4 h-4 text-gray-400 absolute left-4 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-teal-50 text-teal-900 border-b border-teal-100">
                            <tr>
                                <th class="p-4 font-bold text-xs uppercase tracking-wider w-32">Tgl Masuk</th>
                                <th class="p-4 font-bold text-xs uppercase tracking-wider">Pemohon & Berkas</th>
                                <th class="p-4 font-bold text-xs uppercase tracking-wider">Jenis Surat & Keperluan</th>
                                <th class="p-4 font-bold text-xs uppercase tracking-wider text-center">Validasi RT</th>
                                <th class="p-4 font-bold text-xs uppercase tracking-wider text-center">Status Desa</th>
                                <th class="p-4 font-bold text-xs uppercase tracking-wider text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="tableSurat" class="divide-y divide-gray-100 text-sm">
                            <tr><td colspan="6" class="p-8 text-center text-gray-400 italic animate-pulse font-bold">Memuat data pengajuan surat...</td></tr>
                        </tbody>
                    </table>
                </div>

                <div id="paginationSurat" class="px-6 py-4 bg-gray-50 border-t border-gray-100"></div>
            </div>
        </div>
    </main>

    <div id="modalStatus" class="fixed inset-0 z-[60] bg-gray-900/60 hidden flex items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <div id="modalBox" class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl transform scale-95 transition-transform duration-300">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold text-teal-900">Proses Surat Pemohon</h3>
                <button id="btnTutupModal" class="text-gray-400 hover:text-red-500 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <form id="formStatus" class="space-y-4">
                <input type="hidden" id="editSuratId">
                
                <div class="bg-gray-50 p-4 rounded-xl border border-gray-100 mb-4">
                    <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-1">Informasi Pemohon:</p>
                    <p id="labelNama" class="font-bold text-teal-950 text-lg"></p>
                    <p id="labelWilayah" class="text-xs text-amber-600 font-bold mb-2"></p>
                    <p id="labelJenis" class="text-sm text-gray-600 font-medium"></p>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Ubah Status Akhir (Desa) *</label>
                    <select id="inputStatus" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none font-bold">
                        <option value="Menunggu">⏳ Menunggu Diproses</option>
                        <option value="Diproses">🔄 Sedang Diproses</option>
                        <option value="Selesai">✅ Selesai (Siap Diambil)</option>
                        <option value="Ditolak">❌ Ditolak</option>
                    </select>
                </div>

                <div id="containerUploadPdf" class="hidden bg-teal-50 border border-teal-100 p-4 rounded-xl mt-4">
                    <label class="block text-xs font-bold text-teal-900 mb-2">Unggah File Surat (PDF) Hasil Akhir</label>
                    <p class="text-[10px] text-teal-700 mb-3">Warga dapat mengunduh surat ini langsung dari dashboard mereka.</p>
                    <input type="file" id="inputFileHasil" accept=".pdf" class="block w-full text-xs text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-teal-600 file:text-white hover:file:bg-teal-700 transition-all cursor-pointer">
                    <p id="statusUpload" class="text-[10px] text-amber-600 font-bold mt-2 hidden animate-pulse">Sedang mengunggah file...</p>
                </div>

                <div id="containerAlasanTolak" class="hidden bg-rose-50 border border-rose-100 p-4 rounded-xl mt-4">
                    <label class="block text-xs font-bold text-rose-900 mb-2">Berikan Alasan Penolakan *</label>
                    <textarea id="inputAlasanTolak" rows="3" class="w-full px-3 py-2 bg-white border border-rose-200 rounded-lg text-sm focus:ring-2 focus:ring-rose-500 outline-none transition-all" placeholder="Misal: Foto KTP buram, tidak melampirkan pengantar RT, dll..."></textarea>
                </div>

                <div class="pt-4 border-t border-gray-100 mt-4">
                    <button type="submit" id="btnSimpanStatus" class="w-full bg-teal-600 text-white font-bold py-3 px-6 rounded-xl shadow-md hover:bg-teal-700 transition-all active:scale-95">
                        Simpan Perubahan
                    </button>
                </div>
            </form>
        </div>
    </div>

    <Footer />

    <script>
        import { supabase, URL_DOWNLOAD_ZIP } from '../../lib/supabase.js';
        
        // 🔥 STATE GLOBAL UNTUK PENCARIAN & PAGINATION (LIMIT 6) 🔥
        const itemsPerPage = 6;
        let dataGlobal = [];
        let rawSurat = [];
        let filteredSurat = [];

        // --- FUNGSI DOWNLOAD ARSIP ZIP ---
        // --- FUNGSI DOWNLOAD ARSIP ZIP ---
        window.downloadSemuaArsip = async () => {
            const btn = document.getElementById('btnDownloadArsip');
            const teksAsli = btn.innerHTML;
            btn.innerHTML = '⏳ Sedang Membungkus ZIP...';
            btn.disabled = true;

            try {
                // 1. Ambil KTP Admin (Token)
                const { data: { session } } = await supabase.auth.getSession();
                if (!session) throw new Error("Sesi tidak valid, silakan login ulang.");

                // 🔥 2. LANGSUNG TEMBAK PAKAI VARIABEL DARI SUPABASE.JS 🔥
                const response = await fetch(URL_DOWNLOAD_ZIP, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${session.access_token}`
                    }
                });

                if (!response.ok) {
                    const errData = await response.json().catch(() => ({}));
                    throw new Error(errData.error || "Gagal mendownload arsip. Pastikan folder tidak kosong.");
                }

                // 3. Jadikan Blob (Anti-Corrupt)
                const blobData = await response.blob();

                // 4. Eksekusi Download
                const url = window.URL.createObjectURL(blobData);
                const a = document.createElement('a');
                a.href = url;
                
                const tanggal = new Date().toISOString().split('T')[0];
                a.download = `Arsip_Mulyamekar_${tanggal}.zip`;
                
                document.body.appendChild(a);
                a.click();
                
                window.URL.revokeObjectURL(url);
                a.remove();

                if(typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Berhasil', 'Arsip ZIP berhasil di-download!');
                else alert('Arsip ZIP berhasil di-download!');

            } catch (error) {
                console.error("Download Error:", error);
                if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', error.message);
                else alert('Gagal: ' + error.message);
            } finally {
                btn.innerHTML = teksAsli;
                btn.disabled = false;
            }
        };

        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
        }

        // --- HELPER PAGINATION ---
        function createPaginationUI(pageSekarang, totalData) {
            const totalPages = Math.ceil(totalData / itemsPerPage) || 1;
            if (totalPages <= 1) return ''; 

            let prevBtn = pageSekarang === 1 ? `<button disabled class="opacity-30 cursor-not-allowed px-4 py-2 bg-gray-200 rounded-lg text-xs font-bold">&larr; Sebelumnya</button>` : `<button onclick="gantiHalaman(${pageSekarang - 1})" class="px-4 py-2 bg-white border border-gray-200 hover:border-teal-500 text-teal-700 rounded-lg text-xs font-bold transition-all shadow-sm">&larr; Sebelumnya</button>`;
            
            let nextBtn = pageSekarang === totalPages ? `<button disabled class="opacity-30 cursor-not-allowed px-4 py-2 bg-gray-200 rounded-lg text-xs font-bold">Selanjutnya &rarr;</button>` : `<button onclick="gantiHalaman(${pageSekarang + 1})" class="px-4 py-2 bg-white border border-gray-200 hover:border-teal-500 text-teal-700 rounded-lg text-xs font-bold transition-all shadow-sm">Selanjutnya &rarr;</button>`;

            return `
            <div class="flex justify-between items-center w-full">
                <span class="text-[11px] text-gray-500 font-bold uppercase tracking-wider">Menampilkan Halaman <b class="text-gray-900">${pageSekarang}</b> dari <b class="text-gray-900">${totalPages}</b></span>
                <div class="flex gap-2">${prevBtn}${nextBtn}</div>
            </div>`;
        }

        window.gantiHalaman = (page) => renderSurat(page);

        async function initPage() {
            const { data: { session } } = await supabase.auth.getSession();
            if (!session) { window.location.href = '/login'; return; }

            const { data: profil } = await supabase.from('profil_user').select('role').eq('id', session.user.id).single();
            if (!profil || profil.role !== 'admin') {
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Akses Ditolak', 'Khusus Admin Desa.');
                window.location.href = '/'; return;
            }
            loadSurat();
        }

        async function loadSurat() {
            const { data, error } = await supabase.from('pengajuan_surat').select('*').order('created_at', { ascending: false });
            if (error) {
                document.getElementById('tableSurat').innerHTML = `<tr><td colspan="6" class="p-8 text-center text-red-500 font-bold">Gagal memuat: ${error.message}</td></tr>`;
                return;
            }
            
            // 🔥 TRIK UX: FILTER & SEMBUNYIKAN YANG DITOLAK RT 🔥
            // Surat yang status_rt nya 'Ditolak RT' gak bakal masuk ke layar Admin
            const dataBersih = (data || []).filter(item => item.status_rt !== 'Ditolak RT');

            dataGlobal = dataBersih; // Simpan referensi asli buat Modal
            rawSurat = dataBersih;
            filteredSurat = rawSurat;
            renderSurat(1);
        }

        function renderSurat(page) {
            const tbody = document.getElementById('tableSurat');
            const paginasiContainer = document.getElementById('paginationSurat');
            
            if (filteredSurat.length === 0) { 
                tbody.innerHTML = `<tr><td colspan="6" class="p-12 text-center text-gray-400 font-medium">Belum ada pengajuan surat atau laporan.</td></tr>`;
                paginasiContainer.innerHTML = '';
                return; 
            }

            const start = (page - 1) * itemsPerPage;
            const dataTampil = filteredSurat.slice(start, start + itemsPerPage);

            let html = '';
            const sekarang = new Date();

            dataTampil.forEach(item => {
                const tglDibuat = new Date(item.created_at);
                const tglStr = tglDibuat.toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
                const selisihJam = (sekarang - tglDibuat) / (1000 * 60 * 60);
                const isExpired = selisihJam > 24;

                // 🔥 DETEKSI APAKAH INI LAPORAN RT ATAU SURAT BIASA 🔥
                const isLaporanRT = item.jenis_surat.startsWith('LAPORAN RT');

                // 1. Warna Baris Tabel (Ungu untuk RT, Putih untuk Surat Biasa)
                const rowClass = isLaporanRT 
                    ? "bg-purple-50/30 hover:bg-purple-50 transition-colors border-b border-purple-100" 
                    : "hover:bg-gray-50 transition-colors border-b border-gray-50";

                // 2. Tampilan Label Jenis Surat
                const labelJenisSurat = isLaporanRT 
                    ? `<span class="inline-block px-2 py-1 bg-purple-100 text-purple-800 text-[9px] font-black rounded uppercase tracking-wider mb-1 shadow-sm border border-purple-200">📢 Mutasi / Laporan RT</span><br><span class="font-bold text-purple-950 text-xs">${steril(item.jenis_surat.replace('LAPORAN RT: ', ''))}</span>`
                    : `<p class="font-bold text-gray-800 text-xs">${steril(item.jenis_surat)}</p>`;

                // 3. Rapihkan Format Keterangan (Enter jadi <br>)
                const keperluanFormatted = steril(item.keperluan).replace(/\n/g, '<br>');

                // 4. Atur Tombol Aksi Kanan (Contextual Buttons)
                let tombolAksi = '';
                if (isLaporanRT) {
                    tombolAksi = `
                        <button onclick="bukaModal('${item.id}')" class="text-purple-700 font-bold text-[10px] bg-purple-100 px-3 py-2 rounded-lg border border-purple-200 hover:bg-purple-600 hover:text-white shadow-sm transition-all block w-full mb-1.5">
                            PROSES LAPORAN
                        </button>
                        <a href="/admin/penduduk" target="_blank" class="text-emerald-700 font-bold text-[10px] bg-emerald-100 px-3 py-2 rounded-lg border border-emerald-200 hover:bg-emerald-600 hover:text-white shadow-sm transition-all block w-full text-center">
                            BUKA DUKCAPIL <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                    `;
                } else {
                    tombolAksi = `
                        <button onclick="bukaModal('${item.id}')" class="text-teal-600 font-bold text-[10px] bg-teal-50 px-3 py-2 rounded-lg border border-teal-200 hover:bg-teal-600 hover:text-white shadow-sm transition-all block w-full">
                            PROSES SURAT
                        </button>
                    `;
                }

                // Warna Status Desa
                let badgeClass = "bg-amber-100 text-amber-700 border-amber-200";
                if(item.status === 'Diproses') badgeClass = "bg-blue-100 text-blue-700 border-blue-200";
                if(item.status === 'Selesai') badgeClass = "bg-emerald-100 text-emerald-700 border-emerald-200";
                if(item.status === 'Ditolak') badgeClass = "bg-rose-100 text-rose-700 border-rose-200";

                // Warna Status RT
                let rtClass = "bg-gray-100 text-gray-500 border-gray-200";
                if(item.status_rt?.includes('Disetujui')) rtClass = "bg-emerald-50 text-emerald-600 border-emerald-200";
                if(item.status_rt?.includes('Ditolak')) rtClass = "bg-rose-50 text-rose-600 border-rose-200";
                if(item.status_rt === 'Bypass RT' || isLaporanRT) rtClass = "bg-blue-50 text-blue-600 border-blue-200";

                // Cek Lampiran Berkas (Laporan RT biasanya gak pakai berkas)
                let berkasHTML = '';
                if (isExpired && item.status === 'Menunggu' && !isLaporanRT) {
                    berkasHTML = `<span class="inline-block mt-2 bg-rose-50 border border-rose-200 text-rose-600 font-bold px-2 py-1 rounded text-[10px]">⚠️ Berkas Hangus (>24 Jam)</span>`;
                } else if (item.file_persyaratan) {
                    try {
                        const files = JSON.parse(item.file_persyaratan);
                        berkasHTML = `<div class="mt-2 space-y-1">`;
                        for (const [nama, url] of Object.entries(files)) {
                            berkasHTML += `<a href="${url}" target="_blank" class="block text-[10px] text-blue-600 hover:text-blue-800 hover:underline font-semibold flex items-center gap-1">📄 Cek ${nama}</a>`;
                        }
                        berkasHTML += `</div>`;
                    } catch(e) {
                        berkasHTML = `<a href="${item.file_persyaratan}" target="_blank" class="text-[10px] text-blue-600 underline">Lihat Berkas</a>`;
                    }
                }

                html += `
                <tr class="${rowClass}">
                    <td class="p-4 text-xs text-gray-500 font-medium align-top">${tglStr}</td>
                    <td class="p-4 align-top">
                        <p class="font-bold text-teal-950">${steril(item.nama_lengkap)}</p>
                        <p class="text-[10px] font-mono text-gray-500 bg-white/60 inline-block px-1.5 py-0.5 rounded border border-gray-100 mt-1">${steril(item.nik)}</p>
                        <p class="text-[10px] text-teal-600 font-bold mt-1">${steril(item.wilayah_rt)}</p>
                        ${berkasHTML}
                    </td>
                    <td class="p-4 align-top max-w-xs">
                        ${labelJenisSurat}
                        <div class="text-[11px] text-gray-700 mt-2 bg-white/60 p-2.5 rounded-lg border border-gray-200 shadow-sm">${keperluanFormatted}</div>
                        ${item.status === 'Ditolak' && item.alasan_penolakan ? `<div class="mt-2 bg-rose-50 p-2 rounded border border-rose-100"><p class="text-[9px] font-bold text-rose-700">Alasan Tolak:</p><p class="text-[10px] text-rose-600">${steril(item.alasan_penolakan)}</p></div>` : ''}
                        ${item.file_hasil ? `<a href="${item.file_hasil}" target="_blank" class="inline-block mt-2 text-[10px] bg-emerald-50 text-emerald-700 border border-emerald-200 px-2 py-1 rounded-md font-bold shadow-sm">📥 Download Surat Jadi</a>` : ''}
                    </td>
                    <td class="p-4 text-center align-top">
                        <span class="px-3 py-1.5 text-[9px] font-bold uppercase tracking-wider rounded-lg border shadow-sm block ${rtClass}">
                            ${isLaporanRT ? 'Otomatis Desa' : (item.status_rt || 'Menunggu')}
                        </span>
                    </td>
                    <td class="p-4 text-center align-top">
                        <span class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider rounded-full border shadow-sm block ${badgeClass}">
                            ${item.status}
                        </span>
                    </td>
                    <td class="p-4 text-center align-top">
                        ${tombolAksi}
                    </td>
                </tr>`;
            });
            
            tbody.innerHTML = html;
            paginasiContainer.innerHTML = createPaginationUI(page, filteredSurat.length);
        }

        // --- SEARCH EVENT ---
        document.getElementById('searchSurat').addEventListener('input', (e) => {
            const keyword = e.target.value.toLowerCase();
            filteredSurat = rawSurat.filter(s => 
                s.nama_lengkap.toLowerCase().includes(keyword) || 
                s.jenis_surat.toLowerCase().includes(keyword) || 
                s.nik.includes(keyword) ||
                s.status.toLowerCase().includes(keyword)
            );
            renderSurat(1);
        });

        // --- LOGIKA MODAL ---
        const modal = document.getElementById('modalStatus');
        const modalBox = document.getElementById('modalBox');
        const selectStatus = document.getElementById('inputStatus');
        const containerPdf = document.getElementById('containerUploadPdf');
        const containerAlasan = document.getElementById('containerAlasanTolak');
        const inputAlasan = document.getElementById('inputAlasanTolak');
        
        // State Global buat nandain ini Laporan RT atau bukan
        window.isModeLaporanRT = false;

        selectStatus.addEventListener('change', (e) => {
            if (e.target.value === 'Selesai') {
                // 🔥 Kunci UX: Sembunyikan form PDF jika ini Laporan RT 🔥
                if (!window.isModeLaporanRT) containerPdf.classList.remove('hidden');
                containerAlasan.classList.add('hidden');
                inputAlasan.removeAttribute('required');
            } else if (e.target.value === 'Ditolak') {
                containerPdf.classList.add('hidden');
                containerAlasan.classList.remove('hidden');
                inputAlasan.setAttribute('required', 'true');
            } else {
                containerPdf.classList.add('hidden');
                containerAlasan.classList.add('hidden');
                inputAlasan.removeAttribute('required');
            }
        });

        window.bukaModal = (id) => {
            const item = dataGlobal.find(d => d.id === id);
            if (!item) return;

            window.isModeLaporanRT = item.jenis_surat.startsWith('LAPORAN RT');

            document.getElementById('editSuratId').value = item.id;
            document.getElementById('labelNama').innerText = item.nama_lengkap + ' (' + item.nik + ')';
            document.getElementById('labelWilayah').innerText = item.wilayah_rt || 'Wilayah Belum Diset';
            
            // Tampilan Khusus di Judul Modal
            document.getElementById('labelJenis').innerHTML = window.isModeLaporanRT 
                ? `<span class="text-purple-600 font-bold bg-purple-50 px-2 py-1 rounded">📢 ${item.jenis_surat}</span>`
                : item.jenis_surat;

            document.getElementById('inputStatus').value = item.status;
            document.getElementById('inputFileHasil').value = '';
            inputAlasan.value = item.alasan_penolakan || '';
            
            // Reset semua tampilan tambahan
            containerPdf.classList.add('hidden');
            containerAlasan.classList.add('hidden');
            inputAlasan.removeAttribute('required');

            // Buka field sesuai status akhir sebelumnya
            if (item.status === 'Selesai' && !window.isModeLaporanRT) containerPdf.classList.remove('hidden');
            if (item.status === 'Ditolak') {
                containerAlasan.classList.remove('hidden');
                inputAlasan.setAttribute('required', 'true');
            }

            modal.classList.remove('hidden');
            setTimeout(() => { modal.classList.remove('opacity-0'); modalBox.classList.remove('scale-95'); modalBox.classList.add('scale-100'); }, 10);
        };

        const tutupModal = () => {
            modal.classList.add('opacity-0');
            modalBox.classList.remove('scale-100'); modalBox.classList.add('scale-95');
            setTimeout(() => { modal.classList.add('hidden'); }, 300);
        };

        document.getElementById('btnTutupModal').addEventListener('click', tutupModal);

        document.getElementById('formStatus').addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = document.getElementById('editSuratId').value;
            const statusBaru = document.getElementById('inputStatus').value;
            const itemSurat = dataGlobal.find(d => d.id === id);
            
            const btn = document.getElementById('btnSimpanStatus');
            const statUpload = document.getElementById('statusUpload');
            btn.disabled = true; btn.innerText = "Memproses...";

            try {
                let fileHasilUrl = itemSurat.file_hasil; 
                let alasanUpdate = itemSurat.alasan_penolakan;

                // Cek upload PDF (Abaikan kalau Mode Laporan RT)
                if (statusBaru === 'Selesai' && !window.isModeLaporanRT) {
                    const filePdf = document.getElementById('inputFileHasil').files[0];
                    if (filePdf) {
                        statUpload.classList.remove('hidden');
                        const fileExt = filePdf.name.split('.').pop();
                        const namaWarga = itemSurat.nama_lengkap.replace(/[^a-zA-Z0-9]/g, '_');
                        const jenisSurat = itemSurat.jenis_surat.replace(/[^a-zA-Z0-9]/g, '_');
                        const waktuKirim = new Date(itemSurat.created_at).getTime();
                        
                        const fullPath = `hasil_surat/${jenisSurat}/${namaWarga}_${waktuKirim}/Surat_Selesai_${Date.now()}.${fileExt}`;
                        
                        const { error: uploadError } = await supabase.storage.from('berkas_layanan').upload(fullPath, filePdf);
                        if (uploadError) throw new Error("Gagal mengunggah PDF: " + uploadError.message);

                        const { data: publicUrlData } = supabase.storage.from('berkas_layanan').getPublicUrl(fullPath);
                        fileHasilUrl = publicUrlData.publicUrl;
                        statUpload.classList.add('hidden');
                    }
                    alasanUpdate = null;
                } else if (statusBaru === 'Selesai' && window.isModeLaporanRT) {
                    // Kalau RT Selesai, ga ada PDF
                    alasanUpdate = null;
                } else if (statusBaru === 'Ditolak') {
                    alasanUpdate = inputAlasan.value;
                } else {
                    alasanUpdate = null;
                }

                // Kirim perubahan ke database
                const payloadUpdate = { status: statusBaru, alasan_penolakan: alasanUpdate };
                if (fileHasilUrl) payloadUpdate.file_hasil = fileHasilUrl;

                const { error: errorSurat } = await supabase.from('pengajuan_surat').update(payloadUpdate).eq('id', id);
                if (errorSurat) throw errorSurat;

                // Automasi Bansos (SKTM)
                if (statusBaru === 'Selesai' && itemSurat.jenis_surat === 'Surat Keterangan Tidak Mampu (SKTM)') {
                    const payloadBansos = { nik: itemSurat.nik, nama_warga: itemSurat.nama_lengkap, sumber_usulan: 'Otomatis dari Pengajuan SKTM' };
                    const { error: errorBansos } = await supabase.from('usulan_bansos').insert([payloadBansos]);
                    if (errorBansos) console.error("Gagal automasi bansos:", errorBansos.message);
                }

                tutupModal();
                if(typeof showCustomAlert !== 'undefined') {
                    let pesanSukses = window.isModeLaporanRT ? 'Laporan RT berhasil ditandai selesai!' : 'Status pengajuan surat berhasil diperbarui!';
                    if (fileHasilUrl) pesanSukses += ' File PDF balasan berhasil dilampirkan.';
                    await showCustomAlert('success', 'Berhasil', pesanSukses);
                } else alert('Berhasil diperbarui!');
                
                loadSurat();
            } catch (error) {
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Gagal', error.message);
                else alert(error.message);
                statUpload.classList.add('hidden');
            } finally {
                btn.disabled = false;
                btn.innerText = "Simpan Perubahan";
            }
        });

        initPage();
    </script>
</body>
</html>