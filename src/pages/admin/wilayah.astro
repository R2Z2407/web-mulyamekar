---
// src/pages/admin/wilayah.astro
import BaseLayout from '../../layout/BaseLayout.astro';
---

<BaseLayout title="Pemetaan Wilayah RT/RW - Admin Desa">
    <main class="flex-grow pt-24 pb-20">
        <div class="container mx-auto px-4 max-w-6xl">
            
            <a href="/admin" class="text-teal-600 font-bold text-sm hover:text-amber-600 transition-colors">&larr; Kembali ke Dashboard</a>

            <div class="bg-gradient-to-r from-teal-700 to-teal-900 rounded-3xl p-8 text-white shadow-xl relative overflow-hidden mb-6">
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-white/10 rounded-full blur-2xl"></div>
                <div class="relative z-10 flex items-center gap-4">
                    <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-3xl shadow-inner border border-white/30 backdrop-blur-sm shrink-0">
                        🗺️
                    </div>
                    <div>
                        <h2 class="text-2xl font-black tracking-tight">Pemetaan RT & RW</h2>
                        <p class="text-teal-100 text-sm mt-1">Kelola data wilayah agar dropdown pendaftaran warga otomatis terisi dengan akurat.</p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-3xl p-2 shadow-sm border border-slate-100 mb-8 h-64 md:h-80 relative overflow-hidden group">
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-4 py-2 rounded-xl shadow-md z-10 flex items-center gap-2 border border-slate-100 pointer-events-none">
                    <span class="text-rose-500 text-lg animate-bounce">📍</span> 
                    <span class="text-xs font-black text-slate-700 tracking-wide">PETA DESA MULYAMEKAR</span>
                </div>
                <div class="w-full h-full rounded-2xl overflow-hidden bg-slate-100">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d18856.684577026543!2d107.4445346240424!3d-6.505272065780127!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e690dc736e9218b%3A0xde1b5c1acf477787!2sMulyamekar%2C%20Kec.%20Babakancikao%2C%20Kabupaten%20Purwakarta%2C%20Jawa%20Barat!5e0!3m2!1sid!2sid!4v1773041713147!5m2!1sid!2sid" 
                        width="100%" 
                        height="100%" 
                        style="border: 0;" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade"
                        class="grayscale-[20%] group-hover:grayscale-0 transition-all duration-700"
                    ></iframe>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 sticky top-24">
                        <h3 class="text-lg font-black text-slate-800 mb-4 border-b border-slate-100 pb-3">➕ Tambah Wilayah Baru</h3>
                        
                        <form id="formTambahWilayah" class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Nomor RW</label>
                                <div class="relative">
                                    <span class="absolute left-4 top-3 text-slate-400 font-bold text-sm">RW</span>
                                    <input type="text" id="inputNoRW" placeholder="Contoh: 01" required maxlength="3" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full pl-12 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none text-sm font-bold text-slate-900 transition-all">
                                </div>
                            </div>
                            
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Nomor RT</label>
                                <div class="relative">
                                    <span class="absolute left-4 top-3 text-slate-400 font-bold text-sm">RT</span>
                                    <input type="text" id="inputNoRT" placeholder="Contoh: 01" required maxlength="3" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full pl-12 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none text-sm font-bold text-slate-900 transition-all">
                                </div>
                            </div>

                            <button type="submit" id="btnSimpanWilayah" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-xl shadow-md transition-all active:scale-95 flex items-center justify-center gap-2 mt-2">
                                <i class="bi bi-plus-circle-fill"></i> Simpan Wilayah
                            </button>
                        </form>
                    </div>
                </div>

                <div class="lg:col-span-2">
                    <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100">
                        
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 border-b border-slate-100 pb-4 gap-4">
                            <div class="flex items-center gap-3">
                                <h3 class="text-lg font-black text-slate-800">📋 Daftar Wilayah Terdaftar</h3>
                                <span id="totalWilayah" class="bg-teal-50 text-teal-700 font-bold text-xs px-3 py-1 rounded-full border border-teal-100">0 Data</span>
                            </div>
                            
                            <div class="flex items-center gap-2 w-full sm:w-auto bg-slate-50 p-1.5 rounded-xl border border-slate-200">
                                <label for="filterRW" class="text-[10px] font-black text-slate-500 uppercase tracking-wider pl-2">Filter:</label>
                                <select id="filterRW" class="bg-white border-none text-slate-700 text-xs rounded-lg focus:ring-0 block py-1.5 px-3 font-bold outline-none cursor-pointer w-full sm:w-auto shadow-sm">
                                    <option value="ALL">Semua RW</option>
                                    </select>
                            </div>
                        </div>

                        <div class="overflow-x-auto rounded-xl border border-slate-100">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-slate-50 text-slate-500 text-[10px] uppercase tracking-wider">
                                        <th class="p-4 font-black border-b border-slate-200 w-16 text-center">No</th>
                                        <th class="p-4 font-black border-b border-slate-200">Rukun Warga (RW)</th>
                                        <th class="p-4 font-black border-b border-slate-200">Rukun Tetangga (RT)</th>
                                        <th class="p-4 font-black border-b border-slate-200 text-center w-24">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="tabelWilayahBody">
                                    <tr>
                                        <td colspan="4" class="p-8 text-center text-slate-400 font-medium text-sm animate-pulse">
                                            Memuat data wilayah...
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script>
        import { supabase } from '../../lib/supabase.js';

        let allWilayahData = []; // Variabel global buat nampung semua data

        // 1. Cek Autentikasi
        async function cekAksesAdmin() {
            try {
                const { data: { session } } = await supabase.auth.getSession();
                if (!session) { window.location.href = '/'; return; }

                const { data: profil, error } = await supabase
                    .from('profil_user')
                    .select('role')
                    .eq('id', session.user.id)
                    .single();

                if (error || !profil || profil.role !== 'admin') {
                    if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Akses Ditolak', 'Halaman ini khusus Admin.');
                    else alert('Akses Ditolak!');
                    window.location.href = '/';
                    return;
                }

                loadMasterWilayah();
            } catch (err) {
                console.error(err);
                window.location.href = '/';
            }
        }

        // 2. Load Data dari Database
        async function loadMasterWilayah() {
            const tbody = document.getElementById('tabelWilayahBody');
            if (!tbody) return;

            try {
                const { data, error } = await supabase
                    .from('master_wilayah')
                    .select('*')
                    .order('nomor_rw', { ascending: true })
                    .order('nomor_rt', { ascending: true });

                if (error) throw error;

                allWilayahData = data || [];
                
                // Update opsi Dropdown Filter RW
                updateFilterOptions(allWilayahData);
                
                // Render tabel dengan filter yang lagi aktif (Default: ALL)
                const filterAktif = document.getElementById('filterRW').value;
                renderTabel(filterAktif);

            } catch (err) {
                console.error("Gagal muat wilayah:", err);
                tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-rose-500 text-sm font-bold">Gagal memuat data dari server.</td></tr>`;
            }
        }

        // 3. Update Pilihan Dropdown RW Secara Otomatis
        function updateFilterOptions(data) {
            const filterEl = document.getElementById('filterRW');
            const currentFilter = filterEl.value; // Simpan pilihan admin saat ini

            // Ambil list RW yang unik (nggak dobel)
            const rwList = [...new Set(data.map(item => item.nomor_rw))].sort();

            let optionsHtml = '<option value="ALL">Semua RW</option>';
            rwList.forEach(rw => {
                optionsHtml += `<option value="${rw}">Hanya RW ${rw}</option>`;
            });

            filterEl.innerHTML = optionsHtml;

            // Kalau pilihan admin sebelumnya masih ada di list, pertahankan
            if(currentFilter === 'ALL' || rwList.includes(currentFilter)) {
                filterEl.value = currentFilter;
            }
        }

        // 4. Render Tabel ke HTML (Bisa di-Filter)
        function renderTabel(filterRW) {
            const tbody = document.getElementById('tabelWilayahBody');
            const totalLabel = document.getElementById('totalWilayah');

            // Proses Penyaringan (Filter)
            let dataTampil = allWilayahData;
            if (filterRW !== 'ALL') {
                dataTampil = allWilayahData.filter(item => item.nomor_rw === filterRW);
            }

            totalLabel.innerText = `${dataTampil.length} Data`;

            if (dataTampil.length === 0) {
                let pesanKosong = filterRW === 'ALL' 
                    ? 'Belum ada data wilayah. Silakan tambah di form sebelah kiri.' 
                    : `Belum ada RT yang terdaftar di RW ${filterRW}.`;
                    
                tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-slate-500 text-sm font-medium border border-dashed border-slate-200 bg-slate-50">${pesanKosong}</td></tr>`;
                return;
            }

            let html = '';
            dataTampil.forEach((item, index) => {
                html += `
                    <tr class="hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-0">
                        <td class="p-4 text-center font-bold text-slate-400 text-sm">${index + 1}</td>
                        <td class="p-4">
                            <span class="bg-amber-100 text-amber-800 font-bold px-3 py-1.5 rounded-lg text-xs border border-amber-200 shadow-sm">RW ${item.nomor_rw}</span>
                        </td>
                        <td class="p-4">
                            <span class="bg-blue-100 text-blue-800 font-bold px-3 py-1.5 rounded-lg text-xs border border-blue-200 shadow-sm">RT ${item.nomor_rt}</span>
                        </td>
                        <td class="p-4 text-center">
                            <button onclick="hapusWilayah('${item.id}', '${item.nomor_rw}', '${item.nomor_rt}')" class="text-rose-500 bg-rose-50 border border-rose-100 hover:text-white hover:bg-rose-500 px-3 py-1.5 rounded-lg transition-colors shadow-sm" title="Hapus Wilayah">
                                <i class="bi bi-trash3-fill"></i> Hapus
                            </button>
                        </td>
                    </tr>
                `;
            });
            
            tbody.innerHTML = html;
        }

        // 5. Event Listener buat Dropdown Filter
        document.getElementById('filterRW')?.addEventListener('change', (e) => {
            renderTabel(e.target.value);
        });

        // 6. Fungsi Tambah Wilayah
        document.getElementById('formTambahWilayah')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnSimpanWilayah');
            const inputRW = document.getElementById('inputNoRW').value.trim();
            const inputRT = document.getElementById('inputNoRT').value.trim();

            const formatRW = inputRW.padStart(2, '0');
            const formatRT = inputRT.padStart(2, '0');

            btn.disabled = true;
            btn.innerHTML = `<i class="bi bi-hourglass-split animate-spin"></i> Menyimpan...`;

            try {
                const { data: cekData } = await supabase
                    .from('master_wilayah')
                    .select('id')
                    .eq('nomor_rw', formatRW)
                    .eq('nomor_rt', formatRT)
                    .maybeSingle();

                if (cekData) {
                    if(typeof showCustomAlert !== 'undefined') showCustomAlert('warning', 'Duplikat', `RT ${formatRT} / RW ${formatRW} sudah ada di database!`);
                    else alert("Data wilayah ini sudah terdaftar!");
                    return;
                }

                const { error } = await supabase
                    .from('master_wilayah')
                    .insert([{ nomor_rw: formatRW, nomor_rt: formatRT }]);

                if (error) throw error;

                document.getElementById('formTambahWilayah').reset();
                loadMasterWilayah(); // Akan update data dan ngerender ulang tabel otomatis
                
                if(typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Berhasil', `RT ${formatRT} / RW ${formatRW} ditambahkan!`);

            } catch (err) {
                console.error("Error tambah wilayah:", err);
                if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', 'Tidak dapat menyimpan data wilayah.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = `<i class="bi bi-plus-circle-fill"></i> Simpan Wilayah`;
                document.getElementById('inputNoRT').focus(); 
            }
        });

        // 7. Fungsi Hapus Wilayah
        window.hapusWilayah = async (id, rw, rt) => {
            const konfirmasi = confirm(`Hapus RT ${rt} / RW ${rw} dari sistem?\n\nPastikan tidak ada warga yang memakai data wilayah ini!`);
            
            if (konfirmasi) {
                try {
                    const { error } = await supabase.from('master_wilayah').delete().eq('id', id);
                    if (error) throw error;
                    
                    loadMasterWilayah(); // Refresh data otomatis
                    if(typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Terhapus', `RT ${rt}/RW ${rw} dihapus.`);
                    
                } catch (err) {
                    console.error("Error hapus wilayah:", err);
                    if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', 'Tidak dapat menghapus wilayah.');
                }
            }
        };

        // Mulai Gas!
        cekAksesAdmin();
    </script>
</BaseLayout>