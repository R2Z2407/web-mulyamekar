---
// src/pages/admin/penduduk.astro
import AdminLayout from '../../layout/AdminLayout.astro';
---

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

<AdminLayout 
    title="Data Penduduk (Dukcapil) - Admin Mulyamekar"
    pageTitle="Buku Induk Kependudukan"
    pageDesc="Sistem manajemen data warga"
    maxWidth="max-w-[1400px]"
>
    <div slot="action" class="flex gap-2">
        <input type="file" id="fileImport" accept=".csv" class="hidden" onchange="prosesImportCSV(event)">
        <button onclick="document.getElementById('fileImport').click()" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3.5 rounded-xl font-bold transition-all shadow-emerald-600/30 shadow-lg active:scale-95 flex items-center gap-2 text-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            Import CSV
        </button>
        <button onclick="bukaModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3.5 rounded-xl font-bold transition-all shadow-blue-600/30 shadow-lg active:scale-95 flex items-center gap-2 text-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Tambah Data Warga
        </button>
    </div>

            <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
                <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-16 h-16 bg-blue-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Total Warga</p>
                    <p class="text-3xl font-black text-blue-900 mt-1" id="statTotal">0</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-16 h-16 bg-emerald-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Warga Tetap</p>
                    <p class="text-3xl font-black text-emerald-600 mt-1" id="statTetap">0</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-16 h-16 bg-amber-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Pendatang Baru</p>
                    <p class="text-3xl font-black text-amber-500 mt-1" id="statDatang">0</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-16 h-16 bg-slate-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Pindah / Keluar</p>
                    <p class="text-3xl font-black text-slate-600 mt-1" id="statPindah">0</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-16 h-16 bg-rose-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Meninggal</p>
                    <p class="text-3xl font-black text-rose-600 mt-1" id="statMeninggal">0</p>
                </div>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden flex flex-col mb-8">
                
                <div class="bg-slate-50 p-5 sm:p-6 border-b border-slate-200 flex flex-col sm:flex-row gap-4 sm:gap-5 items-start sm:items-center justify-between transition-all">
                    
                    <div class="flex flex-row gap-3 items-center w-full sm:max-w-md justify-between">
                        <div class="relative w-full">
                            <input type="text" id="searchWarga" placeholder="Cari NIK atau Nama Lengkap..." class="w-full pl-12 pr-5 py-3.5 bg-white border border-slate-300 rounded-xl text-sm font-medium focus:ring-2 focus:ring-blue-500 outline-none shadow-sm transition-all">
                            <svg class="absolute left-4 top-3.5 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </div>
                        
                        <button type="button" id="btnToggleFilter" class="sm:hidden flex items-center justify-center bg-white border border-slate-300 text-slate-600 w-12 h-12 rounded-xl shadow-sm hover:bg-slate-100 hover:text-blue-600 transition-colors shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                        </button>
                    </div>

                    <div id="filterDropdownContainer" class="hidden sm:flex flex-col sm:flex-row w-full sm:w-auto gap-3 animate-fadeIn sm:animate-none">
                        <select id="filterStatus" class="px-5 py-3.5 bg-white border border-slate-300 rounded-xl text-sm font-bold text-slate-700 outline-none cursor-pointer shadow-sm hover:border-blue-400 transition-colors">
                            <option value="Semua">Semua Status</option>
                            <option value="Tetap">Warga Tetap</option>
                            <option value="Pendatang">Pendatang</option>
                            <option value="Pindah">Pindah</option>
                            <option value="Meninggal">Meninggal</option>
                        </select>
                        
                        <select id="filterRW" class="px-5 py-3.5 bg-white border border-slate-300 rounded-xl text-sm font-bold text-slate-700 outline-none cursor-pointer shadow-sm hover:border-blue-400 transition-colors">
                            <option value="Semua">Semua RW</option>
                        </select>
                        
                        <select id="filterRT" class="px-5 py-3.5 bg-white border border-slate-300 rounded-xl text-sm font-bold text-slate-700 outline-none cursor-pointer shadow-sm hover:border-blue-400 transition-colors">
                            <option value="Semua">Semua RT</option>
                        </select>
                    </div>
                </div>

                <div class="overflow-x-auto max-h-[600px] custom-scrollbar bg-white">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead class="bg-slate-100 text-slate-800 sticky top-0 z-10 border-b border-slate-200 shadow-sm">
                            <tr>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200">NO. KK / NIK 🔒</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200">NAMA LENGKAP & WA</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200 text-center">L/P</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200">TTL & UMUR 🔒</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200">AGAMA</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200">PENDIDIKAN & PEKERJAAN</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200">ALAMAT & WILAYAH 🔒</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200">STATUS</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest border-r border-slate-200 text-center">STATUS PUNDUDUK</th>
                                <th class="px-5 py-4 font-black text-xs uppercase tracking-widest text-center">OPSI</th>
                            </tr>
                        </thead>
                        <tbody id="tablePenduduk" class="divide-y divide-slate-100 text-sm">
                            <tr><td colspan="8" class="p-12 text-center text-slate-400 font-bold animate-pulse">Memuat & Mendekripsi Data...</td></tr>
                        </tbody>
                    </table>
                </div>
                
                <div id="paginationPenduduk" class="px-6 py-5 bg-slate-50 border-t border-slate-200 flex flex-col sm:flex-row justify-between items-center text-sm gap-4"></div>
            </div>
        </div>
    <div slot="modal">

    <div id="modalPenduduk" class="fixed inset-0 z-[80] bg-slate-900/60 hidden flex items-center justify-center p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <div id="modalBox" class="bg-[#F8FAFC] rounded-3xl w-full max-w-5xl shadow-2xl transform scale-95 transition-transform duration-300 max-h-[95vh] flex flex-col overflow-hidden">
            
            <div class="p-6 border-b border-slate-200 flex justify-between items-center bg-white shrink-0">
                <div>
                    <h3 id="modalTitle" class="text-2xl font-extrabold text-slate-800 tracking-tight">Form Biodata Penduduk</h3>
                    <p class="text-xs text-slate-500 mt-1 font-medium flex items-center gap-1.5">
                        <span class="text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded font-bold">AES Encrypted</span> Data privasi akan disandikan secara otomatis.
                    </p>
                </div>
                <button onclick="tutupModal()" class="text-slate-400 hover:text-rose-500 hover:bg-rose-50 p-2.5 rounded-xl font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <div class="p-6 overflow-y-auto custom-scrollbar">
                
                <div class="mb-6 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100 p-4 rounded-2xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                    <div>
                        <h4 class="text-sm font-bold text-blue-900">Pendataan Bayi Baru Lahir?</h4>
                        <p class="text-xs text-blue-700 mt-0.5">Isi form lebih cepat untuk bayi yang baru saja lahir.</p>
                    </div>
                    <button type="button" onclick="setModeBayi()" class="bg-white text-blue-600 border border-blue-200 hover:bg-blue-600 hover:text-white px-4 py-2 rounded-xl text-xs font-bold transition-colors shadow-sm flex items-center gap-2 shrink-0">
                        👶 Terapkan Template Bayi
                    </button>
                </div>

                <form id="formPenduduk" class="space-y-6">
                    <input type="hidden" id="editId">
                    
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        
                        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 space-y-4">
                            <div class="flex items-center gap-2 border-b border-slate-100 pb-3 mb-2">
                                <span class="p-1.5 bg-blue-50 text-blue-600 rounded-lg"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg></span>
                                <h4 class="font-extrabold text-slate-800 text-sm">Identitas Pribadi</h4>
                            </div>
                            
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Nama Sesuai KTP *</label>
                                <input type="text" id="nama_lengkap" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 font-bold text-sm outline-none uppercase transition-all" placeholder="NAMA LENGKAP">
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider flex justify-between">
                                    <span>Nomor KK *</span> <span class="text-emerald-500">🔒</span>
                                </label>
                                <input type="text" id="no_kk" required maxlength="16" pattern="\\d{16}" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 font-mono text-sm outline-none transition-all" placeholder="16 Digit Angka">
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider flex justify-between">
                                    <span>NIK *</span> <span class="text-emerald-500">🔒</span>
                                </label>
                                <input type="text" id="nik" required maxlength="16" pattern="\\d{16}" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 font-mono text-sm outline-none transition-all" placeholder="16 Digit Angka">
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Jenis Kelamin *</label>
                                <select id="jenis_kelamin" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm font-bold outline-none cursor-pointer transition-all">
                                    <option value="Laki-laki">Laki-laki</option>
                                    <option value="Perempuan">Perempuan</option>
                                </select>
                            </div>
                        </div>

                        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 space-y-4">
                            <div class="flex items-center gap-2 border-b border-slate-100 pb-3 mb-2">
                                <span class="p-1.5 bg-amber-50 text-amber-600 rounded-lg"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg></span>
                                <h4 class="font-extrabold text-slate-800 text-sm">Domisili & Kelahiran</h4>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Tmpt Lahir *</label>
                                    <input type="text" id="tempat_lahir" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm outline-none uppercase transition-all">
                                </div>
                                <div>
                                    <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider flex justify-between">
                                        <span>Tgl Lahir *</span> <span class="text-emerald-500">🔒</span>
                                    </label>
                                    <input type="date" id="tanggal_lahir" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm outline-none cursor-pointer transition-all">
                                </div>
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider flex justify-between">
                                    <span>No. WhatsApp / Telp</span> <span class="text-emerald-500">🔒</span>
                                </label>
                                <input type="text" id="no_telp" oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 font-mono text-sm outline-none transition-all" placeholder="08...">
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider flex justify-between">
                                    <span>Alamat Lengkap *</span> <span class="text-emerald-500">🔒</span>
                                </label>
                                <textarea id="alamat" required rows="2" class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm outline-none transition-all" placeholder="Jalan, Blok, patokan..."></textarea>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Pilih RW *</label>
                                    <select id="pilihRW" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm font-bold text-slate-800 outline-none cursor-pointer transition-all">
                                        <option value="">-- Pilih RW --</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Pilih RT *</label>
                                    <select id="pilihRT" required disabled class="w-full px-3.5 py-2.5 bg-slate-100 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm font-bold text-slate-800 outline-none cursor-not-allowed transition-all">
                                        <option value="">-- Pilih RT --</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 space-y-4">
                            <div class="flex items-center gap-2 border-b border-slate-100 pb-3 mb-2">
                                <span class="p-1.5 bg-emerald-50 text-emerald-600 rounded-lg"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg></span>
                                <h4 class="font-extrabold text-slate-800 text-sm">Profil & Status</h4>
                            </div>
                            
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Pendidikan Terakhir *</label>
                                <select id="pendidikan" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm outline-none cursor-pointer transition-all">
                                    <option value="Belum/Tidak Sekolah">Belum/Tidak Sekolah</option>
                                    <option value="SD Sederajat">SD Sederajat</option>
                                    <option value="SMP Sederajat">SMP Sederajat</option>
                                    <option value="SMA Sederajat">SMA Sederajat</option>
                                    <option value="D1/D2/D3">Diploma (D1/D2/D3)</option>
                                    <option value="S1/D4">S1 / D4</option>
                                    <option value="S2">S2 (Magister)</option>
                                    <option value="S3">S3 (Doktoral)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Pekerjaan *</label>
                                <select id="pekerjaan" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-sm font-bold text-blue-900 outline-none cursor-pointer transition-all">
                                    <option value="Belum/Tidak Bekerja">Belum / Tidak Bekerja</option>
                                    <option value="Mengurus Rumah Tangga">Mengurus Rumah Tangga</option>
                                    <option value="Pelajar/Mahasiswa">Pelajar / Mahasiswa</option>
                                    <option value="Pegawai Negeri Sipil (PNS)">Pegawai Negeri Sipil (PNS)</option>
                                    <option value="TNI/POLRI">TNI / POLRI</option>
                                    <option value="Karyawan Swasta">Karyawan Swasta</option>
                                    <option value="Karyawan BUMN">Karyawan BUMN</option>
                                    <option value="Wiraswasta/Pengusaha">Wiraswasta / Pengusaha</option>
                                    <option value="Pekerja Lepas/Paruh Waktu">Pekerja Lepas / Paruh Waktu</option>
                                    <option value="Petani/Peternak">Petani / Peternak</option>
                                    <option value="Nelayan">Nelayan</option>
                                    <option value="Pensiunan">Pensiunan</option>
                                    <option value="Lainnya">Lainnya</option>
                                </select>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-3 mt-3">
                                <div>
                                    <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Agama *</label>
                                    <select id="agama" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-xs outline-none cursor-pointer transition-all">
                                        <option value="Islam">Islam</option>
                                        <option value="Kristen">Kristen</option>
                                        <option value="Katolik">Katolik</option>
                                        <option value="Hindu">Hindu</option>
                                        <option value="Buddha">Buddha</option>
                                        <option value="Konghucu">Konghucu</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[11px] font-bold text-slate-600 mb-1 uppercase tracking-wider">Status Kawin *</label>
                                    <select id="status_perkawinan" required class="w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 text-xs outline-none cursor-pointer transition-all">
                                        <option value="Belum Kawin">Belum Kawin</option>
                                        <option value="Kawin">Kawin</option>
                                        <option value="Cerai Hidup">Cerai Hidup</option>
                                        <option value="Cerai Mati">Cerai Mati</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mt-4 pt-4 border-t border-slate-100">
                                <label class="block text-[11px] font-bold text-amber-600 mb-2 uppercase tracking-wider">Status Kependudukan *</label>
                                <select id="status_warga" required class="w-full px-3.5 py-3 bg-amber-50 border border-amber-200 rounded-xl focus:ring-2 focus:ring-amber-500 text-sm font-black text-amber-900 outline-none cursor-pointer shadow-sm transition-all">
                                    <option value="Tetap">Warga Tetap</option>
                                    <option value="Pendatang">Pendatang Baru</option>
                                    <option value="Pindah">Pindah Keluar</option>
                                    <option value="Meninggal">Meninggal Dunia</option>
                                </select>
                            </div>
                        </div>

                    </div>
                </form>
            </div>

            <div class="p-6 border-t border-slate-200 bg-white flex flex-col-reverse sm:flex-row justify-end gap-3 shrink-0">
                <button type="button" onclick="tutupModal()" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold rounded-xl text-sm transition-all">Batal</button>
                <button type="submit" form="formPenduduk" id="btnSimpan" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-xl text-sm transition-all shadow-md shadow-blue-600/20 flex items-center justify-center gap-2">
                    🔒 Simpan Data
                </button>
            </div>
    </AdminLayout>

    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 8px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 8px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        #tablePenduduk tr:nth-child(even) { background-color: #f8fafc; }
        #tablePenduduk tr:hover { background-color: #f1f5f9; }
        #tablePenduduk td { padding: 18px 20px; border-right: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    </style>

    <script>
        import { supabase } from '../../lib/supabase.js';
        const SECRET_KEY = "DukcapilMulyamekarAman2026!"; 
        
        const itemsPerPage = 10; 
        let rawData = [];
        let filteredData = [];
        let masterWilayahData = [];

        function encrypt(teks) {
            if (!teks) return "";
            return CryptoJS.AES.encrypt(teks.toString(), SECRET_KEY).toString();
        }

        function decrypt(ciphertext) {
            if (!ciphertext) return "";
            try {
                const bytes = CryptoJS.AES.decrypt(ciphertext, SECRET_KEY);
                const originalText = bytes.toString(CryptoJS.enc.Utf8);
                return originalText || ciphertext; 
            } catch (e) {
                return ciphertext;
            }
        }

        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
        }

        function hitungUmur(tglLahir) {
            if (!tglLahir || tglLahir === "-") return "-";
            const birthDate = new Date(tglLahir);
            if(isNaN(birthDate)) return "-"; 

            const today = new Date();
            let years = today.getFullYear() - birthDate.getFullYear();
            let months = today.getMonth() - birthDate.getMonth();
            let days = today.getDate() - birthDate.getDate();

            if (days < 0) { months--; const lastMonth = new Date(today.getFullYear(), today.getMonth(), 0); days += lastMonth.getDate(); }
            if (months < 0) { years--; months += 12; }

            if (years === 0 && months === 0) return `${days} Hr (Baru Lahir)`;
            if (years === 0) return `${months} Bln, ${days} Hr`;
            return `${years} Thn, ${months} Bln`;
        }

        async function initPage() {
            const { data: { session } } = await supabase.auth.getSession();
            if (!session) { window.location.href = '/login'; return; }
            
            const { data: profil } = await supabase.from('profil_user').select('role').eq('id', session.user.id).single();
            if (!profil || profil.role !== 'admin') { window.location.href = '/'; return; }

            await loadMasterWilayah();
            loadData();
        }

        async function loadMasterWilayah() {
            const { data, error } = await supabase.from('master_wilayah').select('*').order('nomor_rw').order('nomor_rt');
            if (error) { console.error("Gagal load wilayah", error); return; }
            masterWilayahData = data || [];

            const rwUnik = [...new Set(masterWilayahData.map(w => w.nomor_rw))].sort();
            
            let opsiRWFilter = '<option value="Semua">Semua RW</option>';
            let opsiRWForm = '<option value="">-- Pilih RW --</option>';
            
            rwUnik.forEach(rw => {
                opsiRWFilter += `<option value="${rw}">RW ${rw}</option>`;
                opsiRWForm += `<option value="${rw}">RW ${rw}</option>`;
            });

            document.getElementById('filterRW').innerHTML = opsiRWFilter;
            document.getElementById('pilihRW').innerHTML = opsiRWForm;
        }

        function updateDropdownRT(idSelectRW, idSelectRT, allowSemua = false) {
            const rwTerpilih = document.getElementById(idSelectRW).value;
            const selectRT = document.getElementById(idSelectRT);

            if (!rwTerpilih || rwTerpilih === 'Semua') {
                selectRT.innerHTML = allowSemua ? '<option value="Semua">Semua RT</option>' : '<option value="">-- Pilih RT --</option>';
                selectRT.disabled = true;
                selectRT.classList.replace('bg-white', 'bg-slate-100');
                selectRT.classList.replace('cursor-pointer', 'cursor-not-allowed');
                return;
            }

            const rtTersedia = masterWilayahData.filter(w => w.nomor_rw === rwTerpilih).map(w => w.nomor_rt).sort();
            
            let opsiRT = allowSemua ? '<option value="Semua">Semua RT</option>' : '<option value="">-- Pilih RT --</option>';
            rtTersedia.forEach(rt => {
                opsiRT += `<option value="${rt}">RT ${rt}</option>`;
            });

            selectRT.innerHTML = opsiRT;
            selectRT.disabled = false;
            selectRT.classList.replace('bg-slate-100', 'bg-white');
            selectRT.classList.replace('cursor-not-allowed', 'cursor-pointer');
        }

        document.getElementById('filterRW').addEventListener('change', () => { 
            updateDropdownRT('filterRW', 'filterRT', true); 
            terapkanFilter(); 
        });
        document.getElementById('pilihRW').addEventListener('change', () => updateDropdownRT('pilihRW', 'pilihRT', false));

        async function loadData() {
            const { data, error } = await supabase.from('data_penduduk').select('*');
            if (error) {
                document.getElementById('tablePenduduk').innerHTML = `<tr><td colspan="8" class="p-8 text-center text-rose-500 font-bold">Gagal memuat database: ${error.message}</td></tr>`;
                return;
            }
            
            rawData = (data || []).map(d => ({
                ...d,
                no_kk: decrypt(d.no_kk),
                nik: decrypt(d.nik),
                tanggal_lahir: decrypt(d.tanggal_lahir),
                alamat: decrypt(d.alamat),
                no_telp: decrypt(d.no_telp)
            }));
            updateStats(rawData);
            terapkanFilter();
        }

        function updateStats(data) {
            document.getElementById('statTotal').innerText = data.length;
            document.getElementById('statTetap').innerText = data.filter(d => d.status_warga === 'Tetap').length;
            document.getElementById('statDatang').innerText = data.filter(d => d.status_warga === 'Pendatang').length;
            document.getElementById('statPindah').innerText = data.filter(d => d.status_warga === 'Pindah').length;
            document.getElementById('statMeninggal').innerText = data.filter(d => d.status_warga === 'Meninggal').length;
        }

        function terapkanFilter() {
            const keyword = document.getElementById('searchWarga').value.toLowerCase();
            const filterStat = document.getElementById('filterStatus').value;
            const filterRw = document.getElementById('filterRW').value;
            const filterRt = document.getElementById('filterRT').value;

            filteredData = rawData.filter(d => {
            const matchKeyword = (d.nama_lengkap||'').toLowerCase().includes(keyword) || (d.nik||'').includes(keyword);
            const matchStatus = filterStat === 'Semua' ? true : d.status_warga === filterStat;
            
            // 🔥 LOGIKA BARU: Filter ngebut murni dari kolom rt dan rw
            const matchRW = filterRw === 'Semua' ? true : d.rw === filterRw;
            const matchRT = filterRt === 'Semua' ? true : d.rt === filterRt;
            
            return matchKeyword && matchStatus && matchRW && matchRT;
            });
            renderData(1);
        }

        document.getElementById('searchWarga').addEventListener('input', terapkanFilter);
        document.getElementById('filterStatus').addEventListener('change', terapkanFilter);
        document.getElementById('filterRT').addEventListener('change', terapkanFilter);

        // LOGIKA TOMBOL BUKA/TUTUP FILTER DI MOBILE
        document.getElementById('btnToggleFilter')?.addEventListener('click', () => {
            const wadah = document.getElementById('filterDropdownContainer');
            wadah.classList.toggle('hidden');
            wadah.classList.toggle('flex');
        });

        window.gantiHalaman = (page) => renderData(page);
        function renderData(page) {
            const tbody = document.getElementById('tablePenduduk');
            const paginasiContainer = document.getElementById('paginationPenduduk');
            
            if (filteredData.length === 0) { 
                tbody.innerHTML = `<tr><td colspan="8" class="p-16 text-center text-slate-400 font-medium">Tidak ada data warga yang cocok.</td></tr>`;
                paginasiContainer.innerHTML = ''; return; 
            }

            const start = (page - 1) * itemsPerPage;
            const dataTampil = filteredData.slice(start, start + itemsPerPage);

            let html = '';
            dataTampil.forEach(d => {
                let strTglLahir = "-";
                if(d.tanggal_lahir) {
                    strTglLahir = new Date(d.tanggal_lahir).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' });
                }
                const umurAkurat = hitungUmur(d.tanggal_lahir);
                
                let badgeStatus = "bg-emerald-100 text-emerald-800 border-emerald-200";
                if(d.status_warga === 'Pendatang') badgeStatus = "bg-amber-100 text-amber-800 border-amber-200";
                if(d.status_warga === 'Pindah') badgeStatus = "bg-slate-200 text-slate-700 border-slate-300";
                if(d.status_warga === 'Meninggal') badgeStatus = "bg-rose-100 text-rose-800 border-rose-200";

                let colorPekerjaan = "text-slate-600";
                if(d.pekerjaan.includes('PNS') || d.pekerjaan.includes('BUMN') || d.pekerjaan.includes('TNI')) colorPekerjaan = "text-blue-700 font-bold";
                else if(d.pekerjaan.includes('Belum')) colorPekerjaan = "text-rose-500 font-medium";
                else if(d.pekerjaan.includes('Pelajar')) colorPekerjaan = "text-amber-600 font-medium";
                else if(d.pekerjaan.includes('Swasta') || d.pekerjaan.includes('Wiraswasta')) colorPekerjaan = "text-emerald-700 font-bold";

                const pendText = d.pendidikan || 'Belum Diisi';

                html += `
                <tr class="group">
                    <td>
                        <span class="font-mono font-extrabold text-blue-950 block text-xs tracking-tight">${steril(d.nik)}</span>
                        <span class="font-mono text-slate-400 text-[10px]">KK: ${steril(d.no_kk)}</span>
                    </td>
                    <td>
                        <span class="font-black text-slate-800 uppercase text-xs block">${steril(d.nama_lengkap)}</span>
                        <span class="font-mono text-slate-400 text-[10px]">📞 ${steril(d.no_telp) || '-'}</span>
                    </td>
                    <td class="text-center font-black text-slate-400">${d.jenis_kelamin === 'Laki-laki' ? 'L' : 'P'}</td>
                    <td>
                        <span class="text-slate-700 block text-[11px] font-medium">${steril(d.tempat_lahir)}, ${strTglLahir}</span>
                        <span class="text-[10px] font-black text-rose-600 bg-rose-50 border border-rose-100 px-1.5 py-0.5 rounded inline-block mt-1">${umurAkurat}</span>
                    </td>
                    <td>
                        <span class="text-s font-bold text-slate-700 block">${steril(d.agama)}</span>
                    </td>
                    <td>
                        <span class="${colorPekerjaan} block text-xs">${steril(d.pekerjaan)}</span>
                        <span class="text-slate-500 font-medium text-[10px] block">${steril(pendText)}</span>
                    </td>
                    <td>
                        <span class="text-xs font-bold text-slate-700 block">${steril(d.wilayah_rt)}</span>
                        <span class="text-[10px] text-slate-500 block truncate max-w-[160px]" title="${steril(d.alamat)}">${steril(d.alamat)}</span>
                    </td>
                    <td>
                        <span class="text-s font-bold text-slate-700 block">${steril(d.status_perkawinan)}</span>
                    </td>
                    <td class="text-center">
                        <span class="px-2.5 py-1 text-[10px] font-black uppercase tracking-wider rounded-md border shadow-sm ${badgeStatus}">${d.status_warga}</span>
                    </td>
                    <td class="text-center">
                        <div class="flex justify-center gap-1.5 opacity-40 group-hover:opacity-100 transition-opacity">
                            <button onclick="editData('${d.id}')" class="bg-amber-50 hover:bg-amber-500 hover:text-white text-amber-600 px-2.5 py-1.5 rounded-lg text-[10px] font-bold border border-amber-200 transition-all shadow-sm">Edit</button>
                            <button onclick="hapusData('${d.id}')" class="bg-rose-50 hover:bg-rose-500 hover:text-white text-rose-600 px-2.5 py-1.5 rounded-lg text-[10px] font-bold border border-rose-200 transition-all shadow-sm">Del</button>
                        </div>
                    </td>
                </tr>`;
            });
            tbody.innerHTML = html;

            const totalPages = Math.ceil(filteredData.length / itemsPerPage);
            if(totalPages > 1) {
                let btnPrev = page === 1 ? '' : `<button onclick="gantiHalaman(${page - 1})" class="px-4 py-1.5 bg-white border border-slate-300 rounded-lg font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 transition-colors shadow-sm text-xs">Sebelumnya</button>`;
                let btnNext = page === totalPages ? '' : `<button onclick="gantiHalaman(${page + 1})" class="px-4 py-1.5 bg-white border border-slate-300 rounded-lg font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 transition-colors shadow-sm text-xs">Berikutnya</button>`;
                paginasiContainer.innerHTML = `<span class="text-slate-500 font-medium text-xs">Halaman <b class="text-slate-800">${page}</b> dari ${totalPages}</span><div class="flex gap-2">${btnPrev}${btnNext}</div>`;
            } else {
                paginasiContainer.innerHTML = `<span class="text-slate-500 font-medium text-xs">Total: <b class="text-slate-800">${filteredData.length}</b> warga ditampilkan.</span>`;
            }
        }

        const modal = document.getElementById('modalPenduduk');
        const modalBox = document.getElementById('modalBox');

        window.bukaModal = () => {
            document.getElementById('formPenduduk').reset();
            document.getElementById('editId').value = '';
            
            document.getElementById('pilihRT').innerHTML = '<option value="">-- Pilih RT --</option>';
            document.getElementById('pilihRT').disabled = true;
            document.getElementById('pilihRT').classList.replace('bg-white', 'bg-slate-100');
            document.getElementById('pilihRT').classList.replace('cursor-pointer', 'cursor-not-allowed');

            document.getElementById('modalTitle').innerText = 'Tambah Data Warga Baru';
            modal.classList.remove('hidden');
            setTimeout(() => { modal.classList.remove('opacity-0'); modalBox.classList.remove('scale-95'); modalBox.classList.add('scale-100'); }, 10);
        };
        
        window.tutupModal = () => {
            modal.classList.add('opacity-0'); modalBox.classList.remove('scale-100'); modalBox.classList.add('scale-95');
            setTimeout(() => { modal.classList.add('hidden'); }, 300);
        };

        window.editData = (id) => {
            const d = rawData.find(x => String(x.id) === String(id));
            
            if(!d) {
                console.log("Data tidak ditemukan untuk ID:", id); // Biar gampang dilacak kalo error
                return;
            }
            
            document.getElementById('editId').value = d.id;
            document.getElementById('no_kk').value = d.no_kk;
            document.getElementById('nik').value = d.nik;
            document.getElementById('nama_lengkap').value = d.nama_lengkap;
            document.getElementById('tempat_lahir').value = d.tempat_lahir;
            document.getElementById('tanggal_lahir').value = d.tanggal_lahir;
            document.getElementById('jenis_kelamin').value = d.jenis_kelamin;
            document.getElementById('pendidikan').value = d.pendidikan || 'SMA Sederajat';
            document.getElementById('pekerjaan').value = d.pekerjaan || 'Lainnya';
            document.getElementById('agama').value = d.agama || 'Islam';
            document.getElementById('status_perkawinan').value = d.status_perkawinan || 'Belum Kawin';
            document.getElementById('alamat').value = d.alamat || '';
            document.getElementById('no_telp').value = d.no_telp || '';
            document.getElementById('status_warga').value = d.status_warga;

            // 🔥 LOGIKA BARU: Langsung ambil dari kolom rw dan rt
            if (d.rw && d.rt) {
                document.getElementById('pilihRW').value = d.rw;
                updateDropdownRT('pilihRW', 'pilihRT', false);
                setTimeout(() => { document.getElementById('pilihRT').value = d.rt; }, 50);
            } 
            // Fallback: Jaga-jaga kalau ada data lama yang belum ke-update rt/rw-nya
            else if (d.wilayah_rt && d.wilayah_rt.includes('/')) {
                const parts = d.wilayah_rt.split('/');
                const textRT = parts[0].trim().replace('RT ', ''); 
                const textRW = parts[1].trim().replace('RW ', ''); 
                
                document.getElementById('pilihRW').value = textRW;
                updateDropdownRT('pilihRW', 'pilihRT', false);
                setTimeout(() => { document.getElementById('pilihRT').value = textRT; }, 50);
            } else {
                document.getElementById('pilihRW').value = '';
                document.getElementById('pilihRT').innerHTML = '<option value="">-- Pilih RT --</option>';
                document.getElementById('pilihRT').disabled = true;
            }

            document.getElementById('modalTitle').innerText = 'Edit Biodata Warga';
            modal.classList.remove('hidden');
            setTimeout(() => { modal.classList.remove('opacity-0'); modalBox.classList.remove('scale-95'); modalBox.classList.add('scale-100'); }, 10);
        };

        window.setModeBayi = () => {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('tanggal_lahir').value = today;
            document.getElementById('pendidikan').value = 'Belum/Tidak Sekolah';
            document.getElementById('pekerjaan').value = 'Belum/Tidak Bekerja';
            document.getElementById('status_warga').value = 'Tetap';
            if(typeof showCustomAlert !== 'undefined') {
                showCustomAlert('info', 'Template Bayi Diterapkan', 'Tanggal lahir diset hari ini, pendidikan & pekerjaan disesuaikan.');
            } else {
                alert('Template Bayi: Tanggal lahir otomatis diset hari ini.');
            }
        };

        document.getElementById('formPenduduk').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const nikVal = document.getElementById('nik').value;
            const kkVal = document.getElementById('no_kk').value;
            if(nikVal.length !== 16 || kkVal.length !== 16) {
                if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Validasi Gagal', 'NIK dan Nomor KK wajib 16 digit angka!');
                else alert('NIK dan Nomor KK wajib 16 digit angka!');
                return;
            }

            const id = document.getElementById('editId').value;
            const btn = document.getElementById('btnSimpan');
            btn.disabled = true; btn.innerHTML = "Menyimpan...";

            const rtDipilih = document.getElementById('pilihRT').value;
            const rwDipilih = document.getElementById('pilihRW').value;
            const finalWilayahRT = `RT ${rtDipilih} / RW ${rwDipilih}`;

            const payload = {
                no_kk: encrypt(document.getElementById('no_kk').value),
                nik: encrypt(document.getElementById('nik').value),
                tanggal_lahir: encrypt(document.getElementById('tanggal_lahir').value),
                alamat: encrypt(document.getElementById('alamat').value),
                no_telp: encrypt(document.getElementById('no_telp').value),
                
                nama_lengkap: document.getElementById('nama_lengkap').value.toUpperCase(),
                tempat_lahir: document.getElementById('tempat_lahir').value.toUpperCase(),
                
                jenis_kelamin: document.getElementById('jenis_kelamin').value,
                pendidikan: document.getElementById('pendidikan').value,
                pekerjaan: document.getElementById('pekerjaan').value,
                agama: document.getElementById('agama').value, // <--- TAMBAHKAN INI
                status_perkawinan: document.getElementById('status_perkawinan').value, // <--- TAMBAHKAN INI
                
                // 🔥 TRANSISI BARU: Simpan ke 3 kolom sekaligus
                wilayah_rt: finalWilayahRT, 
                rt: rtDipilih, 
                rw: rwDipilih,
                
                status_warga: document.getElementById('status_warga').value
            };

            let errorApi;
            if (id) {
                const { error } = await supabase.from('data_penduduk').update(payload).eq('id', id);
                errorApi = error;
            } else {
                const { error } = await supabase.from('data_penduduk').insert([payload]);
                errorApi = error;
            }

            btn.disabled = false;
            btn.innerHTML = "🔒 Simpan Data";

            if (errorApi) {
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('error', 'Gagal Simpan', errorApi.message);
                else alert('Gagal: ' + errorApi.message);
            } else {
                tutupModal();
                if(typeof showCustomAlert !== 'undefined') await showCustomAlert('success', 'Berhasil', 'Data penduduk berhasil disimpan dengan aman!');
                loadData();
            }
        });

        window.hapusData = async (id) => {
            const yakin = typeof showConfirmAlert !== 'undefined' 
                ? await showConfirmAlert('Hapus Data?', 'Yakin ingin menghapus data warga ini permanen?')
                : confirm('Hapus data warga ini permanen?');
            if(yakin) {
                const { error } = await supabase.from('data_penduduk').delete().eq('id', id);
                if(!error) loadData();
                else alert("Gagal menghapus: " + error.message);
            }
        };

        initPage();
        window.prosesImportCSV = async (event) => {
    const file = event.target.files[0];
    if(!file) return;

    if(typeof showCustomAlert !== 'undefined') {
        showCustomAlert('info', 'Memproses...', 'Sedang mengenkripsi & memasukkan data...');
    } else {
        alert('Sedang memproses data, mohon tunggu...');
    }

    Papa.parse(file, {
        header: true, // Baris pertama file CSV harus berupa nama kolom
        skipEmptyLines: true,
        complete: async function(results) {
            const dataCSV = results.data;
            if(dataCSV.length === 0) return alert('File CSV kosong atau format salah!');

            // Mapping & Enkripsi data otomatis
            // Mapping & Enkripsi data otomatis
            const payloads = dataCSV.map(row => {
                return {
                    no_kk: encrypt(row.no_kk),
                    nik: encrypt(row.nik),
                    nama_lengkap: row.nama_lengkap,
                    tempat_lahir: row.tempat_lahir,
                    tanggal_lahir: encrypt(row.tanggal_lahir),
                    jenis_kelamin: row.jenis_kelamin,
                    alamat: encrypt(row.alamat),
                    
                    // 🔥 Pastikan 3 pilar wilayah ini masuk semua
                    rw: row.rw,
                    rt: row.rt,
                    wilayah_rt: `RT ${row.rt} / RW ${row.rw}`,
                    
                    pekerjaan: row.pekerjaan,
                    pendidikan: row.pendidikan,
                    agama: row.agama || 'Islam', // <--- TAMBAHKAN INI
                    status_perkawinan: row.status_perkawinan || 'Belum Kawin', // <--- TAMBAHKAN INI
                    status_warga: row.status_warga,
                    no_telp: encrypt(row.no_telp)
                };
            });

            // Tembak sekaligus ke Supabase (Batch Insert)
            const { error } = await supabase.from('data_penduduk').insert(payloads);
            
            event.target.value = ''; // Reset file input

            if (error) {
                if(typeof showCustomAlert !== 'undefined') showCustomAlert('error', 'Gagal', error.message);
                else alert('Gagal Import: ' + error.message);
            } else {
                if(typeof showCustomAlert !== 'undefined') showCustomAlert('success', 'Berhasil', `Berhasil import ${payloads.length} data warga!`);
                else alert(`Berhasil mengimport ${payloads.length} data warga!`);
                
                loadData(); // Refresh tabel langsung!
            }
        }
    });
};
    </script>
</BaseLayout>