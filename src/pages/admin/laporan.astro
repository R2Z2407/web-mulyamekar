---
// src/pages/admin/laporan.astro
import AdminLayout from '../../layout/AdminLayout.astro';
---

<AdminLayout 
    title="Laporan Pengajuan Surat - Admin Mulyamekar"
    pageTitle="Data Pengajuan Surat"
    pageDesc="Rekapitulasi permohonan layanan administrasi warga."
>
    <button slot="action" id="btnExport" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all active:scale-95 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        Export ke Excel (CSV)
    </button>
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-teal-50 text-teal-900 border-b border-teal-100">
                                <th class="p-4 font-bold text-sm">Tanggal</th>
                                <th class="p-4 font-bold text-sm">NIK</th>
                                <th class="p-4 font-bold text-sm">Nama Lengkap</th>
                                <th class="p-4 font-bold text-sm">Jenis Surat</th>
                                <th class="p-4 font-bold text-sm">Keperluan</th>
                                <th class="p-4 font-bold text-sm">Status</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody" class="divide-y divide-gray-100 text-sm">
                            <tr>
                                <td colspan="6" class="p-8 text-center text-gray-400">Memuat data dari database...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

</AdminLayout>

    <script>
        import { supabase } from '../../lib/supabase.js';
        let dataLaporan = []; 

        // 🔥 FUNGSI STERILISASI 🔥
        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
            }[char] || char));
        }

        async function initPage() {
            try {
                const { data: { session } } = await supabase.auth.getSession();
                if (!session) { window.location.href = '/login'; return; }

                const { data: profil, error } = await supabase.from('profil_user').select('role').eq('id', session.user.id).single();
                
                if (error || !profil || profil.role !== 'admin') {
                    await showCustomAlert('error','Akses Ditolak!',' Khusus Admin.');
                    window.location.href = '/'; 
                    return;
                }

                loadDataLaporan();
            } catch (error) {
                console.error("Crash Keamanan:", error);
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" class="text-center text-red-500">Error sistem: ${error.message}</td></tr>`;
            }
        }

        async function loadDataLaporan() {
            try {
                const { data, error } = await supabase.from('pengajuan_surat').select('*').order('created_at', { ascending: false });
                const tbody = document.getElementById('tableBody');
                
                if (error) throw error;
                
                if (!data || data.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="6" class="p-8 text-center text-gray-500">Belum ada data pengajuan surat.</td></tr>`;
                    return;
                }

                dataLaporan = data; // Simpan datanya biar bisa diexport
                let html = '';
                
                data.forEach(item => {
                    const tgl = new Date(item.created_at).toLocaleDateString('id-ID');
                    
                    // 🛡️ STERILKAN DATA KETIKAN WARGA
                    const nikAman = steril(item.nik);
                    const namaAman = steril(item.nama_lengkap);
                    const jenisAman = steril(item.jenis_surat);
                    const keperluanAman = steril(item.keperluan);

                    let badgeDesa = 'bg-gray-100 text-gray-600';
                    if(item.status === 'Menunggu') badgeDesa = 'text-amber-600 font-bold';
                    // ... (badge status lainnya) ...

                    html += `
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="p-4 text-gray-600">${tgl}</td>
                            <td class="p-4 font-mono text-xs text-gray-500">${nikAman}</td>
                            <td class="p-4 font-bold text-teal-900">${namaAman}</td>
                            <td class="p-4 text-gray-800">${jenisAman}</td>
                            <td class="p-4 text-xs text-gray-500 truncate max-w-xs">${keperluanAman}</td>
                            <td class="p-4 ${badgeDesa}">${item.status}</td>
                        </tr>
                    `;
                });
                tbody.innerHTML = html;

            } catch (error) {
                console.error("Crash Data:", error);
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" class="text-center text-red-500">Gagal memuat: ${error.message}</td></tr>`;
            }
        }

        // Fitur Export ke Excel (CSV)
        document.getElementById('btnExport')?.addEventListener('click', async () => {
            if (dataLaporan.length === 0) {
                // Karena udah ada async di atas, await di bawah ini jadi sah dan halal
                if(typeof showCustomAlert !== 'undefined') {
                    await showCustomAlert('error', 'Kosong', 'Tidak ada data untuk diekspor');
                } else {
                    alert('Tidak ada data untuk diekspor');
                }
                return;
            }
            
            let csvContent = "data:text/csv;charset=utf-8,Tanggal,NIK,Nama,Jenis Surat,Keperluan,Status\n";
            dataLaporan.forEach(row => {
                const tgl = new Date(row.created_at).toLocaleDateString('id-ID');
                // Hilangkan koma pada teks biar CSV tidak rusak
                const keperluan = row.keperluan ? row.keperluan.replace(/,/g, " ") : "";
                const nama = row.nama_lengkap ? row.nama_lengkap.replace(/,/g, " ") : "";
                csvContent += `${tgl},'${row.nik},${nama},${row.jenis_surat},${keperluan},${row.status}\n`;
            });

            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", "Rekap_Surat_Desa.csv");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        });

        initPage();
    </script>
</body>
</html>