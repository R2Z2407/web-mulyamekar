---
// src/pages/index.astro
import '../global.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import QuickServices from '../components/QuickServices.astro';
// Impor komponen baru
import StatistikDesa from '../components/StatistikDesa.astro';
import TransparencyWidget from '../components/TransparencyWidget.astro';
import AparaturDesa from '../components/AparaturDesa.astro';
import BeritaDesa from '../components/BeritaDesa.astro';
import Footer from '../components/Footer.astro';
import AuthModal from '../components/AuthModal.astro';
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portal Resmi Desa Mulyamekar</title>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  </head>
  <body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen overflow-x-hidden">
    
    <Header />
    
    <main class="flex-grow">
      <Hero />
      <QuickServices />
      <StatistikDesa />
      <TransparencyWidget />
      <AparaturDesa />
      <BeritaDesa />
      <section class="py-20 bg-orange-50 relative overflow-hidden">
    <div class="absolute -right-20 -top-20 w-80 h-80 bg-orange-200 rounded-full blur-3xl opacity-50"></div>
    <div class="container mx-auto px-4 max-w-6xl relative z-10">
        <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4">
            <div>
                <span class="text-orange-600 font-extrabold text-sm tracking-widest uppercase mb-2 block">Dukung Ekonomi Lokal</span>
                <h2 class="text-3xl md:text-4xl font-black text-gray-900">Pasar Desa Mulyamekar 🛍️</h2>
                <p class="text-gray-600 mt-2">Temukan produk kerajinan, makanan, dan hasil bumi asli buatan warga kami.</p>
            </div>
            <a href="/umkm" class="bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-8 rounded-full shadow-lg transition-transform hover:scale-105 whitespace-nowrap">
                Buka Pasar &rarr;
            </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="previewUmkm">
            <p class="text-gray-500 animate-pulse col-span-full text-center">Memuat produk unggulan...</p>
        </div>
    </div>
</section>
    </main>
    <AuthModal />
    <Footer />

    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
      // Inisialisasi animasi AOS secara global
      AOS.init({
        duration: 900, // Durasi sedikit lebih lama biar lebih smooth (0.9 detik)
        once: true,    // Animasi cuma jalan sekali pas di-scroll ke bawah
        offset: 120,   // Jarak trigger animasi dari bawah layar
        delay: 50,     // Delay global awal agar tidak terlalu instan
      });
    </script>
    <script>
    import { supabase } from '../lib/supabase.js';
    
    async function loadPreviewUmkm() {
        const wadah = document.getElementById('previewUmkm');
        if(!wadah) return;
        
        const formatRupiah = (angka) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(angka);
        
        // Ambil 3 produk terbaru aja
        const { data, error } = await supabase.from('umkm_produk').select('*').eq('is_active', true).order('created_at', { ascending: false }).limit(3);
        
        if (error || !data || data.length === 0) {
            wadah.innerHTML = '<p class="text-gray-400 italic text-center col-span-full">Belum ada produk UMKM unggulan yang diunggah.</p>';
            return;
        }

        let html = '';
        data.forEach(p => {
            html += `
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col group">
                <div class="h-40 overflow-hidden relative">
                    <img src="${p.foto_url || 'https://via.placeholder.com/300?text=Produk'}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute bottom-2 left-2 bg-white/90 px-2 py-1 rounded text-[10px] font-bold text-orange-600">${p.kategori}</div>
                </div>
                <div class="p-4 flex flex-col flex-grow">
                    <h3 class="font-bold text-gray-800 line-clamp-1">${p.nama_produk}</h3>
                    <p class="text-xs text-gray-500 mb-3">${p.nama_penjual}</p>
                    <div class="mt-auto flex justify-between items-center">
                        <span class="font-black text-orange-600">${formatRupiah(p.harga)}</span>
                    </div>
                </div>
            </div>`;
        });
        wadah.innerHTML = html;
    }
    
    // Jangan lupa panggil fungsinya pas halaman index dimuat
    document.addEventListener('DOMContentLoaded', () => {
        loadPreviewUmkm();
    });
</script>
  </body>
</html>