---
// src/pages/lupa-password.astro
import '../global.css';
import Header from '../components/Header.astro';
---
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ubah Kata Sandi - Mulyamekar</title>
</head>
<body class="bg-slate-50 flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow flex items-center justify-center p-4 sm:p-6 mt-16 sm:mt-0">
        <div class="bg-white p-6 sm:p-8 rounded-3xl shadow-xl border border-slate-100 w-full max-w-md transition-all">
            
            <div class="text-center mb-6 sm:mb-8">
                <div class="relative w-20 h-20 mx-auto mb-4">
                    <div id="wadahAvatarUbahSandi" class="w-full h-full bg-teal-50 text-teal-600 rounded-full flex items-center justify-center text-3xl font-black border-2 border-teal-100 shadow-sm overflow-hidden transition-all">
                        <i class="bi bi-hourglass-split animate-spin text-teal-300"></i>
                    </div>
                    <div class="absolute bottom-0 right-0 bg-white p-1.5 rounded-full shadow-md border border-slate-100 text-teal-600 text-xs z-10">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                </div>
                <h1 class="text-2xl font-black text-slate-800 tracking-tight">Ubah Kata Sandi</h1>
                <p class="text-slate-500 text-sm mt-2">Pastikan kata sandi baru Anda mudah diingat dan menggunakan minimal 6 karakter.</p>
            </div>
            
            <div id="pesanError" class="hidden mb-5 p-3 sm:p-4 bg-red-50 border border-red-200 text-red-600 rounded-xl text-xs sm:text-sm font-bold flex items-start gap-2">
                <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
                <span id="teksError">Terjadi kesalahan.</span>
            </div>

            <form id="formUbahSandi" class="space-y-4 sm:space-y-5">
                
                <div>
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Kata Sandi Saat Ini</label>
                    <div class="relative">
                        <i class="bi bi-key absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="password" id="sandiLama" required class="w-full pl-11 pr-12 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Masukkan sandi saat ini">
                        <button type="button" onclick="toggleSandi('sandiLama', 'ikonLama')" class="absolute right-4 top-3.5 text-slate-400 hover:text-teal-600 transition-colors">
                            <i class="bi bi-eye-slash text-lg" id="ikonLama"></i>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Kata Sandi Baru</label>
                    <div class="relative">
                        <i class="bi bi-shield-check absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="password" id="sandiBaru" required minlength="6" class="w-full pl-11 pr-12 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Minimal 6 karakter">
                        <button type="button" onclick="toggleSandi('sandiBaru', 'ikonBaru')" class="absolute right-4 top-3.5 text-slate-400 hover:text-teal-600 transition-colors">
                            <i class="bi bi-eye-slash text-lg" id="ikonBaru"></i>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wider">Konfirmasi Sandi Baru</label>
                    <div class="relative">
                        <i class="bi bi-shield-check absolute left-4 top-3.5 text-slate-400 text-lg"></i>
                        <input type="password" id="konfirmasiSandi" required minlength="6" class="w-full pl-11 pr-12 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500 outline-none text-sm font-bold text-slate-900 placeholder-slate-400" placeholder="Ulangi kata sandi baru">
                        <button type="button" onclick="toggleSandi('konfirmasiSandi', 'ikonKonfirmasi')" class="absolute right-4 top-3.5 text-slate-400 hover:text-teal-600 transition-colors">
                            <i class="bi bi-eye-slash text-lg" id="ikonKonfirmasi"></i>
                        </button>
                    </div>
                </div>

                <div class="pt-2">
                    <button type="submit" id="btnSimpan" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-black py-3.5 rounded-xl shadow-md shadow-teal-600/20 transition-all active:scale-95 flex justify-center items-center gap-2">
                        Simpan Kata Sandi
                    </button>
                    <a href="/warga" class="w-full block text-center mt-4 text-sm font-bold text-slate-500 hover:text-slate-800 transition-colors">Batal & Kembali</a>
                </div>
            </form>

            <div id="pesanSukses" class="hidden text-center py-6">
                <div class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 animate-bounce">
                    <i class="bi bi-check-lg"></i>
                </div>
                <h3 class="text-xl font-black text-slate-800">Sandi Diperbarui!</h3>
                <p class="text-slate-500 text-sm mt-2 font-medium">Kata sandi Anda berhasil diubah. Mengalihkan kembali ke Dashboard...</p>
            </div>

        </div>
    </main>

    <script>
        import { supabase } from '../lib/supabase.js';

        // 🔥 FUNGSI TARIK PROFIL OTOMATIS (LOGIKA HEADER.ASTRO)
        async function muatAvatarPribadi() {
            const wadah = document.getElementById('wadahAvatarUbahSandi');
            try {
                // 1. Cek siapa yang lagi login
                const { data: { user }, error: errUser } = await supabase.auth.getUser();
                if (errUser || !user) throw new Error("Belum login");

                // 2. Tarik data lengkap seperti di Header (Role, Avatar URL, Gender)
                const { data: profil } = await supabase.from('profil_user')
                    .select('nama_lengkap, role, avatar_url, jenis_kelamin')
                    .eq('id', user.id)
                    .single();
                
                if (profil) {
                    let finalAvatar = profil.avatar_url;

                    // 🔥 LOGIKA AVATAR SAKTI DARI HEADER.ASTRO 🔥
                    if (profil.role === 'admin') {
                        // Kalau dia Admin, paksa pakai Logo Desa
                        finalAvatar = 'https://i.ibb.co.com/S7Wv5qST/logo-header.png';
                    } 
                    else if (!finalAvatar) {
                        // Kalau Warga/RT dan belum punya foto, pakai Dicebear sesuai Gender
                        const gender = profil.jenis_kelamin === 'Perempuan' ? 'Perempuan' : 'Laki-laki'; 
                        finalAvatar = gender === 'Perempuan' 
                            ? `https://api.dicebear.com/7.x/avataaars/svg?seed=${profil.nama_lengkap}&backgroundColor=ffdfbf&clothing=blazerAndShirt&hair=longButNotTooLong`
                            : `https://api.dicebear.com/7.x/avataaars/svg?seed=${profil.nama_lengkap}&backgroundColor=b6e3f4&clothing=blazerAndSweater&hair=shortHairShortFlat`;
                    }

                    // 3. Suntik gambar ke dalam HTML
                    wadah.innerHTML = `<img src="${finalAvatar}" class="w-full h-full object-cover" alt="Foto Profil">`;
                } else {
                    wadah.innerHTML = `<i class="bi bi-person-fill"></i>`;
                }
            } catch (error) {
                console.error("Gagal memuat avatar:", error);
                wadah.innerHTML = `<i class="bi bi-person-fill text-3xl"></i>`;
            }
        }

        // Jalankan pemuatan avatar
        muatAvatarPribadi();

        // 🔥 Fungsi Intip Kata Sandi (Show/Hide)
        window.toggleSandi = (inputId, iconId) => {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
                icon.classList.replace('text-slate-400', 'text-teal-600');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
                icon.classList.replace('text-teal-600', 'text-slate-400');
            }
        };

        // 🔥 Fungsi Submit Form Ganti Sandi
        document.getElementById('formUbahSandi')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const sandiLama = document.getElementById('sandiLama').value;
            const sandiBaru = document.getElementById('sandiBaru').value;
            const konfirmasi = document.getElementById('konfirmasiSandi').value;
            
            const btn = document.getElementById('btnSimpan');
            const boxError = document.getElementById('pesanError');
            const teksError = document.getElementById('teksError');
            
            // Sembunyikan pesan error sebelumnya
            boxError.classList.add('hidden');

            // 1. Validasi Kecocokan & Panjang Sandi di Frontend
            if (sandiBaru !== konfirmasi) {
                teksError.innerText = "Konfirmasi tidak cocok! Ulangi sandi baru Anda dengan benar.";
                boxError.classList.remove('hidden');
                return;
            }
            if (sandiBaru.length < 6) {
                teksError.innerText = "Kata sandi baru terlalu pendek. Minimal 6 karakter.";
                boxError.classList.remove('hidden');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = "Memverifikasi... <i class='bi bi-hourglass-split animate-spin'></i>";

            try {
                // 2. Ambil data user yang sedang login
                const { data: { user }, error: errUser } = await supabase.auth.getUser();
                if (errUser || !user) throw new Error("Sesi Anda telah berakhir. Silakan login ulang.");

                // 3. Verifikasi kata sandi LAMA dengan cara Re-authenticate
                const { error: errVerifikasi } = await supabase.auth.signInWithPassword({
                    email: user.email,
                    password: sandiLama
                });
                if (errVerifikasi) throw new Error("Kata Sandi Saat Ini yang Anda masukkan SALAH!");

                btn.innerHTML = "Menyimpan... <i class='bi bi-hourglass-split animate-spin'></i>";

                // 4. Update ke kata sandi BARU
                const { error: errUpdate } = await supabase.auth.updateUser({
                    password: sandiBaru
                });
                if (errUpdate) throw new Error("Gagal menyimpan kata sandi baru.");

                // 5. Sukses! Tampilkan layar centang hijau
                document.getElementById('formUbahSandi').classList.add('hidden');
                document.getElementById('pesanSukses').classList.remove('hidden');

                // 6. Alihkan kembali ke halaman warga setelah 2 detik
                setTimeout(() => {
                    window.location.href = '/warga';
                }, 2000);

            } catch (error) {
                console.error("❌ Error Ubah Sandi:", error);
                teksError.innerText = error.message;
                boxError.classList.remove('hidden');
                
                btn.disabled = false;
                btn.innerHTML = "Simpan Kata Sandi";
            }
        });
    </script>
</body>
</html>