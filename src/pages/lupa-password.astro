---
// src/pages/lupa-password.astro
import '../global.css';
import Header from '../components/Header.astro';
---
<html lang="id">
<head>
    <title>Lupa Kata Sandi - Mulyamekar</title>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
    <Header />
    <main class="flex-grow flex items-center justify-center p-4">
        <div class="bg-white p-8 rounded-3xl shadow-xl border border-gray-100 w-full max-w-md text-center">
            <h1 class="text-2xl font-extrabold text-teal-950 mb-2">Reset Kata Sandi</h1>
            <p class="text-gray-500 text-sm mb-6">Masukkan email yang terdaftar. Kami akan mengirimkan tautan (link) untuk membuat kata sandi baru.</p>
            
            <form id="formReset" class="space-y-4 text-left">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Email Anda</label>
                    <input type="email" id="emailReset" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500" placeholder="contoh@email.com">
                </div>
                <button type="submit" id="btnReset" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-xl transition-all active:scale-95">Kirim Tautan Reset</button>
            </form>
            <p id="pesanSukses" class="hidden text-emerald-600 font-bold mt-4 text-sm bg-emerald-50 p-3 rounded-lg border border-emerald-200">Tautan berhasil dikirim! Silakan periksa Kotak Masuk (Inbox) atau folder Spam di Email Anda.</p>
        </div>
    </main>

    <script>
        import { supabase } from '../lib/supabase.js';

        document.getElementById('formReset').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('emailReset').value;
            const btn = document.getElementById('btnReset');
            btn.disabled = true; btn.innerText = "Mengirim...";

            const { error } = await supabase.auth.resetPasswordForEmail(email, {
                // SAKTI: Ini akan mengarahkan user kembali ke web lu setelah klik link di email
                redirectTo: `${window.location.origin}/update-password`,
            });

            if (error) {
                alert('Gagal mengirim link: ' + error.message);
                btn.disabled = false; btn.innerText = "Kirim Tautan Reset";
            } else {
                document.getElementById('formReset').classList.add('hidden');
                document.getElementById('pesanSukses').classList.remove('hidden');
            }
        });
    </script>
</body>
</html>