---
// src/pages/ubah-password.astro
import '../global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ubah Kata Sandi - Mulyamekar</title>
</head>
<body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow pt-24 pb-20 flex justify-center items-center p-4">
        <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl border border-gray-100 w-full max-w-md relative overflow-hidden">
            
            <a href="#" id="btnKembali" class="absolute top-6 left-6 text-teal-600 hover:text-amber-600 text-sm font-bold transition-colors">
                &larr; Kembali
            </a>

            <div class="text-center mb-8 border-b pb-6 mt-6">
                <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                </div>
                <h1 class="text-2xl font-extrabold text-teal-950">Ubah Kata Sandi</h1>
                <p class="text-gray-500 mt-2 text-sm">Gunakan kombinasi huruf dan angka minimal 6 karakter demi keamanan akun Anda.</p>
            </div>

            <form id="formPassword" class="space-y-4 text-left">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Kata Sandi Saat Ini *</label>
                    <input type="password" id="oldPassword" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Kata Sandi Baru *</label>
                    <input type="password" id="newPassword" required minlength="6" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Konfirmasi Sandi Baru *</label>
                    <input type="password" id="confirmPassword" required minlength="6" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-teal-500 text-sm">
                </div>
                <button type="submit" id="btnUbahPassword" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3.5 rounded-xl transition-all active:scale-95 text-lg mt-4 shadow-lg">
                    Perbarui Sandi
                </button>
            </form>
        </div>
    </main>
    <Footer />

    <script>
        import { supabase } from '../lib/supabase.js';

        let currentUserEmail = null;

        async function initPage() {
            const { data: { session } } = await supabase.auth.getSession();
            if (!session) { window.location.href = '/login'; return; }
            
            currentUserEmail = session.user.email;

            // Atur tombol kembali sesuai role
            const { data: profil } = await supabase.from('profil_user').select('role').eq('id', session.user.id).single();
            const btnKembali = document.getElementById('btnKembali');
            if (profil) {
                if (profil.role === 'admin') btnKembali.href = '/admin';
                else if (profil.role === 'rt_rw') btnKembali.href = '/rt';
                else btnKembali.href = '/warga';
            }
        }

        document.getElementById('formPassword').addEventListener('submit', async (e) => {
            e.preventDefault();
            const oldPass = document.getElementById('oldPassword').value;
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;
            const btn = document.getElementById('btnUbahPassword');

            if (newPass !== confirmPass) {
                alert('Kata sandi baru dan konfirmasi tidak cocok!');
                return;
            }

            btn.disabled = true; btn.innerText = "Memverifikasi...";

            // Verifikasi sandi lama
            const { error: signInError } = await supabase.auth.signInWithPassword({
                email: currentUserEmail,
                password: oldPass
            });

            if (signInError) {
                alert('Kata sandi saat ini yang Anda masukkan salah!');
                btn.disabled = false; btn.innerText = "Perbarui Sandi";
                return;
            }

            // Update Password
            btn.innerText = "Memperbarui...";
            const { error: updateError } = await supabase.auth.updateUser({ password: newPass });

            btn.disabled = false; btn.innerText = "Perbarui Sandi";

            if (updateError) {
                alert('Gagal memperbarui sandi: ' + updateError.message);
            } else {
                alert('Kata sandi berhasil diperbarui!');
                document.getElementById('formPassword').reset();
                document.getElementById('btnKembali').click(); // Otomatis balik ke halaman sebelumnya
            }
        });

        initPage();
    </script>
</body>
</html>