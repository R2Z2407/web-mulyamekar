---
// src/pages/pemerintahan.astro
import BaseLayout from '../layout/BaseLayout.astro';
import { supabase } from '../lib/supabase.js';

// 1. Tarik semua data dari database
const { data: aparatur, error } = await supabase
  .from('aparatur')
  .select('*')
  .order('urutan', { ascending: true });

if (error) {
  console.error("Gagal menarik data Pemerintahan:", error);
}

// 2. SMART SORTER (Pisahkan berdasarkan Jabatan)
const dataAparatur = aparatur || [];

// Kades (Prioritas: Urutan 1 atau ada kata "Kepala Desa")
const kades = dataAparatur.find(p => p.urutan === 1 || p.jabatan.toLowerCase().includes('kepala desa')) || { nama: "Belum Diatur", jabatan: "Kepala Desa", foto_url: "" };

// Sekdes (Cari kata "Sekretaris" atau "Sekdes")
const sekdes = dataAparatur.find(p => p.jabatan.toLowerCase().includes('sekretaris') || p.jabatan.toLowerCase().includes('sekdes'));

// Kaur (Kepala Urusan - Tata Usaha, Keuangan, Perencanaan)
const kaur = dataAparatur.filter(p => p.jabatan.toLowerCase().includes('kaur') || p.jabatan.toLowerCase().includes('urusan'));

// Kasi (Kepala Seksi - Pemerintahan, Kesejahteraan, Pelayanan)
const kasi = dataAparatur.filter(p => p.jabatan.toLowerCase().includes('kasi') || p.jabatan.toLowerCase().includes('seksi'));

// Kadus (Kepala Dusun) / Ketua RW
const kadus = dataAparatur.filter(p => p.jabatan.toLowerCase().includes('dusun') || p.jabatan.toLowerCase().includes('kadus') || p.jabatan.toLowerCase().includes('rw'));

// Sisa Perangkat yang tidak masuk kategori di atas
const filterIds = [kades?.id, sekdes?.id, ...kaur.map(k=>k.id), ...kasi.map(k=>k.id), ...kadus.map(k=>k.id)];
const stafLainnya = dataAparatur.filter(p => !filterIds.includes(p.id) && p.urutan !== 1);
---

<BaseLayout title="Pemerintahan - Portal Resmi Desa Mulyamekar">
    
    <section class="bg-teal-900 text-white py-20 max-md:landscape:py-12 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-teal-400 via-teal-900 to-teal-950"></div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-amber-400 drop-shadow-md">Aparatur Desa</h1>
            <p class="text-lg md:text-xl text-teal-100 max-w-2xl mx-auto drop-shadow">Struktur Organisasi dan Tata Kerja (SOTK) Pemerintah Desa Mulyamekar.</p>
        </div>
    </section>

    <section class="py-20 max-md:landscape:py-12 bg-gray-50 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]">
        <div class="container mx-auto px-4 max-w-7xl">
            
            <div class="flex flex-col items-center mb-10 relative z-10" data-aos="fade-down">
                <div class="bg-white rounded-3xl p-8 shadow-xl border-t-8 border-teal-600 max-w-sm w-full text-center relative">
                    <span class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-amber-500 text-teal-950 text-xs font-black px-4 py-1.5 rounded-full shadow-md uppercase tracking-widest">Pimpinan</span>
                    <div class="w-32 h-32 mx-auto rounded-full overflow-hidden border-4 border-amber-400 shadow-inner mb-6 mt-2 bg-gray-100">
                        {kades.foto_url ? <img src={kades.foto_url} alt={kades.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-4xl">👤</div>}
                    </div>
                    <h2 class="text-2xl font-black text-teal-950 mb-1">{kades.nama}</h2>
                    <p class="text-sm font-bold text-teal-600 uppercase tracking-widest">{kades.jabatan}</p>
                </div>
                {sekdes && <div class="w-1 h-12 bg-teal-300 relative"><div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-3 h-3 bg-teal-500 rounded-full"></div></div>}
            </div>

            {sekdes && (
                <div class="flex flex-col items-center mb-12 relative z-10" data-aos="fade-up">
                    <div class="bg-white rounded-2xl p-6 shadow-lg border-t-4 border-amber-500 max-w-xs w-full text-center">
                        <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-4 border-gray-100 shadow-sm mb-4 bg-gray-50">
                            {sekdes.foto_url ? <img src={sekdes.foto_url} alt={sekdes.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-3xl">👤</div>}
                        </div>
                        <h2 class="text-lg font-bold text-gray-900 mb-1">{sekdes.nama}</h2>
                        <p class="text-xs font-bold text-amber-600 uppercase tracking-wider">{sekdes.jabatan}</p>
                    </div>
                </div>
            )}

            {(kaur.length > 0 || kasi.length > 0) && (
                <div class="hidden md:block w-3/4 max-w-4xl h-1 bg-teal-200 mx-auto mb-10 relative rounded-full">
                    <div class="absolute -top-6 left-1/2 transform -translate-x-1/2 w-1 h-6 bg-teal-200"></div> <div class="absolute -bottom-1 left-0 w-3 h-3 rounded-full bg-teal-500 shadow-[0_0_10px_rgba(20,184,166,0.5)]"></div>
                    <div class="absolute -bottom-1 right-0 w-3 h-3 rounded-full bg-teal-500 shadow-[0_0_10px_rgba(20,184,166,0.5)]"></div>
                    <div class="absolute -bottom-1 left-1/2 transform -translate-x-1/2 w-3 h-3 rounded-full bg-teal-600 shadow-[0_0_10px_rgba(13,148,136,0.5)]"></div>
                </div>
            )}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-16">
                {kaur.length > 0 && (
                    <div class="bg-white/50 p-6 rounded-3xl border border-teal-100">
                        <h3 class="text-center text-sm font-black text-teal-800 uppercase tracking-widest mb-6 bg-teal-100 py-2 rounded-xl">Bagian Sekretariat (Kaur)</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {kaur.map((orang, index) => (
                                <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 hover:border-teal-400 hover:shadow-md transition-all flex flex-col items-center text-center group" data-aos="fade-up" data-aos-delay={index * 50}>
                                    <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-gray-100 group-hover:border-teal-200 mb-3 bg-gray-50">
                                        {orang.foto_url ? <img src={orang.foto_url} alt={orang.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-2xl">👤</div>}
                                    </div>
                                    <h4 class="text-sm font-bold text-gray-900 leading-tight mb-1">{orang.nama}</h4>
                                    <p class="text-[10px] font-bold text-teal-600 uppercase bg-teal-50 px-2 py-1 rounded-md">{orang.jabatan}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {kasi.length > 0 && (
                    <div class="bg-white/50 p-6 rounded-3xl border border-amber-100">
                        <h3 class="text-center text-sm font-black text-amber-800 uppercase tracking-widest mb-6 bg-amber-100 py-2 rounded-xl">Pelaksana Teknis (Kasi)</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {kasi.map((orang, index) => (
                                <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 hover:border-amber-400 hover:shadow-md transition-all flex flex-col items-center text-center group" data-aos="fade-up" data-aos-delay={index * 50}>
                                    <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-gray-100 group-hover:border-amber-200 mb-3 bg-gray-50">
                                        {orang.foto_url ? <img src={orang.foto_url} alt={orang.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-2xl">👤</div>}
                                    </div>
                                    <h4 class="text-sm font-bold text-gray-900 leading-tight mb-1">{orang.nama}</h4>
                                    <p class="text-[10px] font-bold text-amber-600 uppercase bg-amber-50 px-2 py-1 rounded-md">{orang.jabatan}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                )}
            </div>

            {(kadus.length > 0 || stafLainnya.length > 0) && (
                <div class="max-w-5xl mx-auto border-t border-gray-200 pt-10">
                    <h3 class="text-center text-sm font-black text-gray-500 uppercase tracking-widest mb-8">Pelaksana Kewilayahan & Staf Desa</h3>
                    <div class="flex flex-wrap justify-center gap-6">
                        {[...kadus, ...stafLainnya].map((orang, index) => (
                            <div class="w-40 bg-white rounded-xl p-4 shadow-sm border border-gray-100 hover:-translate-y-1 transition-transform flex flex-col items-center text-center" data-aos="zoom-in" data-aos-delay={index * 50}>
                                <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-gray-100 mb-3 bg-gray-50">
                                    {orang.foto_url ? <img src={orang.foto_url} alt={orang.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-xl">👤</div>}
                                </div>
                                <h4 class="text-xs font-bold text-gray-900 leading-tight mb-1">{orang.nama}</h4>
                                <p class="text-[9px] font-bold text-gray-500 uppercase">{orang.jabatan}</p>
                            </div>
                        ))}
                    </div>
                </div>
            )}

        </div>
    </section>

</BaseLayout>