---
// src/pages/pemerintahan.astro
import BaseLayout from '../layout/BaseLayout.astro';
import { supabase } from '../lib/supabase.js';

// 1. Tarik semua data dari database
const { data: aparatur, error } = await supabase
  .from('aparatur')
  .select('*')
  .order('urutan', { ascending: true });

if (error) {
  console.error("Gagal menarik data Pemerintahan:", error);
}

// 2. SMART SORTER (Pisahkan berdasarkan Jabatan SOTK Standar)
const dataAparatur = aparatur || [];

// Pimpinan & Koordinator
const kades = dataAparatur.find(p => p.urutan === 1 || p.jabatan.toLowerCase().includes('kepala desa')) || { nama: "Belum Diatur", jabatan: "Kepala Desa", foto_url: "" };
const sekdes = dataAparatur.find(p => p.jabatan.toLowerCase().includes('sekretaris') || p.jabatan.toLowerCase().includes('sekdes'));

// 3 Pilar Desa
const kaur = dataAparatur.filter(p => p.jabatan.toLowerCase().includes('kaur') || p.jabatan.toLowerCase().includes('urusan'));
const kasi = dataAparatur.filter(p => p.jabatan.toLowerCase().includes('kasi') || p.jabatan.toLowerCase().includes('seksi'));
const kadus = dataAparatur.filter(p => p.jabatan.toLowerCase().includes('dusun') || p.jabatan.toLowerCase().includes('kadus') || p.jabatan.toLowerCase().includes('rw'));

// Sisa Perangkat / Staf (Jika ada)
const filterIds = [kades?.id, sekdes?.id, ...kaur.map(k=>k.id), ...kasi.map(k=>k.id), ...kadus.map(k=>k.id)];
const stafLainnya = dataAparatur.filter(p => !filterIds.includes(p.id) && p.urutan !== 1);
---

<BaseLayout title="Pemerintahan - Portal Resmi Desa Mulyamekar">
    
    <section class="bg-teal-900 text-white py-20 max-md:landscape:py-12 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-teal-400 via-teal-900 to-teal-950"></div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-amber-400 drop-shadow-md">Aparatur Desa</h1>
            <p class="text-lg md:text-xl text-teal-100 max-w-2xl mx-auto drop-shadow">Struktur Organisasi dan Tata Kerja (SOTK) Pemerintah Desa Mulyamekar.</p>
        </div>
    </section>

    <section class="py-20 bg-gray-50 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] overflow-x-hidden">
        <div class="container mx-auto px-4 max-w-6xl">
            
            <div class="flex flex-col items-center relative z-20">
                <div class="bg-white rounded-3xl p-6 shadow-xl border-b-8 border-amber-500 w-64 text-center relative z-10 hover:-translate-y-2 transition-transform duration-300">
                    <span class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-amber-500 text-teal-950 text-xs font-black px-4 py-1.5 rounded-full shadow-md uppercase tracking-widest whitespace-nowrap">Kepala Desa</span>
                    <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-4 border-amber-100 shadow-inner mb-4 mt-2 bg-gray-100">
                        {kades.foto_url ? <img src={kades.foto_url} alt={kades.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-4xl">👤</div>}
                    </div>
                    <h2 class="text-lg font-black text-gray-900 mb-1 leading-tight">{kades.nama}</h2>
                </div>
            </div>

            {sekdes && (
                <div class="w-1 h-8 bg-teal-500 mx-auto relative z-0"></div>
            )}

            {sekdes && (
                <div class="flex flex-col items-center relative z-20">
                    <div class="bg-white rounded-2xl p-5 shadow-lg border-b-4 border-teal-500 w-56 text-center relative z-10 hover:-translate-y-1 transition-transform">
                        <span class="absolute -top-3 left-1/2 transform -translate-x-1/2 bg-teal-600 text-white text-[10px] font-black px-3 py-1 rounded-full shadow-md uppercase tracking-wider whitespace-nowrap">Sekretaris Desa</span>
                        <div class="w-20 h-20 mx-auto rounded-full overflow-hidden border-4 border-teal-50 shadow-sm mb-3 mt-1 bg-gray-50">
                            {sekdes.foto_url ? <img src={sekdes.foto_url} alt={sekdes.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-3xl">👤</div>}
                        </div>
                        <h2 class="text-base font-bold text-gray-900 leading-tight">{sekdes.nama}</h2>
                    </div>
                </div>
            )}

            {(kaur.length > 0 || kasi.length > 0 || kadus.length > 0) && (
                <div class="relative w-full max-w-4xl mx-auto">
                    <div class="w-1 h-8 bg-teal-500 mx-auto"></div>
                    <div class="hidden md:block border-t-4 border-teal-500 w-[80%] mx-auto relative">
                        <div class="absolute left-0 top-0 w-1 h-8 bg-teal-500"></div>
                        <div class="absolute left-1/2 top-0 w-1 h-8 bg-teal-500 transform -translate-x-1/2"></div>
                        <div class="absolute right-0 top-0 w-1 h-8 bg-teal-500"></div>
                    </div>
                    <div class="md:hidden w-1 h-8 bg-teal-500 mx-auto"></div>
                </div>
            )}

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 lg:gap-8 max-w-5xl mx-auto mt-0 md:mt-2 relative z-20">
                
                {kaur.length > 0 && (
                    <div class="flex flex-col items-center w-full">
                        <div class="bg-emerald-100 text-emerald-800 text-xs font-black px-6 py-2 rounded-full mb-6 shadow-sm border border-emerald-200 z-10 uppercase tracking-widest w-max">Sekretariat</div>
                        <div class="flex flex-col gap-6 relative w-full items-center">
                            <div class="absolute left-1/2 top-0 bottom-8 w-1 bg-emerald-200 transform -translate-x-1/2 -z-10"></div>
                            
                            {kaur.map((orang) => (
                                <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 border-l-4 border-l-emerald-500 w-full max-w-[220px] text-center flex flex-col items-center hover:-translate-y-1 transition-transform bg-opacity-95">
                                    <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-emerald-50 mb-3 bg-gray-50">
                                        {orang.foto_url ? <img src={orang.foto_url} alt={orang.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-xl">👤</div>}
                                    </div>
                                    <h4 class="text-sm font-bold text-gray-900 leading-tight mb-1">{orang.nama}</h4>
                                    <p class="text-[10px] font-bold text-emerald-600 uppercase">{orang.jabatan}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {kasi.length > 0 && (
                    <div class="flex flex-col items-center w-full">
                        <div class="bg-amber-100 text-amber-800 text-xs font-black px-6 py-2 rounded-full mb-6 shadow-sm border border-amber-200 z-10 uppercase tracking-widest w-max">Pelaksana Teknis</div>
                        <div class="flex flex-col gap-6 relative w-full items-center">
                            <div class="absolute left-1/2 top-0 bottom-8 w-1 bg-amber-200 transform -translate-x-1/2 -z-10"></div>
                            
                            {kasi.map((orang) => (
                                <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 border-l-4 border-l-amber-500 w-full max-w-[220px] text-center flex flex-col items-center hover:-translate-y-1 transition-transform bg-opacity-95">
                                    <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-amber-50 mb-3 bg-gray-50">
                                        {orang.foto_url ? <img src={orang.foto_url} alt={orang.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-xl">👤</div>}
                                    </div>
                                    <h4 class="text-sm font-bold text-gray-900 leading-tight mb-1">{orang.nama}</h4>
                                    <p class="text-[10px] font-bold text-amber-600 uppercase">{orang.jabatan}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {kadus.length > 0 && (
                    <div class="flex flex-col items-center w-full">
                        <div class="bg-blue-100 text-blue-800 text-xs font-black px-6 py-2 rounded-full mb-6 shadow-sm border border-blue-200 z-10 uppercase tracking-widest w-max">Kewilayahan</div>
                        <div class="flex flex-col gap-6 relative w-full items-center">
                            <div class="absolute left-1/2 top-0 bottom-8 w-1 bg-blue-200 transform -translate-x-1/2 -z-10"></div>
                            
                            {kadus.map((orang) => (
                                <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 border-l-4 border-l-blue-500 w-full max-w-[220px] text-center flex flex-col items-center hover:-translate-y-1 transition-transform bg-opacity-95">
                                    <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-blue-50 mb-3 bg-gray-50">
                                        {orang.foto_url ? <img src={orang.foto_url} alt={orang.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-xl">👤</div>}
                                    </div>
                                    <h4 class="text-sm font-bold text-gray-900 leading-tight mb-1">{orang.nama}</h4>
                                    <p class="text-[10px] font-bold text-blue-600 uppercase">{orang.jabatan}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

            </div>

            {stafLainnya.length > 0 && (
                <div class="max-w-5xl mx-auto border-t border-gray-200 pt-10 mt-12">
                    <h3 class="text-center text-sm font-black text-gray-500 uppercase tracking-widest mb-8">Staf & Asisten Lainnya</h3>
                    <div class="flex flex-wrap justify-center gap-6">
                        {stafLainnya.map((orang) => (
                            <div class="w-40 bg-white rounded-xl p-4 shadow-sm border border-gray-100 hover:-translate-y-1 transition-transform flex flex-col items-center text-center">
                                <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-gray-100 mb-3 bg-gray-50">
                                    {orang.foto_url ? <img src={orang.foto_url} alt={orang.nama} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-xl">👤</div>}
                                </div>
                                <h4 class="text-xs font-bold text-gray-900 leading-tight mb-1">{orang.nama}</h4>
                                <p class="text-[9px] font-bold text-gray-500 uppercase">{orang.jabatan}</p>
                            </div>
                        ))}
                    </div>
                </div>
            )}

        </div>
    </section>
</BaseLayout>