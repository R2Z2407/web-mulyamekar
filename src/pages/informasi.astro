---
// src/pages/informasi.astro
import '../global.css';
import Header from '../components/Header.astro';
import AuthModal from '../components/AuthModal.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase.js';

// 1. Tarik SEMUA data berita dari Supabase di sisi server
const { data: berita, error } = await supabase
  .from('berita')
  .select('*')
  .eq('is_published', true)
  .order('created_at', { ascending: false });

if (error) {
  console.error("Gagal menarik data Berita:", error);
}
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Informasi & Berita - Portal Resmi Desa Mulyamekar</title>
  </head>
  <body class="bg-gray-50 font-sans text-gray-800 flex flex-col min-h-screen">
    
    <Header />
    
    <main class="flex-grow">
      
      <section class="bg-teal-900 text-white py-20 max-md:landscape:py-12 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
        <div class="container mx-auto px-4 relative z-10 text-center">
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-amber-400 drop-shadow-md">Kabar Desa</h1>
          <p class="text-lg md:text-xl text-teal-100 max-w-2xl mx-auto drop-shadow">Kumpulan berita, pengumuman, dan artikel terbaru seputar Desa Mulyamekar.</p>
        </div>
      </section>

      <section class="py-20 max-md:landscape:py-10">
        <div class="container mx-auto px-4 max-w-6xl">
          
          <div class="flex flex-col md:flex-row justify-between items-center mb-12 max-md:landscape:mb-6 gap-6 max-md:landscape:gap-3 bg-white p-4 max-md:landscape:p-2 rounded-2xl shadow-sm border border-gray-100"> 
            
            <div id="tagsContainer" class="flex gap-2 overflow-x-auto w-full md:w-auto pb-2 md:pb-0 scrollbar-hide">
                </div>
            
            <div class="relative w-full md:w-72">
              <input type="text" id="inputSearch" placeholder="Cari berita..." class="w-full bg-gray-50 border border-gray-200 text-gray-800 text-sm max-md:landscape:text-xs rounded-full focus:ring-teal-500 focus:border-teal-500 block pl-10 p-2.5 max-md:landscape:p-1.5 transition-all outline-none" />
              <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              </div>
            </div>
          </div>

          <div id="beritaContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-md:landscape:gap-4 max-md:landscape:grid-cols-3"> 
            <div class="col-span-full text-center py-20 bg-white rounded-2xl border border-gray-100 shadow-sm">
              <p class="text-gray-500 font-medium">Memuat berita...</p>
            </div>
          </div>

          <div class="flex justify-center mt-16 max-md:landscape:mt-8">
            <nav id="paginationContainer" class="inline-flex rounded-full shadow-sm bg-white border border-gray-200 p-1">
              </nav>
          </div>

        </div>
      </section>

    </main>
    <AuthModal />
    <Footer />

    <style>
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    </style>

    <script is:inline define:vars={{ beritaServer: berita }}>
        
        // State Management
        let semuaBerita = beritaServer || [];
        let beritaTampil = [...semuaBerita];
        let currentPage = 1;
        const itemsPerPage = 6; // Tampilkan 6 berita per halaman
        let activeTag = 'Semua Berita';

        // Fungsi Utilities
        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
            }[char] || char));
        }

        function formatTanggal(dateString) {
            const options = { day: 'numeric', month: 'long', year: 'numeric' };
            return new Date(dateString).toLocaleDateString('id-ID', options);
        }

        // ==========================================
        // 1. LOGIKA TAGS & FILTER PENCARIAN
        // ==========================================
        function initTags() {
            const container = document.getElementById('tagsContainer');
            if (!container) return;

            // Ambil kategori unik dari database
            const kategoriUnik = ['Semua Berita', ...new Set(semuaBerita.map(b => b.kategori).filter(Boolean))];

            let html = '';
            kategoriUnik.forEach(kat => {
                const isActive = kat === activeTag;
                const activeClass = isActive 
                    ? "bg-teal-600 text-white" 
                    : "bg-gray-100 text-gray-600 hover:bg-gray-200";
                
                html += `<button onclick="setTag('${steril(kat)}')" class="${activeClass} px-4 py-2 max-md:landscape:py-1 max-md:landscape:px-3 rounded-full text-sm max-md:landscape:text-xs font-bold whitespace-nowrap cursor-pointer transition-colors border-none outline-none">${steril(kat)}</button>`;
            });
            container.innerHTML = html;
        }

        window.setTag = (kategori) => {
            activeTag = kategori;
            initTags(); // Re-render warna tombol
            terapkanFilter();
        };

        document.getElementById('inputSearch')?.addEventListener('input', terapkanFilter);

        function terapkanFilter() {
            const kataKunci = document.getElementById('inputSearch').value.toLowerCase();

            beritaTampil = semuaBerita.filter(b => {
                const cocokTag = activeTag === 'Semua Berita' || b.kategori === activeTag;
                const cocokKata = (b.judul && b.judul.toLowerCase().includes(kataKunci)) || 
                                  (b.ringkasan && b.ringkasan.toLowerCase().includes(kataKunci));
                return cocokTag && cocokKata;
            });

            currentPage = 1; // Reset ke halaman pertama tiap filter berubah
            renderGrid();
            renderPagination();
        }

        // ==========================================
        // 2. RENDER GRID (Persis Sesuai Desain Asli)
        // ==========================================
        function renderGrid() {
            const container = document.getElementById('beritaContainer');
            if (!container) return;

            if (beritaTampil.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full text-center py-20 bg-white rounded-2xl border border-gray-100 shadow-sm">
                        <p class="text-gray-500 font-medium">Pencarian tidak menemukan hasil.</p>
                    </div>`;
                return;
            }

            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            const dataHalamanIni = beritaTampil.slice(startIndex, endIndex);

            let html = '';
            dataHalamanIni.forEach(item => {
                const imgAman = steril(item.gambar_url) || 'https://via.placeholder.com/600x400?text=Desa+Mulyamekar';
                const slugAman = steril(item.slug) || '#';
                
                // Templating persis seperti kode asli lu!
                html += `
                <article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 group flex flex-col">
                  <div class="relative h-52 max-md:landscape:h-32 overflow-hidden">
                    <div class="absolute inset-0 bg-teal-900/20 group-hover:bg-transparent transition-colors z-10"></div>
                    <img src="${imgAman}" alt="${steril(item.judul)}" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500" onerror="this.src='https://via.placeholder.com/600x400?text=Gambar+Tidak+Tersedia'" />
                    <span class="absolute top-4 left-4 z-20 bg-amber-500 text-teal-950 text-[10px] font-bold px-2 py-0.5 rounded-full shadow-md">
                      ${steril(item.kategori)}
                    </span>
                  </div>

                  <div class="p-6 max-md:landscape:p-3 flex flex-col flex-grow">
                    <div class="flex items-center gap-2 text-gray-400 text-xs mb-3 max-md:landscape:mb-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                      <span>${formatTanggal(item.created_at)}</span>
                    </div>
                    
                    <h4 class="text-xl max-md:landscape:text-xs font-bold text-gray-900 mb-3 max-md:landscape:mb-1 group-hover:text-teal-700 transition-colors line-clamp-2 leading-snug">
                      <a href="/berita/${slugAman}">${steril(item.judul)}</a>
                    </h4>
                    
                    <p class="text-gray-600 text-sm leading-relaxed mb-6 max-md:landscape:hidden line-clamp-3 flex-grow">
                      ${steril(item.ringkasan)}
                    </p>
                    
                    <a href="/berita/${slugAman}" class="mt-auto inline-flex items-center gap-2 text-teal-600 font-bold text-sm max-md:landscape:text-[10px] hover:text-amber-600 transition-colors">
                      Baca Selengkapnya
                      <svg class="w-4 h-4 max-md:landscape:w-3 max-md:landscape:h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </a>
                  </div>
                </article>
                `;
            });
            container.innerHTML = html;
        }

        // ==========================================
        // 3. RENDER PAGINATION (Sesuai Desain Asli)
        // ==========================================
        function renderPagination() {
            const container = document.getElementById('paginationContainer');
            if (!container) return;

            const totalPages = Math.ceil(beritaTampil.length / itemsPerPage);

            if (totalPages <= 1) {
                container.innerHTML = ''; 
                return;
            }

            let html = '';

            // Prev Button
            if (currentPage > 1) {
                html += `<button onclick="pindahPage(${currentPage - 1})" class="px-4 py-2 max-md:landscape:px-2 max-md:landscape:py-1 text-sm max-md:landscape:text-xs font-medium text-gray-500 hover:text-teal-600 hover:bg-teal-50 rounded-full transition-colors">Sebelumnya</button>`;
            } else {
                html += `<span class="px-4 py-2 max-md:landscape:px-2 max-md:landscape:py-1 text-sm max-md:landscape:text-xs font-medium text-gray-300 rounded-full cursor-not-allowed">Sebelumnya</span>`;
            }

            // Page Numbers
            for (let i = 1; i <= totalPages; i++) {
                if (i === currentPage) {
                    html += `<button class="px-4 py-2 max-md:landscape:px-2 max-md:landscape:py-1 text-sm max-md:landscape:text-xs font-bold text-white bg-teal-600 rounded-full">${i}</button>`;
                } else {
                    html += `<button onclick="pindahPage(${i})" class="px-4 py-2 max-md:landscape:px-2 max-md:landscape:py-1 text-sm max-md:landscape:text-xs font-medium text-gray-500 hover:text-teal-600 hover:bg-teal-50 rounded-full transition-colors">${i}</button>`;
                }
            }

            // Next Button
            if (currentPage < totalPages) {
                html += `<button onclick="pindahPage(${currentPage + 1})" class="px-4 py-2 max-md:landscape:px-2 max-md:landscape:py-1 text-sm max-md:landscape:text-xs font-medium text-gray-500 hover:text-teal-600 hover:bg-teal-50 rounded-full transition-colors">Selanjutnya</button>`;
            } else {
                html += `<span class="px-4 py-2 max-md:landscape:px-2 max-md:landscape:py-1 text-sm max-md:landscape:text-xs font-medium text-gray-300 rounded-full cursor-not-allowed">Selanjutnya</span>`;
            }

            container.innerHTML = html;
        }

        window.pindahPage = (pageNum) => {
            const totalPages = Math.ceil(beritaTampil.length / itemsPerPage);
            if (pageNum >= 1 && pageNum <= totalPages) {
                currentPage = pageNum;
                renderGrid();
                renderPagination();
                // Scroll ke area atas berita biar enak bacanya
                document.getElementById('tagsContainer').scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        };

        // Inisialisasi awal
        initTags();
        terapkanFilter();

    </script>
  </body>
</html>