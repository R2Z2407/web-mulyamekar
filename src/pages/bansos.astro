---
// src/pages/bansos.astro
import BaseLayout from '../layout/BaseLayout.astro';
---

<BaseLayout title="Transparansi Bansos - Mulyamekar">
    
    <main class="flex-grow pb-20">
        <section class="bg-teal-950 text-white py-16 mb-10 relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
            <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-amber-500 rounded-full blur-3xl opacity-20"></div>
            <div class="container mx-auto px-4 max-w-4xl relative z-10 text-center">
                <span class="inline-block px-4 py-1.5 bg-amber-500 text-teal-950 font-bold rounded-full text-xs tracking-widest uppercase mb-4 shadow-sm">Transparansi Publik</span>
                <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Penerima Bantuan Sosial</h1>
                <p class="text-teal-100 max-w-2xl mx-auto text-lg">Daftar Keluarga Penerima Manfaat (KPM) Desa Mulyamekar yang telah diverifikasi dan disahkan.</p>
            </div>
        </section>

        <div class="container mx-auto px-4 max-w-5xl min-h-[400px]">
            
            <div id="filterPanel" class="hidden bg-white p-4 rounded-2xl shadow-sm border border-gray-100 mb-8 flex flex-col md:flex-row justify-between items-center gap-4 transition-all">
                <div class="w-full md:w-auto">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Pilih Tahun</p>
                    <div id="yearContainer" class="flex gap-2 overflow-x-auto pb-2 md:pb-0 hide-scrollbar">
                        </div>
                </div>

                <div class="w-full md:w-72">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Filter Program</p>
                    <div class="relative">
                        <select id="programFilter" onchange="gantiProgram(this.value)" class="w-full pl-4 pr-10 py-2.5 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-teal-500 font-bold text-teal-900 appearance-none cursor-pointer transition-all">
                            <option value="Semua">Tampilkan Semua Program</option>
                            </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-400">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div id="bansos-container">
                <div class="flex flex-col items-center justify-center py-20" id="loadingData">
                    <svg class="animate-spin h-10 w-10 text-teal-600 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    <p class="text-gray-500 font-bold animate-pulse">Menarik data dari server desa...</p>
                </div>
            </div>

        </div>
    </main>

    <style>
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .animate-fadeUp { animation: fadeUp 0.4s ease-out forwards; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>

    <script>
        import { supabase } from '../lib/supabase.js';

        // Variabel Global untuk nyimpen data mentah
        let dataProgramMentah = [];
        let dataPenerimaMentah = [];
        let listTahun = [];
        
        // Status Pilihan User (State)
        let tahunAktif = null;
        let programAktif = 'Semua';

        async function initBansos() {
            const container = document.getElementById('bansos-container');
            const filterPanel = document.getElementById('filterPanel');
            const loading = document.getElementById('loadingData');
            
            try {
                // 1. Ambil Data Program
                const { data: programs, error: errProg } = await supabase.from('bansos').select('*');
                if (errProg) throw errProg;
                dataProgramMentah = programs || [];

                // 2. Ambil Data Penerima (Yang udah Disetujui aja)
                const { data: penerima, error: errPen } = await supabase.from('usulan_bansos').select('*').eq('status_usulan', 'Disetujui');
                if (errPen) throw errPen;
                dataPenerimaMentah = penerima || [];

                // Kalau kosong blong
                if (dataProgramMentah.length === 0) {
                    filterPanel.classList.add('hidden');
                    container.innerHTML = `
                        <div class="bg-white p-12 rounded-3xl text-center border border-gray-100 shadow-sm animate-fadeUp">
                            <div class="text-6xl mb-4">📭</div>
                            <h3 class="text-xl font-bold text-gray-800">Belum Ada Data Program</h3>
                            <p class="text-gray-500 mt-2">Pemerintah Desa belum menerbitkan program bansos apapun.</p>
                        </div>`;
                    return;
                }

                // 3. Ekstrak Tahun Unik (Misal: [2026, 2025, 2024])
                listTahun = [...new Set(dataProgramMentah.map(p => p.tahun))].sort((a, b) => b - a);
                
                // Set Default: Tahun terbaru & Semua Program
                tahunAktif = listTahun[0]; 
                programAktif = 'Semua';

                // Tampilkan Filter Panel & Render
                if(loading) loading.style.display = 'none';
                filterPanel.classList.remove('hidden');
                
                renderFilterTahun();
                renderFilterProgram();
                renderDataLayar();

            } catch (error) {
                console.error(error);
                if(loading) loading.style.display = 'none';
                container.innerHTML = `
                    <div class="bg-rose-50 border border-rose-200 p-8 rounded-3xl text-center shadow-sm">
                        <div class="text-rose-500 mb-3"><svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                        <h3 class="text-lg font-bold text-rose-800">Gagal Memuat Data</h3>
                        <p class="text-rose-600 text-sm mt-1">Gagal terhubung ke pangkalan data desa. Silakan muat ulang (refresh) halaman.</p>
                    </div>`;
            }
        }

        // --- FUNGSI RENDER TAB TAHUN ---
        function renderFilterTahun() {
            const tContainer = document.getElementById('yearContainer');
            let html = '';
            listTahun.forEach(thn => {
                const isActive = thn === tahunAktif;
                const baseClass = "px-5 py-2 rounded-xl text-sm font-bold transition-all whitespace-nowrap border shadow-sm ";
                const colorClass = isActive 
                    ? "bg-teal-600 text-white border-teal-700" 
                    : "bg-white text-gray-500 border-gray-200 hover:bg-gray-50";
                
                html += `<button onclick="gantiTahun(${thn})" class="${baseClass} ${colorClass}">${thn}</button>`;
            });
            tContainer.innerHTML = html;
        }

        // --- FUNGSI RENDER DROPDOWN PROGRAM BERDASARKAN TAHUN AKTIF ---
        function renderFilterProgram() {
            const pDropdown = document.getElementById('programFilter');
            
            // Ambil program yang tahunnya sama dengan tahunAktif
            const progDiTahunIni = dataProgramMentah.filter(p => p.tahun === tahunAktif);
            
            let html = '<option value="Semua">Tampilkan Semua Program</option>';
            progDiTahunIni.forEach(p => {
                const isSelected = p.nama_bantuan === programAktif ? 'selected' : '';
                html += `<option value="${steril(p.nama_bantuan)}" ${isSelected}>${steril(p.nama_bantuan)}</option>`;
            });
            
            pDropdown.innerHTML = html;
        }

        // --- FUNGSI UTAMA NAMPILIN DATA KE LAYAR ---
        function renderDataLayar() {
            const container = document.getElementById('bansos-container');
            
            // Filter program berdasar Tahun dan Program Aktif
            let progYangTampil = dataProgramMentah.filter(p => p.tahun === tahunAktif);
            
            if (programAktif !== 'Semua') {
                progYangTampil = progYangTampil.filter(p => p.nama_bantuan === programAktif);
            }

            if (progYangTampil.length === 0) {
                container.innerHTML = `
                    <div class="bg-white p-10 rounded-3xl text-center border border-gray-100 shadow-sm animate-fadeUp">
                        <p class="text-gray-400 font-bold">Tidak ada program "${programAktif}" di tahun ${tahunAktif}.</p>
                    </div>`;
                return;
            }

            let html = `<div class="animate-fadeUp">`;
            
            progYangTampil.forEach(prog => {
                // LOGIKA CERDAS MENCARI PENERIMA (Mengatasi Data Ganda Beda Tahun)
                const recipients = dataPenerimaMentah.filter(r => {
                    // Cari yang formatnya pake tahun (Bantuan Sembako [2026])
                    const formatBaru = `${prog.nama_bantuan} [${prog.tahun}]`;
                    if (r.nama_program === formatBaru) return true;
                    // Fallback kalau data lama belum pake kurung siku tahun
                    if (r.nama_program === prog.nama_bantuan) {
                        const thnUsul = new Date(r.created_at).getFullYear();
                        return thnUsul == prog.tahun;
                    }
                    return false;
                });

                let katWarna = prog.kategori === 'Tunai' ? 'bg-emerald-50 text-emerald-600 border-emerald-200' : 'bg-amber-50 text-amber-600 border-amber-200';

                html += `
                <div class="bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden mb-8 transition-all hover:shadow-md">
                    <div class="bg-gradient-to-r from-teal-50 to-white p-6 border-b border-gray-100 flex flex-col md:flex-row justify-between md:items-center gap-4">
                        <div>
                            <h3 class="text-xl font-bold text-teal-950 flex items-center gap-2">
                                📦 ${steril(prog.nama_bantuan)}
                            </h3>
                            <div class="flex flex-wrap gap-2 mt-3">
                                <span class="bg-white border border-gray-200 text-gray-600 px-3 py-1 rounded-full text-[11px] font-bold shadow-sm">Sumber: ${steril(prog.sumber_dana)}</span>
                                <span class="border px-3 py-1 rounded-full text-[11px] font-bold shadow-sm ${katWarna}">Kategori: ${steril(prog.kategori)}</span>
                            </div>
                        </div>
                        <div class="bg-white px-6 py-3 rounded-2xl shadow-sm border border-gray-100 text-center flex-shrink-0 min-w-[120px]">
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Total KPM</p>
                            <p class="text-3xl font-extrabold text-teal-600 leading-none">${recipients.length} <span class="text-sm font-medium text-gray-500">Orang</span></p>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="bg-gray-50 text-gray-600 text-xs uppercase tracking-wider border-b border-gray-200">
                                <tr>
                                    <th class="p-4 w-16 text-center font-bold">No</th>
                                    <th class="p-4 font-bold">Nama Penerima</th>
                                    <th class="p-4 font-bold">NIK (Terlindungi)</th>
                                    <th class="p-4 font-bold text-center">Status Penetapan</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 text-sm">
                `;

                if (recipients.length > 0) {
                    recipients.forEach((r, idx) => {
                        // SENSOR NIK 
                        const maskedNik = r.nik && r.nik.length === 16 
                            ? r.nik.substring(0,6) + '<span class="text-gray-300">******</span>' + r.nik.substring(12) 
                            : 'Data Tidak Valid';

                        html += `
                                <tr class="hover:bg-teal-50/30 transition-colors">
                                    <td class="p-4 text-center font-bold text-gray-400">${idx + 1}</td>
                                    <td class="p-4 font-bold text-gray-800">${steril(r.nama_warga)}</td>
                                    <td class="p-4 font-mono text-gray-600 tracking-wider">${maskedNik}</td>
                                    <td class="p-4 text-center">
                                        <span class="bg-emerald-50 text-emerald-600 px-3 py-1 rounded-md text-[10px] font-bold border border-emerald-200">
                                            ✅ Tervalidasi
                                        </span>
                                    </td>
                                </tr>
                        `;
                    });
                } else {
                    html += `
                                <tr>
                                    <td colspan="4" class="p-10 text-center">
                                        <p class="text-gray-400 italic mb-1">Belum ada data penerima yang disahkan untuk program ini.</p>
                                    </td>
                                </tr>
                    `;
                }

                html += `
                            </tbody>
                        </table>
                    </div>
                </div>
                `;
            });

            html += `</div>`;
            container.innerHTML = html;
        }

        // =====================================
        // EVENT LISTENER DARI TOMBOL UI
        // =====================================
        window.gantiTahun = (thn) => {
            tahunAktif = thn;
            programAktif = 'Semua'; // Reset program filter pas ganti tahun
            renderFilterTahun();
            renderFilterProgram();
            renderDataLayar();
        };

        window.gantiProgram = (namaProg) => {
            programAktif = namaProg;
            renderDataLayar();
        };

        // Fungsi Pensteril
        function steril(teks) {
            if (!teks) return '';
            return String(teks).replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char] || char));
        }

        document.addEventListener('DOMContentLoaded', initBansos);
    </script>
</BaseLayout>